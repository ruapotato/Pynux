# user/cmp.ad
#
# Hamnix `cmp A B`: byte-compares two files. Silent on match
# (exit 0). On mismatch, prints "A B differ: byte N, line L" and
# exits 1. Errors (missing file etc) exit 2 with diagnostic.
# Bounded by 8 KiB per file (matches the M16.64 single-block cap).

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

BUF_MAX: uint64 = 8192

a_buf: Array[8192, uint8]
b_buf: Array[8192, uint8]


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def write_dec(fd: int32, v: uint64):
    if v == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[20, uint8]
    di: uint64 = 0
    while v > 0:
        digits[di] = cast[uint8]((v % 10) + 48)
        v = v / 10
        di = di + 1
    while di > 0:
        di = di - 1
        sys_write(fd, &digits[di], 1)


def slurp(path: Ptr[char], buf: Ptr[uint8]) -> int64:
    fd: int32 = sys_open(path)
    if fd < 0:
        return -1
    total: uint64 = 0
    while total < BUF_MAX:
        n: int64 = sys_read(fd, cast[Ptr[uint8]](
            cast[uint64](buf) + total), BUF_MAX - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    return cast[int64](total)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        write_str(2, "usage: cmp A B\n")
        return 2
    a_path: Ptr[char] = cast[Ptr[char]](argv[1])
    b_path: Ptr[char] = cast[Ptr[char]](argv[2])
    a_n: int64 = slurp(a_path, &a_buf[0])
    if a_n < 0:
        write_str(2, "cmp: cannot open A\n")
        return 2
    b_n: int64 = slurp(b_path, &b_buf[0])
    if b_n < 0:
        write_str(2, "cmp: cannot open B\n")
        return 2

    au: uint64 = cast[uint64](a_n)
    bu: uint64 = cast[uint64](b_n)
    minlen: uint64 = au
    if bu < au:
        minlen = bu

    # Walk both, tracking line number for human-friendly output.
    i: uint64 = 0
    line: uint64 = 1
    while i < minlen:
        if a_buf[i] != b_buf[i]:
            write_str(1, cast[Ptr[uint8]](a_path))
            sys_write(1, " ", 1)
            write_str(1, cast[Ptr[uint8]](b_path))
            sys_write(1, " differ: byte ", 14)
            write_dec(1, i + 1)
            sys_write(1, ", line ", 7)
            write_dec(1, line)
            sys_write(1, "\n", 1)
            return 1
        if a_buf[i] == 10:
            line = line + 1
        i = i + 1
    if au != bu:
        write_str(1, "cmp: EOF mismatch\n")
        return 1
    return 0
