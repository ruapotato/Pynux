# user/apt.ad
#
# Hamnix V0 of the `apt`/`apt-get`/`apt-cache` package-index tool — the
# first userland binary to fetch and parse a Debian repository index
# over the network. It is the apt-path piece that follows dpkg_deb
# (.deb unpack) and dpkg (local DB record/query): where those operate
# on a .deb already on disk, `apt` reaches OUT to a Debian mirror,
# pulls the repo index, decompresses it and answers queries against it.
#
#   apt update <base-url> <suite>   fetch + decompress + store the index
#   apt show <pkg>                  print one package's stanza
#   apt pkgnames                    print every package name
#   apt install <pkg>               download + verify + dpkg-install a .deb
#
# (Modern Debian unifies apt-get + apt-cache into a single `apt`
# front-end; this binary follows that — `apt update` is `apt-get
# update`, `apt show`/`apt pkgnames` are `apt-cache show`/`apt-cache
# pkgnames`. The Hamnix build maps user/apt.ad -> /bin/apt; argv[1]
# selects the sub-command.)
#
# -- apt install <pkg> -------------------------------------------------
#
# Chains the apt-path pieces end to end: index lookup -> HTTP download
# -> SHA-256 verification -> `dpkg -i`.
#
#   1. Read the base-url back from /tmp/apt/base-url — a one-line file
#      `apt update` now writes (it is the only place the base-url is
#      known; `apt install` is a separate process invocation).
#   2. Read /tmp/apt/Packages, find the stanza for <pkg>, and extract
#      its `Filename` (path to the .deb relative to base-url), `Size`
#      and `SHA256` fields.
#   3. HTTP(S) GET <base-url>/<Filename> — reuses the same _http_get
#      code `apt update` uses, so an https:// base-url downloads the
#      .deb over the validated TLS connection too. The .deb is BINARY:
#      the body bytes are saved raw (no text processing) to
#      /tmp/apt/<pkg>.deb.
#   4. SHA-256-verify the downloaded bytes against the index's SHA256
#      field. A mismatch is a hard error: the .deb is NOT installed and
#      the process exits non-zero. SHA-256 is a standalone port here
#      (the kernel TLS stack's SHA-256 in drivers/net/tls.ad keys off
#      tls_* globals and is not callable from userland) — see the
#      `_sha256_*` section. The Size field, when present, is also
#      checked against the byte count actually downloaded.
#   5. sys_spawn `/bin/dpkg -i /tmp/apt/<pkg>.deb`; dpkg's exit code is
#      surfaced as our own.
#   6. Print `apt: installed <pkg> <version>` on success.
#
# -- DEPENDENCY RESOLUTION (V1, this milestone) ------------------------
#
# `apt install <pkg>` now installs <pkg>'s transitive `Depends:` first.
# Before downloading anything it walks the index: for <pkg> and every
# dependency it has not yet seen and is not already installed, it reads
# that package's `Depends:` field and recurses. The walk is recorded
# post-order, so a package's dependencies always land before it in the
# install order (deps before dependents). A "seen" set both
# de-duplicates a diamond dependency and breaks a cycle. A dependency
# already in the dpkg DB is skipped; a dependency name absent from the
# index aborts the WHOLE install with a clear diagnostic (no partial
# install).
#
# The resolved closure is then installed package-by-package in
# dependency order: for each package we download + SHA-256-verify the
# .deb, then immediately `dpkg -i` it before moving to the next. (Until
# the in-kernel TCP stack rotated its ephemeral source port per connect
# this loop needed a fetch-all/dpkg-all split plus an inter-download
# delay to dodge a SLIRP handshake wedge; that kernel bug is fixed, so
# the natural sequential flow is used.)
#
# V1 `Depends:` parsing is pragmatic: the field is split on ',', the
# name of a term is the token before any '(' or '|', an alternative
# ("a | b") picks the FIRST alternative, and version constraints
# ("(>= x)") are parsed-past but NOT checked. The closure is bounded at
# 64 packages (DEP_MAX) — exceeding it is a hard error.
#
# NOT in V1 (V2 backlog): version-constraint satisfaction,
# alternative-preference logic beyond "first wins",
# Conflicts:/Breaks:/Pre-Depends: ordering, Recommends:/Suggests:,
# `apt remove`. The .deb download budget is the same 256 KiB
# HTTP cap as the index fetch — a larger .deb is a hard error
# (streaming to a file is a V1 concern).
#
# -- apt update <base-url> <suite> -------------------------------------
#
#   1. Parse <base-url> into host + port + path. Accepts both
#      `http://host[:port][/path]` and `https://host[:port][/path]`
#      (no userinfo, no query string). Default port 80 for http, 443
#      for https.
#   2. Open an AF_INET SOCK_STREAM socket, connect to host:port. For an
#      https URL the connected fd is then taken through the TLS 1.3
#      handshake via sys_tls_connect(2) (SYS_TLS_CONNECT 277 -> the
#      in-kernel TLS stack: X25519 + server cert-chain validation
#      against the kernel CA store + CertificateVerify transcript
#      binding). After tls_connect succeeds the fd is TLS-active and
#      write()/read() are transparently encrypted — the HTTP codepath
#      is scheme-agnostic. Fetch <path>/dists/<suite>/Release with a
#      raw HTTP/1.0 GET (Connection: close → the server FINs after the
#      body).
#   3. STREAM the binary-amd64 Packages index. The gz index is the
#      primary path: <path>/dists/<suite>/<component>/binary-amd64/
#      Packages.gz is fetched, gzip-inflated, stanza-counted and
#      persisted ALL INCREMENTALLY — the compressed body is drained
#      64 KiB at a time, the resumable inflater (lib/zlib/inflate.ad)
#      emits 64 KiB at a time, and nothing holds the whole index.
#      `Packages.xz` is the fallback (single-shot) when a mirror has
#      no `.gz`.
#   4. `mkdir /tmp/apt` and write the decompressed index incrementally
#      to /tmp/apt/Packages, bounded by the tmpfs per-file cap.
#   5. Print `apt-get: fetched index, N packages` where N is the TRUE
#      blank-line-separated RFC822 stanza count from the streaming
#      pass — bounded by nothing, even for a multi-MB `main` index.
#
# -- apt show <pkg> / apt pkgnames -------------------------------------
#
# Both read /tmp/apt/Packages (written by `apt update`) and treat it as
# a run of RFC822 stanzas — the same wire format dpkg.ad's status DB
# uses, parsed with the same field-matching approach. `show` prints the
# stanza whose `Package:` value equals <pkg> (stderr + non-zero exit if
# absent); `pkgnames` prints every `Package:` value, one per line.
#
# -- STREAMING vs BUFFER CAPS (V2 — incremental index) -----------------
#
# `apt update` no longer buffers the whole compressed download nor the
# whole decompressed index. A real Debian `main/binary-amd64/Packages`
# is multi-MB compressed and tens of MB decompressed — far past any
# RAM buffer the 256 MiB guest could spare. So the download → decompress
# → parse pipeline is INCREMENTAL:
#
#   * the HTTP body is drained off the socket CHUNK BY CHUNK into a
#     fixed STAGING buffer (HTTP_STAGE, 64 KiB) — never the whole body;
#   * each compressed chunk is fed to the streaming gzip inflater
#     (lib/zlib/inflate.ad's inflate_feed is already resumable), which
#     emits decompressed bytes a CHUNK at a time into a second staging
#     buffer (PKG_STAGE, 64 KiB) — never the whole index;
#   * each decompressed chunk is streamed straight through the RFC822
#     stanza counter AND written incrementally to /tmp/apt/Packages.
#
# Index size is therefore bounded by what apt *keeps*, not by the
# index itself: the streaming counter holds nothing, and the persisted
# /tmp/apt/Packages is bounded by the tmpfs per-file cap (the leading
# bytes of the index — the entire thing for a fixture-sized repo, a
# leading-stanzas cache for a giant `main`; a final stanza split by
# the cap is simply skipped by the stanza parsers, which tolerate a
# truncated tail). `apt update` reports the TRUE full stanza count
# from the streaming pass regardless of whether the cache truncated.
#
#   HTTP_STAGE = 65536  (64 KiB)  one socket-drain chunk
#   PKG_STAGE  = 65536  (64 KiB)  one inflate-output chunk
#   PKG_CAP    = 524288 (512 KiB) the in-RAM index buffer for QUERIES
#                                 (show / pkgnames / install) — sized
#                                 to the tmpfs per-file cap, the most
#                                 the persisted index can ever be.
#
# The single-shot xz path still buffers (xz streaming is a follow-up);
# it is capped at PKG_CAP for both the compressed download and the
# decompressed output. A `.xz` index past that cap is a hard error and
# `apt update` advises the gz fallback — the gz path is unbounded.
# Buffers live in top-level BSS arenas (the U9 nested-frame-Array
# compiler quirk: large Arrays must never be parked in a nested frame).
#
# NOT in V0 (V1 backlog): signature/InRelease verification, the
# canonical /var/lib/apt/lists/ paths, chunked transfer-encoding,
# redirects, multi-arch. (HTTPS now works — see the `apt update`
# step 2 above — and `apt install`'s .deb download reuses the same
# _http_get, so it is HTTPS-capable for free.)
#
# Build: scripts/build_user.sh -> build/user/apt.elf -> /bin/apt.
# Test:  scripts/test_apt_get.sh.

from lib.zlib.inflate import (
    InflateState,
    inflate_init,
    inflate_feed,
)

# xz/LZMA2 decompressor — modern Debian ships `Packages.xz` (LZMA2)
# as the primary binary-amd64 index. `apt update` probes for `.xz`
# first and routes the body through xz_decompress(); a single-shot
# call mirroring how inflate_feed handles the gzip `.gz` fallback.
from lib.xz.xz import (
    xz_decompress,
)

# OpenPGP signature verification of the repository `InRelease` file.
# This closes the apt chain-of-trust gap: before V1, apt trusted the
# `Release`/`Packages` index on transport security alone — a MITM or a
# malicious mirror could serve a forged index. `apt update` now fetches
# the inline-clearsigned `InRelease`, verifies its OpenPGP signature
# against a baked Debian-style archive key, and only then trusts the
# metadata. lib/pgp parses the OpenPGP packet stream + the cleartext-
# signature framework; lib/rsa does the RSA PKCS#1 v1.5 math.
from lib.pgp.pgp import (
    PgpPubkey,
    PgpKeyring,
    PgpSig,
    pgp_keyring_load,
    pgp_inrelease_split,
    pgp_dearmor,
    pgp_sig_parse,
    pgp_next_packet,
    pgp_build_signed_data,
    pgp_signed_data,
    pgp_sig_packet,
)
from lib.rsa.rsa import (
    RsaPubkey,
    rsa_init,
    rsa_pkcs1_v1_5_verify,
    RSA_DIGEST_SHA256,
    RSA_DIGEST_SHA384,
    RSA_DIGEST_SHA512,
)

# Native-ABI syscalls. socket()/connect() are the U-socket bridge
# (runtime.S numbers 41/42 -> _u_socket/_u_connect); read/write/close
# on a socket fd already route through the in-kernel TCP stack via the
# FD_SOCKET_MARK arms in fs/vfs.ad.
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_mkdir(path: Ptr[char]) -> int32
extern def sys_socket(domain: int32, sock_type: int32, proto: int32) -> int32
extern def sys_connect(fd: int32, addr: Ptr[uint8], addrlen: uint64) -> int32
# U-resolve: native-ABI hostname -> IPv4. SYS_RESOLVE (269) bridges to
# the in-kernel DNS resolver (drivers/net/dns.ad). Returns the IPv4
# packed big-endian in the low 32 bits (octet 0 in bits 31:24), or a
# negative errno (-2 == cannot resolve).
extern def sys_resolve(hostname: Ptr[uint8], hlen: uint64) -> int64
# U-TLS: native-ABI tls_connect(2). SYS_TLS_CONNECT (277) bridges to
# the in-kernel TLS 1.3 stack (drivers/net/tls.ad). Takes a socket fd
# that has already been connect()ed and runs the TLS 1.3 handshake
# (X25519 key exchange + server cert-chain validation against the
# kernel CA store + CertificateVerify transcript binding) over its TCP
# slot. `hostname` is the SNI / cert-name-validation host (NOT the IP).
# Returns 0 on success; afterwards read()/write() on the fd are
# transparently TLS-decrypted/encrypted. Negative errno on failure
# (-EPROTO handshake/cert failure, -EBUSY a TLS session already live).
extern def sys_tls_connect(fd: int32, hostname: Ptr[uint8],
                           hostlen: uint64) -> int32
# `apt install` shells out to /bin/dpkg -i to do the actual install.
extern def sys_spawn(path: Ptr[char], argv: Ptr[uint64],
                     stdin_fd: int32, stdout_fd: int32,
                     envp: Ptr[uint64]) -> int32
extern def sys_waitpid(pid: int32) -> int64


# -- bounded BSS arenas (Hamnix idiom: never park large Arrays in a
#    nested frame — memory/feedback_compiler_quirks.md U9) -------------

HTTP_STAGE: uint64 = 65536      # 64 KiB socket-drain staging chunk
PKG_STAGE:  uint64 = 65536      # 64 KiB inflate-output staging chunk
PKG_CAP:    uint64 = 524288     # 512 KiB in-RAM index for QUERIES

# HTTP_CAP bounds the single-shot codepaths that still buffer a whole
# body: the xz index download/decompress, and the .deb download. The
# streaming gz `apt update` path does NOT use it.
HTTP_CAP:   uint64 = 524288     # 512 KiB single-shot HTTP body cap

http_buf: Array[524288, uint8]   # raw bytes off the socket (single-shot)
pkg_buf:  Array[524288, uint8]   # decompressed index for queries / xz

# Streaming staging buffers for the incremental gz `apt update` path.
# http_stage holds one socket-drain chunk of the COMPRESSED body;
# pkg_stage holds one inflate-output chunk of the DECOMPRESSED index.
# Neither ever holds the whole index — that is the whole point.
http_stage: Array[65536, uint8]
pkg_stage:  Array[65536, uint8]

# Streaming gzip inflater state (~40 KiB).
inf_state: InflateState

# -- incremental stanza-counter + persisted-index-writer state --------
#
# The streaming `apt update` pass feeds decompressed chunks through
# _sink_feed(), which holds NO copy of the index. It tracks just
# enough cross-chunk state to (a) count blank-line-separated RFC822
# stanzas exactly and (b) write whole complete stanzas to the
# persisted /tmp/apt/Packages until the tmpfs file cap is reached.
#
# Stanza counting is a tiny line-oriented state machine: a stanza is
# counted on the transition from "in a blank region" to "in a stanza".
# Because a chunk boundary can split a line, the counter carries the
# "saw any non-blank byte on the current line" + "the line so far is
# all CR/blank" flags across calls.
sink_count:        uint64 = 0   # stanzas seen so far
sink_in_stanza:    int32 = 0    # currently inside a (non-blank) stanza
sink_line_blank:   int32 = 1    # current line is still all-blank so far
sink_line_started: int32 = 0    # the current line has at least one byte

# Persisted-index writer. _sink_feed appends decompressed bytes to the
# open fd sink_fd at offset sink_written until the tmpfs per-file cap
# (PKG_CAP) would be exceeded; past that it stops persisting (the
# counter keeps going). sink_persist_full is 1 while the persisted
# file still mirrors the index exactly, 0 once it was truncated.
sink_fd:           int32 = -1
sink_written:      uint64 = 0
sink_persist_full: int32 = 1

# Scratch: the HTTP request line/headers we send.
req_buf:  Array[1024, uint8]

# Scratch: the parsed-out connection target.
host_buf: Array[256, uint8]      # NUL-terminated hostname / dotted-quad
path_buf: Array[512, uint8]      # NUL-terminated base path (no trailing /)

# Scheme flag set by _parse_url: 0 == http (plain TCP), 1 == https (the
# socket is taken through the TLS 1.3 handshake after connect()). The
# whole HTTP request/response codepath is scheme-agnostic — the ONLY
# difference for https is the tls_connect step and the default port.
url_scheme: int32 = 0            # 0 == http, 1 == https

# Scratch: the absolute repo path for one GET (path + dists/... ).
url_path_buf: Array[768, uint8]

# The repository component apt fetches the binary-amd64 index from.
# Debian splits an archive into components — `main`, `contrib`,
# `non-free`, ... — each with its own `<component>/binary-amd64/
# Packages.gz`. V0 hardcoded `main`; `apt update` now takes an
# OPTIONAL 4th argument naming the component, defaulting to `main`
# when omitted so every existing call site is unchanged. Because the
# gz index now streams (no fixed-buffer size limit), the genuine
# multi-MB `main` index works directly — the component argument is a
# convenience, no longer a workaround for a small cap.
comp_buf: Array[64, uint8]       # NUL-terminated component name

# struct sockaddr_in, 16 bytes (built fresh for each connect).
sa_buf: Array[16, uint8]

# -- apt install scratch ----------------------------------------------
#
# The .deb download lands in `deb_buf`. Same 256 KiB cap as the HTTP
# response — a fixture-sized .deb sits far inside it; a larger .deb is
# a hard error (streaming straight to a file is a V1 concern). It is a
# separate top-level BSS arena (the U9 nested-frame-Array quirk) so the
# raw binary body never has to share http_buf with the inflate state.
DEB_CAP:  uint64 = 262144      # 256 KiB raw downloaded .deb
deb_buf:  Array[262144, uint8]

# Fields lifted out of the matched Packages stanza for `apt install`.
fld_filename: Array[512, uint8]    # Filename: path of the .deb (rel base-url)
fld_sha256:   Array[80, uint8]     # SHA256: 64 lowercase hex chars + NUL
fld_size:     Array[32, uint8]     # Size: decimal byte count + NUL
fld_version2: Array[256, uint8]    # Version: for the summary line

# The base-url, read back from /tmp/apt/base-url by `apt install`.
baseurl_buf: Array[768, uint8]

# Composed /tmp/apt/<pkg>.deb output path.
debpath_buf: Array[256, uint8]

# argv handed to the spawned `/bin/dpkg -i <debpath>`.
dpkg_argv:   Array[8, uint64]

# -- dependency-resolution scratch (V1) -------------------------------
#
# `apt install <pkg>` now walks the package's `Depends:` field
# transitively. Two fixed-size BSS tables back the resolver (top-level
# arenas — the U9 nested-frame-Array quirk):
#
#   dep_seen   — every package name visited by the resolver. Doubles
#                as the dedup set AND the cycle guard: a package
#                already in dep_seen is never recursed into again, so
#                a dependency that loops back into the set terminates.
#   dep_order  — the resolved install order, appended post-order
#                (deepest dependency first, the named package last).
#
# Both are bounded at DEP_MAX entries; exceeding that is a hard error
# (a real Debian dependency closure is far larger, but a fixture-sized
# graph sits well inside 64). Each name slot is DEP_NAME_CAP bytes.
DEP_MAX:      uint64 = 64          # max packages in one install closure
DEP_NAME_CAP: uint64 = 64          # max package-name length (+ NUL)

dep_seen:   Array[4096, uint8]     # DEP_MAX * DEP_NAME_CAP visited names
dep_seen_n: uint64 = 0             # count of names in dep_seen

dep_order:  Array[4096, uint8]     # DEP_MAX * DEP_NAME_CAP install order
dep_order_n: uint64 = 0            # count of names in dep_order

# Scratch: one dependency name pulled out of a `Depends:` term. This
# is shared scratch — clobbered by every _dep_term_name call — so the
# resolver copies the name it cares about into the per-depth name
# stack below before recursing.
dep_name_buf: Array[64, uint8]

# Per-recursion-depth name stack. _resolve copies its `pkg` argument
# (which itself points into the shared dep_name_buf of the caller)
# into its own DEP_NAME_CAP-byte slot here on entry, so a nested
# _resolve clobbering dep_name_buf does not corrupt this frame's name.
# Bounded at DEP_MAX depths — a chain deeper than 64 is a hard error.
dep_namestack: Array[4096, uint8]   # DEP_MAX * DEP_NAME_CAP

# Scratch: the raw `Depends:` field value of the stanza being resolved.
# Like dep_name_buf this is clobbered by a nested _resolve; the term
# loop re-extracts it after each recursive call.
dep_field_buf: Array[1024, uint8]

# Scratch: the resolver records which package's dependency was missing
# so the abort diagnostic can name the dependent.
dep_missing_parent: Array[64, uint8]

# SHA-256 working state for the download-verification path.
sha_state:   Array[8, uint32]      # 8 working hash words
sha_k:       Array[64, uint32]     # round constants
sha_w:       Array[64, uint32]     # message schedule scratch
sha_block:   Array[64, uint8]      # one 64-byte input block
sha_digest:  Array[32, uint8]      # 32-byte final digest
sha_hex:     Array[80, uint8]      # digest as 64 lowercase hex chars + NUL

# -- InRelease signature verification (V1: chain of trust) ------------
#
# The baked OpenPGP trust anchor lives in the initramfs at
# /etc/apt-trusted.gpg (planted by scripts/build_initramfs.py, the same
# way the kernel's TLS CA roots are baked at /etc/tls-ca-*.der). It is
# the raw bytes of `gpg --export` — a stream of v4 RSA Public-Key
# packets. The real `debian-archive-keyring.gpg` carries SEVERAL
# signing keys; apt loads ALL of them once at `apt update` time and
# verifies the `InRelease` signature against whichever key signed it.
#
# These are top-level BSS arenas — never function-locals — per the U9
# nested-frame-Array quirk (memory/feedback_compiler_quirks.md). The
# keyring path "/etc/apt-trusted.gpg" is materialised inline at the
# call sites (the x86_64 backend rejects string-literal globals).
#
# APT_KEYRING_CAP is sized for a real multi-key debian-archive-keyring
# (each RSA-4096 key + its User-ID + self-signature runs a few KiB; a
# dozen keys plus headroom).
APT_KEYRING_CAP:  uint64 = 131072      # multi-key keyring, ~128 KiB cap

apt_keyring_buf:  Array[131072, uint8] # raw baked keyring blob
apt_pgp_ring:     PgpKeyring           # all parsed trust-anchor RSA keys
apt_pgp_sig:      PgpSig               # parsed InRelease signature packet
# The keyring's keys re-shaped into lib/rsa's RsaPubkey form, one per
# PgpKeyring slot. Verification walks these until one accepts the
# signature. A flat top-level Array of RsaPubkey — `&apt_rsa_keys[i]`
# is a usable Ptr[RsaPubkey]. Sized to match PgpKeyring's 32-key
# capacity (PGP_KEYRING_MAX_KEYS): the real Debian keyring carries both
# primary keys and signing subkeys, so this must not be smaller.
apt_rsa_keys:     Array[32, RsaPubkey]
apt_rsa_nkeys:    uint64 = 0

# The InRelease body is fetched into http_buf; before the (later)
# Packages fetch overwrites http_buf, the InRelease bytes are copied
# here so verification survives the second GET.
INRELEASE_CAP:    uint64 = 262144
inrelease_buf:    Array[262144, uint8]
inrelease_len:    uint64 = 0

# The RSA signature value, left-zero-padded to exactly the modulus
# byte length. OpenPGP MPIs are minimal-length (no leading zero
# octets), but lib/rsa's PKCS#1 v1.5 verify requires a signature
# octet string of length exactly k (RFC 8017 §8.2.2 step 1), so the
# minimal MPI is right-aligned into this k-byte buffer.
apt_sig_padded:   Array[520, uint8]


# -- tiny stdio helpers (mirrors dpkg.ad / cat.ad) ---------------------

def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def write_dec_u64(fd: int32, value: uint64):
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def _write_full(fd: int32, buf: Ptr[uint8], count: uint64) -> int64:
    written: uint64 = 0
    while written < count:
        room: uint64 = count - written
        ptr: Ptr[uint8] = cast[Ptr[uint8]](cast[uint64](buf) + written)
        rc: int64 = sys_write(fd, ptr, room)
        if rc < 0:
            return rc
        if rc == 0:
            return cast[int64](written)
        written = written + cast[uint64](rc)
    return cast[int64](written)


# -- URL parsing -------------------------------------------------------
#
# Accepts `http://host[:port][/path]` and `https://host[:port][/path]`.
# Splits the URL into host_buf (NUL-terminated), path_buf
# (NUL-terminated, no trailing slash, "" for a bare host), records the
# scheme in the url_scheme global (0 == http, 1 == https) and returns
# the port (default 80 for http, 443 for https), or -1 on a malformed
# URL. No userinfo, no query string.

def _parse_url(url: Ptr[uint8]) -> int64:
    # Detect the scheme prefix. `https://` is 8 chars, `http://` is 7;
    # probe https first so the longer prefix wins. url_scheme + the
    # authority start offset are set from whichever matched.
    https_pfx: Ptr[uint8] = "https://"
    http_pfx:  Ptr[uint8] = "http://"
    a: uint64 = 0
    is_https: int32 = 1
    i: uint64 = 0
    while i < 8:
        if url[i] != https_pfx[i]:
            is_https = 0
            break
        i = i + 1
    if is_https != 0:
        url_scheme = 1
        a = 8
    else:
        # Not https:// — require the plain http:// prefix (7 chars).
        hp: uint64 = 0
        while hp < 7:
            if url[hp] != http_pfx[hp]:
                write_str(2, "apt-get: only http:// and https:// URLs supported\n")
                return -1
            hp = hp + 1
        url_scheme = 0
        a = 7

    # Authority spans from `a` up to the first '/' or the NUL.
    auth_end: uint64 = a
    while url[auth_end] != 0 and url[auth_end] != 47:   # '/'
        auth_end = auth_end + 1

    # Within the authority, ':' (if present) splits host from port.
    colon: uint64 = a
    have_colon: int32 = 0
    j: uint64 = a
    while j < auth_end:
        if url[j] == 58:                                # ':'
            colon = j
            have_colon = 1
            break
        j = j + 1

    host_end: uint64 = auth_end
    if have_colon != 0:
        host_end = colon
    if host_end <= a:
        write_str(2, "apt-get: malformed URL (empty host)\n")
        return -1

    # Copy the host.
    ho: uint64 = 0
    k: uint64 = a
    while k < host_end and ho + 1 < 256:
        host_buf[ho] = url[k]
        ho = ho + 1
        k = k + 1
    host_buf[ho] = 0

    # Parse the port (decimal) if a ':' was present, else default to
    # the scheme's well-known port: 80 for http, 443 for https.
    port: int64 = 80
    if url_scheme != 0:
        port = 443
    if have_colon != 0:
        port = 0
        p: uint64 = colon + 1
        if p >= auth_end:
            write_str(2, "apt-get: malformed URL (empty port)\n")
            return -1
        while p < auth_end:
            c: uint8 = url[p]
            if c < 48 or c > 57:
                write_str(2, "apt-get: malformed URL (non-numeric port)\n")
                return -1
            port = port * 10 + cast[int64](c - 48)
            if port > 65535:
                write_str(2, "apt-get: malformed URL (port out of range)\n")
                return -1
            p = p + 1

    # Copy the path = everything from auth_end onward, with any single
    # trailing '/' trimmed so later joins produce "<path>/dists/..."
    # not "<path>//dists/...". A bare host yields the empty path.
    po: uint64 = 0
    m: uint64 = auth_end
    while url[m] != 0 and po + 1 < 512:
        path_buf[po] = url[m]
        po = po + 1
        m = m + 1
    while po > 0 and path_buf[po - 1] == 47:            # trim trailing '/'
        po = po - 1
    path_buf[po] = 0

    return port


# -- host resolution: IPv4 literal or DNS ------------------------------
#
# A repo URL's host is either a dotted-quad IPv4 literal ("10.0.2.2")
# or a DNS name ("deb.debian.org"). _parse_ipv4 probes host_buf for a
# dotted-quad and, on a clean parse, fills out0..out3 with the four
# octets — it is SILENT on a non-dotted-quad (returns -1 without
# printing) so the caller can fall through to DNS. _resolve_host is
# the entry point: it tries the literal first, then bridges to the
# in-kernel DNS resolver via sys_resolve (SYS_RESOLVE 269).

def _parse_ipv4(out0: Ptr[uint8], out1: Ptr[uint8],
                out2: Ptr[uint8], out3: Ptr[uint8]) -> int32:
    octet: uint32 = 0
    have_digit: int32 = 0
    idx: uint32 = 0                                     # which octet (0..3)
    i: uint64 = 0
    while True:
        c: uint8 = host_buf[i]
        if c == 46 or c == 0:                           # '.' or NUL
            if have_digit == 0:
                return -1
            if octet > 255:
                return -1
            if idx == 0:
                out0[0] = cast[uint8](octet)
            elif idx == 1:
                out1[0] = cast[uint8](octet)
            elif idx == 2:
                out2[0] = cast[uint8](octet)
            else:
                out3[0] = cast[uint8](octet)
            if c == 0:
                if idx != 3:
                    return -1
                return 0
            idx = idx + 1
            if idx > 3:
                return -1
            octet = 0
            have_digit = 0
        elif c >= 48 and c <= 57:
            octet = octet * 10 + cast[uint32](c - 48)
            have_digit = 1
        else:
            # A non-digit, non-dot, non-NUL byte: host_buf is not a
            # dotted-quad. Bail quietly — _resolve_host falls back to
            # DNS for anything that isn't a literal.
            return -1
        i = i + 1


# Resolve host_buf into four IPv4 octets written through out0..out3.
# A dotted-quad literal is used verbatim; anything else is handed to
# the in-kernel DNS resolver via sys_resolve. Returns 0 on success,
# -1 on a resolution failure (the caller has already had a clear
# diagnostic printed here).

def _resolve_host(out0: Ptr[uint8], out1: Ptr[uint8],
                  out2: Ptr[uint8], out3: Ptr[uint8]) -> int32:
    # Fast path: a dotted-quad literal needs no DNS round-trip.
    if _parse_ipv4(out0, out1, out2, out3) == 0:
        return 0
    # Not a literal — resolve the name through the kernel DNS bridge.
    # sys_resolve returns the IPv4 packed big-endian in the low 32
    # bits (octet 0 in bits 31:24), or a negative errno on failure.
    resolved_ip: int64 = sys_resolve(&host_buf[0], strlen_u8(&host_buf[0]))
    if resolved_ip < 0:
        write_str(2, "apt: cannot resolve ")
        write_str(2, &host_buf[0])
        write_str(2, "\n")
        return -1
    u: uint64 = cast[uint64](resolved_ip)
    out0[0] = cast[uint8]((u >> 24) & 0xFF)
    out1[0] = cast[uint8]((u >> 16) & 0xFF)
    out2[0] = cast[uint8]((u >> 8) & 0xFF)
    out3[0] = cast[uint8](u & 0xFF)
    write_str(1, "apt: resolved ")
    write_str(1, &host_buf[0])
    write_str(1, " -> ")
    write_dec_u64(1, cast[uint64](out0[0]))
    write_str(1, ".")
    write_dec_u64(1, cast[uint64](out1[0]))
    write_str(1, ".")
    write_dec_u64(1, cast[uint64](out2[0]))
    write_str(1, ".")
    write_dec_u64(1, cast[uint64](out3[0]))
    write_str(1, "\n")
    return 0


# -- HTTP response-length probe ----------------------------------------
#
# Given the `total` bytes drained into http_buf so far, work out how
# many bytes the whole HTTP response will be, when that is already
# knowable. The response is complete once we have the CRLFCRLF header
# terminator plus a `Content-Length:` worth of body bytes.
#
# Returns the expected total response length (header bytes + body
# bytes) once BOTH the header terminator AND a Content-Length header
# have been seen; returns 0 while either is still missing — i.e. "keep
# reading". A 0 result is also the answer for a response with no
# Content-Length at all, in which case _http_get falls back to draining
# until the peer FINs (read() == 0).
#
# Why this matters for HTTPS: a plain-HTTP server FINs promptly after
# the body, so a read-until-EOF loop sees a clean 0. The kernel TLS
# stack's peer (and real TLS mirrors) can be slow to send the
# close_notify / FIN, so a post-body read() blocks for the kernel
# socket-read budget on every fetch — and a syscall runs with the
# timer IRQ masked, so `jiffies` doesn't advance and that bounded poll
# never times out: the read wedges forever. Stopping as soon as
# Content-Length bytes have arrived avoids that trailing read entirely.
#
# Header-name matching is case-insensitive (RFC 7230 §3.2); the value
# is parsed as a run of ASCII digits after optional spaces.

def _http_expected_len(total: uint64) -> uint64:
    # 1. Locate the end of the header block (first CRLFCRLF).
    hdr_end: uint64 = 0
    found: int32 = 0
    p: uint64 = 0
    while p + 3 < total:
        if http_buf[p] == 13 and http_buf[p + 1] == 10 \
                and http_buf[p + 2] == 13 and http_buf[p + 3] == 10:
            hdr_end = p + 4
            found = 1
            break
        p = p + 1
    if found == 0:
        return 0                               # headers still arriving

    # 2. Walk the header lines looking for "Content-Length:" (ci).
    name: Ptr[uint8] = "content-length"
    name_len: uint64 = 14
    line: uint64 = 0
    while line < hdr_end:
        # Does this line start with the Content-Length field name?
        match_n: int32 = 1
        j: uint64 = 0
        while j < name_len:
            c: uint8 = http_buf[line + j]
            # ASCII upper -> lower so the compare is case-insensitive.
            if c >= 65 and c <= 90:
                c = c + 32
            if c != name[j]:
                match_n = 0
                break
            j = j + 1
        if match_n != 0 and http_buf[line + name_len] == 58:    # ':'
            # Skip the ':' and any leading spaces, then parse digits.
            v: uint64 = line + name_len + 1
            while v < hdr_end and http_buf[v] == 32:            # ' '
                v = v + 1
            clen: uint64 = 0
            have_digit: int32 = 0
            while v < hdr_end and http_buf[v] >= 48 \
                    and http_buf[v] <= 57:
                clen = clen * 10 + cast[uint64](http_buf[v] - 48)
                have_digit = 1
                v = v + 1
            if have_digit != 0:
                return hdr_end + clen
            return 0
        # Advance to the start of the next header line (past the LF).
        nl: uint64 = line
        while nl < hdr_end and http_buf[nl] != 10:              # '\n'
            nl = nl + 1
        line = nl + 1
    return 0                                   # no Content-Length header


# -- HTTP GET ----------------------------------------------------------
#
# Connect to host:port, issue a raw HTTP/1.0 GET for `url_path` (a
# NUL-terminated absolute path beginning with '/'), drain the whole
# response into http_buf, and return the byte offset where the body
# starts (just past the first CRLFCRLF) packed with the total length.
#
# Returns the BODY length, writes the body start offset through
# *body_off. Returns -1 on any socket / HTTP error.
#
# `quiet`: when non-zero, a non-200 HTTP status (notably a 404 — the
# expected outcome when probing for an optional resource like
# Packages.xz on a mirror that only ships Packages.gz) returns the
# distinct sentinel -2 WITHOUT writing a diagnostic to stderr, so the
# caller can fall back silently. Socket-level failures still return -1
# and still print. quiet==0 keeps the original loud behaviour.

# -- shared connect + request helpers ---------------------------------
#
# _http_connect resolves host_buf, opens an AF_INET stream socket,
# connect()s to host:port and (for https) runs the TLS 1.3 handshake.
# Returns the connected fd, or -1 on any failure (diagnostic printed).
# _http_send_request builds the HTTP/1.0 GET for url_path_buf into
# req_buf and writes it to `fd`; returns 0 on success, -1 on a short
# write. Both are shared by the buffered _http_get and the streaming
# `apt update` index fetch so the two never drift apart.

def _http_connect(port: int64) -> int32:
    ip0: uint8 = 0
    ip1: uint8 = 0
    ip2: uint8 = 0
    ip3: uint8 = 0
    if _resolve_host(&ip0, &ip1, &ip2, &ip3) != 0:
        return -1

    # struct sockaddr_in: family(2, host order) port(2, BE) addr(4, BE)
    # zero(8). AF_INET == 2.
    k: uint64 = 0
    while k < 16:
        sa_buf[k] = 0
        k = k + 1
    sa_buf[0] = 2                                       # AF_INET low
    sa_buf[1] = 0                                       # AF_INET high
    sa_buf[2] = cast[uint8]((cast[uint64](port) >> 8) & 0xFF)   # port hi
    sa_buf[3] = cast[uint8](cast[uint64](port) & 0xFF)         # port lo
    sa_buf[4] = ip0
    sa_buf[5] = ip1
    sa_buf[6] = ip2
    sa_buf[7] = ip3

    # AF_INET == 2, SOCK_STREAM == 1, protocol 0 (= TCP).
    fd: int32 = sys_socket(2, 1, 0)
    if fd < 0:
        write_str(2, "apt-get: socket() failed\n")
        return -1

    crc: int32 = sys_connect(fd, &sa_buf[0], 16)
    if crc != 0:
        write_str(2, "apt-get: connect() failed (is the mirror reachable?)\n")
        sys_close(fd)
        return -1

    # https: run the TLS 1.3 handshake over the connected socket before
    # any HTTP bytes flow.
    if url_scheme != 0:
        tls_rc: int32 = sys_tls_connect(fd, &host_buf[0],
                                        strlen_u8(&host_buf[0]))
        if tls_rc != 0:
            write_str(2, "apt: TLS handshake failed for ")
            write_str(2, &host_buf[0])
            write_str(2, "\n")
            sys_close(fd)
            return -1
        write_str(1, "apt: TLS handshake ok for ")
        write_str(1, &host_buf[0])
        write_str(1, "\n")
    return fd


def _http_send_request(fd: int32) -> int32:
    # Build the request: HTTP/1.0 + Connection: close so the server
    # FINs after the body. String literals are materialised inline (the
    # x86_64 backend rejects string-literal globals).
    ro: uint64 = 0
    g: Ptr[uint8] = "GET "
    gi: uint64 = 0
    while g[gi] != 0:
        req_buf[ro] = g[gi]
        ro = ro + 1
        gi = gi + 1
    pi: uint64 = 0
    while url_path_buf[pi] != 0 and ro < 1000:
        req_buf[ro] = url_path_buf[pi]
        ro = ro + 1
        pi = pi + 1
    tail1: Ptr[uint8] = " HTTP/1.0\r\nHost: "
    ti: uint64 = 0
    while tail1[ti] != 0:
        req_buf[ro] = tail1[ti]
        ro = ro + 1
        ti = ti + 1
    hi: uint64 = 0
    while host_buf[hi] != 0 and ro < 1000:
        req_buf[ro] = host_buf[hi]
        ro = ro + 1
        hi = hi + 1
    tail2: Ptr[uint8] = "\r\nUser-Agent: hamnix-apt/0\r\nConnection: close\r\n\r\n"
    si: uint64 = 0
    while tail2[si] != 0:
        req_buf[ro] = tail2[si]
        ro = ro + 1
        si = si + 1

    wn: int64 = _write_full(fd, &req_buf[0], ro)
    if wn < 0 or cast[uint64](wn) != ro:
        write_str(2, "apt-get: short write sending HTTP request\n")
        return -1
    return 0


def _http_get(port: int64, body_off: Ptr[uint64], quiet: int32) -> int64:
    fd: int32 = _http_connect(port)
    if fd < 0:
        return -1
    if _http_send_request(fd) != 0:
        sys_close(fd)
        return -1

    # Drain the response into http_buf. We stop as soon as the whole
    # response is in hand: once the headers + a Content-Length worth of
    # body bytes have arrived (_http_expected_len), we must NOT issue
    # another read() — on the https path a trailing read past the body
    # blocks until the peer's slow close_notify/FIN and wedges the
    # syscall (the timer IRQ is masked in syscall context, so the
    # kernel socket-read's bounded poll never times out). A response
    # with no Content-Length falls back to draining until read()==0.
    total: uint64 = 0
    while total < HTTP_CAP:
        want: uint64 = _http_expected_len(total)
        if want != 0 and total >= want:
            break                              # full response received
        room: uint64 = HTTP_CAP - total
        n: int64 = sys_read(fd, cast[Ptr[uint8]](
            cast[uint64](&http_buf[0]) + total), room)
        if n < 0:
            write_str(2, "apt-get: read() error on HTTP response\n")
            sys_close(fd)
            return -1
        if n == 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)

    # If Content-Length was known, trim any bytes a final read pulled
    # in past the body (e.g. a TLS close_notify record riding the same
    # segment) so the returned body length is exact.
    exact: uint64 = _http_expected_len(total)
    if exact != 0 and total > exact:
        total = exact

    if total == 0:
        write_str(2, "apt-get: empty HTTP response\n")
        return -1
    if total >= HTTP_CAP:
        write_str(2, "apt-get: HTTP response exceeds the single-shot 512 KiB cap\n")
        write_str(2, "apt-get: (a large gz index streams unbounded; this cap is the xz / .deb path)\n")
        return -1

    # The status line must be "HTTP/1.x 200 ...". Anything else (404,
    # 301, 500, ...) is a hard error — V0 does not follow redirects.
    if total < 12:
        write_str(2, "apt-get: truncated HTTP status line\n")
        return -1
    if http_buf[0] != 72 or http_buf[1] != 84 or http_buf[2] != 84 \
            or http_buf[3] != 80:                       # "HTTP"
        write_str(2, "apt-get: malformed HTTP status line\n")
        return -1
    # Status code occupies bytes 9..11 ("HTTP/1.0 NNN ...").
    if http_buf[9] != 50 or http_buf[10] != 48 or http_buf[11] != 48:  # "200"
        if quiet != 0:
            # Probe miss (e.g. a 404 for an optional Packages.xz) — the
            # caller will fall back; stay silent.
            return -2
        write_str(2, "apt-get: HTTP request did not return 200 OK\n")
        return -1

    # Find the header/body boundary: the first CRLFCRLF.
    bo: uint64 = 0
    found: int32 = 0
    p: uint64 = 0
    while p + 3 < total:
        if http_buf[p] == 13 and http_buf[p + 1] == 10 \
                and http_buf[p + 2] == 13 and http_buf[p + 3] == 10:
            bo = p + 4
            found = 1
            break
        p = p + 1
    if found == 0:
        write_str(2, "apt-get: HTTP response has no header terminator\n")
        return -1

    body_off[0] = bo
    return cast[int64](total - bo)


# -- streaming gzip index fetch (the unbounded `apt update` path) -----
#
# _http_stream_gz_index fetches url_path_buf and runs the WHOLE
# download → gzip-inflate → stanza-count → persist pipeline
# incrementally. Nothing in this function holds the whole compressed
# body or the whole decompressed index — a real multi-MB Debian `main`
# index is processed in 64 KiB staging chunks. This is the fix that
# lifts the old fixed-RAM-buffer size limit.
#
# Flow:
#   1. connect + send the GET.
#   2. drain the socket into http_stage one chunk at a time.
#   3. the FIRST chunks carry the HTTP headers; we accumulate just the
#      header bytes until the CRLFCRLF terminator, validate the status
#      line, then treat everything after the terminator as body.
#   4. each body chunk is fed to inflate_feed; the inflater emits
#      decompressed bytes into pkg_stage, which we drain to _sink_feed
#      (count + persist). inflate_feed is looped until it has consumed
#      the whole input chunk (it can stop early when pkg_stage fills).
#   5. on read()==0 (peer FIN) or done==1 we stop.
#
# The persisted file fd must already be open as `sink_fd` and
# _sink_reset() already called. Returns the decompressed byte count
# (>= 0) on success, or -1 on any error.

_HDR_MAX: uint64 = 8192          # cap on HTTP header bytes we buffer


def _stream_drain_inflate(in_ptr: Ptr[uint8], in_len: uint64,
                          done: Ptr[int32]) -> int64:
    # Feed [in_ptr, in_len) to the inflater, looping so the whole input
    # chunk is consumed even if pkg_stage fills mid-chunk; each time
    # pkg_stage has output, drain it to the sink. Returns decompressed
    # bytes produced (>= 0) or -1 on error. Sets *done on end-of-stream.
    produced: int64 = 0
    in_done: uint64 = 0
    while in_done < in_len:
        out_consumed: uint64 = 0
        in_consumed: uint64 = 0
        d: int32 = 0
        chunk_ptr: Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](in_ptr) + in_done)
        irc: int32 = inflate_feed(&inf_state,
                                  chunk_ptr, in_len - in_done,
                                  &pkg_stage[0], PKG_STAGE,
                                  &out_consumed, &in_consumed, &d)
        if irc < 0:
            return -1
        if out_consumed > 0:
            if _sink_feed(&pkg_stage[0], out_consumed) != 0:
                return -1
            produced = produced + cast[int64](out_consumed)
        in_done = in_done + in_consumed
        if d != 0:
            done[0] = 1
            return produced
        # inflate_feed returns 0 when it needs more input OR when the
        # out buffer filled. If it consumed nothing AND produced
        # nothing, it is genuinely starved — break to refill input.
        if in_consumed == 0 and out_consumed == 0:
            break
    return produced


def _http_stream_gz_index(port: int64) -> int64:
    fd: int32 = _http_connect(port)
    if fd < 0:
        return -1
    if _http_send_request(fd) != 0:
        sys_close(fd)
        return -1

    inflate_init(&inf_state)

    # Header accumulation: http_stage[0, hdr_len) holds header bytes
    # until the CRLFCRLF terminator is found. Once found, body bytes
    # that arrived in the same read are forwarded straight to the
    # inflater; later reads are pure body.
    hdr_len: uint64 = 0
    headers_done: int32 = 0
    status_ok: int32 = 0
    total_out: int64 = 0
    stream_done: int32 = 0

    while True:
        # Read one chunk off the socket. While still in headers we read
        # into http_stage just past the buffered header bytes; once
        # headers are parsed we always read into http_stage[0..].
        dst_off: uint64 = 0
        if headers_done == 0:
            dst_off = hdr_len
        room: uint64 = HTTP_STAGE - dst_off
        if room == 0:
            write_str(2, "apt-get: HTTP headers exceed staging buffer\n")
            sys_close(fd)
            return -1
        rp: Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](&http_stage[0]) + dst_off)
        n: int64 = sys_read(fd, rp, room)
        if n < 0:
            write_str(2, "apt-get: read() error streaming the index\n")
            sys_close(fd)
            return -1
        if n == 0:
            break                                       # peer FIN

        if headers_done == 0:
            # Grow the buffered header span and hunt for CRLFCRLF.
            hdr_len = hdr_len + cast[uint64](n)
            term: uint64 = 0
            found: int32 = 0
            p: uint64 = 0
            while p + 3 < hdr_len:
                if http_stage[p] == 13 and http_stage[p + 1] == 10 \
                        and http_stage[p + 2] == 13 \
                        and http_stage[p + 3] == 10:
                    term = p + 4
                    found = 1
                    break
                p = p + 1
            if found == 0:
                if hdr_len > _HDR_MAX:
                    write_str(2, "apt-get: HTTP header block too large\n")
                    sys_close(fd)
                    return -1
                continue                                # need more header
            # Validate the status line ("HTTP/1.x 200 ...").
            if hdr_len < 12 or http_stage[0] != 72 or http_stage[1] != 84 \
                    or http_stage[2] != 84 or http_stage[3] != 80:
                write_str(2, "apt-get: malformed HTTP status line\n")
                sys_close(fd)
                return -1
            if http_stage[9] != 50 or http_stage[10] != 48 \
                    or http_stage[11] != 48:            # "200"
                write_str(2, "apt-get: HTTP request did not return 200 OK\n")
                sys_close(fd)
                return -1
            status_ok = 1
            headers_done = 1
            # Body bytes that arrived in this same read: [term, hdr_len).
            if term < hdr_len:
                blen: uint64 = hdr_len - term
                bptr: Ptr[uint8] = cast[Ptr[uint8]](
                    cast[uint64](&http_stage[0]) + term)
                pr: int64 = _stream_drain_inflate(bptr, blen,
                                                  &stream_done)
                if pr < 0:
                    write_str(2, "apt-get: gzip inflate error in stream\n")
                    sys_close(fd)
                    return -1
                total_out = total_out + pr
            if stream_done != 0:
                break
        else:
            # Pure body chunk — straight into the inflater.
            pr2: int64 = _stream_drain_inflate(&http_stage[0],
                                               cast[uint64](n),
                                               &stream_done)
            if pr2 < 0:
                write_str(2, "apt-get: gzip inflate error in stream\n")
                sys_close(fd)
                return -1
            total_out = total_out + pr2
            if stream_done != 0:
                break

    sys_close(fd)

    if status_ok == 0:
        write_str(2, "apt-get: HTTP response had no complete header block\n")
        return -1
    if stream_done == 0:
        write_str(2, "apt-get: gzip stream did not reach end-of-stream\n")
        return -1
    return total_out


# -- compose "<base-path>/dists/<suite>/<tail>" into url_path_buf ------
#
# `tail` is the suffix below the suite directory (e.g. "Release" or
# "main/binary-amd64/Packages.gz"). The base path may be empty (a bare
# host); the result always begins with a single '/'.

def _build_index_path(suite: Ptr[uint8], tail: Ptr[uint8]):
    o: uint64 = 0
    # Base path (already trimmed of a trailing '/'). If empty we still
    # want the result to start with '/', which the literal below adds.
    bi: uint64 = 0
    while path_buf[bi] != 0 and o + 1 < 768:
        url_path_buf[o] = path_buf[bi]
        o = o + 1
        bi = bi + 1
    mid: Ptr[uint8] = "/dists/"
    mi: uint64 = 0
    while mid[mi] != 0 and o + 1 < 768:
        url_path_buf[o] = mid[mi]
        o = o + 1
        mi = mi + 1
    si: uint64 = 0
    while suite[si] != 0 and o + 1 < 768:
        url_path_buf[o] = suite[si]
        o = o + 1
        si = si + 1
    url_path_buf[o] = 47                                # '/'
    o = o + 1
    ti: uint64 = 0
    while tail[ti] != 0 and o + 1 < 768:
        url_path_buf[o] = tail[ti]
        o = o + 1
        ti = ti + 1
    url_path_buf[o] = 0


# -- compose the binary-amd64 Packages index path into url_path_buf ---
#
# Builds "<base-path>/dists/<suite>/<component>/binary-amd64/
# Packages.<ext>" where <component> is the comp_buf global (`main` by
# default, or whatever `apt update`'s optional 4th argument named) and
# <ext> is the caller-supplied compression suffix ("xz" or "gz").
# Split out from _build_index_path because the component is a runtime
# value, not a string-literal tail.
#
# `ext` is "gz" or "xz": real Debian ships an xz-compressed
# `Packages.xz` (LZMA2) alongside the older `Packages.gz`, and
# `apt update` probes for `.xz` first (smaller, the modern default)
# before falling back to `.gz`.

def _build_packages_path(suite: Ptr[uint8], ext: Ptr[uint8]):
    o: uint64 = 0
    bi: uint64 = 0
    while path_buf[bi] != 0 and o + 1 < 768:
        url_path_buf[o] = path_buf[bi]
        o = o + 1
        bi = bi + 1
    mid: Ptr[uint8] = "/dists/"
    mi: uint64 = 0
    while mid[mi] != 0 and o + 1 < 768:
        url_path_buf[o] = mid[mi]
        o = o + 1
        mi = mi + 1
    si: uint64 = 0
    while suite[si] != 0 and o + 1 < 768:
        url_path_buf[o] = suite[si]
        o = o + 1
        si = si + 1
    url_path_buf[o] = 47                                # '/'
    o = o + 1
    ci: uint64 = 0
    while comp_buf[ci] != 0 and o + 1 < 768:
        url_path_buf[o] = comp_buf[ci]
        o = o + 1
        ci = ci + 1
    tail: Ptr[uint8] = "/binary-amd64/Packages."
    ti: uint64 = 0
    while tail[ti] != 0 and o + 1 < 768:
        url_path_buf[o] = tail[ti]
        o = o + 1
        ti = ti + 1
    ei: uint64 = 0
    while ext[ei] != 0 and o + 1 < 768:
        url_path_buf[o] = ext[ei]
        o = o + 1
        ei = ei + 1
    url_path_buf[o] = 0


# -- incremental decompressed-index sink ------------------------------
#
# _sink_feed(buf, n) processes one chunk of decompressed Packages-index
# bytes from the streaming `apt update` pass. It is called repeatedly
# with successive chunks and keeps NO copy of the index — index size
# is bounded by what apt keeps, which here is nothing (the counter) and
# the persisted-file cap (a partial cache for a giant index).
#
# Two jobs per chunk:
#   1. Count blank-line-separated RFC822 stanzas exactly, carrying the
#      line-state flags (sink_*) across chunk boundaries so a line or
#      stanza split by a chunk edge still counts once.
#   2. Append the bytes to the open persisted file (sink_fd) until the
#      tmpfs per-file cap (PKG_CAP) would be exceeded; past that the
#      persist stops (sink_persist_full -> 0) but counting continues.

def _sink_reset():
    sink_count = 0
    sink_in_stanza = 0
    sink_line_blank = 1
    sink_line_started = 0
    sink_written = 0
    sink_persist_full = 1


# Flush the line-state machine at end-of-stream: an index whose final
# line is non-blank and carries no trailing '\n' still counts that last
# stanza (matches the buffered _count_stanzas behaviour).

def _sink_flush():
    if sink_line_started != 0 and sink_line_blank == 0:
        if sink_in_stanza == 0:
            sink_count = sink_count + 1
            sink_in_stanza = 1


def _sink_feed(buf: Ptr[uint8], n: uint64) -> int64:
    # --- 1. stanza counting (byte-at-a-time line state machine) ---
    i: uint64 = 0
    while i < n:
        c: uint8 = buf[i]
        if c == 10:                                     # '\n' — end of line
            # A line counts as blank if every byte on it was a blank
            # or CR (sink_line_blank stays 1). The empty line (no bytes
            # at all) is blank too.
            if sink_line_blank != 0:
                sink_in_stanza = 0                      # blank line
            else:
                if sink_in_stanza == 0:
                    sink_count = sink_count + 1
                    sink_in_stanza = 1
            # Reset per-line state for the next line.
            sink_line_blank = 1
            sink_line_started = 0
        else:
            sink_line_started = 1
            # A '\r' (CRLF) does not make the line non-blank; any other
            # byte does.
            if c != 13:
                sink_line_blank = 0
        i = i + 1

    # --- 2. persist to /tmp/apt/Packages until the cap ---
    if sink_fd >= 0 and sink_persist_full != 0:
        room: uint64 = 0
        if sink_written < PKG_CAP:
            room = PKG_CAP - sink_written
        take: uint64 = n
        if take > room:
            take = room
            sink_persist_full = 0                       # cache truncated
        if take > 0:
            wn: int64 = _write_full(sink_fd, buf, take)
            if wn < 0:
                return -1
            sink_written = sink_written + cast[uint64](wn)
            if cast[uint64](wn) != take:
                sink_persist_full = 0
    return 0


# -- count RFC822 stanzas in pkg_buf[0, len) ---------------------------
#
# A Packages index is blank-line-separated stanzas. We count a stanza
# for every run of non-blank lines: a transition from "inside blank
# region" to "inside a stanza". Trailing blank lines don't add a count.
# Used by the QUERY commands against the in-RAM pkg_buf; the streaming
# `apt update` pass uses the incremental _sink_feed counter above.

def _count_stanzas(plen: uint64) -> uint64:
    count: uint64 = 0
    in_stanza: int32 = 0
    pos: uint64 = 0
    while pos < plen:
        lstart: uint64 = pos
        lend: uint64 = pos
        while lend < plen and pkg_buf[lend] != 10:
            lend = lend + 1
        # Trim a trailing '\r' so CRLF indexes count cleanly.
        tend: uint64 = lend
        if tend > lstart and pkg_buf[tend - 1] == 13:
            tend = tend - 1
        if tend == lstart:
            in_stanza = 0                               # blank line
        else:
            if in_stanza == 0:
                count = count + 1
                in_stanza = 1
        pos = lend
        if pos < plen:
            pos = pos + 1
    return count


# -- SHA-256 (FIPS 180-4), standalone userland port --------------------
#
# `apt install` must verify the downloaded .deb against the index's
# SHA256 field. The kernel TLS stack carries a SHA-256
# (drivers/net/tls.ad) but it keys off tls_* kernel globals and a
# running-transcript model — it is not callable from a userland binary.
# A standalone SHA-256 is small (~130 lines); this is a faithful one-
# shot port. State lives in the sha_* BSS arenas above (frames stay
# tiny — the U9 quirk). _sha256_hash() hashes deb_buf[0, n) and writes
# the 64-char lowercase-hex digest into sha_hex.

def _sha256_rotr32(v: uint32, n: uint64) -> uint32:
    x: uint64 = cast[uint64](v) & 0xFFFFFFFF
    lo: uint64 = x >> n
    hi: uint64 = (x << (32 - n)) & 0xFFFFFFFF
    return cast[uint32](lo | hi)


def _sha256_init_k():
    sha_k[0]  = 0x428A2F98
    sha_k[1]  = 0x71374491
    sha_k[2]  = 0xB5C0FBCF
    sha_k[3]  = 0xE9B5DBA5
    sha_k[4]  = 0x3956C25B
    sha_k[5]  = 0x59F111F1
    sha_k[6]  = 0x923F82A4
    sha_k[7]  = 0xAB1C5ED5
    sha_k[8]  = 0xD807AA98
    sha_k[9]  = 0x12835B01
    sha_k[10] = 0x243185BE
    sha_k[11] = 0x550C7DC3
    sha_k[12] = 0x72BE5D74
    sha_k[13] = 0x80DEB1FE
    sha_k[14] = 0x9BDC06A7
    sha_k[15] = 0xC19BF174
    sha_k[16] = 0xE49B69C1
    sha_k[17] = 0xEFBE4786
    sha_k[18] = 0x0FC19DC6
    sha_k[19] = 0x240CA1CC
    sha_k[20] = 0x2DE92C6F
    sha_k[21] = 0x4A7484AA
    sha_k[22] = 0x5CB0A9DC
    sha_k[23] = 0x76F988DA
    sha_k[24] = 0x983E5152
    sha_k[25] = 0xA831C66D
    sha_k[26] = 0xB00327C8
    sha_k[27] = 0xBF597FC7
    sha_k[28] = 0xC6E00BF3
    sha_k[29] = 0xD5A79147
    sha_k[30] = 0x06CA6351
    sha_k[31] = 0x14292967
    sha_k[32] = 0x27B70A85
    sha_k[33] = 0x2E1B2138
    sha_k[34] = 0x4D2C6DFC
    sha_k[35] = 0x53380D13
    sha_k[36] = 0x650A7354
    sha_k[37] = 0x766A0ABB
    sha_k[38] = 0x81C2C92E
    sha_k[39] = 0x92722C85
    sha_k[40] = 0xA2BFE8A1
    sha_k[41] = 0xA81A664B
    sha_k[42] = 0xC24B8B70
    sha_k[43] = 0xC76C51A3
    sha_k[44] = 0xD192E819
    sha_k[45] = 0xD6990624
    sha_k[46] = 0xF40E3585
    sha_k[47] = 0x106AA070
    sha_k[48] = 0x19A4C116
    sha_k[49] = 0x1E376C08
    sha_k[50] = 0x2748774C
    sha_k[51] = 0x34B0BCB5
    sha_k[52] = 0x391C0CB3
    sha_k[53] = 0x4ED8AA4A
    sha_k[54] = 0x5B9CCA4F
    sha_k[55] = 0x682E6FF3
    sha_k[56] = 0x748F82EE
    sha_k[57] = 0x78A5636F
    sha_k[58] = 0x84C87814
    sha_k[59] = 0x8CC70208
    sha_k[60] = 0x90BEFFFA
    sha_k[61] = 0xA4506CEB
    sha_k[62] = 0xBEF9A3F7
    sha_k[63] = 0xC67178F2


# Compress the 64-byte block in sha_block into sha_state.

def _sha256_compress():
    i: uint64 = 0
    while i < 16:
        b0: uint32 = cast[uint32](sha_block[i * 4 + 0])
        b1: uint32 = cast[uint32](sha_block[i * 4 + 1])
        b2: uint32 = cast[uint32](sha_block[i * 4 + 2])
        b3: uint32 = cast[uint32](sha_block[i * 4 + 3])
        sha_w[i] = (b0 << 24) | (b1 << 16) | (b2 << 8) | b3
        i = i + 1
    while i < 64:
        s0: uint32 = _sha256_rotr32(sha_w[i - 15], 7) \
            ^ _sha256_rotr32(sha_w[i - 15], 18) \
            ^ (sha_w[i - 15] >> 3)
        s1: uint32 = _sha256_rotr32(sha_w[i - 2], 17) \
            ^ _sha256_rotr32(sha_w[i - 2], 19) \
            ^ (sha_w[i - 2] >> 10)
        sum_v: uint64 = (cast[uint64](sha_w[i - 16]) & 0xFFFFFFFF) \
            + (cast[uint64](s0) & 0xFFFFFFFF) \
            + (cast[uint64](sha_w[i - 7]) & 0xFFFFFFFF) \
            + (cast[uint64](s1) & 0xFFFFFFFF)
        sha_w[i] = cast[uint32](sum_v & 0xFFFFFFFF)
        i = i + 1

    a: uint32 = sha_state[0]
    b: uint32 = sha_state[1]
    c: uint32 = sha_state[2]
    d: uint32 = sha_state[3]
    e: uint32 = sha_state[4]
    f: uint32 = sha_state[5]
    g: uint32 = sha_state[6]
    h: uint32 = sha_state[7]
    i = 0
    while i < 64:
        S1: uint32 = _sha256_rotr32(e, 6) ^ _sha256_rotr32(e, 11) \
            ^ _sha256_rotr32(e, 25)
        ch: uint32 = (e & f) ^ ((~e) & g)
        t1_64: uint64 = (cast[uint64](h) & 0xFFFFFFFF) \
            + (cast[uint64](S1) & 0xFFFFFFFF) \
            + (cast[uint64](ch) & 0xFFFFFFFF) \
            + (cast[uint64](sha_k[i]) & 0xFFFFFFFF) \
            + (cast[uint64](sha_w[i]) & 0xFFFFFFFF)
        t1: uint32 = cast[uint32](t1_64 & 0xFFFFFFFF)
        S0: uint32 = _sha256_rotr32(a, 2) ^ _sha256_rotr32(a, 13) \
            ^ _sha256_rotr32(a, 22)
        maj: uint32 = (a & b) ^ (a & c) ^ (b & c)
        t2_64: uint64 = (cast[uint64](S0) & 0xFFFFFFFF) \
            + (cast[uint64](maj) & 0xFFFFFFFF)
        t2: uint32 = cast[uint32](t2_64 & 0xFFFFFFFF)
        h = g
        g = f
        f = e
        d64: uint64 = (cast[uint64](d) & 0xFFFFFFFF) \
            + (cast[uint64](t1) & 0xFFFFFFFF)
        e = cast[uint32](d64 & 0xFFFFFFFF)
        d = c
        c = b
        b = a
        a64: uint64 = (cast[uint64](t1) & 0xFFFFFFFF) \
            + (cast[uint64](t2) & 0xFFFFFFFF)
        a = cast[uint32](a64 & 0xFFFFFFFF)
        i = i + 1

    sum_0: uint64 = cast[uint64](sha_state[0]) + cast[uint64](a)
    sum_1: uint64 = cast[uint64](sha_state[1]) + cast[uint64](b)
    sum_2: uint64 = cast[uint64](sha_state[2]) + cast[uint64](c)
    sum_3: uint64 = cast[uint64](sha_state[3]) + cast[uint64](d)
    sum_4: uint64 = cast[uint64](sha_state[4]) + cast[uint64](e)
    sum_5: uint64 = cast[uint64](sha_state[5]) + cast[uint64](f)
    sum_6: uint64 = cast[uint64](sha_state[6]) + cast[uint64](g)
    sum_7: uint64 = cast[uint64](sha_state[7]) + cast[uint64](h)
    sha_state[0] = cast[uint32](sum_0 & 0xFFFFFFFF)
    sha_state[1] = cast[uint32](sum_1 & 0xFFFFFFFF)
    sha_state[2] = cast[uint32](sum_2 & 0xFFFFFFFF)
    sha_state[3] = cast[uint32](sum_3 & 0xFFFFFFFF)
    sha_state[4] = cast[uint32](sum_4 & 0xFFFFFFFF)
    sha_state[5] = cast[uint32](sum_5 & 0xFFFFFFFF)
    sha_state[6] = cast[uint32](sum_6 & 0xFFFFFFFF)
    sha_state[7] = cast[uint32](sum_7 & 0xFFFFFFFF)


# _sha256_hash(n): one-shot SHA-256 of deb_buf[0, n). Writes the
# 64-char lowercase-hex digest (NUL-terminated) into sha_hex.

def _sha256_hash(n: uint64):
    _sha256_init_k()
    sha_state[0] = 0x6A09E667
    sha_state[1] = 0xBB67AE85
    sha_state[2] = 0x3C6EF372
    sha_state[3] = 0xA54FF53A
    sha_state[4] = 0x510E527F
    sha_state[5] = 0x9B05688C
    sha_state[6] = 0x1F83D9AB
    sha_state[7] = 0x5BE0CD19

    # Compress every full 64-byte block of the input.
    off: uint64 = 0
    while off + 64 <= n:
        i: uint64 = 0
        while i < 64:
            sha_block[i] = deb_buf[off + i]
            i = i + 1
        _sha256_compress()
        off = off + 64

    # Final block(s): the tail bytes + 0x80 + zero-pad + 64-bit BE
    # message length in bits.
    rem: uint64 = n - off
    buflen: uint64 = 0
    i: uint64 = 0
    while i < rem:
        sha_block[buflen] = deb_buf[off + i]
        buflen = buflen + 1
        i = i + 1
    sha_block[buflen] = 0x80
    buflen = buflen + 1
    if buflen > 56:
        while buflen < 64:
            sha_block[buflen] = 0
            buflen = buflen + 1
        _sha256_compress()
        buflen = 0
    while buflen < 56:
        sha_block[buflen] = 0
        buflen = buflen + 1
    total_bits: uint64 = n * 8
    j: uint64 = 0
    while j < 8:
        shift: uint64 = (7 - j) * 8
        sha_block[56 + j] = cast[uint8]((total_bits >> shift) & 0xFF)
        j = j + 1
    _sha256_compress()

    # State -> 32 big-endian bytes -> 64 lowercase hex chars.
    hexd: Ptr[uint8] = "0123456789abcdef"
    k: uint64 = 0
    while k < 8:
        w: uint32 = sha_state[k]
        sha_digest[k * 4 + 0] = cast[uint8]((w >> 24) & 0xFF)
        sha_digest[k * 4 + 1] = cast[uint8]((w >> 16) & 0xFF)
        sha_digest[k * 4 + 2] = cast[uint8]((w >> 8) & 0xFF)
        sha_digest[k * 4 + 3] = cast[uint8](w & 0xFF)
        k = k + 1
    m: uint64 = 0
    while m < 32:
        byte_v: uint8 = sha_digest[m]
        sha_hex[m * 2 + 0] = hexd[cast[uint64]((byte_v >> 4) & 0x0F)]
        sha_hex[m * 2 + 1] = hexd[cast[uint64](byte_v & 0x0F)]
        m = m + 1
    sha_hex[64] = 0


# -- InRelease OpenPGP signature verification --------------------------
#
# Closes the apt chain-of-trust gap. The flow:
#
#   1. Load the baked trust anchor from /etc/apt-trusted.gpg — the raw
#      `gpg --export` of the archive signing key. Parsed once into an
#      RsaPubkey.
#   2. Fetch <dists>/<suite>/InRelease — the inline-clearsigned
#      `Release`. One HTTP GET, self-contained.
#   3. Split it into cleartext body + ASCII-armored signature.
#   4. De-armor (base64-decode) the signature into an OpenPGP packet
#      and parse it: hash algorithm, hashed-subpacket region, RSA
#      signature MPI.
#   5. Assemble the v4 signed-data byte string (canonicalised
#      cleartext || hashed section || 04 FF <len> trailer) and run
#      RSA PKCS#1 v1.5 verification against the trust anchor.
#
# Returns:
#    1  signature present and VALID — the InRelease is authentic.
#    0  signature present but INVALID — forged / tampered. apt MUST
#       abort: the repository cannot be trusted.
#   -1  InRelease not available (404) or no trust anchor baked — the
#       repository is UNAUTHENTICATED. apt warns loudly and (for an
#       unsigned mirror) may proceed; a tampered signature never
#       reaches this branch.
#
# `port` is the connection port (from _parse_url); `suite` the
# repository suite. On a return of 1 the verified `InRelease` cleartext
# is available in inrelease_buf[0, inrelease_len).

# Re-shape one parsed OpenPGP key (`src`) into lib/rsa's RsaPubkey
# (`dst`). The modulus / exponent byte strings transfer directly;
# mod_bits / mod_bytes are derived the same way rsa_parse_pubkey does.

def _reshape_rsa_key(src: Ptr[PgpPubkey], dst: Ptr[RsaPubkey]):
    i: uint64 = 0
    while i < src[0].mod_len:
        dst[0].mod_bytes_be[i] = src[0].mod_be[i]
        i = i + 1
    dst[0].mod_len = src[0].mod_len
    i = 0
    while i < src[0].exp_len:
        dst[0].exp_bytes_be[i] = src[0].exp_be[i]
        i = i + 1
    dst[0].exp_len = src[0].exp_len
    # Bit length of the modulus (skip a leading DER-style 0x00 if the
    # MPI carried one — OpenPGP MPIs are minimal so this is rare, but
    # harmless to guard).
    skip: uint64 = 0
    if src[0].mod_len > 1 and src[0].mod_be[0] == 0:
        skip = 1
    top: uint8 = src[0].mod_be[skip]
    bit: uint64 = 7
    while bit > 0:
        if ((top >> bit) & 1) != 0:
            break
        bit = bit - 1
    full_bytes: uint64 = src[0].mod_len - skip - 1
    dst[0].mod_bits = full_bytes * 8 + bit + 1
    dst[0].mod_bytes = (dst[0].mod_bits + 7) / 8


def _load_trust_anchor() -> int32:
    fd: int32 = sys_open(cast[Ptr[char]]("/etc/apt-trusted.gpg"))
    if fd < 0:
        return -1
    total: uint64 = 0
    while total < APT_KEYRING_CAP:
        room: uint64 = APT_KEYRING_CAP - total
        ptr: Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](&apt_keyring_buf[0]) + total)
        n: int64 = sys_read(fd, ptr, room)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    if total == 0:
        return -1
    # Load EVERY Public-Key packet from the (possibly multi-key)
    # keyring. A real debian-archive-keyring.gpg carries several.
    rc: int32 = pgp_keyring_load(&apt_keyring_buf[0], total, &apt_pgp_ring)
    if rc != 0:
        write_str(2, "apt-get: baked keyring /etc/apt-trusted.gpg is malformed\n")
        return -1
    # Re-shape each parsed OpenPGP key into lib/rsa's RsaPubkey form.
    apt_rsa_nkeys = apt_pgp_ring.n_keys
    ki: uint64 = 0
    while ki < apt_rsa_nkeys:
        _reshape_rsa_key(&apt_pgp_ring.keys[ki], &apt_rsa_keys[ki])
        ki = ki + 1
    return 0


def _verify_inrelease(port: int64, suite: Ptr[uint8]) -> int32:
    # 1. Load the baked trust anchor.
    if _load_trust_anchor() != 0:
        write_str(2, "apt-get: WARNING: no archive keyring baked at ")
        write_str(2, "/etc/apt-trusted.gpg")
        write_str(2, " — cannot authenticate the repository\n")
        return -1

    # 2. Fetch the inline-clearsigned InRelease. A quiet GET — a 404
    #    just means this mirror publishes only an unsigned `Release`.
    _build_index_path(suite, cast[Ptr[uint8]]("InRelease"))
    ir_body_off: uint64 = 0
    ir_len: int64 = _http_get(port, &ir_body_off, 1)
    if ir_len <= 0:
        write_str(2, "apt-get: WARNING: no InRelease on this mirror — ")
        write_str(2, "repository is UNAUTHENTICATED\n")
        return -1

    # Copy the InRelease body out of http_buf — the later Packages
    # fetch reuses http_buf and would otherwise clobber it.
    irl: uint64 = cast[uint64](ir_len)
    if irl > INRELEASE_CAP:
        write_str(2, "apt-get: InRelease exceeds 256 KiB cap\n")
        return 0
    ci: uint64 = 0
    while ci < irl:
        inrelease_buf[ci] = http_buf[ir_body_off + ci]
        ci = ci + 1
    inrelease_len = irl

    # 3. Split InRelease into cleartext body + signature armor.
    clear_off: uint64 = 0
    clear_end: uint64 = 0
    armor_off: uint64 = 0
    if pgp_inrelease_split(&inrelease_buf[0], inrelease_len,
                           &clear_off, &clear_end, &armor_off) != 0:
        write_str(2, "apt-get: InRelease is not a valid clearsigned file\n")
        return 0

    # 4. De-armor the signature block into a raw OpenPGP packet.
    sig_n: int64 = pgp_dearmor(&inrelease_buf[0], armor_off,
                               inrelease_len,
                               &pgp_sig_packet[0], cast[uint64](4096))
    if sig_n <= 0:
        write_str(2, "apt-get: InRelease signature armor is malformed\n")
        return 0

    # 5. Walk EVERY signature packet in the dearmored block and try to
    #    verify it. A real Debian `InRelease` is signed by more than one
    #    key — the dearmored block carries several concatenated Tag 2
    #    packets (today: two RSA-4096 signatures from two archive signing
    #    SUBKEYS, plus one Ed25519 signature). The InRelease is authentic
    #    if ANY one of those signatures verifies against ANY key in the
    #    baked keyring. We must not parse only the first packet: its
    #    signer might have rotated out of the keyring while a later
    #    packet is from a key apt still trusts. Non-RSA packets (Ed25519,
    #    pub-alg 22) make pgp_sig_parse return -1 — those are simply
    #    skipped, not fatal.
    if apt_rsa_nkeys == 0:
        write_str(2, "apt-get: no usable keys in the trust anchor\n")
        return 0
    sig_total: uint64 = cast[uint64](sig_n)
    pkt_pos: uint64 = 0
    saw_rsa_sig: int32 = 0
    while pkt_pos < sig_total:
        pkt_off: uint64 = 0
        pkt_len: uint64 = 0
        if pgp_next_packet(&pgp_sig_packet[0], sig_total, pkt_pos,
                           &pkt_off, &pkt_len) != 0:
            break
        # Advance past this packet for the next iteration regardless of
        # whether it parses as a usable RSA signature.
        pkt_pos = pkt_off + pkt_len

        # Parse this packet as a v4 RSA signature. A non-RSA / non-v4 /
        # unsupported-hash packet returns -1 — skip it and try the next.
        if pgp_sig_parse(&pgp_sig_packet[pkt_off], pkt_len,
                         &apt_pgp_sig) != 0:
            continue
        saw_rsa_sig = 1

        # Map the OpenPGP hash-algorithm id to lib/rsa's digest selector.
        # 8 == SHA-256, 9 == SHA-384, 10 == SHA-512 (pgp_sig_parse
        # already rejected anything else). The real deb.debian.org
        # archive signs `InRelease` with a SHA-256 digest; all three are
        # supported.
        digest_alg: int32 = RSA_DIGEST_SHA256
        if apt_pgp_sig.hash_alg == 9:
            digest_alg = RSA_DIGEST_SHA384
        elif apt_pgp_sig.hash_alg == 10:
            digest_alg = RSA_DIGEST_SHA512

        # 6. Assemble the v4 signed-data byte string for THIS signature
        #    packet (its hashed section + trailer differ per packet).
        signed_len: uint64 = 0
        if pgp_build_signed_data(&inrelease_buf[0], clear_off, clear_end,
                                 &pgp_sig_packet[pkt_off], &apt_pgp_sig,
                                 &signed_len) != 0:
            write_str(2, "apt-get: InRelease cleartext too large to verify\n")
            return 0

        # 7. RSA PKCS#1 v1.5 verification. The keyring may carry several
        #    archive keys (primaries AND signing subkeys); the signature
        #    is valid if ANY of them accepts it. We try each in turn —
        #    the signature's Issuer subpacket is advisory only, so trying
        #    every key is the sound approach (and avoids needing a SHA-1
        #    fingerprint to index the keyring).
        #
        #    For each key: right-align the (minimal-length) OpenPGP
        #    signature MPI into a k-byte buffer (lib/rsa's verifier
        #    requires a signature octet string of length exactly the
        #    modulus byte width), then rsa_pkcs1_v1_5_verify hashes the
        #    signed-data, recovers the EM via s^e mod n, and
        #    byte-exact-compares against the expected EMSA-PKCS1-v1_5
        #    encoding.
        ki: uint64 = 0
        while ki < apt_rsa_nkeys:
            k: uint64 = apt_rsa_keys[ki].mod_bytes
            # A key whose modulus is too small for this signature simply
            # cannot be the signer — skip it rather than fail outright.
            if apt_pgp_sig.sig_mpi_len <= k and k <= 520:
                pad: uint64 = k - apt_pgp_sig.sig_mpi_len
                pi: uint64 = 0
                while pi < pad:
                    apt_sig_padded[pi] = 0
                    pi = pi + 1
                pi = 0
                while pi < apt_pgp_sig.sig_mpi_len:
                    apt_sig_padded[pad + pi] = \
                        pgp_sig_packet[pkt_off + apt_pgp_sig.sig_mpi_off + pi]
                    pi = pi + 1
                vrc: int32 = rsa_pkcs1_v1_5_verify(
                    &apt_rsa_keys[ki],
                    cast[Ptr[uint8]](0), cast[uint64](0),
                    digest_alg,
                    &pgp_signed_data[0], signed_len,
                    &apt_sig_padded[0], k)
                if vrc == 1:
                    return 1
            ki = ki + 1

    # No (signature, trusted-key) pair verified.
    if saw_rsa_sig == 0:
        write_str(2, "apt-get: InRelease carries no RSA signature this ")
        write_str(2, "build can verify\n")
    return 0


# -- apt update --------------------------------------------------------

def _do_update(base_url: Ptr[uint8], suite: Ptr[uint8],
               component: Ptr[uint8]) -> int32:
    port: int64 = _parse_url(base_url)
    if port < 0:
        return 1

    # Stash the component (`main` by default) into the comp_buf global
    # — _build_packages_path reads it when composing the Packages.gz
    # path. A bare apt-archive component name has no '/' so no path
    # sanitising is needed; we just cap it at the buffer size.
    cc: uint64 = 0
    while component[cc] != 0 and cc + 1 < 64:
        comp_buf[cc] = component[cc]
        cc = cc + 1
    comp_buf[cc] = 0

    # 0. Authenticate the repository BEFORE trusting any metadata from
    #    it. apt fetches the inline-clearsigned `InRelease` and verifies
    #    its OpenPGP signature against the baked archive key. This is
    #    the chain-of-trust anchor: without it a MITM or a malicious
    #    mirror could serve a forged index.
    #
    #      verify == 1  -> InRelease signature VALID; the repository is
    #                      authentic, proceed.
    #      verify == 0  -> InRelease signature INVALID (forged/tampered)
    #                      -> HARD ABORT. We refuse to touch the index.
    #      verify == -1 -> InRelease absent / no keyring baked; the
    #                      repository is unsigned. _verify_inrelease has
    #                      already printed a loud WARNING. We proceed
    #                      (an unsigned mirror is still usable, exactly
    #                      as `apt` treats a `[trusted=yes]` source) —
    #                      but a tampered signature can NEVER land here.
    rsa_init()
    vrc: int32 = _verify_inrelease(port, suite)
    if vrc == 0:
        write_str(2, "apt-get: InRelease signature verification FAILED ")
        write_str(2, "— repository is NOT authentic, aborting\n")
        return 1
    if vrc == 1:
        write_str(1, "apt-get: InRelease OpenPGP signature verified ")
        write_str(1, "— repository is authentic\n")

    # 1. Fetch the Release file. With a verified InRelease in hand the
    #    Release fetch mainly confirms the suite exists; when no
    #    InRelease was available it is still the only metadata we have.
    _build_index_path(suite, cast[Ptr[uint8]]("Release"))
    rel_body_off: uint64 = 0
    rel_len: int64 = _http_get(port, &rel_body_off, 0)
    if rel_len < 0:
        write_str(2, "apt-get: failed to fetch Release\n")
        return 1
    write_str(1, "apt-get: fetched Release (")
    write_dec_u64(1, cast[uint64](rel_len))
    write_str(1, " bytes)\n")

    # 2. Fetch the <component>/binary-amd64 Packages index (component
    #    is the comp_buf global — `main` by default, set from
    #    `apt update`'s optional 4th argument).
    #
    #    GZIP IS THE PRIMARY, STREAMING PATH. A real Debian `main`
    #    index is multi-MB compressed / tens of MB decompressed —
    #    nothing the 256 MiB guest could buffer whole. The gzip
    #    inflater (lib/zlib/inflate.ad) is fully resumable, so the gz
    #    index is fetched + inflated + counted + persisted INCREMENTALLY
    #    in 64 KiB staging chunks (_http_stream_gz_index) — index size
    #    is bounded only by what apt keeps. Every Debian mirror ships
    #    `Packages.gz`, so this is the path real `main` takes.
    #
    #    `Packages.xz` (LZMA2) is the FALLBACK, used only when a mirror
    #    has no `.gz`. The xz decoder is still single-shot (xz streaming
    #    is a follow-up), so the `.xz` path is capped at the single-shot
    #    HTTP_CAP / PKG_CAP buffers — fine for a fixture-sized or small
    #    component, a hard error with a gz-fallback hint for a giant one.
    #
    #    pkg_len is the decompressed index length; for the streaming gz
    #    path it is the count-pass byte total (the whole index need not
    #    fit RAM). nstanzas is the TRUE stanza count regardless of
    #    whether the persisted /tmp/apt/Packages cache was truncated.
    pkg_len:  uint64 = 0
    nstanzas: uint64 = 0
    persisted_full: int32 = 1

    # mkdir /tmp/apt up front — both paths persist into it.
    sys_mkdir(cast[Ptr[char]]("/tmp/apt"))

    _build_packages_path(suite, cast[Ptr[uint8]]("gz"))
    # A quiet probe: does this mirror ship Packages.gz? We only need the
    # status, but _http_get also drains the body — for the streaming
    # path we discard that and re-fetch through _http_stream_gz_index.
    # To avoid a double download we instead go straight to the streaming
    # fetch and treat its "no 200" failure as the cue to try `.xz`.
    gz_index_fd: int32 = sys_open_write(cast[Ptr[char]]("/tmp/apt/Packages"))
    if gz_index_fd < 0:
        write_str(2, "apt-get: cannot open /tmp/apt/Packages for write\n")
        return 1
    sink_fd = gz_index_fd
    _sink_reset()
    gz_out: int64 = _http_stream_gz_index(port)
    sys_close(gz_index_fd)
    sink_fd = -1

    if gz_out >= 0:
        # Streaming gz path won.
        _sink_flush()
        pkg_len = cast[uint64](gz_out)
        nstanzas = sink_count
        persisted_full = sink_persist_full
        write_str(1, "apt-get: streamed gz index (")
        write_dec_u64(1, pkg_len)
        write_str(1, " bytes decompressed)\n")
    else:
        # No usable Packages.gz — fall back to the single-shot xz path.
        # (A genuine socket error already printed; the xz attempt below
        # will reprint if the mirror is truly unreachable.)
        write_str(1, "apt-get: no streaming gz index — trying Packages.xz\n")
        _build_packages_path(suite, cast[Ptr[uint8]]("xz"))
        xz_body_off: uint64 = 0
        xz_len: int64 = _http_get(port, &xz_body_off, 0)
        if xz_len < 0:
            write_str(2, "apt-get: failed to fetch Packages index (no gz, no xz)\n")
            return 1
        if xz_len == 0:
            write_str(2, "apt-get: Packages.xz body is empty\n")
            return 1
        write_str(1, "apt-get: using xz-compressed index (Packages.xz)\n")
        drc: int64 = xz_decompress(&http_buf[xz_body_off],
                                   cast[uint64](xz_len),
                                   &pkg_buf[0], PKG_CAP)
        if drc < 0:
            write_str(2, "apt-get: Packages.xz decompress failed (corrupt, or\n")
            write_str(2, "apt-get: larger than the 512 KiB single-shot cap — a mirror\n")
            write_str(2, "apt-get: that also ships Packages.gz streams unbounded)\n")
            return 1
        pkg_len = cast[uint64](drc)
        # Persist the xz-decompressed index and count its stanzas.
        wfd: int32 = sys_open_write(cast[Ptr[char]]("/tmp/apt/Packages"))
        if wfd < 0:
            write_str(2, "apt-get: cannot open /tmp/apt/Packages for write\n")
            return 1
        wn: int64 = _write_full(wfd, &pkg_buf[0], pkg_len)
        sys_close(wfd)
        if wn < 0 or cast[uint64](wn) != pkg_len:
            write_str(2, "apt-get: short write storing Packages index\n")
            return 1
        nstanzas = _count_stanzas(pkg_len)

    # 4b. Persist the base-url to /tmp/apt/base-url (a one-line file)
    #     so a later `apt install` — a separate process invocation —
    #     can recover the mirror to download .debs from. A trailing
    #     newline is written; `apt install`'s reader trims it.
    base_len: uint64 = strlen_u8(base_url)
    bfd: int32 = sys_open_write(cast[Ptr[char]]("/tmp/apt/base-url"))
    if bfd < 0:
        write_str(2, "apt-get: cannot open /tmp/apt/base-url for write\n")
        return 1
    bw: int64 = _write_full(bfd, base_url, base_len)
    sys_write(bfd, "\n", 1)
    sys_close(bfd)
    if bw < 0 or cast[uint64](bw) != base_len:
        write_str(2, "apt-get: short write storing base-url\n")
        return 1

    # 5. Summary. nstanzas is the TRUE full count from the streaming
    #    (or single-shot) pass; if the persisted /tmp/apt/Packages cache
    #    was truncated at the tmpfs file cap, say so — `apt update` still
    #    succeeded, but later `show`/`install` only see the cached head.
    write_str(1, "apt-get: fetched index, ")
    write_dec_u64(1, nstanzas)
    write_str(1, " packages\n")
    if persisted_full == 0:
        write_str(1, "apt-get: note: index larger than the /tmp/apt/Packages cache cap (")
        write_dec_u64(1, PKG_CAP)
        write_str(1, " bytes);\n")
        write_str(1, "apt-get: the cache holds the leading stanzas — show/install resolve those\n")
    return 0


# -- Packages-index queries (show / pkgnames) --------------------------
#
# Both readers slurp /tmp/apt/Packages into pkg_buf and walk it as a
# run of RFC822 stanzas (same wire format dpkg.ad parses).

def _read_index() -> int64:
    fd: int32 = sys_open(cast[Ptr[char]]("/tmp/apt/Packages"))
    if fd < 0:
        write_str(2, "apt-cache: no package index — run `apt update` first\n")
        return -1
    total: uint64 = 0
    while total < PKG_CAP:
        room: uint64 = PKG_CAP - total
        ptr: Ptr[uint8] = cast[Ptr[uint8]](cast[uint64](&pkg_buf[0]) + total)
        n: int64 = sys_read(fd, ptr, room)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    return cast[int64](total)


# _line_is_package(lstart, lend): the line begins exactly with
# "Package:" in column 0. Returns 1 if so, else 0.

def _line_is_package(lstart: uint64, lend: uint64) -> int32:
    name: Ptr[uint8] = "Package:"
    if lstart + 8 > lend:
        return 0
    i: uint64 = 0
    while i < 8:
        if pkg_buf[lstart + i] != name[i]:
            return 0
        i = i + 1
    return 1


# apt show <pkg>: print the stanza whose Package: value equals <pkg>.
# Returns 0 on success, 1 if the index is unreadable or the package is
# absent.

def _do_show(pkg: Ptr[uint8]) -> int32:
    ilen_i: int64 = _read_index()
    if ilen_i < 0:
        return 1
    ilen: uint64 = cast[uint64](ilen_i)
    pkg_len: uint64 = strlen_u8(pkg)

    pos: uint64 = 0
    while pos < ilen:
        lstart: uint64 = pos
        lend: uint64 = pos
        while lend < ilen and pkg_buf[lend] != 10:
            lend = lend + 1
        if _line_is_package(lstart, lend) != 0:
            # The stanza runs [sstart, send): from this Package: line
            # to the next blank line (or end of buffer).
            sstart: uint64 = lstart
            send: uint64 = lstart
            while send < ilen:
                ls: uint64 = send
                le: uint64 = send
                while le < ilen and pkg_buf[le] != 10:
                    le = le + 1
                te: uint64 = le
                if te > ls and pkg_buf[te - 1] == 13:
                    te = te - 1
                if te == ls:                            # blank line
                    break
                send = le
                if send < ilen:
                    send = send + 1

            # The Package: value spans column 8 to end-of-line, with
            # leading blanks trimmed.
            v: uint64 = lstart + 8
            vend: uint64 = lend
            if vend > lstart and pkg_buf[vend - 1] == 13:
                vend = vend - 1
            while v < vend and (pkg_buf[v] == 32 or pkg_buf[v] == 9):
                v = v + 1
            # Compare the value to `pkg` exactly.
            eq: int32 = 1
            i: uint64 = 0
            while i < pkg_len:
                if v + i >= vend or pkg_buf[v + i] != pkg[i]:
                    eq = 0
                    break
                i = i + 1
            if eq != 0 and (v + pkg_len) != vend:
                eq = 0
            if eq != 0:
                _write_full(1, &pkg_buf[sstart], send - sstart)
                write_str(1, "\n")
                return 0
            pos = send
        else:
            pos = lend
        if pos < ilen:
            pos = pos + 1

    write_str(2, "apt-cache: package '")
    write_str(2, pkg)
    write_str(2, "' not found in index\n")
    return 1


# apt pkgnames: print every Package: value, one per line. Returns 0 on
# success, 1 if the index is unreadable.

def _do_pkgnames() -> int32:
    ilen_i: int64 = _read_index()
    if ilen_i < 0:
        return 1
    ilen: uint64 = cast[uint64](ilen_i)

    pos: uint64 = 0
    while pos < ilen:
        lstart: uint64 = pos
        lend: uint64 = pos
        while lend < ilen and pkg_buf[lend] != 10:
            lend = lend + 1
        if _line_is_package(lstart, lend) != 0:
            v: uint64 = lstart + 8
            vend: uint64 = lend
            if vend > lstart and pkg_buf[vend - 1] == 13:
                vend = vend - 1
            while v < vend and (pkg_buf[v] == 32 or pkg_buf[v] == 9):
                v = v + 1
            if vend > v:
                _write_full(1, &pkg_buf[v], vend - v)
            write_str(1, "\n")
        pos = lend
        if pos < ilen:
            pos = pos + 1
    return 0


# -- apt install -------------------------------------------------------
#
# Chains: read base-url -> find stanza -> HTTP GET the .deb -> SHA-256
# verify -> dpkg -i. The helpers below extract one named field from the
# matched stanza into a destination buffer.


# Read /tmp/apt/base-url back into baseurl_buf (NUL-terminated, trailing
# newline / CR trimmed). Returns 0 on success, -1 if the file is absent
# (apt update never ran) or empty.

def _read_base_url() -> int32:
    fd: int32 = sys_open(cast[Ptr[char]]("/tmp/apt/base-url"))
    if fd < 0:
        write_str(2, "apt: no base-url on file — run `apt update` first\n")
        return -1
    total: uint64 = 0
    while total + 1 < 768:
        room: uint64 = 768 - 1 - total
        ptr: Ptr[uint8] = cast[Ptr[uint8]](cast[uint64](&baseurl_buf[0]) + total)
        n: int64 = sys_read(fd, ptr, room)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    # Trim a trailing newline / carriage return.
    while total > 0 and (baseurl_buf[total - 1] == 10
                         or baseurl_buf[total - 1] == 13):
        total = total - 1
    baseurl_buf[total] = 0
    if total == 0:
        write_str(2, "apt: /tmp/apt/base-url is empty — run `apt update` first\n")
        return -1
    return 0


# _stanza_extract_field: within pkg_buf[sstart, send) — a single RFC822
# stanza — find the line beginning "<name>:" in column 0 and copy its
# value (leading blanks trimmed, trailing CR trimmed) into `dst` of
# capacity `cap`. Returns 1 if the field was found, else 0. `dst` is
# left NUL-terminated either way.

def _stanza_extract_field(sstart: uint64, send: uint64,
                          name: Ptr[uint8], name_len: uint64,
                          dst: Ptr[uint8], cap: uint64) -> int32:
    dst[0] = 0
    pos: uint64 = sstart
    while pos < send:
        lstart: uint64 = pos
        lend: uint64 = pos
        while lend < send and pkg_buf[lend] != 10:
            lend = lend + 1
        # A field line begins in column 0; continuation lines start
        # with a space/tab and are skipped.
        first: uint8 = pkg_buf[lstart]
        if first != 32 and first != 9:
            # Does the line start with "<name>:"?
            is_match: int32 = 1
            if lstart + name_len + 1 > lend:
                is_match = 0
            if is_match != 0:
                i: uint64 = 0
                while i < name_len:
                    if pkg_buf[lstart + i] != name[i]:
                        is_match = 0
                        break
                    i = i + 1
            if is_match != 0 and pkg_buf[lstart + name_len] != 58:   # ':'
                is_match = 0
            if is_match != 0:
                v: uint64 = lstart + name_len + 1
                vend: uint64 = lend
                if vend > lstart and pkg_buf[vend - 1] == 13:
                    vend = vend - 1
                while v < vend and (pkg_buf[v] == 32 or pkg_buf[v] == 9):
                    v = v + 1
                o: uint64 = 0
                while v < vend and o + 1 < cap:
                    dst[o] = pkg_buf[v]
                    o = o + 1
                    v = v + 1
                dst[o] = 0
                return 1
        pos = lend
        if pos < send:
            pos = pos + 1
    return 0


# _find_stanza: locate the RFC822 stanza in pkg_buf[0, ilen) whose
# `Package:` value equals <pkg>. On success writes the stanza span
# [*out_start, *out_end) and returns 0; returns -1 if <pkg> has no
# stanza in the index. Factored out of _lookup_install_fields so the
# dependency resolver can find a package's stanza to read its
# `Depends:` field without pulling the install fields too.

def _find_stanza(pkg: Ptr[uint8], ilen: uint64,
                 out_start: Ptr[uint64], out_end: Ptr[uint64]) -> int32:
    pkg_len: uint64 = strlen_u8(pkg)
    pos: uint64 = 0
    while pos < ilen:
        lstart: uint64 = pos
        lend: uint64 = pos
        while lend < ilen and pkg_buf[lend] != 10:
            lend = lend + 1
        if _line_is_package(lstart, lend) != 0:
            # Stanza spans [lstart, send) up to the next blank line.
            send: uint64 = lstart
            while send < ilen:
                ls: uint64 = send
                le: uint64 = send
                while le < ilen and pkg_buf[le] != 10:
                    le = le + 1
                te: uint64 = le
                if te > ls and pkg_buf[te - 1] == 13:
                    te = te - 1
                if te == ls:                            # blank line
                    break
                send = le
                if send < ilen:
                    send = send + 1

            # The Package: value: column 8 to EOL, leading blanks
            # trimmed, trailing CR trimmed.
            v: uint64 = lstart + 8
            vend: uint64 = lend
            if vend > lstart and pkg_buf[vend - 1] == 13:
                vend = vend - 1
            while v < vend and (pkg_buf[v] == 32 or pkg_buf[v] == 9):
                v = v + 1
            eq: int32 = 1
            i: uint64 = 0
            while i < pkg_len:
                if v + i >= vend or pkg_buf[v + i] != pkg[i]:
                    eq = 0
                    break
                i = i + 1
            if eq != 0 and (v + pkg_len) != vend:
                eq = 0
            if eq != 0:
                out_start[0] = lstart
                out_end[0] = send
                return 0
            pos = send
        else:
            pos = lend
        if pos < ilen:
            pos = pos + 1
    return -1


# Locate the stanza for <pkg> in pkg_buf[0, ilen) and pull Filename,
# SHA256, Size and Version into the fld_* buffers. Returns 0 on
# success, -1 if the package is absent or has no Filename field.

def _lookup_install_fields(pkg: Ptr[uint8], ilen: uint64) -> int32:
    sstart: uint64 = 0
    send: uint64 = 0
    if _find_stanza(pkg, ilen, &sstart, &send) != 0:
        write_str(2, "apt: package '")
        write_str(2, pkg)
        write_str(2, "' not found in index — run `apt update` first?\n")
        return -1
    # Extract the install fields out of the matched stanza.
    fld_filename[0] = 0
    fld_sha256[0] = 0
    fld_size[0] = 0
    fld_version2[0] = 0
    if _stanza_extract_field(sstart, send,
                             cast[Ptr[uint8]]("Filename"), 8,
                             &fld_filename[0], 512) == 0:
        write_str(2, "apt: package '")
        write_str(2, pkg)
        write_str(2, "' has no Filename field in the index\n")
        return -1
    _stanza_extract_field(sstart, send,
                          cast[Ptr[uint8]]("SHA256"), 6,
                          &fld_sha256[0], 80)
    _stanza_extract_field(sstart, send,
                          cast[Ptr[uint8]]("Size"), 4,
                          &fld_size[0], 32)
    _stanza_extract_field(sstart, send,
                          cast[Ptr[uint8]]("Version"), 7,
                          &fld_version2[0], 256)
    return 0


# Compose "<base-path>/<Filename>" into url_path_buf. The Filename in a
# Packages index is repo-root-relative ("pool/main/..."); the result
# always begins with a single '/'.

def _build_deb_path():
    o: uint64 = 0
    bi: uint64 = 0
    while path_buf[bi] != 0 and o + 1 < 768:
        url_path_buf[o] = path_buf[bi]
        o = o + 1
        bi = bi + 1
    url_path_buf[o] = 47                                # '/'
    o = o + 1
    fi: uint64 = 0
    # Skip any leading '/' on the Filename so we never emit "//".
    if fld_filename[0] == 47:
        fi = 1
    while fld_filename[fi] != 0 and o + 1 < 768:
        url_path_buf[o] = fld_filename[fi]
        o = o + 1
        fi = fi + 1
    url_path_buf[o] = 0


# Compose /tmp/apt/<pkg>.deb into debpath_buf. The last path component
# is "<pkg>.deb"; tmpfs caps a component at TMPFS_NAME_LEN(32) bytes
# including the NUL, so the package name is truncated to 27 chars
# (".deb"(4) + NUL(1) = 5 reserved). A fixture-sized package name sits
# far inside that — the truncation is a defensive cap, not a normal
# path.

def _build_debpath(pkg: Ptr[uint8]):
    prefix: Ptr[uint8] = "/tmp/apt/"
    o: uint64 = 0
    while prefix[o] != 0:
        debpath_buf[o] = prefix[o]
        o = o + 1
    i: uint64 = 0
    while pkg[i] != 0 and i < 27:
        debpath_buf[o] = pkg[i]
        o = o + 1
        i = i + 1
    suffix: Ptr[uint8] = ".deb"
    k: uint64 = 0
    while suffix[k] != 0:
        debpath_buf[o] = suffix[k]
        o = o + 1
        k = k + 1
    debpath_buf[o] = 0


# Parse decimal ASCII in fld_size into a uint64. Returns -1 if the
# field is empty or non-numeric (treated as "Size absent").

def _parse_size() -> int64:
    if fld_size[0] == 0:
        return -1
    n: int64 = 0
    i: uint64 = 0
    while fld_size[i] != 0:
        c: uint8 = fld_size[i]
        if c < 48 or c > 57:
            return -1
        n = n * 10 + cast[int64](c - 48)
        i = i + 1
    return n


# -- dependency resolution (V1) ----------------------------------------
#
# `apt install <pkg>` now installs <pkg>'s transitive `Depends:` first.
# The algorithm is a recursive post-order walk of the dependency graph:
#
#   resolve(p):
#       if p in dep_seen:        return        # dedup + cycle guard
#       add p to dep_seen
#       if p already installed:  return        # dpkg DB already has it
#       for each dep in p's Depends: field:
#           resolve(dep)                       # recurse FIRST
#       append p to dep_order                  # ...then record p
#
# Post-order append means a package's dependencies always precede it
# in dep_order — exactly the install order we want (deps before
# dependents). The dep_seen set both de-duplicates a diamond
# dependency and breaks a cycle: a package that depends back into the
# closure is already in dep_seen and is not recursed into a second
# time.
#
# V1 SCOPE — pragmatic `Depends:` parsing only:
#   * the field is split on ',' into terms;
#   * for a term, the package name is the token before any '(' or '|';
#   * an alternative ("libfoo | libbar") picks the FIRST alternative;
#   * version constraints ("(>= 2.34)") are IGNORED — the name is
#     resolved, the constraint is not checked.
# Version-aware resolution, alternative-preference logic, and
# Conflicts:/Breaks:/Pre-Depends: ordering are all V2 backlog.


# Does dep_seen already contain the NUL-terminated name <name>?
# Returns 1 if present, 0 if not.

def _dep_seen_has(name: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while i < dep_seen_n:
        base: uint64 = i * 64
        eq: int32 = 1
        j: uint64 = 0
        while True:
            a: uint8 = dep_seen[base + j]
            b: uint8 = name[j]
            if a != b:
                eq = 0
                break
            if a == 0:
                break
            j = j + 1
        if eq != 0:
            return 1
        i = i + 1
    return 0


# Append <name> to dep_seen. Returns 0 on success, -1 if the table is
# full (closure exceeds DEP_MAX packages).

def _dep_seen_add(name: Ptr[uint8]) -> int32:
    if dep_seen_n >= 64:
        write_str(2, "apt: dependency closure exceeds 64 packages (V1 limit)\n")
        return -1
    base: uint64 = dep_seen_n * 64
    i: uint64 = 0
    while name[i] != 0 and i + 1 < 64:
        dep_seen[base + i] = name[i]
        i = i + 1
    dep_seen[base + i] = 0
    dep_seen_n = dep_seen_n + 1
    return 0


# Append <name> to dep_order (the resolved install order). Returns 0
# on success, -1 if the table is full.

def _dep_order_add(name: Ptr[uint8]) -> int32:
    if dep_order_n >= 64:
        write_str(2, "apt: install order exceeds 64 packages (V1 limit)\n")
        return -1
    base: uint64 = dep_order_n * 64
    i: uint64 = 0
    while name[i] != 0 and i + 1 < 64:
        dep_order[base + i] = name[i]
        i = i + 1
    dep_order[base + i] = 0
    dep_order_n = dep_order_n + 1
    return 0


# Pointer to the i'th name in dep_order.

def _dep_order_at(i: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&dep_order[0]) + i * 64)


# Is <pkg> already recorded in the dpkg status DB? Reads the flattened
# tmpfs status DB /tmp/dpkg-status (same path dpkg.ad's -i path writes
# and -s reads) and scans it for a stanza whose `Package:` value
# equals <pkg>. Returns 1 if installed, 0 if not (or the DB is absent).
#
# The status DB is reused as scratch in pkg_buf's tail-free region —
# but pkg_buf already holds the live Packages index, so the DB is read
# into deb_buf instead (deb_buf is otherwise idle until a download).

def _is_installed(pkg: Ptr[uint8]) -> int32:
    fd: int32 = sys_open(cast[Ptr[char]]("/tmp/dpkg-status"))
    if fd < 0:
        return 0
    total: uint64 = 0
    while total < DEB_CAP:
        room: uint64 = DEB_CAP - total
        ptr: Ptr[uint8] = cast[Ptr[uint8]](cast[uint64](&deb_buf[0]) + total)
        n: int64 = sys_read(fd, ptr, room)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)

    pkg_len: uint64 = strlen_u8(pkg)
    name: Ptr[uint8] = "Package:"
    pos: uint64 = 0
    while pos < total:
        lstart: uint64 = pos
        lend: uint64 = pos
        while lend < total and deb_buf[lend] != 10:
            lend = lend + 1
        # Does this line begin with "Package:"?
        is_pkg: int32 = 1
        if lstart + 8 > lend:
            is_pkg = 0
        if is_pkg != 0:
            k: uint64 = 0
            while k < 8:
                if deb_buf[lstart + k] != name[k]:
                    is_pkg = 0
                    break
                k = k + 1
        if is_pkg != 0:
            v: uint64 = lstart + 8
            vend: uint64 = lend
            if vend > lstart and deb_buf[vend - 1] == 13:
                vend = vend - 1
            while v < vend and (deb_buf[v] == 32 or deb_buf[v] == 9):
                v = v + 1
            eq: int32 = 1
            i: uint64 = 0
            while i < pkg_len:
                if v + i >= vend or deb_buf[v + i] != pkg[i]:
                    eq = 0
                    break
                i = i + 1
            if eq != 0 and (v + pkg_len) != vend:
                eq = 0
            if eq != 0:
                return 1
        pos = lend
        if pos < total:
            pos = pos + 1
    return 0


# _dep_term_name: extract the package name from one `Depends:` term
# starting at dep_field_buf[start]. The name is the run of bytes up to
# (but not including) the first '(' , '|' , ',' or NUL, with leading
# and trailing blanks trimmed. For an alternative ("libfoo | libbar")
# this naturally takes the FIRST alternative (the run stops at '|').
# The name is written NUL-terminated into dep_name_buf. Returns 1 if a
# non-empty name was extracted, 0 if the term was blank.

def _dep_term_name(start: uint64, term_end: uint64) -> int32:
    # Trim leading blanks.
    s: uint64 = start
    while s < term_end and (dep_field_buf[s] == 32 or dep_field_buf[s] == 9):
        s = s + 1
    # The name ends at the first '(' , '|' or the term end.
    e: uint64 = s
    while e < term_end:
        c: uint8 = dep_field_buf[e]
        if c == 40 or c == 124:                         # '(' or '|'
            break
        e = e + 1
    # Trim trailing blanks of the name span.
    while e > s and (dep_field_buf[e - 1] == 32 or dep_field_buf[e - 1] == 9):
        e = e - 1
    if e <= s:
        dep_name_buf[0] = 0
        return 0
    o: uint64 = 0
    i: uint64 = s
    while i < e and o + 1 < 64:
        dep_name_buf[o] = dep_field_buf[i]
        o = o + 1
        i = i + 1
    dep_name_buf[o] = 0
    return 1


# Pointer to recursion-depth `d`'s slot in dep_namestack.

def _dep_namestack_at(d: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&dep_namestack[0]) + d * 64)


# _resolve: recursive post-order walk of <pkg>'s dependency closure.
# On return, dep_order holds the install order with <pkg> last and its
# (transitive) dependencies before it. dep_seen is the dedup + cycle
# guard. Returns 0 on success, -1 on any error (table full, recursion
# too deep, or a dependency name absent from the index — a hard abort).
#
# `ilen` is the live Packages-index length in pkg_buf. `depth` is the
# recursion depth: _resolve copies <pkg> into dep_namestack[depth] on
# entry so that a nested _resolve clobbering the shared dep_name_buf
# (the buffer <pkg> typically points into) cannot corrupt this frame's
# notion of which package it is resolving.

def _resolve(pkg: Ptr[uint8], ilen: uint64, depth: uint64) -> int32:
    if depth >= 64:
        write_str(2, "apt: dependency chain exceeds 64 levels (V1 limit)\n")
        return -1
    # Stabilise <pkg> into this frame's own name slot — every read of
    # the package name below uses `me`, never the volatile `pkg`.
    me: Ptr[uint8] = _dep_namestack_at(depth)
    np: uint64 = 0
    while pkg[np] != 0 and np + 1 < 64:
        me[np] = pkg[np]
        np = np + 1
    me[np] = 0

    # Already visited — dedup, and (since dep_seen is added BEFORE the
    # recursion) the cycle guard. A package that depends back into the
    # closure is already here and is not walked a second time.
    if _dep_seen_has(me) != 0:
        return 0
    if _dep_seen_add(me) != 0:
        return -1

    # Already installed — skip it (and its subtree: a satisfied
    # dependency's own deps are by definition already satisfied too).
    # The package is NOT added to dep_order — nothing to download.
    if _is_installed(me) != 0:
        write_str(1, "apt: ")
        write_str(1, me)
        write_str(1, " already installed, skipping\n")
        return 0

    # Find this package's stanza so we can read its `Depends:` field.
    sstart: uint64 = 0
    send: uint64 = 0
    if _find_stanza(me, ilen, &sstart, &send) != 0:
        # A missing *dependency* is reported here with its parent (set
        # by the caller); a missing root package has no parent set.
        if dep_missing_parent[0] != 0:
            write_str(2, "apt: dependency '")
            write_str(2, me)
            write_str(2, "' of '")
            write_str(2, &dep_missing_parent[0])
            write_str(2, "' not found in index\n")
        else:
            write_str(2, "apt: package '")
            write_str(2, me)
            write_str(2, "' not found in index — run `apt update` first?\n")
        return -1

    # Pull the `Depends:` field. Absent / empty -> no dependencies.
    have_deps: int32 = _stanza_extract_field(sstart, send,
                                             cast[Ptr[uint8]]("Depends"), 7,
                                             &dep_field_buf[0], 1024)
    if have_deps != 0 and dep_field_buf[0] != 0:
        # Walk the comma-separated terms, recursing into each.
        flen: uint64 = strlen_u8(&dep_field_buf[0])
        term_start: uint64 = 0
        i: uint64 = 0
        while i <= flen:
            if i == flen or dep_field_buf[i] == 44:      # ',' or end
                if _dep_term_name(term_start, i) != 0:
                    # Record `me` as the parent so a missing-dep abort
                    # names the dependent.
                    p: uint64 = 0
                    while me[p] != 0 and p + 1 < 64:
                        dep_missing_parent[p] = me[p]
                        p = p + 1
                    dep_missing_parent[p] = 0
                    # _dep_term_name wrote the dependency name into the
                    # shared dep_name_buf; recurse on it. The nested
                    # _resolve copies it into its own depth slot first.
                    if _resolve(&dep_name_buf[0], ilen, depth + 1) != 0:
                        return -1
                    # A nested _resolve clobbered dep_field_buf with the
                    # child's Depends — re-extract this stanza's Depends
                    # for the remaining terms.
                    _stanza_extract_field(sstart, send,
                                          cast[Ptr[uint8]]("Depends"), 7,
                                          &dep_field_buf[0], 1024)
                term_start = i + 1
            i = i + 1

    # Post-order: record `me` AFTER all its dependencies.
    if _dep_order_add(me) != 0:
        return -1
    return 0


# -- sequential install: fetch then dpkg, one package at a time -------
#
# `apt install <pkg>` installs the whole dependency closure in
# dependency order (deepest dependency first, <pkg> last). For each
# package the per-package helpers run back-to-back:
#
#   _fetch_one: download + SHA-256-verify the .deb, save it to
#               /tmp/apt/<pkg>.deb.
#   _dpkg_one:  `dpkg -i` the saved .deb.
#
# Each .deb download opens one socket connection; the in-kernel TCP
# stack rotates the ephemeral source port per active-open connect, so
# back-to-back downloads use distinct 4-tuples and never collide.


# _fetch_one — download + verify + save one package's .deb. `port` is
# the parsed mirror port. Returns 0 on success, non-zero on any
# failure. The .deb lands at /tmp/apt/<pkg>.deb. Performs exactly one
# socket connect.

def _fetch_one(pkg: Ptr[uint8], port: int64) -> int32:
    # Locate <pkg>'s stanza and pull the install fields.
    ilen_i: int64 = _read_index()
    if ilen_i < 0:
        return 1
    if _lookup_install_fields(pkg, cast[uint64](ilen_i)) != 0:
        return 1

    # HTTP GET <base-url>/<Filename> — the .deb is binary, the body
    # bytes are captured raw (no text processing). _http_get drains
    # into http_buf; we then copy the body span verbatim into deb_buf
    # so the SHA-256 path sees a clean image.
    _build_deb_path()
    write_str(1, "apt: fetching ")
    write_str(1, &fld_filename[0])
    write_str(1, "\n")
    body_off: uint64 = 0
    body_len_i: int64 = _http_get(port, &body_off, 0)
    if body_len_i < 0:
        write_str(2, "apt: failed to download the .deb\n")
        return 1
    if body_len_i == 0:
        write_str(2, "apt: downloaded .deb is empty\n")
        return 1
    deb_len: uint64 = cast[uint64](body_len_i)
    if deb_len > DEB_CAP:
        write_str(2, "apt: .deb exceeds 256 KiB cap (V0 limit)\n")
        return 1
    ci: uint64 = 0
    while ci < deb_len:
        deb_buf[ci] = http_buf[body_off + ci]
        ci = ci + 1

    # Optional Size cross-check: a Size mismatch means the wrong /
    # truncated file — bail before the (more expensive) hash.
    want_size: int64 = _parse_size()
    if want_size >= 0 and cast[uint64](want_size) != deb_len:
        write_str(2, "apt: downloaded size mismatch — expected ")
        write_dec_u64(2, cast[uint64](want_size))
        write_str(2, " bytes, got ")
        write_dec_u64(2, deb_len)
        write_str(2, "\n")
        return 1

    # SHA-256 verification. The index's SHA256 field is the trust
    # anchor: hash the bytes we downloaded and compare. A mismatch
    # aborts the install — the corrupt/wrong .deb is NEVER handed to
    # dpkg. If the index carries no SHA256 we proceed with a loud
    # warning (documented V0.1 backlog: require it).
    if fld_sha256[0] == 0:
        write_str(2, "apt: WARNING: SHA256 not verified (index stanza has no SHA256 field)\n")
    else:
        _sha256_hash(deb_len)
        # Compare lowercase-hex digests. The index field is normalised
        # to lowercase as we compare so an uppercase index value still
        # matches.
        hash_ok: int32 = 1
        i: uint64 = 0
        while i < 64:
            want_c: uint8 = fld_sha256[i]
            if want_c >= 65 and want_c <= 70:           # 'A'..'F'
                want_c = want_c + 32
            if want_c != sha_hex[i]:
                hash_ok = 0
                break
            i = i + 1
        if hash_ok != 0 and fld_sha256[64] != 0:
            hash_ok = 0                                 # index hash too long
        if hash_ok == 0:
            write_str(2, "apt: SHA256 verification FAILED for ")
            write_str(2, pkg)
            write_str(2, "\n")
            write_str(2, "apt:   expected ")
            write_str(2, &fld_sha256[0])
            write_str(2, "\n")
            write_str(2, "apt:   computed ")
            write_str(2, &sha_hex[0])
            write_str(2, "\n")
            write_str(2, "apt: refusing to install a corrupt package\n")
            return 1
        write_str(1, "apt: SHA256 OK (")
        write_dec_u64(1, deb_len)
        write_str(1, " bytes)\n")

    # Save the verified .deb to /tmp/apt/<pkg>.deb for the dpkg step.
    _build_debpath(pkg)
    wfd: int32 = sys_open_write(cast[Ptr[char]](&debpath_buf[0]))
    if wfd < 0:
        write_str(2, "apt: cannot open ")
        write_str(2, &debpath_buf[0])
        write_str(2, " for write\n")
        return 1
    wn: int64 = _write_full(wfd, &deb_buf[0], deb_len)
    sys_close(wfd)
    if wn < 0 or cast[uint64](wn) != deb_len:
        write_str(2, "apt: short write saving the downloaded .deb\n")
        return 1
    return 0


# _dpkg_one — `dpkg -i` one already-downloaded package. The .deb is the
# /tmp/apt/<pkg>.deb that _fetch_one saved. Re-reads the index only to
# recover the Version for the summary line (no networking). Returns 0
# on success, non-zero on any failure.

def _dpkg_one(pkg: Ptr[uint8]) -> int32:
    # Recover the Version field for the summary line (index re-read is
    # local — /tmp/apt/Packages — and does not touch the network).
    fld_version2[0] = 0
    ilen_i: int64 = _read_index()
    if ilen_i >= 0:
        _lookup_install_fields(pkg, cast[uint64](ilen_i))

    # Hand the saved .deb to `/bin/dpkg -i <debpath>`. dpkg records the
    # package in the status DB; its exit code gates ours.
    _build_debpath(pkg)
    dpkg_argv[0] = cast[uint64](cast[Ptr[uint8]]("/bin/dpkg"))
    dpkg_argv[1] = cast[uint64](cast[Ptr[uint8]]("-i"))
    dpkg_argv[2] = cast[uint64](&debpath_buf[0])
    dpkg_argv[3] = 0
    pid: int32 = sys_spawn(cast[Ptr[char]]("/bin/dpkg"), &dpkg_argv[0],
                           0, 1, cast[Ptr[uint64]](0))
    if pid < 0:
        write_str(2, "apt: failed to spawn /bin/dpkg\n")
        return 1
    rc: int64 = sys_waitpid(pid)
    if rc != 0:
        write_str(2, "apt: dpkg -i failed (exit ")
        if rc < 0:
            write_str(2, "-")
            write_dec_u64(2, cast[uint64](0 - rc))
        else:
            write_dec_u64(2, cast[uint64](rc))
        write_str(2, ")\n")
        return 1

    # Per-package summary.
    write_str(1, "apt: installed ")
    write_str(1, pkg)
    if fld_version2[0] != 0:
        write_str(1, " ")
        write_str(1, &fld_version2[0])
    write_str(1, "\n")
    return 0


# apt install <pkg>: resolve <pkg>'s transitive `Depends:`, then
# install the whole closure in dependency order (deepest dependency
# first, <pkg> last). Returns 0 on success, non-zero on any failure.
#
# A dependency already recorded in the dpkg DB is skipped; a
# dependency name absent from the index aborts the WHOLE install
# before any package is downloaded — no partial install.

def _do_install(pkg: Ptr[uint8]) -> int32:
    # 1. Recover the mirror base-url and validate it parses — this is
    #    an early, clean failure if `apt update` never ran. _fetch_one
    #    uses the parsed port for each download.
    if _read_base_url() != 0:
        return 1
    port: int64 = _parse_url(&baseurl_buf[0])
    if port < 0:
        return 1

    # 2. Read the package index — the resolver walks it in pkg_buf.
    ilen_i: int64 = _read_index()
    if ilen_i < 0:
        return 1
    ilen: uint64 = cast[uint64](ilen_i)

    # The named root package must exist before we resolve anything.
    rs: uint64 = 0
    re: uint64 = 0
    if _find_stanza(pkg, ilen, &rs, &re) != 0:
        write_str(2, "apt: package '")
        write_str(2, pkg)
        write_str(2, "' not found in index — run `apt update` first?\n")
        return 1

    # 3. Resolve the dependency closure (post-order -> dep_order).
    dep_seen_n = 0
    dep_order_n = 0
    dep_missing_parent[0] = 0
    if _resolve(pkg, ilen, 0) != 0:
        write_str(2, "apt: aborting — dependency resolution failed (no packages installed)\n")
        return 1

    # 4. Print the install plan. dep_order ends with <pkg>; everything
    #    before it is a (transitive) dependency to install first.
    ndeps: uint64 = 0
    if dep_order_n > 0:
        ndeps = dep_order_n - 1
    write_str(1, "apt: installing ")
    write_str(1, pkg)
    write_str(1, " and ")
    write_dec_u64(1, ndeps)
    if ndeps == 1:
        write_str(1, " dependency")
    else:
        write_str(1, " dependencies")
    if dep_order_n > 0:
        write_str(1, ": ")
        oi: uint64 = 0
        while oi < dep_order_n:
            if oi > 0:
                write_str(1, ", ")
            write_str(1, _dep_order_at(oi))
            oi = oi + 1
    write_str(1, "\n")

    # 5. Install each package in dependency order: download + verify the
    #    .deb, then `dpkg -i` it, before moving on to the next. A package
    #    already in the dpkg DB is skipped — but the resolver already
    #    pruned installed packages from dep_order, so this is a defensive
    #    re-check only.
    ii: uint64 = 0
    while ii < dep_order_n:
        one: Ptr[uint8] = _dep_order_at(ii)
        if _is_installed(one) != 0:
            write_str(1, "apt: ")
            write_str(1, one)
            write_str(1, " already installed, skipping\n")
        else:
            if _fetch_one(one, port) != 0:
                write_str(2, "apt: download of '")
                write_str(2, one)
                write_str(2, "' failed — aborting\n")
                return 1
            if _dpkg_one(one) != 0:
                write_str(2, "apt: install of '")
                write_str(2, one)
                write_str(2, "' failed — aborting\n")
                return 1
        ii = ii + 1

    # 6. Final summary.
    write_str(1, "apt: installed ")
    write_str(1, pkg)
    write_str(1, " (+")
    write_dec_u64(1, ndeps)
    write_str(1, " deps)\n")
    return 0


# -- top-level driver --------------------------------------------------

def _usage(progname: Ptr[uint8]) -> int32:
    write_str(2, "Usage: ")
    write_str(2, progname)
    write_str(2, " update <base-url> <suite> [component]\n")
    write_str(2, "       ")
    write_str(2, progname)
    write_str(2, " show <package>\n")
    write_str(2, "       ")
    write_str(2, progname)
    write_str(2, " pkgnames\n")
    write_str(2, "       ")
    write_str(2, progname)
    write_str(2, " install <package>\n")
    return 2


def _streq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while True:
        if a[i] != b[i]:
            return 0
        if a[i] == 0:
            return 1
        i = i + 1


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    progname: Ptr[uint8] = cast[Ptr[uint8]](argv[0])
    if argc < 2:
        return _usage(progname)
    verb: Ptr[uint8] = cast[Ptr[uint8]](argv[1])

    # update <base-url> <suite> [component]
    # The component is optional and defaults to `main` — every existing
    # call site (the fixture tests) omits it. A live Debian mirror's
    # whole `main` index is far past the 256 KiB cap, so the live test
    # passes a smaller component (e.g. `contrib`).
    if _streq(verb, cast[Ptr[uint8]]("update")) != 0:
        if argc != 4 and argc != 5:
            return _usage(progname)
        comp: Ptr[uint8] = cast[Ptr[uint8]]("main")
        if argc == 5:
            comp = cast[Ptr[uint8]](argv[4])
        return _do_update(cast[Ptr[uint8]](argv[2]),
                          cast[Ptr[uint8]](argv[3]),
                          comp)

    # show <package>
    if _streq(verb, cast[Ptr[uint8]]("show")) != 0:
        if argc != 3:
            return _usage(progname)
        return _do_show(cast[Ptr[uint8]](argv[2]))

    # pkgnames
    if _streq(verb, cast[Ptr[uint8]]("pkgnames")) != 0:
        if argc != 2:
            return _usage(progname)
        return _do_pkgnames()

    # install <package>
    if _streq(verb, cast[Ptr[uint8]]("install")) != 0:
        if argc != 3:
            return _usage(progname)
        return _do_install(cast[Ptr[uint8]](argv[2]))

    write_str(2, "apt: unknown sub-command (supports: update, show, pkgnames, install)\n")
    return _usage(progname)
