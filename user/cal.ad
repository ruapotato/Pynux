# user/cal.ad
#
# Hamnix `cal`: prints a fixed May 2026 month grid. Real cal does
# date math against the proleptic Gregorian calendar; we don't have
# a wall clock yet (no RTC driver), so a hard-coded month keeps the
# UX recognizable without pretending to know the current date.
# When the RTC + Zeller's-congruence math land this binary grows
# argv parsing for cal MONTH YEAR.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def main() -> int32:
    write_str(1, "    May 2026\n")
    write_str(1, "Su Mo Tu We Th Fr Sa\n")
    write_str(1, "                1  2\n")
    write_str(1, " 3  4  5  6  7  8  9\n")
    write_str(1, "10 11 12 13 14 15 16\n")
    write_str(1, "17 18 19 20 21 22 23\n")
    write_str(1, "24 25 26 27 28 29 30\n")
    write_str(1, "31\n")
    return 0
