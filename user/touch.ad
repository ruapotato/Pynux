# user/touch.ad
#
# Hamnix `touch`: ensures each path in argv[1..] exists by opening it
# for write (which creates an empty file in tmpfs) and immediately
# closing. Mirrors coreutils' `touch` at the smallest meaningful
# scope — no timestamps, no -c, no -a/-m flags (we have no mtime
# fields yet). Failing opens are reported to stderr but processing
# continues for the remaining paths; exit code is 0 iff every path
# was touched successfully.
#
# tmpfs_open_for_write already truncates on existing entries — that
# matches `touch`'s "create if missing, leave alone if present"
# contract closely enough at this scale (we don't have real file
# contents to preserve across a no-op touch yet; M16.66+ when tmpfs
# grows non-truncating open modes).

extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        write_str(2, "touch: missing operand\n")
        return 1
    failed: int32 = 0
    i: int32 = 1
    while i < argc:
        path: Ptr[char] = cast[Ptr[char]](argv[cast[uint64](i)])
        fd: int32 = sys_open_write(path)
        if fd < 0:
            write_str(2, "touch: cannot touch ")
            write_str(2, cast[Ptr[uint8]](path))
            write_str(2, "\n")
            failed = 1
        else:
            sys_close(fd)
        i = i + 1
    return failed
