# user/test.ad
#
# Hamnix `test` / `[`: minimal POSIX test. Supports -z / -n string
# predicates and = / != string compares. Exit 0 = true, 1 = false,
# 2 = bad usage. We accept a trailing literal "]" for the bracket
# form without enforcing that argv[0] was actually "[" — the shell
# never lies about that, and the cost of a strict check isn't worth
# the extra branch this early in M16.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def str_eq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while True:
        if a[i] != b[i]:
            return 0
        if a[i] == 0:
            return 1
        i = i + 1
    return 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # Trim a trailing "]" so `[ EXPR ]` and `test EXPR` share one
    # parser. Real /bin/[ verifies argv[0]=='[' before doing this.
    n: int32 = argc
    if n >= 2:
        last: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](n - 1)])
        if last[0] == 93 and last[1] == 0:
            n = n - 1
    if n == 1:
        # `test` with no args is false in POSIX.
        return 1
    if n == 2:
        # `test STR` — true iff STR is non-empty.
        s: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        if s[0] == 0:
            return 1
        return 0
    if n == 3:
        op: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        s: Ptr[uint8] = cast[Ptr[uint8]](argv[2])
        if str_eq(op, "-z") != 0:
            if s[0] == 0:
                return 0
            return 1
        if str_eq(op, "-n") != 0:
            if s[0] != 0:
                return 0
            return 1
        write_str(2, "test: unknown unary operator\n")
        return 2
    if n == 4:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        op: Ptr[uint8] = cast[Ptr[uint8]](argv[2])
        b: Ptr[uint8] = cast[Ptr[uint8]](argv[3])
        if str_eq(op, "=") != 0:
            if str_eq(a, b) != 0:
                return 0
            return 1
        if str_eq(op, "!=") != 0:
            if str_eq(a, b) == 0:
                return 0
            return 1
        write_str(2, "test: unknown binary operator\n")
        return 2
    write_str(2, "test: bad expression\n")
    return 2
