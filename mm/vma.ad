# mm/vma.ad
#
# Per-task VMA (Virtual Memory Area) layer. First real address-space
# bookkeeping in Hamnix — replaces the flat 256-slot (base, order)
# table that linux_abi/u_syscalls.ad has been using since U7. The slot
# table was good enough for MAP_ANONYMOUS|MAP_PRIVATE and for ld.so's
# "reserve then MAP_FIXED overlay" two-phase DSO load, but couldn't
# honour MAP_FIXED at arbitrary user-chosen addresses — and that's
# exactly what dynamic Linux binaries expect from mmap once ld.so
# transfers control to the application's _start.
#
# Plan 9 framing
#
#   Per docs/architecture.md + memory/feedback_plan9_namespace_framing,
#   the VMA list is NOT a global "kernel memory map" — it is a per-task
#   namespace of virtual-address contents, in the same shape as `/` is
#   a per-task namespace of names. There is no master vma table that
#   the kernel consults out-of-band; the only ground truth about
#   "what is mapped where" is whatever the current task's vma_list
#   says. Forks (rfork RFPROC without RFMEM) give the child its own
#   VMA list mirroring the parent's, with every mmap page COPY-ON-WRITE
#   shared (see vma_fork_copy); the thread path (RFMEM) shares the list
#   itself. Init's task is born with an empty list; every subsequent
#   VMA is created either by mmap from userspace or by the ELF loader
#   on do_execve.
#
# Shape
#
#   Sorted singly-linked list of VmaNode records, keyed by `start`.
#   Each node owns the half-open range [start, end). Adjacent nodes
#   do not overlap. Lookup is O(N) — for the small VMA count a single
#   user process accrues (Debian /bin/true with glibc has ~12 VMAs),
#   a sorted linked list is faster than a tree and the code stays
#   small. Real Linux uses an mm_struct + interval tree; we can grow
#   there once the VMA count per process crosses ~32.
#
# Backing memory
#
#   Today every page is RWX U=1 in the 4 GiB identity map. Per-VMA
#   `prot` is therefore advisory at the page-table level — we record
#   it for future per-page mprotect wiring but the page fault handler
#   doesn't consult it yet.
#
#   Pages are allocated EAGERLY at vma_alloc time via alloc_pages —
#   not lazily on first touch. Demand-paging through a #PF handler
#   would require touching arch/x86/kernel/idt.ad which is locked
#   under this commit; eager allocation is the correct trade-off
#   given the constraint.
#
# Allocator
#
#   VmaNode records are kmalloc'd (56 bytes per node after struct
#   padding). Backing pages come from alloc_pages at the order that
#   covers the page-rounded length.

from kernel.printk.printk import printk1
from kernel.sched.core import (
    TaskStruct,
    task_vma_list_head, set_task_vma_list_head,
    current_idx_get, task_pml4,
)
from mm.slab import kmalloc, kfree
from mm.page_alloc import alloc_pages, free_pages, free_page
from mm.cow import cow_drop_page, cow_pte_bit
from fs.elf import elf_install_user_mapping, vm_cow_share_range

extern def memset(dst: Ptr[uint8], val: int32, n: uint64) -> Ptr[uint8]
extern def memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64) -> Ptr[uint8]
extern def load_cr3(value: uint64)

# ---------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------

# MAP_* flag bits. Mirror Linux <bits/mman-linux.h>. Same numeric
# values defined locally in linux_abi/u_syscalls.ad (kept in sync by
# hand — the two files import from each other not at all).
VMA_MAP_PRIVATE:   int32 = 0x02
VMA_MAP_FIXED:     int32 = 0x10
VMA_MAP_ANONYMOUS: int32 = 0x20

# PROT_* — stored but not yet honoured by the page table.
VMA_PROT_NONE:  int32 = 0x0
VMA_PROT_READ:  int32 = 0x1
VMA_PROT_WRITE: int32 = 0x2
VMA_PROT_EXEC:  int32 = 0x4

VMA_PAGE_SIZE: uint64 = 0x1000

# Buddy allocator MAX_ORDER (mm/page_alloc.ad) is 10 -> the largest
# single alloc_pages call covers 2^10 pages = 4 MiB. A VMA whose
# page-rounded length exceeds this is backed by MULTIPLE buddy chunks
# (each up to 4 MiB) mapped at consecutive virtual addresses so the
# VMA still presents one contiguous virtual range. See vma_alloc.
VMA_MAX_ORDER:    int32  = 10
VMA_MAX_CHUNK:    uint64 = 0x400000          # 4 MiB == 2^MAX_ORDER pages

# A multi-chunk VMA owns an array of VmaChunk descriptors (one per
# buddy allocation). Each descriptor is 16 bytes; the array is kmalloc'd
# and pointed to by VmaNode.chunks. Single-chunk / alias VMAs leave
# chunks == 0 and nchunks == 0 and use the legacy backing/order fields.
VMA_CHUNK_SIZE:   uint64 = 16

# x86_64 page-table constants — mirror fs/elf.ad's PT_FLAG_* / PT_ADDR_MASK.
# Used by the COW-aware free path (_vma_pte_lookup / _vma_free_cow_range)
# to walk a task's PML4 and read the physical page behind each VMA page.
VMA_PT_FLAG_P:    uint64 = 0x1                   # Present
VMA_PT_FLAG_PS:   uint64 = 0x80                  # Page-Size (huge leaf)
VMA_PT_ADDR_MASK: uint64 = 0x000FFFFFFFFFF000    # bits [51:12]: phys base

# Virtual-address window for multi-chunk VMAs.
#
# A single-chunk VMA returns its buddy chunk's physical/identity
# address as the VMA base — the buddy allocator owns that physical
# run exclusively, so the VMA's virtual range can never be re-handed
# to another allocation. A multi-chunk VMA can't do that: its virtual
# range [base, base+length) is far larger than chunk 0's 4 MiB, and
# the buddy allocator would happily hand the physical pages sitting
# under [base+4MiB, base+length) to the NEXT large mmap — two VMAs
# would then overlap virtually and corrupt each other.
#
# So multi-chunk VMAs live in a DEDICATED virtual window starting at
# 1 GiB. QEMU/typical hardware RAM here is far under 1 GiB and the
# buddy allocator only ever hands out physical pages from real low
# RAM, so nothing else — no buddy allocation, no small VMA (which
# sits at its low identity address), no ELF image / brk / stack —
# ever lands in [1 GiB, 4 GiB). A monotonic bump pointer carves
# 4-MiB-aligned windows out of it; freed windows are not reclaimed
# (consistent with the buddy allocator's no-merge stance and the
# kstack/ustack leak task_reap already tolerates). EVERY chunk of a
# multi-chunk VMA — including chunk 0 — is overlaid into the page
# table, because the window has no physical RAM behind its identity
# mapping. The window stays inside the boot stub's 4 GiB identity map
# so elf_install_user_mapping's PDPT walker always finds a live entry.
VMA_LARGE_BASE:   uint64 = 0x40000000           # 1 GiB
VMA_LARGE_LIMIT:  uint64 = 0xFFC00000           # just under 4 GiB

# Bump pointer for the next free multi-chunk virtual window. 4-MiB-
# aligned so every 4-MiB chunk install stays within one 1 GiB PDPT
# entry (elf_install_user_mapping refuses a range crossing 1 GiB).
vma_large_next:   uint64 = 0x40000000


# ---------------------------------------------------------------------
# VmaChunk / VmaNode
# ---------------------------------------------------------------------

class VmaChunk:
    phys:  uint64
    order: int32
    pad:   int32


class VmaNode:
    start:       uint64
    end:         uint64
    file_offset: uint64
    backing:     uint64
    next:        uint64
    chunks:      uint64
    prot:        int32
    flags:       int32
    file_fd:     int32
    order:       int32
    nchunks:     int32
    # is_cow: 1 once this node's pages have been COW-shared on fork
    # (in either the parent or the child). A COW node's `backing` /
    # `chunks` physical addresses are no longer the authority for what
    # to free — COW resolution can repoint individual PTEs at fresh
    # pages outside the original buddy run — so _vma_node_free frees a
    # COW node by walking the owning task's page table page-by-page and
    # routing each physical page through cow_drop_page. A non-COW node
    # (0) keeps the fast bulk free_pages path. Replaces the old `pad0`
    # padding slot, so the struct size (72 bytes) is unchanged.
    is_cow:      int32


# ---------------------------------------------------------------------
# Allocation helpers
# ---------------------------------------------------------------------

def _vma_node_new() -> uint64:
    p: uint64 = kmalloc(72)
    if p == 0:
        return 0
    memset(cast[Ptr[uint8]](p), 0, 72)
    return p


def _vma_node_set(node: uint64, start: uint64, end: uint64,
                  prot: int32, flags: int32, file_fd: int32,
                  file_offset: uint64, backing: uint64,
                  order: int32):
    cast[Ptr[VmaNode]](node)[0].start       = start
    cast[Ptr[VmaNode]](node)[0].end         = end
    cast[Ptr[VmaNode]](node)[0].prot        = prot
    cast[Ptr[VmaNode]](node)[0].flags       = flags
    cast[Ptr[VmaNode]](node)[0].file_fd     = file_fd
    cast[Ptr[VmaNode]](node)[0].file_offset = file_offset
    cast[Ptr[VmaNode]](node)[0].backing     = backing
    cast[Ptr[VmaNode]](node)[0].order       = order
    cast[Ptr[VmaNode]](node)[0].next        = 0
    cast[Ptr[VmaNode]](node)[0].chunks      = 0
    cast[Ptr[VmaNode]](node)[0].nchunks     = 0
    cast[Ptr[VmaNode]](node)[0].is_cow      = 0


def _vma_node_get_next(node: uint64) -> uint64:
    return cast[Ptr[VmaNode]](node)[0].next


def _vma_node_set_next(node: uint64, nxt: uint64):
    cast[Ptr[VmaNode]](node)[0].next = nxt


def _vma_node_start(node: uint64) -> uint64:
    return cast[Ptr[VmaNode]](node)[0].start


def _vma_node_end(node: uint64) -> uint64:
    return cast[Ptr[VmaNode]](node)[0].end


# ---------------------------------------------------------------------
# COW-aware page-table walk for the free path
# ---------------------------------------------------------------------
#
# Once a VMA's pages have been COW-shared on fork (is_cow == 1) the
# node's `backing` / `chunks` physical addresses no longer describe
# what the owning task actually maps: a COW write fault (cow_resolve_pte
# in fs/elf.ad) allocates a FRESH page outside the original buddy run
# and repoints just that one PTE. So freeing a COW node by its recorded
# backing run would (a) leak every COW-resolved fresh page and (b)
# unconditionally free pages still mapped COW in another process — a
# use-after-free.
#
# The ground truth for a COW node is the page table itself. The free
# path walks the owning task's PML4 over the VMA's virtual range and,
# for each present 4 KiB PTE, routes the physical page through
# cow_drop_page: the page is returned to the buddy allocator (one
# order-0 free, which the buddy merge re-coalesces) ONLY when its
# refcount falls to 0. A still-shared page is left untouched for the
# other holder. A COW-resolved fresh page is refcount-0 (untracked) so
# cow_drop_page returns 1 and it is freed correctly too.
#
# vm_cow_share_range cracks every huge-page entry it touches down to
# 4 KiB granularity, so every page of a COW node is reached through a
# private 4 KiB PTE — _vma_pte_lookup never needs to handle a huge leaf
# here (it returns 0 on one, defensively skipping the page).

def _vma_pte_lookup(pml4_phys: uint64, vaddr: uint64) -> uint64:
    # Return the value of the 4 KiB PTE mapping `vaddr` in `pml4_phys`,
    # or 0 if any level is not-present or the leaf is a huge page.
    # Read-only: it never allocates or cracks a table — used by the
    # COW-aware free path, which must not mutate page tables.
    if pml4_phys == 0:
        return 0
    pml4_idx: uint64 = (vaddr >> 39) & 0x1FF
    pdpt_idx: uint64 = (vaddr >> 30) & 0x1FF
    pd_idx:   uint64 = (vaddr >> 21) & 0x1FF
    pt_idx:   uint64 = (vaddr >> 12) & 0x1FF

    pml4: Ptr[uint64] = cast[Ptr[uint64]](pml4_phys & VMA_PT_ADDR_MASK)
    pml4e: uint64 = pml4[pml4_idx]
    if (pml4e & VMA_PT_FLAG_P) == 0:
        return 0
    pdpt: Ptr[uint64] = cast[Ptr[uint64]](pml4e & VMA_PT_ADDR_MASK)
    pdpte: uint64 = pdpt[pdpt_idx]
    if (pdpte & VMA_PT_FLAG_P) == 0:
        return 0
    if (pdpte & VMA_PT_FLAG_PS) != 0:
        return 0
    pd: Ptr[uint64] = cast[Ptr[uint64]](pdpte & VMA_PT_ADDR_MASK)
    pde: uint64 = pd[pd_idx]
    if (pde & VMA_PT_FLAG_P) == 0:
        return 0
    if (pde & VMA_PT_FLAG_PS) != 0:
        return 0
    pt: Ptr[uint64] = cast[Ptr[uint64]](pde & VMA_PT_ADDR_MASK)
    pte: uint64 = pt[pt_idx]
    if (pte & VMA_PT_FLAG_P) == 0:
        return 0
    return pte


def _vma_free_cow_range(pml4_phys: uint64, vlo: uint64, vhi: uint64):
    # Free every present 4 KiB page of a COW node in [vlo, vhi) through
    # the COW refcount. cow_drop_page(phys) returns 1 when this was the
    # last holder (refcount fell to 0) — only then is the page returned
    # to the buddy allocator. A page another process still maps COW
    # (refcount > 1) drops to a lower count and is left alone.
    #
    # Each surviving page of the original buddy run is freed at order 0;
    # free_pages' buddy-merge logic re-coalesces neighbouring free pages
    # back into the larger run, so no fragmentation accumulates once a
    # run is fully released.
    vaddr: uint64 = vlo
    while vaddr < vhi:
        pte: uint64 = _vma_pte_lookup(pml4_phys, vaddr)
        if pte != 0:
            phys: uint64 = pte & VMA_PT_ADDR_MASK
            if phys != 0:
                if cow_drop_page(phys) != 0:
                    free_page(phys)
        vaddr = vaddr + VMA_PAGE_SIZE


def _vma_node_free(node: uint64, pml4_phys: uint64):
    # Release the node's backing pages (if any) then the node itself.
    # backing == 0 marks "no kernel-owned pages here" (an alias node
    # for a MAP_FIXED slice inside an enclosing region; only the
    # enclosing node owns the pages).
    #
    # COW node (is_cow == 1): the node's pages were COW-shared on fork,
    # so the recorded backing run is stale (COW resolution can repoint
    # PTEs at fresh pages). Free by walking the owning task's page
    # table over [start, end) and routing each physical page through
    # cow_drop_page — see _vma_free_cow_range. `pml4_phys` is the PML4
    # of the task that owns this VMA list.
    #
    # A multi-chunk VMA (nchunks > 0) instead owns an array of VmaChunk
    # descriptors; free every chunk at its own order, then release the
    # descriptor array. backing/order are unused for such nodes.
    is_cow: int32 = cast[Ptr[VmaNode]](node)[0].is_cow
    if is_cow != 0:
        v_start: uint64 = cast[Ptr[VmaNode]](node)[0].start
        v_end:   uint64 = cast[Ptr[VmaNode]](node)[0].end
        _vma_free_cow_range(pml4_phys, v_start, v_end)
        # The COW node never owns a separate backing run / chunk array
        # of its own (vma_fork_copy clears both on the share path), so
        # there is nothing else to release but the descriptor blocks.
        carr: uint64 = cast[Ptr[VmaNode]](node)[0].chunks
        if carr != 0:
            kfree(carr)
        kfree(node)
        return

    nchunks: int32 = cast[Ptr[VmaNode]](node)[0].nchunks
    if nchunks > 0:
        carr: uint64 = cast[Ptr[VmaNode]](node)[0].chunks
        if carr != 0:
            i: int32 = 0
            while i < nchunks:
                ce: uint64 = carr + cast[uint64](i) * VMA_CHUNK_SIZE
                cphys: uint64 = cast[Ptr[VmaChunk]](ce)[0].phys
                corder: int32 = cast[Ptr[VmaChunk]](ce)[0].order
                if cphys != 0:
                    free_pages(cphys, corder)
                i = i + 1
            kfree(carr)
        kfree(node)
        return
    backing: uint64 = cast[Ptr[VmaNode]](node)[0].backing
    if backing != 0:
        order: int32 = cast[Ptr[VmaNode]](node)[0].order
        free_pages(backing, order)
    kfree(node)


def _order_for_bytes(n: uint64) -> int32:
    # Smallest alloc_pages(order) that satisfies an n-byte request.
    # MAX_ORDER=10 -> 4 MiB per single alloc_pages call. Returns -1
    # when n exceeds one MAX_ORDER chunk; callers above 4 MiB take the
    # multi-chunk path instead of treating that as an error.
    order: int32 = 0
    block: uint64 = VMA_PAGE_SIZE
    while block < n:
        if order >= VMA_MAX_ORDER:
            return -1
        order = order + 1
        block = block << 1
    return order


def _order_for_chunk(n: uint64) -> int32:
    # Order covering an n-byte chunk that is KNOWN to be <= 4 MiB.
    # Identical to _order_for_bytes but never returns -1 (the caller
    # guarantees n <= VMA_MAX_CHUNK).
    order: int32 = 0
    block: uint64 = VMA_PAGE_SIZE
    while block < n:
        order = order + 1
        block = block << 1
    return order


# ---------------------------------------------------------------------
# List walk
# ---------------------------------------------------------------------

def vma_find(slot: uint64, addr: uint64) -> uint64:
    cur: uint64 = task_vma_list_head(slot)
    while cur != 0:
        s: uint64 = _vma_node_start(cur)
        e: uint64 = _vma_node_end(cur)
        if s <= addr and addr < e:
            return cur
        if s > addr:
            return 0
        cur = _vma_node_get_next(cur)
    return 0


def _vma_find_enclosing(slot: uint64, start: uint64,
                        end: uint64) -> uint64:
    # Returns a VmaNode whose [s, e) fully contains [start, end), or 0.
    # Used to detect ld.so's "reserve then MAP_FIXED overlay" case.
    cur: uint64 = task_vma_list_head(slot)
    while cur != 0:
        s: uint64 = _vma_node_start(cur)
        e: uint64 = _vma_node_end(cur)
        if s <= start and end <= e:
            return cur
        if s > start:
            return 0
        cur = _vma_node_get_next(cur)
    return 0


def _vma_insert_sorted(slot: uint64, node: uint64):
    head: uint64 = task_vma_list_head(slot)
    n_start: uint64 = _vma_node_start(node)
    if head == 0:
        _vma_node_set_next(node, 0)
        set_task_vma_list_head(slot, node)
        return
    if _vma_node_start(head) > n_start:
        _vma_node_set_next(node, head)
        set_task_vma_list_head(slot, node)
        return
    prev: uint64 = head
    cur:  uint64 = _vma_node_get_next(head)
    while cur != 0:
        if _vma_node_start(cur) >= n_start:
            _vma_node_set_next(node, cur)
            _vma_node_set_next(prev, node)
            return
        prev = cur
        cur  = _vma_node_get_next(cur)
    _vma_node_set_next(node, 0)
    _vma_node_set_next(prev, node)


# ---------------------------------------------------------------------
# Carve / unmap
# ---------------------------------------------------------------------

def _vma_unlink(slot: uint64, target: uint64) -> int32:
    head: uint64 = task_vma_list_head(slot)
    if head == 0:
        return 0
    if head == target:
        set_task_vma_list_head(slot, _vma_node_get_next(head))
        return 1
    prev: uint64 = head
    cur:  uint64 = _vma_node_get_next(head)
    while cur != 0:
        if cur == target:
            _vma_node_set_next(prev, _vma_node_get_next(cur))
            return 1
        prev = cur
        cur  = _vma_node_get_next(cur)
    return 0


def _vma_carve_range(slot: uint64, start: uint64, end: uint64):
    # Remove every node whose range overlaps [start, end). Any
    # overlap -> drop the whole node and free its pages. No partial-
    # range split: no current Linux userspace consumer munmaps a
    # partial range from the middle of a VMA.
    #
    # A COW-shared node frees through the refcount, so _vma_node_free
    # needs the owning task's PML4 to walk its page table.
    pml4: uint64 = task_pml4(cast[int32](slot))
    cur: uint64 = task_vma_list_head(slot)
    done: int32 = 0
    while cur != 0 and done == 0:
        nxt: uint64 = _vma_node_get_next(cur)
        s: uint64 = _vma_node_start(cur)
        e: uint64 = _vma_node_end(cur)
        if s < end and start < e:
            _vma_unlink(slot, cur)
            _vma_node_free(cur, pml4)
            cur = nxt
        elif s >= end:
            done = 1
        else:
            cur = nxt


# ---------------------------------------------------------------------
# _vma_alloc_large — multi-chunk backing path
# ---------------------------------------------------------------------
#
# A VMA whose page-rounded length exceeds VMA_MAX_CHUNK (4 MiB, the
# buddy allocator's largest single run) cannot be backed by one
# alloc_pages call. glibc's pthread library defaults to an 8 MiB
# thread stack, so this is a real, common request.
#
# _vma_alloc_large() backs such a VMA with MULTIPLE buddy chunks (each
# up to 4 MiB) and stitches them into ONE contiguous virtual range:
#
#   1. A 4-MiB-aligned virtual window of `length` bytes is carved from
#      the dedicated multi-chunk region [1 GiB, 4 GiB) by the
#      vma_large_next bump pointer. Nothing else is ever placed there
#      (buddy physical RAM is well under 1 GiB; small VMAs sit at their
#      low identity addresses; ELF image / brk / stack load low), so
#      two large VMAs can never overlap and no buddy allocation can
#      re-hand the physical pages under the window.
#   2. Each 4-MiB-or-smaller chunk gets its own buddy allocation
#      (scattered low physical pages) and is zeroed via its identity
#      address.
#   3. EVERY chunk — including chunk 0 — is overlaid into the calling
#      task's PML4 by elf_install_user_mapping() so the whole window
#      [base, base+length) points at the right physical chunk. (Unlike
#      a single-chunk VMA, the window has no physical RAM behind its
#      identity mapping, so chunk 0 cannot rely on identity.)
#   4. The chunk array (phys, order per chunk) is recorded on the
#      VmaNode so _vma_node_free releases every chunk and vma_fork_copy
#      copies every chunk.
#
# Because we overlay the live task's PML4, the caller's CR3 is reloaded
# afterwards to flush any stale TLB entries for the remapped range.
#
# Returns the resolved base on success, or a negative Linux errno.

def _vma_alloc_large(slot: uint64, length: uint64, prot: int32,
                     flags: int32, file_fd: int32,
                     file_offset: uint64) -> int64:
    # Number of chunks: ceil(length / 4 MiB).
    nchunks: int32 = cast[int32]((length + VMA_MAX_CHUNK - 1)
                                 / VMA_MAX_CHUNK)
    if nchunks <= 0:
        return cast[int64](-22)

    # Carve a 4-MiB-aligned virtual window. Rounding the reservation
    # up to a 4 MiB multiple keeps vma_large_next 4-MiB-aligned so
    # every per-chunk install stays inside one 1 GiB PDPT entry.
    window: uint64 = (length + VMA_MAX_CHUNK - 1) \
                     & ~(VMA_MAX_CHUNK - 1)
    base: uint64 = vma_large_next
    if base + window > VMA_LARGE_LIMIT:
        printk1("vma: large window exhausted (need 0x%x)\n", window)
        return cast[int64](-12)

    node: uint64 = _vma_node_new()
    if node == 0:
        return cast[int64](-12)

    carr: uint64 = kmalloc(cast[uint64](nchunks) * VMA_CHUNK_SIZE)
    if carr == 0:
        kfree(node)
        return cast[int64](-12)
    memset(cast[Ptr[uint8]](carr), 0,
           cast[uint64](nchunks) * VMA_CHUNK_SIZE)

    pml4: uint64 = task_pml4(cast[int32](slot))

    # Allocate + zero every chunk.
    i: int32 = 0
    ok: int32 = 1
    while i < nchunks and ok != 0:
        off: uint64 = cast[uint64](i) * VMA_MAX_CHUNK
        remain: uint64 = length - off
        csize: uint64 = VMA_MAX_CHUNK
        if remain < csize:
            csize = remain
        corder: int32 = _order_for_chunk(csize)
        cphys: uint64 = alloc_pages(corder)
        if cphys == 0:
            printk1("vma: large alloc OOM at chunk order=%d\n",
                    cast[uint64](corder))
            ok = 0
        else:
            memset(cast[Ptr[uint8]](cphys), 0, csize)
            ce: uint64 = carr + cast[uint64](i) * VMA_CHUNK_SIZE
            cast[Ptr[VmaChunk]](ce)[0].phys  = cphys
            cast[Ptr[VmaChunk]](ce)[0].order = corder
            cast[Ptr[VmaChunk]](ce)[0].pad   = 0
            i = i + 1

    if ok == 0:
        # Roll back: free whatever chunks we already grabbed.
        j: int32 = 0
        while j < i:
            ce: uint64 = carr + cast[uint64](j) * VMA_CHUNK_SIZE
            free_pages(cast[Ptr[VmaChunk]](ce)[0].phys,
                       cast[Ptr[VmaChunk]](ce)[0].order)
            j = j + 1
        kfree(carr)
        kfree(node)
        return cast[int64](-12)

    # Overlay EVERY chunk into the calling task's PML4 so the whole
    # window [base, base+length) presents one contiguous virtual range.
    m: int32 = 0
    while m < nchunks:
        ce: uint64 = carr + cast[uint64](m) * VMA_CHUNK_SIZE
        cphys: uint64 = cast[Ptr[VmaChunk]](ce)[0].phys
        off: uint64 = cast[uint64](m) * VMA_MAX_CHUNK
        remain: uint64 = length - off
        csize: uint64 = VMA_MAX_CHUNK
        if remain < csize:
            csize = remain
        vlo: uint64 = base + off
        rc: int32 = elf_install_user_mapping(pml4, vlo, vlo + csize,
                                             cphys)
        if rc < 0:
            printk1("vma: large remap failed at chunk %d\n",
                    cast[uint64](m))
            # Roll back every chunk allocation; the partial page-table
            # overlay is harmless (it points at our own freed pages and
            # is torn down with the task's PML4) but the box stays
            # diagnosable rather than aliasing live memory.
            j2: int32 = 0
            while j2 < nchunks:
                ce2: uint64 = carr + cast[uint64](j2) * VMA_CHUNK_SIZE
                free_pages(cast[Ptr[VmaChunk]](ce2)[0].phys,
                           cast[Ptr[VmaChunk]](ce2)[0].order)
                j2 = j2 + 1
            kfree(carr)
            kfree(node)
            return cast[int64](-12)
        m = m + 1

    # The overlay touched the live task's PML4; flush stale TLB
    # entries for the remapped range by reloading CR3 with its own
    # value (drops every non-global entry).
    load_cr3(pml4)

    # Commit the window: bump the allocator past it.
    vma_large_next = base + window

    end_v: uint64 = base + length
    _vma_node_set(node, base, end_v, prot, flags, file_fd,
                  file_offset, 0, 0)
    cast[Ptr[VmaNode]](node)[0].chunks  = carr
    cast[Ptr[VmaNode]](node)[0].nchunks = nchunks
    _vma_insert_sorted(slot, node)
    return cast[int64](base)


# ---------------------------------------------------------------------
# vma_alloc
# ---------------------------------------------------------------------

def vma_alloc(slot: uint64, addr_in: uint64, len_in: uint64,
              prot: int32, flags: int32, file_fd: int32,
              file_offset: uint64) -> int64:
    # Allocate a fresh VMA + its backing pages, splice it into the
    # task's vma_list, and return the resolved start address (cast
    # to int64 so the caller can return it through the syscall ABI).
    # On failure returns a negative Linux errno.
    if len_in == 0:
        return cast[int64](-22)

    length: uint64 = (len_in + VMA_PAGE_SIZE - 1) & ~(VMA_PAGE_SIZE - 1)

    is_fixed: int32 = 0
    if (flags & VMA_MAP_FIXED) != 0:
        is_fixed = 1

    # MAP_FIXED handling runs FIRST so a large MAP_FIXED that lands
    # inside an existing reservation is recorded as a metadata-only
    # alias (regardless of length); a non-enclosed MAP_FIXED carves
    # the overlap and then falls through to the size-based routing
    # below with addr_in treated as a hint.
    if is_fixed != 0 and addr_in != 0:
        end_req: uint64 = addr_in + length
        encl: uint64 = _vma_find_enclosing(slot, addr_in, end_req)
        if encl != 0:
            # MAP_FIXED into existing reservation: alias node.
            alias: uint64 = _vma_node_new()
            if alias == 0:
                return cast[int64](-12)
            _vma_node_set(alias, addr_in, end_req, prot, flags,
                          file_fd, file_offset, 0, 0)
            _vma_insert_sorted(slot, alias)
            return cast[int64](addr_in)
        # MAP_FIXED but no enclosing region: carve any overlap then
        # fall through (the user's requested addr is just a hint).
        _vma_carve_range(slot, addr_in, end_req)
        printk1("vma: MAP_FIXED at 0x%x not enclosed; addr as hint\n",
                addr_in)

    # Large request: more than one buddy MAX_ORDER chunk. Back it with
    # multiple chunks stitched into a contiguous virtual range. glibc's
    # 8 MiB default pthread stack lands here.
    if length > VMA_MAX_CHUNK:
        return _vma_alloc_large(slot, length, prot, flags,
                                file_fd, file_offset)

    order: int32 = _order_for_bytes(length)
    if order < 0:
        # Defensive: _order_for_bytes only returns -1 above 4 MiB, and
        # that case was already routed to _vma_alloc_large. Treat any
        # residual -1 as a multi-chunk request rather than failing.
        return _vma_alloc_large(slot, length, prot, flags,
                                file_fd, file_offset)

    base: uint64 = alloc_pages(order)
    if base == 0:
        printk1("vma: alloc_pages OOM len=%d\n", length)
        return cast[int64](-12)

    memset(cast[Ptr[uint8]](base), 0, length)

    node: uint64 = _vma_node_new()
    if node == 0:
        free_pages(base, order)
        return cast[int64](-12)
    end_v: uint64 = base + length
    _vma_node_set(node, base, end_v, prot, flags, file_fd,
                  file_offset, base, order)
    _vma_insert_sorted(slot, node)
    return cast[int64](base)


def vma_unmap(slot: uint64, addr: uint64, len_in: uint64) -> int64:
    if len_in == 0:
        return cast[int64](-22)
    length: uint64 = (len_in + VMA_PAGE_SIZE - 1) & ~(VMA_PAGE_SIZE - 1)
    end_v: uint64 = addr + length
    _vma_carve_range(slot, addr, end_v)
    return 0


# ---------------------------------------------------------------------
# vma_protect (mprotect)
# ---------------------------------------------------------------------

def vma_protect(slot: uint64, addr: uint64, len_in: uint64,
                prot: int32) -> int64:
    if len_in == 0:
        return cast[int64](-22)
    length: uint64 = (len_in + VMA_PAGE_SIZE - 1) & ~(VMA_PAGE_SIZE - 1)
    end_v: uint64 = addr + length
    cur: uint64 = task_vma_list_head(slot)
    done: int32 = 0
    while cur != 0 and done == 0:
        s: uint64 = _vma_node_start(cur)
        e: uint64 = _vma_node_end(cur)
        if s < end_v and addr < e:
            cast[Ptr[VmaNode]](cur)[0].prot = prot
        if s >= end_v:
            done = 1
        else:
            cur = _vma_node_get_next(cur)
    # Always 0 — anything outside the VMA list is in the kernel's
    # identity map which is RWX U=1 anyway. glibc-startup mprotect
    # of GOT/relro pages used to succeed unconditionally and we keep
    # that compat.
    return 0


# ---------------------------------------------------------------------
# vma_clear — wipe the current task's address space on execve
# ---------------------------------------------------------------------

def vma_clear(slot: uint64):
    # execve / task-teardown path: free EVERY VMA the task holds.
    # A COW-shared node frees through the refcount, so _vma_node_free
    # is handed the task's PML4 to walk its page table — a still-shared
    # page (mapped COW in a forked relative) is left for that holder
    # instead of being freed out from under it.
    pml4: uint64 = task_pml4(cast[int32](slot))
    cur: uint64 = task_vma_list_head(slot)
    while cur != 0:
        nxt: uint64 = _vma_node_get_next(cur)
        _vma_node_free(cur, pml4)
        cur = nxt
    set_task_vma_list_head(slot, 0)


# ---------------------------------------------------------------------
# fork(): COW-share a parent's VMA list into a child
# ---------------------------------------------------------------------
#
# vma_fork_copy() gives a forked child its own VMA list mirroring the
# parent's, with every mmap page COPY-ON-WRITE shared instead of eager-
# copied. This is the mmap-VMA counterpart of fs/elf.ad::vm_cow_share_all
# (which COW-shares the ELF image / brk / stack); together they make the
# WHOLE address space copy-on-write on fork.
#
# For every parent VMA that OWNS backing pages (single-chunk: backing
# != 0; multi-chunk: nchunks > 0) it:
#
#   1. links a child VmaNode mirroring the parent's metadata,
#   2. calls vm_cow_share_range over the VMA's [start, end): every
#      present user page is cracked to 4 KiB granularity, marked
#      READ-ONLY + COW (PTE bit 9) in BOTH the parent's and the child's
#      PML4, both pointing at the SAME physical page, and the page's
#      per-PFN refcount is bumped (mm/cow.ad). The first write by either
#      side faults into the productive #PF handler, which copies just
#      that one 4 KiB page.
#   3. marks BOTH the parent's VMA node and the child's node is_cow,
#      because each now holds COW references — their pages must be
#      freed through cow_drop_page (see _vma_node_free).
#
# A COW-shared child node does NOT own a private backing run / chunk
# array: it shares the parent's physical pages until a write fault
# resolves them. backing / chunks / order / nchunks are all cleared on
# the child node; _vma_node_free's COW path frees purely by walking the
# page table, so those fields are vestigial for a COW node.
#
# Alias VMAs (backing == 0, nchunks == 0 — a MAP_FIXED slice inside an
# enclosing region) are copied as METADATA ONLY: their pages belong to
# the enclosing owner node, which COW-shares the whole range including
# the alias slice. COW-sharing an alias range too would bump the
# refcount of those pages a SECOND time and leak them, so alias nodes
# are deliberately skipped by the share pass.
#
# Single-chunk and multi-chunk VMAs take the SAME path here — both are
# just a contiguous virtual range that is fully mapped in the parent's
# (currently live) PML4, which is exactly what vm_cow_share_range walks.
#
# Returns 0 on success, -1 on OOM (vm_cow_share_range failed to crack a
# table — the caller aborts the fork).


def vma_fork_copy(child_slot: uint64, parent_slot: uint64,
                  child_pml4: uint64) -> int32:
    parent_pml4: uint64 = task_pml4(cast[int32](parent_slot))
    cur: uint64 = task_vma_list_head(parent_slot)
    while cur != 0:
        p_start:  uint64 = cast[Ptr[VmaNode]](cur)[0].start
        p_end:    uint64 = cast[Ptr[VmaNode]](cur)[0].end
        p_prot:   int32  = cast[Ptr[VmaNode]](cur)[0].prot
        p_flags:  int32  = cast[Ptr[VmaNode]](cur)[0].flags
        p_fd:     int32  = cast[Ptr[VmaNode]](cur)[0].file_fd
        p_off:    uint64 = cast[Ptr[VmaNode]](cur)[0].file_offset
        p_back:   uint64 = cast[Ptr[VmaNode]](cur)[0].backing
        p_nchunks: int32 = cast[Ptr[VmaNode]](cur)[0].nchunks
        node: uint64 = _vma_node_new()
        if node == 0:
            return -1

        owns_pages: int32 = 0
        if p_nchunks > 0:
            owns_pages = 1
        elif p_back != 0:
            owns_pages = 1

        if owns_pages != 0:
            # Owner VMA — COW-share every page across [p_start, p_end)
            # between parent and child. The child node mirrors the
            # parent's metadata but owns NO private backing run: it
            # shares the parent's physical pages COW. Both nodes are
            # flagged is_cow so _vma_node_free routes their frees
            # through cow_drop_page.
            _vma_node_set(node, p_start, p_end, p_prot, p_flags,
                          p_fd, p_off, 0, 0)
            cast[Ptr[VmaNode]](node)[0].is_cow = 1
            if vm_cow_share_range(parent_pml4, child_pml4,
                                  p_start, p_end) < 0:
                printk1("vma_fork: COW share OOM for VMA @ 0x%x\n",
                        p_start)
                kfree(node)
                return -1
            # The parent's pages are now COW-shared too — its node must
            # also free through the refcount from here on.
            cast[Ptr[VmaNode]](cur)[0].is_cow = 1
            _vma_insert_sorted(child_slot, node)
        else:
            # Alias VMA (MAP_FIXED slice in an enclosing region): pure
            # metadata copy. Its pages were COW-shared via the enclosing
            # owner node's range, so we must NOT share them again here.
            _vma_node_set(node, p_start, p_end, p_prot, p_flags,
                          p_fd, p_off, 0, 0)
            _vma_insert_sorted(child_slot, node)
        cur = cast[Ptr[VmaNode]](cur)[0].next
    return 0


# ---------------------------------------------------------------------
# Diagnostics
# ---------------------------------------------------------------------

def vma_count(slot: uint64) -> uint64:
    n: uint64 = 0
    cur: uint64 = task_vma_list_head(slot)
    while cur != 0:
        n = n + 1
        cur = _vma_node_get_next(cur)
    return n
