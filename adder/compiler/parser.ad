# adder/compiler/parser.ad
#
# Adder-in-Adder implementation of the Adder parser.
#
# This is the SECOND self-hosting milestone (the lexer was the first):
# the Adder compiler's own recursive-descent parser, rewritten IN Adder,
# consuming the token stream the Adder lexer (compiler/lexer.ad) produces
# and building an AST. The grammar/AST mirror compiler/parser.py and
# compiler/ast_nodes.py faithfully so this is a reimplementation, not a
# parallel invention.
#
# Design constraints (Adder/bare-metal — same as lexer.ad):
#   - No dynamic allocation: all storage is global fixed arrays.
#   - AST: an arena of nodes stored in parallel arrays, indexed by an
#     integer "node id". A node id of 0 means "no node" (null), so the
#     arena starts allocating real nodes at index 1.
#   - Each node has a kind tag (ND_*), a token-derived auxiliary integer
#     (e.g. operator kind, or a strbuf offset for names), and up to four
#     child node-id slots (a, b, c, d). Variable-length child lists (call
#     args, block statements, parameters) are stored as singly-linked
#     sibling chains via the `next` slot, with the head node id kept in a
#     child slot and the count in an aux slot.
#
# The parser reads the lexer's global token arrays (tok_type, tok_line,
# tok_val_start, tok_val_len, tok_num_val, tok_count, strbuf) directly,
# since the lexer is a single-instance global module too.

from compiler.lexer import (
    tok_type,
    tok_line,
    tok_val_start,
    tok_val_len,
    tok_num_val,
    tok_count,
    strbuf,
    TOK_DEF,
    TOK_CLASS,
    TOK_FROM,
    TOK_IMPORT,
    TOK_AS,
    TOK_RETURN,
    TOK_IF,
    TOK_ELIF,
    TOK_ELSE,
    TOK_WHILE,
    TOK_DO,
    TOK_FOR,
    TOK_IN,
    TOK_BREAK,
    TOK_CONTINUE,
    TOK_PASS,
    TOK_WITH,
    TOK_RAISE,
    TOK_TRY,
    TOK_EXCEPT,
    TOK_FINALLY,
    TOK_LAMBDA,
    TOK_YIELD,
    TOK_AND,
    TOK_OR,
    TOK_NOT,
    TOK_IS,
    TOK_ASSERT,
    TOK_GLOBAL,
    TOK_DEL,
    TOK_EXTERN,
    TOK_ASM,
    TOK_DEFER,
    TOK_MATCH,
    TOK_CASE,
    TOK_VOLATILE,
    TOK_UNION,
    TOK_PTR,
    TOK_FN,
    TOK_LIST,
    TOK_DICT,
    TOK_TUPLE,
    TOK_OPTIONAL,
    TOK_INT8,
    TOK_INT16,
    TOK_INT32,
    TOK_INT64,
    TOK_UINT8,
    TOK_UINT16,
    TOK_UINT32,
    TOK_UINT64,
    TOK_FLOAT32,
    TOK_FLOAT64,
    TOK_BOOL,
    TOK_CHAR,
    TOK_STR,
    TOK_INT,
    TOK_FLOAT,
    TOK_ARRAY,
    TOK_CAST,
    TOK_SELF,
    TOK_IDENT,
    TOK_NUMBER,
    TOK_STRING,
    TOK_FSTRING,
    TOK_CHAR_LIT,
    TOK_TRUE,
    TOK_FALSE,
    TOK_NONE,
    TOK_PLUS,
    TOK_MINUS,
    TOK_STAR,
    TOK_SLASH,
    TOK_DOUBLE_SLASH,
    TOK_PERCENT,
    TOK_DOUBLE_STAR,
    TOK_EQUALS,
    TOK_NOT_EQUALS,
    TOK_LESS,
    TOK_GREATER,
    TOK_LESS_EQUALS,
    TOK_GREATER_EQUALS,
    TOK_AMPERSAND,
    TOK_PIPE,
    TOK_CARET,
    TOK_TILDE,
    TOK_SHL,
    TOK_SHR,
    TOK_ASSIGN,
    TOK_PLUS_EQUALS,
    TOK_MINUS_EQUALS,
    TOK_STAR_EQUALS,
    TOK_SLASH_EQUALS,
    TOK_PERCENT_EQUALS,
    TOK_AMPERSAND_EQUALS,
    TOK_PIPE_EQUALS,
    TOK_CARET_EQUALS,
    TOK_SHL_EQUALS,
    TOK_SHR_EQUALS,
    TOK_LPAREN,
