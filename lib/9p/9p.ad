    if rc != 0:
        return rc
    return _p9_header_finish(c)


def p9_decode_rerror(buf: Ptr[uint8], buf_len: uint64,
                     out_tag: Ptr[uint16],
                     out_ename: Ptr[Ptr[uint8]],
                     out_ename_len: Ptr[uint64]) -> int64:
    sz: uint32 = 0
    tg: uint16 = 0
    body_off: uint64 = 0
    body_end: uint64 = 0
    rc: int32 = _p9_decode_header_for(buf, buf_len, P9_RERROR,
                                      &sz, &tg, &body_off, &body_end)
    if rc != 0:
        return cast[int64](rc)
    n: int64 = _p9_get_string(buf, body_end, body_off, out_ename, out_ename_len)
