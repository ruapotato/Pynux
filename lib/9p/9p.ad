    if _p9_get_qid(buf, body_end, body_off,
                   out_qtype, out_qvers, out_qpath) < 0:
        return cast[int64](-2)
    body_off = body_off + 13
    rc = _p9_get_u32(buf, body_end, body_off, out_iounit)
    if rc != 0:
        return cast[int64](-2)
    body_off = body_off + 4
    if body_off != body_end:
