def p9_decode_ropen(buf: Ptr[uint8], buf_len: uint64,
                    out_tag: Ptr[uint16],
                    out_qtype: Ptr[uint8], out_qvers: Ptr[uint32],
                    out_qpath: Ptr[uint64],
