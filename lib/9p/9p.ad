def p9_decode_tcreate(buf: Ptr[uint8], buf_len: uint64,
                      out_tag: Ptr[uint16],
                      out_fid: Ptr[uint32],
                      out_name: Ptr[Ptr[uint8]], out_name_len: Ptr[uint64],
