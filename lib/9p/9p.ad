    return cast[int64](sz)


# -- Tread / Rread -----------------------------------------------------------

def p9_emit_tread(c: Ptr[P9Cursor], tag: uint16,
                  fid: uint32, offset: uint64, count: uint32) -> int32:
    rc: int32 = _p9_header_begin(c, P9_TREAD, tag)
    if rc < 0:
        return rc
    rc = _p9_put_u32(c, fid)
    if rc != 0:
        return rc
    rc = _p9_put_u64(c, offset)
    if rc != 0:
        return rc
    rc = _p9_put_u32(c, count)
    if rc != 0:
        return rc
    return _p9_header_finish(c)


def p9_emit_rread(c: Ptr[P9Cursor], tag: uint16,
                  data: Ptr[uint8], count: uint32) -> int32:
    rc: int32 = _p9_header_begin(c, P9_RREAD, tag)
    if rc < 0:
        return rc
    rc = _p9_put_u32(c, count)
    if rc != 0:
        return rc
    rc = _p9_put_bytes(c, data, cast[uint64](count))
    if rc != 0:
        return rc
    return _p9_header_finish(c)


def p9_decode_tread(buf: Ptr[uint8], buf_len: uint64,
                    out_tag: Ptr[uint16],
                    out_fid: Ptr[uint32], out_offset: Ptr[uint64],
                    out_count: Ptr[uint32]) -> int64:
    sz: uint32 = 0
    tg: uint16 = 0
    body_off: uint64 = 0
    body_end: uint64 = 0
    rc: int32 = _p9_decode_header_for(buf, buf_len, P9_TREAD,
                                      &sz, &tg, &body_off, &body_end)
    if rc != 0:
        return cast[int64](rc)
    rc = _p9_get_u32(buf, body_end, body_off, out_fid)
    if rc != 0:
        return cast[int64](-2)
    body_off = body_off + 4
    rc = _p9_get_u64(buf, body_end, body_off, out_offset)
    if rc != 0:
        return cast[int64](-2)
    body_off = body_off + 8
    rc = _p9_get_u32(buf, body_end, body_off, out_count)
    if rc != 0:
        return cast[int64](-2)
    body_off = body_off + 4
    if body_off != body_end:
        return cast[int64](-2)
    out_tag[0] = tg
    return cast[int64](sz)


def p9_decode_rread(buf: Ptr[uint8], buf_len: uint64,
                    out_tag: Ptr[uint16],
                    out_data: Ptr[Ptr[uint8]],
                    out_count: Ptr[uint32]) -> int64:
    sz: uint32 = 0
    tg: uint16 = 0
    body_off: uint64 = 0
    body_end: uint64 = 0
    rc: int32 = _p9_decode_header_for(buf, buf_len, P9_RREAD,
                                      &sz, &tg, &body_off, &body_end)
    if rc != 0:
        return cast[int64](rc)
    rc = _p9_get_u32(buf, body_end, body_off, out_count)
    if rc != 0:
        return cast[int64](-2)
    body_off = body_off + 4
    if body_off + cast[uint64](out_count[0]) != body_end:
        return cast[int64](-2)
    out_data[0] = &buf[body_off]
    out_tag[0] = tg
    return cast[int64](sz)


# -- Twrite / Rwrite ---------------------------------------------------------

def p9_emit_twrite(c: Ptr[P9Cursor], tag: uint16,
                   fid: uint32, offset: uint64,
                   data: Ptr[uint8], count: uint32) -> int32:
    rc: int32 = _p9_header_begin(c, P9_TWRITE, tag)
    if rc < 0:
        return rc
    rc = _p9_put_u32(c, fid)
    if rc != 0:
        return rc
    rc = _p9_put_u64(c, offset)
    if rc != 0:
        return rc
    rc = _p9_put_u32(c, count)
    if rc != 0:
        return rc
    rc = _p9_put_bytes(c, data, cast[uint64](count))
    if rc != 0:
        return rc
    return _p9_header_finish(c)


def p9_emit_rwrite(c: Ptr[P9Cursor], tag: uint16, count: uint32) -> int32:
    rc: int32 = _p9_header_begin(c, P9_RWRITE, tag)
    if rc < 0:
        return rc
    rc = _p9_put_u32(c, count)
    if rc != 0:
        return rc
    return _p9_header_finish(c)


def p9_decode_twrite(buf: Ptr[uint8], buf_len: uint64,
                     out_tag: Ptr[uint16],
                     out_fid: Ptr[uint32], out_offset: Ptr[uint64],
                     out_data: Ptr[Ptr[uint8]],
                     out_count: Ptr[uint32]) -> int64:
    sz: uint32 = 0
    tg: uint16 = 0
    body_off: uint64 = 0
    body_end: uint64 = 0
    rc: int32 = _p9_decode_header_for(buf, buf_len, P9_TWRITE,
                                      &sz, &tg, &body_off, &body_end)
    if rc != 0:
        return cast[int64](rc)
    rc = _p9_get_u32(buf, body_end, body_off, out_fid)
    if rc != 0:
        return cast[int64](-2)
    body_off = body_off + 4
    rc = _p9_get_u64(buf, body_end, body_off, out_offset)
    if rc != 0:
        return cast[int64](-2)
    body_off = body_off + 8
    rc = _p9_get_u32(buf, body_end, body_off, out_count)
    if rc != 0:
        return cast[int64](-2)
    body_off = body_off + 4
    if body_off + cast[uint64](out_count[0]) != body_end:
        return cast[int64](-2)
    out_data[0] = &buf[body_off]
    out_tag[0] = tg
    return cast[int64](sz)


def p9_decode_rwrite(buf: Ptr[uint8], buf_len: uint64,
                     out_tag: Ptr[uint16],
                     out_count: Ptr[uint32]) -> int64:
    sz: uint32 = 0
    tg: uint16 = 0
    body_off: uint64 = 0
    body_end: uint64 = 0
    rc: int32 = _p9_decode_header_for(buf, buf_len, P9_RWRITE,
                                      &sz, &tg, &body_off, &body_end)
    if rc != 0:
        return cast[int64](rc)
    rc = _p9_get_u32(buf, body_end, body_off, out_count)
    if rc != 0:
        return cast[int64](-2)
    body_off = body_off + 4
    if body_off != body_end:
        return cast[int64](-2)
    out_tag[0] = tg
    return cast[int64](sz)


# -- Tclunk / Rclunk ---------------------------------------------------------

def p9_emit_tclunk(c: Ptr[P9Cursor], tag: uint16, fid: uint32) -> int32:
    rc: int32 = _p9_header_begin(c, P9_TCLUNK, tag)
    if rc < 0:
        return rc
    rc = _p9_put_u32(c, fid)
    if rc != 0:
        return rc
    return _p9_header_finish(c)


def p9_emit_rclunk(c: Ptr[P9Cursor], tag: uint16) -> int32:
    rc: int32 = _p9_header_begin(c, P9_RCLUNK, tag)
    if rc < 0:
        return rc
    return _p9_header_finish(c)


def p9_decode_tclunk(buf: Ptr[uint8], buf_len: uint64,
                     out_tag: Ptr[uint16],
                     out_fid: Ptr[uint32]) -> int64:
    sz: uint32 = 0
    tg: uint16 = 0
    body_off: uint64 = 0
    body_end: uint64 = 0
    rc: int32 = _p9_decode_header_for(buf, buf_len, P9_TCLUNK,
                                      &sz, &tg, &body_off, &body_end)
    if rc != 0:
        return cast[int64](rc)
    rc = _p9_get_u32(buf, body_end, body_off, out_fid)
    if rc != 0:
        return cast[int64](-2)
    body_off = body_off + 4
    if body_off != body_end:
        return cast[int64](-2)
    out_tag[0] = tg
    return cast[int64](sz)


def p9_decode_rclunk(buf: Ptr[uint8], buf_len: uint64,
                     out_tag: Ptr[uint16]) -> int64:
    sz: uint32 = 0
    tg: uint16 = 0
    body_off: uint64 = 0
    body_end: uint64 = 0
    rc: int32 = _p9_decode_header_for(buf, buf_len, P9_RCLUNK,
                                      &sz, &tg, &body_off, &body_end)
    if rc != 0:
        return cast[int64](rc)
    if body_off != body_end:
        return cast[int64](-2)
    out_tag[0] = tg
    return cast[int64](sz)


# -- Stat record encode/decode ----------------------------------------------
#
# A Stat record is the inner sub-record used by Rstat, Twstat and
# directory Tread payloads. Layout in docs/9p.md §4.2:
#
#   size[2] type[2] dev[4] qid[13] mode[4] atime[4] mtime[4] length[8]
#   name[s] uid[s] gid[s] muid[s]
#
# size[2] is the count of bytes that follow size itself (== total
# record bytes - 2).

def p9_emit_stat(c: Ptr[P9Cursor],
                 stat_type: uint16, dev: uint32,
                 qtype: uint8, qvers: uint32, qpath: uint64,
                 mode: uint32, atime: uint32, mtime: uint32,
                 length: uint64,
                 name: Ptr[uint8], name_len: uint64,
                 uid: Ptr[uint8], uid_len: uint64,
                 gid: Ptr[uint8], gid_len: uint64,
                 muid: Ptr[uint8], muid_len: uint64) -> int32:
    # We don't know the size until the rest is laid down. Reserve a
    # uint16 placeholder, write the body, then backpatch.
    start_pos: uint64 = c[0].pos
    rc: int32 = _p9_put_u16(c, 0)
    if rc != 0:
        return rc
    rc = _p9_put_u16(c, stat_type)
    if rc != 0:
        return rc
    rc = _p9_put_u32(c, dev)
    if rc != 0:
        return rc
    rc = _p9_put_qid(c, qtype, qvers, qpath)
    if rc != 0:
        return rc
    rc = _p9_put_u32(c, mode)
    if rc != 0:
        return rc
    rc = _p9_put_u32(c, atime)
    if rc != 0:
        return rc
    rc = _p9_put_u32(c, mtime)
    if rc != 0:
        return rc
    rc = _p9_put_u64(c, length)
    if rc != 0:
        return rc
    rc = _p9_put_string(c, name, name_len)
    if rc != 0:
        return rc
    rc = _p9_put_string(c, uid, uid_len)
    if rc != 0:
        return rc
    rc = _p9_put_string(c, gid, gid_len)
    if rc != 0:
        return rc
    rc = _p9_put_string(c, muid, muid_len)
    if rc != 0:
        return rc
    if c[0].err != 0:
        return c[0].err
    # Backpatch size[2] = (c[0].pos - start_pos) - 2.
    inner: uint64 = (c[0].pos - start_pos) - 2
    if inner > 0xFFFF:
        c[0].err = -2
        return -2
    c[0].buf[start_pos]     = cast[uint8](inner & 0xFF)
    c[0].buf[start_pos + 1] = cast[uint8]((inner >> 8) & 0xFF)
    return cast[int32](c[0].pos - start_pos)


# Decode a Stat record at (buf, buf_len, off). Returns bytes consumed
# (>= 2 + inner_size) or negative. All four string outputs point into
# the source buffer.
def p9_decode_stat(buf: Ptr[uint8], buf_len: uint64, off: uint64,
                   out_stat_type: Ptr[uint16], out_dev: Ptr[uint32],
                   out_qtype: Ptr[uint8], out_qvers: Ptr[uint32],
                   out_qpath: Ptr[uint64],
                   out_mode: Ptr[uint32],
                   out_atime: Ptr[uint32], out_mtime: Ptr[uint32],
                   out_length: Ptr[uint64],
                   out_name: Ptr[Ptr[uint8]], out_name_len: Ptr[uint64],
                   out_uid: Ptr[Ptr[uint8]], out_uid_len: Ptr[uint64],
                   out_gid: Ptr[Ptr[uint8]], out_gid_len: Ptr[uint64],
                   out_muid: Ptr[Ptr[uint8]],
                   out_muid_len: Ptr[uint64]) -> int64:
    if off + 2 > buf_len:
        return cast[int64](-1)
    inner_lo: uint64 = cast[uint64](buf[off])
    inner_hi: uint64 = cast[uint64](buf[off + 1])
    inner: uint64 = inner_lo | (inner_hi << 8)
    record_end: uint64 = off + 2 + inner
    if record_end > buf_len:
        return cast[int64](-2)
    p: uint64 = off + 2
    rc: int32 = _p9_get_u16(buf, record_end, p, out_stat_type)
    if rc != 0:
        return cast[int64](-2)
    p = p + 2
    rc = _p9_get_u32(buf, record_end, p, out_dev)
    if rc != 0:
        return cast[int64](-2)
    p = p + 4
    if _p9_get_qid(buf, record_end, p,
                   out_qtype, out_qvers, out_qpath) < 0:
        return cast[int64](-2)
    p = p + 13
    rc = _p9_get_u32(buf, record_end, p, out_mode)
    if rc != 0:
        return cast[int64](-2)
    p = p + 4
    rc = _p9_get_u32(buf, record_end, p, out_atime)
    if rc != 0:
        return cast[int64](-2)
    p = p + 4
    rc = _p9_get_u32(buf, record_end, p, out_mtime)
    if rc != 0:
        return cast[int64](-2)
    p = p + 4
    rc = _p9_get_u64(buf, record_end, p, out_length)
    if rc != 0:
        return cast[int64](-2)
    p = p + 8
    n: int64 = _p9_get_string(buf, record_end, p, out_name, out_name_len)
    if n < 0:
        return cast[int64](-2)
    p = p + cast[uint64](n)
    n = _p9_get_string(buf, record_end, p, out_uid, out_uid_len)
    if n < 0:
        return cast[int64](-2)
    p = p + cast[uint64](n)
    n = _p9_get_string(buf, record_end, p, out_gid, out_gid_len)
    if n < 0:
        return cast[int64](-2)
    p = p + cast[uint64](n)
    n = _p9_get_string(buf, record_end, p, out_muid, out_muid_len)
    if n < 0:
        return cast[int64](-2)
    p = p + cast[uint64](n)
    if p != record_end:
        return cast[int64](-2)
    return cast[int64](record_end - off)


# -- Tstat / Rstat -----------------------------------------------------------

def p9_emit_tstat(c: Ptr[P9Cursor], tag: uint16, fid: uint32) -> int32:
    rc: int32 = _p9_header_begin(c, P9_TSTAT, tag)
    if rc < 0:
        return rc
    rc = _p9_put_u32(c, fid)
    if rc != 0:
        return rc
    return _p9_header_finish(c)


# Rstat carries `stat[n]` — a 2-byte length followed by n bytes of
# Stat. This emit wraps p9_emit_stat in the right outer length prefix.
def p9_emit_rstat(c: Ptr[P9Cursor], tag: uint16,
                  stat_type: uint16, dev: uint32,
                  qtype: uint8, qvers: uint32, qpath: uint64,
                  mode: uint32, atime: uint32, mtime: uint32,
                  length: uint64,
                  name: Ptr[uint8], name_len: uint64,
                  uid: Ptr[uint8], uid_len: uint64,
                  gid: Ptr[uint8], gid_len: uint64,
                  muid: Ptr[uint8], muid_len: uint64) -> int32:
    rc: int32 = _p9_header_begin(c, P9_RSTAT, tag)
    if rc < 0:
        return rc
    # Outer wrapper: 2-byte length of the stat record that follows.
    # We reserve, emit_stat, then backpatch.
    outer_pos: uint64 = c[0].pos
    rc = _p9_put_u16(c, 0)
    if rc != 0:
        return rc
    stat_bytes: int32 = p9_emit_stat(c, stat_type, dev,
                                     qtype, qvers, qpath, mode,
                                     atime, mtime, length,
                                     name, name_len,
                                     uid, uid_len,
                                     gid, gid_len,
                                     muid, muid_len)
    if stat_bytes < 0:
        return stat_bytes
    n: uint64 = cast[uint64](stat_bytes)
    if n > 0xFFFF:
        c[0].err = -2
        return -2
    c[0].buf[outer_pos]     = cast[uint8](n & 0xFF)
    c[0].buf[outer_pos + 1] = cast[uint8]((n >> 8) & 0xFF)
    return _p9_header_finish(c)


def p9_decode_tstat(buf: Ptr[uint8], buf_len: uint64,
                    out_tag: Ptr[uint16],
                    out_fid: Ptr[uint32]) -> int64:
    sz: uint32 = 0
    tg: uint16 = 0
    body_off: uint64 = 0
    body_end: uint64 = 0
    rc: int32 = _p9_decode_header_for(buf, buf_len, P9_TSTAT,
                                      &sz, &tg, &body_off, &body_end)
    if rc != 0:
        return cast[int64](rc)
    rc = _p9_get_u32(buf, body_end, body_off, out_fid)
    if rc != 0:
        return cast[int64](-2)
    body_off = body_off + 4
    if body_off != body_end:
        return cast[int64](-2)
    out_tag[0] = tg
    return cast[int64](sz)


# Decode Rstat. The outer 2-byte length must match the inner stat
# record exactly.
def p9_decode_rstat(buf: Ptr[uint8], buf_len: uint64,
                    out_tag: Ptr[uint16],
                    out_stat_type: Ptr[uint16], out_dev: Ptr[uint32],
                    out_qtype: Ptr[uint8], out_qvers: Ptr[uint32],
                    out_qpath: Ptr[uint64],
                    out_mode: Ptr[uint32],
                    out_atime: Ptr[uint32], out_mtime: Ptr[uint32],
                    out_length: Ptr[uint64],
                    out_name: Ptr[Ptr[uint8]], out_name_len: Ptr[uint64],
                    out_uid: Ptr[Ptr[uint8]], out_uid_len: Ptr[uint64],
                    out_gid: Ptr[Ptr[uint8]], out_gid_len: Ptr[uint64],
                    out_muid: Ptr[Ptr[uint8]],
                    out_muid_len: Ptr[uint64]) -> int64:
    sz: uint32 = 0
    tg: uint16 = 0
    body_off: uint64 = 0
    body_end: uint64 = 0
    rc: int32 = _p9_decode_header_for(buf, buf_len, P9_RSTAT,
                                      &sz, &tg, &body_off, &body_end)
    if rc != 0:
        return cast[int64](rc)
    if body_off + 2 > body_end:
        return cast[int64](-2)
    outer_lo: uint64 = cast[uint64](buf[body_off])
    outer_hi: uint64 = cast[uint64](buf[body_off + 1])
    outer: uint64 = outer_lo | (outer_hi << 8)
    body_off = body_off + 2
    if body_off + outer != body_end:
        return cast[int64](-2)
    stat_bytes: int64 = p9_decode_stat(buf, body_end, body_off,
                                       out_stat_type, out_dev,
                                       out_qtype, out_qvers, out_qpath,
                                       out_mode, out_atime, out_mtime,
                                       out_length,
                                       out_name, out_name_len,
                                       out_uid, out_uid_len,
                                       out_gid, out_gid_len,
                                       out_muid, out_muid_len)
    if stat_bytes < 0:
        return cast[int64](-2)
    if body_off + cast[uint64](stat_bytes) != body_end:
        return cast[int64](-2)
    out_tag[0] = tg
    return cast[int64](sz)


# -- Twstat / Rwstat ---------------------------------------------------------
#
# Wire layout for Twstat:
#   size[4] type[1]=126 tag[2] fid[4] stat[n]
# where `stat[n]` is again the outer-length-prefixed wrapper used in
# Rstat. Encoding/decoding mirrors Rstat exactly.

def p9_emit_twstat(c: Ptr[P9Cursor], tag: uint16, fid: uint32,
                   stat_type: uint16, dev: uint32,
                   qtype: uint8, qvers: uint32, qpath: uint64,
                   mode: uint32, atime: uint32, mtime: uint32,
                   length: uint64,
                   name: Ptr[uint8], name_len: uint64,
                   uid: Ptr[uint8], uid_len: uint64,
                   gid: Ptr[uint8], gid_len: uint64,
                   muid: Ptr[uint8], muid_len: uint64) -> int32:
    rc: int32 = _p9_header_begin(c, P9_TWSTAT, tag)
    if rc < 0:
        return rc
    rc = _p9_put_u32(c, fid)
    if rc != 0:
        return rc
    outer_pos: uint64 = c[0].pos
    rc = _p9_put_u16(c, 0)
    if rc != 0:
        return rc
    stat_bytes: int32 = p9_emit_stat(c, stat_type, dev,
                                     qtype, qvers, qpath, mode,
                                     atime, mtime, length,
                                     name, name_len,
                                     uid, uid_len,
                                     gid, gid_len,
                                     muid, muid_len)
    if stat_bytes < 0:
        return stat_bytes
    n: uint64 = cast[uint64](stat_bytes)
    if n > 0xFFFF:
        c[0].err = -2
        return -2
    c[0].buf[outer_pos]     = cast[uint8](n & 0xFF)
    c[0].buf[outer_pos + 1] = cast[uint8]((n >> 8) & 0xFF)
    return _p9_header_finish(c)


def p9_emit_rwstat(c: Ptr[P9Cursor], tag: uint16) -> int32:
    rc: int32 = _p9_header_begin(c, P9_RWSTAT, tag)
    if rc < 0:
        return rc
    return _p9_header_finish(c)


def p9_decode_twstat(buf: Ptr[uint8], buf_len: uint64,
                     out_tag: Ptr[uint16], out_fid: Ptr[uint32],
                     out_stat_type: Ptr[uint16], out_dev: Ptr[uint32],
                     out_qtype: Ptr[uint8], out_qvers: Ptr[uint32],
                     out_qpath: Ptr[uint64],
                     out_mode: Ptr[uint32],
                     out_atime: Ptr[uint32], out_mtime: Ptr[uint32],
                     out_length: Ptr[uint64],
                     out_name: Ptr[Ptr[uint8]], out_name_len: Ptr[uint64],
                     out_uid: Ptr[Ptr[uint8]], out_uid_len: Ptr[uint64],
                     out_gid: Ptr[Ptr[uint8]], out_gid_len: Ptr[uint64],
                     out_muid: Ptr[Ptr[uint8]],
                     out_muid_len: Ptr[uint64]) -> int64:
    sz: uint32 = 0
    tg: uint16 = 0
    body_off: uint64 = 0
    body_end: uint64 = 0
    rc: int32 = _p9_decode_header_for(buf, buf_len, P9_TWSTAT,
                                      &sz, &tg, &body_off, &body_end)
    if rc != 0:
        return cast[int64](rc)
    rc = _p9_get_u32(buf, body_end, body_off, out_fid)
    if rc != 0:
        return cast[int64](-2)
    body_off = body_off + 4
    if body_off + 2 > body_end:
        return cast[int64](-2)
    outer_lo: uint64 = cast[uint64](buf[body_off])
    outer_hi: uint64 = cast[uint64](buf[body_off + 1])
    outer: uint64 = outer_lo | (outer_hi << 8)
    body_off = body_off + 2
    if body_off + outer != body_end:
        return cast[int64](-2)
    stat_bytes: int64 = p9_decode_stat(buf, body_end, body_off,
                                       out_stat_type, out_dev,
                                       out_qtype, out_qvers, out_qpath,
                                       out_mode, out_atime, out_mtime,
                                       out_length,
                                       out_name, out_name_len,
                                       out_uid, out_uid_len,
                                       out_gid, out_gid_len,
                                       out_muid, out_muid_len)
    if stat_bytes < 0:
        return cast[int64](-2)
    if body_off + cast[uint64](stat_bytes) != body_end:
        return cast[int64](-2)
    out_tag[0] = tg
    return cast[int64](sz)


def p9_decode_rwstat(buf: Ptr[uint8], buf_len: uint64,
                     out_tag: Ptr[uint16]) -> int64:
    sz: uint32 = 0
    tg: uint16 = 0
    body_off: uint64 = 0
    body_end: uint64 = 0
    rc: int32 = _p9_decode_header_for(buf, buf_len, P9_RWSTAT,
                                      &sz, &tg, &body_off, &body_end)
    if rc != 0:
        return cast[int64](rc)
    if body_off != body_end:
        return cast[int64](-2)
    out_tag[0] = tg
    return cast[int64](sz)
