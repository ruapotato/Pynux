# -- Tflush / Rflush ---------------------------------------------------------

def p9_emit_tflush(c: Ptr[P9Cursor], tag: uint16, oldtag: uint16) -> int32:
    rc: int32 = _p9_header_begin(c, P9_TFLUSH, tag)
    if rc < 0:
        return rc
    rc = _p9_put_u16(c, oldtag)
    if rc != 0:
        return rc
    return _p9_header_finish(c)


def p9_emit_rflush(c: Ptr[P9Cursor], tag: uint16) -> int32:
    rc: int32 = _p9_header_begin(c, P9_RFLUSH, tag)
    if rc < 0:
        return rc
    return _p9_header_finish(c)


def p9_decode_tflush(buf: Ptr[uint8], buf_len: uint64,
                     out_tag: Ptr[uint16],
                     out_oldtag: Ptr[uint16]) -> int64:
    sz: uint32 = 0
    tg: uint16 = 0
    body_off: uint64 = 0
    body_end: uint64 = 0
    rc: int32 = _p9_decode_header_for(buf, buf_len, P9_TFLUSH,
                                      &sz, &tg, &body_off, &body_end)
    if rc != 0:
        return cast[int64](rc)
    rc = _p9_get_u16(buf, body_end, body_off, out_oldtag)
    if rc != 0:
        return cast[int64](-2)
    body_off = body_off + 2
    if body_off != body_end:
        return cast[int64](-2)
    out_tag[0] = tg
    return cast[int64](sz)


def p9_decode_rflush(buf: Ptr[uint8], buf_len: uint64,
                     out_tag: Ptr[uint16]) -> int64:
    sz: uint32 = 0
    tg: uint16 = 0
    body_off: uint64 = 0
    body_end: uint64 = 0
    rc: int32 = _p9_decode_header_for(buf, buf_len, P9_RFLUSH,
                                      &sz, &tg, &body_off, &body_end)
    if rc != 0:
        return cast[int64](rc)
    if body_off != body_end:
        return cast[int64](-2)
    out_tag[0] = tg
    return cast[int64](sz)


# -- Twalk / Rwalk -----------------------------------------------------------
#
# The Twalk wname array and the Rwalk wqid array are caller-supplied as
# parallel ptr+len arrays (the codec is allocation-free; the caller owns
# the storage). Twalk caps at 16 names; Rwalk caps at 16 qids.

def p9_emit_twalk(c: Ptr[P9Cursor], tag: uint16,
                  fid: uint32, newfid: uint32, nwname: uint16,
                  wnames: Ptr[Ptr[uint8]],
                  wname_lens: Ptr[uint64]) -> int32:
    if cast[uint64](nwname) > P9_MAX_WELEM:
        return -3
    rc: int32 = _p9_header_begin(c, P9_TWALK, tag)
    if rc < 0:
        return rc
    rc = _p9_put_u32(c, fid)
    if rc != 0:
        return rc
    rc = _p9_put_u32(c, newfid)
    if rc != 0:
        return rc
    rc = _p9_put_u16(c, nwname)
    if rc != 0:
        return rc
    i: uint64 = 0
    while i < cast[uint64](nwname):
        rc = _p9_put_string(c, wnames[i], wname_lens[i])
        if rc != 0:
            return rc
        i = i + 1
    return _p9_header_finish(c)


def p9_emit_rwalk(c: Ptr[P9Cursor], tag: uint16, nwqid: uint16,
                  qtypes: Ptr[uint8], qvers: Ptr[uint32],
                  qpaths: Ptr[uint64]) -> int32:
    if cast[uint64](nwqid) > P9_MAX_WELEM:
        return -3
    rc: int32 = _p9_header_begin(c, P9_RWALK, tag)
    if rc < 0:
        return rc
    rc = _p9_put_u16(c, nwqid)
    if rc != 0:
        return rc
    i: uint64 = 0
    while i < cast[uint64](nwqid):
        rc = _p9_put_qid(c, qtypes[i], qvers[i], qpaths[i])
        if rc != 0:
            return rc
        i = i + 1
    return _p9_header_finish(c)


def p9_decode_twalk(buf: Ptr[uint8], buf_len: uint64,
                    out_tag: Ptr[uint16],
                    out_fid: Ptr[uint32], out_newfid: Ptr[uint32],
                    out_nwname: Ptr[uint16],
                    out_wnames: Ptr[Ptr[uint8]],
                    out_wname_lens: Ptr[uint64]) -> int64:
    sz: uint32 = 0
    tg: uint16 = 0
    body_off: uint64 = 0
    body_end: uint64 = 0
    rc: int32 = _p9_decode_header_for(buf, buf_len, P9_TWALK,
                                      &sz, &tg, &body_off, &body_end)
    if rc != 0:
        return cast[int64](rc)
    rc = _p9_get_u32(buf, body_end, body_off, out_fid)
    if rc != 0:
        return cast[int64](-2)
    body_off = body_off + 4
    rc = _p9_get_u32(buf, body_end, body_off, out_newfid)
    if rc != 0:
        return cast[int64](-2)
    body_off = body_off + 4
    nw: uint16 = 0
    rc = _p9_get_u16(buf, body_end, body_off, &nw)
    if rc != 0:
        return cast[int64](-2)
    body_off = body_off + 2
    if cast[uint64](nw) > P9_MAX_WELEM:
        return cast[int64](-2)
    i: uint64 = 0
    while i < cast[uint64](nw):
        n: int64 = _p9_get_string(buf, body_end, body_off,
                                  &out_wnames[i], &out_wname_lens[i])
        if n < 0:
            return cast[int64](-2)
        body_off = body_off + cast[uint64](n)
        i = i + 1
    if body_off != body_end:
        return cast[int64](-2)
    out_tag[0] = tg
    out_nwname[0] = nw
    return cast[int64](sz)


def p9_decode_rwalk(buf: Ptr[uint8], buf_len: uint64,
                    out_tag: Ptr[uint16], out_nwqid: Ptr[uint16],
                    out_qtypes: Ptr[uint8], out_qvers: Ptr[uint32],
                    out_qpaths: Ptr[uint64]) -> int64:
    sz: uint32 = 0
    tg: uint16 = 0
    body_off: uint64 = 0
    body_end: uint64 = 0
    rc: int32 = _p9_decode_header_for(buf, buf_len, P9_RWALK,
                                      &sz, &tg, &body_off, &body_end)
    if rc != 0:
        return cast[int64](rc)
    nq: uint16 = 0
    rc = _p9_get_u16(buf, body_end, body_off, &nq)
    if rc != 0:
        return cast[int64](-2)
    body_off = body_off + 2
    if cast[uint64](nq) > P9_MAX_WELEM:
        return cast[int64](-2)
    i: uint64 = 0
    while i < cast[uint64](nq):
        if _p9_get_qid(buf, body_end, body_off,
                       &out_qtypes[i], &out_qvers[i],
                       &out_qpaths[i]) < 0:
            return cast[int64](-2)
        body_off = body_off + 13
        i = i + 1
    if body_off != body_end:
        return cast[int64](-2)
    out_tag[0] = tg
    out_nwqid[0] = nq
    return cast[int64](sz)


