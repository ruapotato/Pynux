# tests/test_hamUI_phase1.ad
#
# hamUI Phase 1 regression. Exercises the /dev/wsys/1/* AI-debug
# surface from a single userland process:
#
#   1. Read /dev/wsys/1/kind      — assert exactly "text\n"
#   2. Read /dev/wsys/1/geometry  — assert "0 0 80 24\n"
#   3. Read /dev/wsys/1/pid       — assert it's a small positive int
#   4. Read /dev/wsys/1/uid       — assert it's "1\n" (hostowner default)
#   5. Read /dev/wsys              — assert "1\n" (one window in Phase 1)
#   6. Write a marker via /dev/wsys/1/cmd, then read /dev/wsys/1/text
#      — the marker bytes are exactly what we wrote (since `cmd`
#      injection feeds devcons_read which hamsh's readline already
#      drains; but our fixture isn't a shell — we just verify the
#      write side succeeds without an error). Reading /dev/wsys/1/text
#      should contain the [test_hamUI_phase1] banner printed via
#      sys_write(1,...).
#   7. Read /dev/wsys/1/ns        — assert it's a non-empty blob
#      (the boot binds populate the root Pgrp).
#
# This fixture proves the FILE TREE is wired and the I/O tee works.
# The end-to-end cmd-injection-becomes-readline test lives in the
# .sh driver (which pipes commands to hamsh and greps for INJECT_OK
# in the captured serial log).
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_hamUI_phase1.ad -o build/user/test_hamUI_phase1.elf

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def _bytes_eq(buf: Ptr[uint8], n: uint64, needle: Ptr[uint8]) -> int32:
    # buf[0..n] vs. needle (NUL-terminated). 1 on exact match.
    nn: uint64 = strlen(needle)
    if n != nn:
        return 0
    i: uint64 = 0
    while i < nn:
        if buf[i] != needle[i]:
            return 0
        i = i + 1
    return 1


def _bytes_contains(buf: Ptr[uint8], n: uint64, needle: Ptr[uint8]) -> int32:
    # 1 if `needle` (NUL-terminated) appears anywhere in buf[0..n].
    nn: uint64 = strlen(needle)
    if nn == 0:
        return 1
    if nn > n:
        return 0
    limit: uint64 = n - nn
    i: uint64 = 0
    while i <= limit:
        j: uint64 = 0
        ok: int32 = 1
        while j < nn:
            if buf[i + j] != needle[j]:
                ok = 0
                # don't break — keep loop simple for the codegen
            j = j + 1
        if ok != 0:
            return 1
        i = i + 1
    return 0


def _is_decimal(buf: Ptr[uint8], n: uint64) -> int32:
    # 1 iff n >= 2 (at least one digit + '\n') AND buf[0..n-1] are all
    # ASCII digits AND buf[n-1] == '\n'.
    if n < 2:
        return 0
    if buf[n - 1] != 10:
        return 0
    i: uint64 = 0
    while i < n - 1:
        c: uint8 = buf[i]
        if c < 48 or c > 57:
            return 0
        i = i + 1
    return 1


def _read_path(path: Ptr[char], buf: Ptr[uint8], cap: uint64) -> int64:
    # Read up to `cap` bytes from `path` into `buf`. Returns bytes read
    # (>=0) or -1 on open failure.
    fd: int32 = sys_open(path)
    if fd < 0:
        return -1
    # Drain in a small loop so a short first read still gathers the
    # whole snapshot (devwsys returns one window per read; the next
    # read at the bumped fd_pos reports EOF).
    total: uint64 = 0
    while total < cap:
        n: int64 = sys_read(fd, &buf[total], cap - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    return cast[int64](total)


def main() -> int32:
    write_str(1, "[test_hamUI_phase1] start\n")
    fails: int32 = 0

    # ---- 1. /dev/wsys/1/kind == "text\n" ----
    buf_kind: Array[64, uint8]
    nk: int64 = _read_path("/dev/wsys/1/kind", &buf_kind[0], 64)
    if nk <= 0:
        write_str(1, "[test_hamUI_phase1] kind read FAIL\n")
        fails = fails + 1
    elif _bytes_eq(&buf_kind[0], cast[uint64](nk), "text\n") == 0:
        write_str(1, "[test_hamUI_phase1] kind != text FAIL\n")
        fails = fails + 1
    else:
        write_str(1, "[test_hamUI_phase1] kind_ok=1\n")

    # ---- 2. /dev/wsys/1/geometry == "0 0 80 24\n" ----
    buf_geom: Array[64, uint8]
    ng: int64 = _read_path("/dev/wsys/1/geometry", &buf_geom[0], 64)
    if ng <= 0:
        write_str(1, "[test_hamUI_phase1] geometry read FAIL\n")
        fails = fails + 1
    elif _bytes_eq(&buf_geom[0], cast[uint64](ng), "0 0 80 24\n") == 0:
        write_str(1, "[test_hamUI_phase1] geometry shape FAIL\n")
        fails = fails + 1
    else:
        write_str(1, "[test_hamUI_phase1] geometry_ok=1\n")

    # ---- 3. /dev/wsys/1/pid is "<decimal>\n" ----
    buf_pid: Array[64, uint8]
    np: int64 = _read_path("/dev/wsys/1/pid", &buf_pid[0], 64)
    if np <= 0:
        write_str(1, "[test_hamUI_phase1] pid read FAIL\n")
        fails = fails + 1
    elif _is_decimal(&buf_pid[0], cast[uint64](np)) == 0:
        write_str(1, "[test_hamUI_phase1] pid not decimal FAIL\n")
        fails = fails + 1
    else:
        write_str(1, "[test_hamUI_phase1] pid=")
        sys_write(1, &buf_pid[0], cast[uint64](np))
        write_str(1, "[test_hamUI_phase1] pid_ok=1\n")

    # ---- 4. /dev/wsys/1/uid is "1\n" (hostowner on the test bench) ----
    buf_uid: Array[64, uint8]
    nu: int64 = _read_path("/dev/wsys/1/uid", &buf_uid[0], 64)
    if nu <= 0:
        write_str(1, "[test_hamUI_phase1] uid read FAIL\n")
        fails = fails + 1
    elif _bytes_eq(&buf_uid[0], cast[uint64](nu), "1\n") == 0:
        write_str(1, "[test_hamUI_phase1] uid != 1 FAIL\n")
        fails = fails + 1
    else:
        write_str(1, "[test_hamUI_phase1] uid_ok=1\n")

    # ---- 5. /dev/wsys starts with the wid 1 line ----
    # Phase 2 grew the listing into the per-spec format
    #   "<wid> active text uid=<u> pid=<p> hamsh\n"
    # for each active wid. We check that the listing begins with
    # "1 active" — wid 1 (the foreground hamsh) is always live in
    # this fixture's universe, and the substring proves the cdev
    # backend rendered the per-spec shape rather than the Phase 1
    # bare-digit format.
    buf_list: Array[256, uint8]
    nl: int64 = _read_path("/dev/wsys", &buf_list[0], 256)
    if nl <= 0:
        write_str(1, "[test_hamUI_phase1] wsys list read FAIL\n")
        fails = fails + 1
    elif _bytes_contains(&buf_list[0], cast[uint64](nl),
                         "1 active text uid=") == 0:
        write_str(1, "[test_hamUI_phase1] wsys listing shape FAIL\n")
        fails = fails + 1
    else:
        write_str(1, "[test_hamUI_phase1] listing_ok=1\n")

    # ---- 6. /dev/wsys/1/cmd write side ----
    # Drop a benign marker into the cmd queue; the next devcons_read
    # will pop it. We don't drain it back here (this fixture isn't a
    # shell) — the .sh driver verifies the readline side. We just
    # assert the write doesn't error.
    wfd: int32 = sys_open_write("/dev/wsys/1/cmd")
    if wfd < 0:
        write_str(1, "[test_hamUI_phase1] cmd open_write FAIL\n")
        fails = fails + 1
    else:
        nw: int64 = sys_write(wfd, "echo HAMUI_CMD_OK\n", 18)
        sys_close(wfd)
        if nw < 18:
            write_str(1, "[test_hamUI_phase1] cmd short-write FAIL\n")
            fails = fails + 1
        else:
            write_str(1, "[test_hamUI_phase1] cmd_write_ok=1\n")

    # ---- 7. /dev/wsys/1/text contains our banner ----
    # Every byte we wrote to fd 1 above flowed through devcons_write
    # (the ambient stdio binding) and got tee'd into the wsys text
    # ring. So the text ring must contain "[test_hamUI_phase1]".
    buf_text: Array[4096, uint8]
    nt: int64 = _read_path("/dev/wsys/1/text", &buf_text[0], 4096)
    if nt <= 0:
        write_str(1, "[test_hamUI_phase1] text read FAIL\n")
        fails = fails + 1
    elif _bytes_contains(&buf_text[0], cast[uint64](nt),
                         "[test_hamUI_phase1]") == 0:
        write_str(1, "[test_hamUI_phase1] text tee MISS FAIL\n")
        fails = fails + 1
    else:
        write_str(1, "[test_hamUI_phase1] text_tee_ok=1\n")

    # ---- 8. /dev/wsys/1/ns is non-empty ----
    buf_ns: Array[4096, uint8]
    nns: int64 = _read_path("/dev/wsys/1/ns", &buf_ns[0], 4096)
    if nns <= 0:
        write_str(1, "[test_hamUI_phase1] ns empty FAIL\n")
        fails = fails + 1
    else:
        write_str(1, "[test_hamUI_phase1] ns_ok=1\n")

    if fails != 0:
        write_str(1, "[test_hamUI_phase1] FAIL\n")
        return 1
    # Final PASS marker the .sh driver greps for.
    write_str(1, "[test_hamUI_phase1] PASS\n")
    write_str(1, "[test_hamUI_phase1] done\n")
    return 0
