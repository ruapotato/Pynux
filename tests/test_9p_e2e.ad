# tests/test_9p_e2e.ad
#
# V4.1 — end-to-end Plan-9 loop. THE TEST that the user-space ↔ kernel
# 9P loop closes for real:
#
#     userspace fixture          kernel                userspace server
#     ─────────────────          ──────                ─────────────────
#  1. sys_pipe(c2s)  ─────────────────────────────────►  fd 0 (T-msg in)
#  2. sys_pipe(s2c)  ─────────────────────────────────►  fd 1 (R-msg out)
#  3. sys_spawn("/bin/p9srv_demo", stdin=c2s_rfd, stdout=s2c_wfd)
#  4. sys_srv_post("p9e2e", c2s_wfd)
#  5. fd = sys_srv_open("p9e2e")
#  6. sys_mount(fd, -1, "/n/demo", MREPL, "p9rx:<s2c_rfd>:") ──┐
#                                          │                  │
#                                          ▼                  │
#                            kernel _p9_send/_p9_recv ◄───────┘
#                            (Tversion + Tattach over the pipe pair)
#  7. h = sys_open("/n/demo/hello")
#                                          │
#                                          ▼
#                            kernel walks + opens via the same pipes
#  8. n = sys_read(h, buf, 32)
#                                          │
#                                          ▼
#                            kernel issues Tread, gets Rread back
#  9. assert buf == "p9demo says hi\n"
# 10. sys_close(h)            kernel issues Tclunk
# 11. sys_waitpid             reap the server
#
# THE PIPE-PAIR TRANSPORT
# -----------------------
# Hamnix pipes are unidirectional (see fs/pipe.ad — every Pipe has a
# `readers` and `writers` refcount, and `pipe_read`/`pipe_write` operate
# on a single ring buffer). A bidirectional 9P transport therefore needs
# TWO pipe slots: one for the T-direction (kernel→server) and one for
# the R-direction (server→kernel). sys_mount(2) only carries ONE srvfd,
# so we smuggle the rx-side fd through the `spec` argument as a magic
# prefix "p9rx:<fd>:" — the in-kernel 9P client (sys/src/9/port/9p_client.ad,
# _parse_rx_prefix) strips and consumes it before Tversion runs. The
# rest of `spec` becomes the real 9P attach aname (which p9srv_demo
# ignores anyway).
#
# This keeps sys_mount(2)'s shape unchanged and avoids touching the
# stable syschan.ad / chan.ad / devsrv.ad surface. Once a real
# bidirectional transport (socketpair / network connection) lands, the
# prefix becomes optional and the same fixture works against either.
#
# MARKERS grepped by scripts/test_9p_e2e.sh:
#
#   [p9_e2e] start
#   [p9_e2e] pipes OK
#   [p9_e2e] spawn OK
#   [p9_e2e] srv_post OK
#   [p9_e2e] srv_open OK
#   [p9_e2e] mount OK
#   [p9_e2e] open OK
#   [p9_e2e] read=15
#   [p9_e2e] payload OK
#   [p9_e2e] close OK
#   [p9_e2e] PASS

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_pipe(fds: Ptr[int32]) -> int32
extern def sys_waitpid(pid: uint64) -> int64
extern def sys_kill(pid: int32, sig: int32) -> int32
extern def sys_exit(code: uint64)
extern def sys_srv_post(name: Ptr[char], srvfd: int32) -> int32
extern def sys_srv_open(name: Ptr[char]) -> int32
extern def sys_errstr(buf: Ptr[uint8], nbuf: uint64) -> int32
extern def sys_spawn(path: Ptr[char], argv: Ptr[uint64],
                     stdin_fd: int32, stdout_fd: int32,
                     envp: Ptr[uint64]) -> int32
extern def sys_mount(srvfd: int32, afd: int32, old: Ptr[char],
                     flag: int32, spec: Ptr[char]) -> int32

MREPL: int32 = 0
SIGKILL: int32 = 9

# Top-level scratch buffers (Adder nested-frame Array bug avoidance).
c2s_fds: Array[2, int32]
s2c_fds: Array[2, int32]
spawn_argv: Array[2, uint64]
read_buf: Array[64, uint8]
err_buf:  Array[128, uint8]
spec_buf: Array[32, uint8]      # holds "p9rx:<NN>:" + NUL
mount_path: Array[16, uint8]    # "/n/demo"
hello_path: Array[32, uint8]    # "/n/demo/hello"
srv_name:   Array[16, uint8]    # "p9e2e"

# Expected payload for /hello — "p9demo says hi\n" (15 bytes).
expected: Array[16, uint8]
EXPECTED_LEN: uint64 = 15


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def dump_errstr(label: Ptr[uint8]):
    sys_errstr(&err_buf[0], 128)
    write_str(1, label)
    write_str(1, &err_buf[0])
    write_str(1, "\n")


def write_dec(fd: int32, value: uint64):
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def fill_spec(rx_fd: int32):
    # Build "p9rx:<rx_fd>:" + NUL into spec_buf. Top-level Array so
    # the digits go where _parse_rx_prefix in 9p_client.ad expects.
    spec_buf[0] = 112    # 'p'
    spec_buf[1] = 57     # '9'
    spec_buf[2] = 114    # 'r'
    spec_buf[3] = 120    # 'x'
    spec_buf[4] = 58     # ':'
    # Decimal digits.
    pos: uint64 = 5
    v: uint64 = cast[uint64](rx_fd)
    if v == 0:
        spec_buf[pos] = 48                                # '0'
        pos = pos + 1
    else:
        digits: Array[8, uint8]
        n: uint64 = 0
        while v != 0:
            digits[n] = cast[uint8](v % 10) + 48
            v = v / 10
            n = n + 1
        while n > 0:
            n = n - 1
            spec_buf[pos] = digits[n]
            pos = pos + 1
    spec_buf[pos] = 58                                    # ':'
    spec_buf[pos + 1] = 0


def init_expected():
    # "p9demo says hi\n" — same bytes user/p9srv_demo.ad emits.
    expected[0]  = 112
    expected[1]  = 57
    expected[2]  = 100
    expected[3]  = 101
    expected[4]  = 109
    expected[5]  = 111
    expected[6]  = 32
    expected[7]  = 115
    expected[8]  = 97
    expected[9]  = 121
    expected[10] = 115
    expected[11] = 32
    expected[12] = 104
    expected[13] = 105
    expected[14] = 10


def init_paths():
    # "/p9demo" — mount point. We deliberately pick a path NOT under
    # /n/, /srv/, /proc/, or any other path the userspace `init`
    # recipe (user/init.ad) has bound to a `#X` device-alias. Those
    # binds get applied by resolve_path BEFORE _try_open_p9 runs, so
    # mounting at /n/demo would surface as "#/demo/<...>" by the time
    # vfs_open sees it — and #/ only resolves to the bare empty-dir
    # slot in fs/vfs.ad's _open_hash_alias, not to our mount entry.
    # Plain-old /p9demo dodges every active bind.
    mount_path[0] = 47    # '/'
    mount_path[1] = 112   # 'p'
    mount_path[2] = 57    # '9'
    mount_path[3] = 100   # 'd'
    mount_path[4] = 101   # 'e'
    mount_path[5] = 109   # 'm'
    mount_path[6] = 111   # 'o'
    mount_path[7] = 0
    # "/p9demo/hello"
    hello_path[0]  = 47
    hello_path[1]  = 112
    hello_path[2]  = 57
    hello_path[3]  = 100
    hello_path[4]  = 101
    hello_path[5]  = 109
    hello_path[6]  = 111
    hello_path[7]  = 47
    hello_path[8]  = 104
    hello_path[9]  = 101
    hello_path[10] = 108
    hello_path[11] = 108
    hello_path[12] = 111
    hello_path[13] = 0
    # "p9e2e"
    srv_name[0] = 112
    srv_name[1] = 57
    srv_name[2] = 101
    srv_name[3] = 50
    srv_name[4] = 101
    srv_name[5] = 0


def main() -> int32:
    init_expected()
    init_paths()
    write_str(1, "[p9_e2e] start\n")

    # 1. Pipes. c2s (client→server, T-msgs) and s2c (server→client, R-msgs).
    if sys_pipe(&c2s_fds[0]) < 0:
        dump_errstr("[p9_e2e] FAIL: sys_pipe c2s errstr=")
        return 1
    if sys_pipe(&s2c_fds[0]) < 0:
        dump_errstr("[p9_e2e] FAIL: sys_pipe s2c errstr=")
        return 2
    c2s_rfd: int32 = c2s_fds[0]                       # server reads T
    c2s_wfd: int32 = c2s_fds[1]                       # kernel writes T
    s2c_rfd: int32 = s2c_fds[0]                       # kernel reads R
    s2c_wfd: int32 = s2c_fds[1]                       # server writes R
    write_str(1, "[p9_e2e] pipes OK\n")

    # 2. Spawn /bin/p9srv_demo. sys_spawn dup's c2s_rfd → child fd 0 and
    #    s2c_wfd → child fd 1 BEFORE the child runs; the parent's copies
    #    must be closed afterwards so the child's eventual EOF-on-stdin
    #    is reachable when we tear down.
    spawn_argv[0] = cast[uint64](&"/bin/p9srv_demo"[0])
    spawn_argv[1] = 0
    pid: int32 = sys_spawn("/bin/p9srv_demo", &spawn_argv[0],
                           c2s_rfd, s2c_wfd, cast[Ptr[uint64]](0))
    if pid < 0:
        dump_errstr("[p9_e2e] FAIL: sys_spawn errstr=")
        return 3
    write_str(1, "[p9_e2e] spawn OK\n")

    # Drop the parent-side inherited ends — the child has its own dups.
    sys_close(c2s_rfd)
    sys_close(s2c_wfd)

    # 3. Post c2s_wfd at /srv/p9e2e. The kernel client will pipe_write
    #    T-msgs through this fd's pipe slot; the rx side (s2c_rfd) is
    #    threaded through the mount() spec below.
    if sys_srv_post(cast[Ptr[char]](&srv_name[0]), c2s_wfd) < 0:
        dump_errstr("[p9_e2e] FAIL: sys_srv_post errstr=")
        return 4
    write_str(1, "[p9_e2e] srv_post OK\n")

    # 4. sys_srv_open returns a NEW fd in our table that's a dup of the
    #    posted c2s_wfd (pipe-writer side, slot for c2s). Mount uses this.
    srv_fd: int32 = sys_srv_open(cast[Ptr[char]](&srv_name[0]))
    if srv_fd < 0:
        dump_errstr("[p9_e2e] FAIL: sys_srv_open errstr=")
        return 5
    write_str(1, "[p9_e2e] srv_open OK\n")

    # 5. Mount. spec encodes the rx-side srvfd so the in-kernel 9P
    #    client can pipe_read R-msgs from the correct slot.
    fill_spec(s2c_rfd)
    rc: int32 = sys_mount(srv_fd, -1,
                          cast[Ptr[char]](&mount_path[0]),
                          MREPL,
                          cast[Ptr[char]](&spec_buf[0]))
    if rc < 0:
        dump_errstr("[p9_e2e] FAIL: sys_mount errstr=")
        return 6
    write_str(1, "[p9_e2e] mount OK\n")

    # 6. Open /n/demo/hello. Routes through fs/vfs.ad's _try_open_p9
    #    which walks + opens via the in-kernel 9P client. Every wire
    #    byte goes through the new _p9_send/_p9_recv pipe path.
    h: int32 = sys_open(cast[Ptr[char]](&hello_path[0]))
    if h < 0:
        dump_errstr("[p9_e2e] FAIL: sys_open /p9demo/hello errstr=")
        return 7
    write_str(1, "[p9_e2e] open OK\n")

    # 7. Read. The kernel client issues Tread and copies Rread payload
    #    into our buffer. /hello carries "p9demo says hi\n" (15 bytes).
    n: int64 = sys_read(h, &read_buf[0], 32)
    if n < 0:
        dump_errstr("[p9_e2e] FAIL: sys_read errstr=")
        sys_close(h)
        return 8
    write_str(1, "[p9_e2e] read=")
    write_dec(1, cast[uint64](n))
    write_str(1, "\n")
    if cast[uint64](n) != EXPECTED_LEN:
        write_str(1, "[p9_e2e] FAIL: read count mismatch\n")
        sys_close(h)
        return 9

    # 8. Byte-for-byte payload check.
    i: uint64 = 0
    while i < EXPECTED_LEN:
        if read_buf[i] != expected[i]:
            write_str(1, "[p9_e2e] FAIL: payload mismatch at i=")
            write_dec(1, i)
            write_str(1, "\n")
            sys_close(h)
            return 10
        i = i + 1
    write_str(1, "[p9_e2e] payload OK\n")

    # 9. Close the kernel-client fd. vfs_close routes FD_P9_MARK through
    #    p9c_clunk which issues Tclunk over the same pipes.
    if sys_close(h) < 0:
        dump_errstr("[p9_e2e] FAIL: sys_close errstr=")
        return 11
    write_str(1, "[p9_e2e] close OK\n")

    # 10. Tear down. Close the srv_open dup and the original c2s_wfd so
    #     the server sees EOF on its stdin. Closing both writers (parent
    #     side) drops the pipe's writer count to 1 (the child's own
    #     unused inherited fd 0 doesn't count — it's a reader).
    sys_close(srv_fd)
    sys_close(c2s_wfd)
    # Also close our rx end so the server's eventual write-on-broken-pipe
    # is visible too (defensive — the server should exit on stdin EOF
    # first).
    sys_close(s2c_rfd)

    # Best-effort: signal the child so we don't hang waiting on it if
    # somehow EOF didn't propagate. SIGKILL is the safe choice — no
    # handler in the demo, terminates immediately.
    sys_kill(pid, SIGKILL)
    sys_waitpid(cast[uint64](pid))

    write_str(1, "[p9_e2e] PASS\n")
    return 0
