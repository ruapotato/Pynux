# tests/test_p9mount.ad
#
# Phase C / M16.107 regression: exercise the Plan 9 namespace
# primitives bind (257), mount (258), unmount (259). The first two
# get a happy-path bind + open + close + unbind; the third proves
# mount() accepts an srvfd-shape call without erroring (the actual
# 9P transactions aren't real yet — Phase D scope).
#
# Contract markers grepped by scripts/test_p9mount.sh:
#
#   [p9mount] start
#   [p9mount] bind /sysroot -> /etc ok
#   [p9mount] open /sysroot/motd ok fd=<n>
#   [p9mount] read /sysroot/motd ok (got <n> bytes)
#   [p9mount] unmount /sysroot ok
#   [p9mount] open /sysroot/motd after unmount fails (expected)
#   [p9mount] mount srvfd ok
#   [p9mount] unmount srv ok
#   [p9mount] PASS
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_p9mount.ad -o build/user/test_p9mount.elf
#
# Run via scripts/test_p9mount.sh.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def syscall6(nr: uint64, a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64

SYS_BIND:    uint64 = 257
SYS_MOUNT:   uint64 = 258
SYS_UNMOUNT: uint64 = 259

# Plan 9 bind/mount flag bits. We only use MREPL (0) at this
# milestone — union mounts (MBEFORE / MAFTER) are recorded but
# not honoured.
MREPL:   int32 = 0


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def write_dec(fd: int32, value: uint64):
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def main() -> int32:
    write_str(1, "[p9mount] start\n")

    # ----------------------------------------------------------------
    # 1) bind /sysroot -> /etc. After this, opens of /sysroot/<x>
    # resolve to /etc/<x>. The kernel canonicalises both arguments
    # before storing.
    rc: int64 = syscall6(SYS_BIND,
                         cast[uint64](&"/sysroot"[0]),
                         cast[uint64](&"/etc"[0]),
                         cast[uint64](MREPL), 0, 0, 0)
    if rc != 0:
        write_str(1, "[p9mount] FAIL: bind returned ")
        write_dec(1, cast[uint64](rc))
        write_str(1, "\n")
        return 1
    write_str(1, "[p9mount] bind /sysroot -> /etc ok\n")

    # ----------------------------------------------------------------
    # 2) open /sysroot/motd via the regular SYS_OPEN path. The mount-
    # table prefix rewrite in resolve_path turns this into a lookup
    # of /etc/motd against the cpio archive, which carries the file
    # baked at build_initramfs.py time. A successful open here is
    # the proof that the bind is wired through resolve_path.
    fd: int32 = sys_open("/sysroot/motd")
    if fd < 0:
        write_str(1, "[p9mount] FAIL: open /sysroot/motd returned ")
        write_dec(1, cast[uint64](fd))
        write_str(1, "\n")
        return 2
    write_str(1, "[p9mount] open /sysroot/motd ok fd=")
    write_dec(1, cast[uint64](fd))
    write_str(1, "\n")

    # ----------------------------------------------------------------
    # 3) read a few bytes — purely sanity that the fd resolves to a
    # real backing file (vs. a synthetic /dev marker that would
    # happily open but return weird semantics on read).
    buf: Array[64, uint8]
    nread: int64 = sys_read(fd, &buf[0], 64)
    if nread <= 0:
        write_str(1, "[p9mount] FAIL: read returned ")
        write_dec(1, cast[uint64](nread))
        write_str(1, "\n")
        sys_close(fd)
        return 3
    write_str(1, "[p9mount] read /sysroot/motd ok (got ")
    write_dec(1, cast[uint64](nread))
    write_str(1, " bytes)\n")
    sys_close(fd)

    # ----------------------------------------------------------------
    # 4) unmount /sysroot. NULL `new` removes every binding visible
    # at the named path. After this, the prefix rewrite is gone and
    # subsequent opens of /sysroot/<x> should fail.
    rc = syscall6(SYS_UNMOUNT,
                  0,
                  cast[uint64](&"/sysroot"[0]),
                  0, 0, 0, 0)
    if rc != 0:
        write_str(1, "[p9mount] FAIL: unmount returned ")
        write_dec(1, cast[uint64](rc))
        write_str(1, "\n")
        return 4
    write_str(1, "[p9mount] unmount /sysroot ok\n")

    # ----------------------------------------------------------------
    # 5) re-open /sysroot/motd — must now -ENOENT. The mount entry
    # is gone, the cpio archive doesn't ship a real /sysroot/, so the
    # lookup falls through to the not-found branch.
    fd2: int32 = sys_open("/sysroot/motd")
    if fd2 >= 0:
        write_str(1, "[p9mount] FAIL: open after unmount returned fd=")
        write_dec(1, cast[uint64](fd2))
        write_str(1, "\n")
        sys_close(fd2)
        return 5
    write_str(1, "[p9mount] open /sysroot/motd after unmount fails (expected)\n")

    # ----------------------------------------------------------------
    # 6) mount() shape. Phase C accepted any in-range srvfd because
    # the stub just stored the int. V1 (sys/src/9/port/p9_client.ad)
    # turns mount() into "Tversion + Tattach over the supplied fd"
    # — so a non-9P-speaking fd (like /etc/motd) MUST now return -1
    # rather than silently succeeding. We assert the rejection.
    # The kernel-side smoke responder lives in init/p9_smoke.ad and
    # runs at boot before this fixture even loads, so an in-kernel
    # PASS lands separately on the serial log; this user-side test
    # only validates that userland mount() of a bad fd surfaces the
    # error cleanly.
    sfd: int32 = sys_open("/etc/motd")
    if sfd < 0:
        write_str(1, "[p9mount] FAIL: open /etc/motd for srvfd returned ")
        write_dec(1, cast[uint64](sfd))
        write_str(1, "\n")
        return 6
    rc = syscall6(SYS_MOUNT,
                  cast[uint64](sfd),
                  cast[uint64](-1),       # afd = -1 (no auth)
                  cast[uint64](&"/srvmnt"[0]),
                  cast[uint64](MREPL),
                  cast[uint64](&""[0]),   # spec = ""
                  0)
    # V1: a non-9P fd MUST fail. Pre-V1 expected rc == 0 here.
    if rc == 0:
        write_str(1, "[p9mount] FAIL: V1 mount() should reject bad srvfd\n")
        sys_close(sfd)
        return 7
    write_str(1, "[p9mount] mount srvfd ok\n")
    sys_close(sfd)

    # 7) unmount the srv mount path. Even though the mount() above
    # failed, we attempt the unmount to ensure the failure path
    # didn't leave a stale entry — V1's do_mount rolls back the
    # mnttab entry on attach failure. The unmount MUST report "not
    # mounted" (rc != 0).
    rc = syscall6(SYS_UNMOUNT,
                  0,
                  cast[uint64](&"/srvmnt"[0]),
                  0, 0, 0, 0)
    if rc == 0:
        write_str(1, "[p9mount] FAIL: V1 unmount should report not-mounted\n")
        return 8
    write_str(1, "[p9mount] unmount srv ok\n")

    write_str(1, "[p9mount] PASS\n")
    return 0
