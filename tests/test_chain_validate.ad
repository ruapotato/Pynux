# A target unix time inside the certs' validity window
# (Jun 1 2026 00:00:00 UTC == 1780272000). Both certs run
# May 19 2026 .. May 16 2036.
NOW_GOOD: uint64 = 1780272000

# Past the not_after (May 16 2036 05:41:27 UTC = 2094529287);
# any value strictly greater is past expiry. Pick May 25 2036.
NOW_EXPIRED: uint64 = 2095286400


def main() -> int32:
    _wstr("[chain] start\n")

    # 0. Initialize OID tables + crypto runtime state.
    asn1_init_oids()
    p256_init()
    rsa_init()
    ecdsa_init()
    castore_init()
    _init_root()
    _init_leaf()

    # Plant the chain table: chain[0] = leaf only (root comes from the
    # CA store, not from the on-the-wire chain — typical TLS shape).
    chain_ptrs[0] = &leaf_der[0]
    chain_lens[0] = leaf_der_len

    # 1. Add the root to the CA store. Expect slot 0.
    slot: int32 = castore_add_root(&root_der[0], root_der_len)
    _check_eq_i32(slot, 0, "castore_add_root returns slot 0")
    _check_eq_i32(castore_count(), 1, "castore_count == 1 after add")

    # 2. Legitimate chain validation: expect 1.
    _wstr("[chain] case 1: legitimate chain (ecdsa verify ~5s)\n")
    rc: int32 = validate_cert_chain(&chain_ptrs[0], &chain_lens[0],
                                    cast[int32](1),
                                    "test.hamnix.local", NOW_GOOD)
    _check_eq_i32(rc, 1, "legitimate chain returns 1")

    # 3. Tamper test (a): flip one byte of the leaf signature. The
    # signature BIT STRING is the trailing ECDSA SEQUENCE; offset 360
    # is well inside the `r` INTEGER body (cert is 421 bytes total).
    saved_a: uint8 = leaf_der[360]
    leaf_der[360] = saved_a ^ 0x01
    _wstr("[chain] case (a): leaf sig bit-flipped\n")
    rc = validate_cert_chain(&chain_ptrs[0], &chain_lens[0],
                             cast[int32](1),
                             "test.hamnix.local", NOW_GOOD)
    _check_eq_i32(rc, 0, "(a) flipped leaf sig returns 0")
    leaf_der[360] = saved_a

    # 4. Tamper test (b): wrong host.
    _wstr("[chain] case (b): wrong host\n")
    rc = validate_cert_chain(&chain_ptrs[0], &chain_lens[0],
                             cast[int32](1),
                             "evil.hamnix.local", NOW_GOOD)
    _check_eq_i32(rc, 0, "(b) wrong host returns 0")

    # 5. Tamper test (c): now_unix past leaf.not_after.
    _wstr("[chain] case (c): past not_after\n")
    rc = validate_cert_chain(&chain_ptrs[0], &chain_lens[0],
                             cast[int32](1),
                             "test.hamnix.local", NOW_EXPIRED)
    _check_eq_i32(rc, 0, "(c) past not_after returns 0")

    # 6. Tamper test (d): remove the root from the CA store.
    castore_remove_all()
    _check_eq_i32(castore_count(), 0, "castore_count == 0 after remove_all")
    _wstr("[chain] case (d): no anchor in CA store\n")
    rc = validate_cert_chain(&chain_ptrs[0], &chain_lens[0],
                             cast[int32](1),
                             "test.hamnix.local", NOW_GOOD)
    _check_eq_i32(rc, 0, "(d) empty CA store returns 0")

    _wstr("[chain] failures=")
    _wdec(cast[uint64](fail_count))
    _wstr("\n")
    if fail_count == 0:
        _wstr("[chain] PASS\n")
        return 0
    _wstr("[chain] FAIL\n")
    return 1
