# tests/test_chain_validate.ad
#
# Chain-validation + CA-store + validity-window (V4) end-to-end regression.
# Boots an openssl-generated two-cert chain (leaf signed by a self-signed
# ECDSA-P256 CA root) and drives them through
# lib/x509/chain.ad::validate_cert_chain. Both certs were emitted as DER
# at build time and byte-dumped here — Adder top-level Array literals
# don't survive to the linked image (per memory/feedback_compiler_
# quirks.md), so we replay via an _init_*()-style runtime fill.
#
# CA root (CN=Hamnix Test CA, CA:TRUE, prime256v1) — 394 bytes.
# Leaf   (CN=test.hamnix.local, DNS SAN, signed by the root) — 421 bytes.
# Both certs are valid May 19 2026 .. May 16 2036; the fixture passes
# now_unix = 1780272000 (Jun 1 2026 00:00:00 UTC) — inside that window.
#
# Asserts (all pass = `[chain] PASS`):
#   (1) legitimate chain → validate_cert_chain returns 1
#   (a) flip one byte of the leaf signature → returns 0
#   (b) call with host "evil.hamnix.local" → returns 0
#   (c) call with now_unix past not_after → returns 0
#   (d) remove the root from the CA store → returns 0
#
# Driven by scripts/test_chain_validate.sh.

from lib.asn1.asn1 import (
    asn1_init_oids,
)
from lib.x509.x509 import (
    X509Cert,
    x509_parse,
)
from lib.ec.p256 import (
    p256_init,
)
from lib.rsa.rsa import (
    rsa_init,
)
from lib.ecdsa.ecdsa import (
    ecdsa_init,
)
from lib.x509.chain import (
    castore_init,
    castore_add_root,
    castore_remove_all,
    castore_count,
    validate_cert_chain,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)


# -- tiny printer ----------------------------------------------------------

def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _wstr(s: Ptr[uint8]):
    sys_write(1, s, _strlen(s))


def _wdec(value: uint64):
    if value == 0:
        sys_write(1, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(1, &out[0], i)


def _wdec_signed(value: int64):
    if value < 0:
        sys_write(1, "-", 1)
        _wdec(cast[uint64](-value))
        return
    _wdec(cast[uint64](value))


# -- failure aggregator ----------------------------------------------------

fail_count: int32 = 0


def _check_eq_i32(a: int32, b: int32, label: Ptr[uint8]):
    if a != b:
        _wstr("[chain] FAIL: ")
        _wstr(label)
        _wstr(" got=")
        _wdec_signed(cast[int64](a))
        _wstr(" want=")
        _wdec_signed(cast[int64](b))
        _wstr("\n")
        fail_count = fail_count + 1


# -- chain pointer table ---------------------------------------------------

chain_ptrs: Array[8, Ptr[uint8]]
chain_lens: Array[8, uint64]


# -- root_der / leaf_der: openssl-emitted DER, byte-dumped at build time ---
#
# Generated via:
#   openssl ecparam -name prime256v1 -out ec.params
#   openssl req -x509 -newkey ec:ec.params -keyout root.key -out root.crt \
#       -days 3650 -nodes -subj '/CN=Hamnix Test CA' \
#       -addext 'basicConstraints=critical,CA:TRUE'
#   openssl ecparam -name prime256v1 -genkey -noout -out leaf.key
#   openssl req -new -key leaf.key -out leaf.csr -subj '/CN=test.hamnix.local'
#   openssl x509 -req -in leaf.csr -CA root.crt -CAkey root.key \
#       -CAcreateserial -out leaf.crt -days 3650 \
#       -extfile <(printf 'basicConstraints=CA:FALSE\nsubjectAltName=DNS:test.hamnix.local\n')

root_der: Array[512, uint8]
root_der_len: uint64 = 394

leaf_der: Array[512, uint8]
leaf_der_len: uint64 = 421


