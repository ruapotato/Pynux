# tests/test_x509_walker.ad
#
# X.509 v3 walker (V1) round-trip regression. Boots a real DER-encoded
# ECDSA-P256 cert (generated by `openssl req -x509 ... -subj
# '/CN=test.hamnix.local'` against a prime256v1 key) and verifies every
# field on the X509Cert struct comes back right. The cert was emitted
# DER then byte-dumped at build time; we replay the bytes here through
# an _init_bytes()-style fixture because Adder top-level Array literals
# don't survive to the linked image (per
# memory/feedback_compiler_quirks.md).
#
# Asserts (all pass = `[x509] PASS`):
#   - version == 3
#   - serial length == 20 (max-width X.509 serial)
#   - sig_alg_oid matches OID_ECDSA_WITH_SHA256
#   - pubkey_alg_oid matches OID_EC_PUBLIC_KEY
#   - issuer_dn / subject_dn bytes recovered and identical (self-signed
#     test cert)
#   - subject_dn ASCII contains "test.hamnix.local"
#   - not_before / not_after recovered as 13-byte UTCTime
#   - pubkey_bytes_len == 65 (SEC1 uncompressed P-256 point: 0x04 + X + Y)
#   - pubkey_bytes[0] == 0x04 (uncompressed-point marker)
#   - is_ca == 1 (extension marks CA:TRUE)
#   - san_dns_count == 2 (test.hamnix.local + *.hamnix.local)
#   - tbs_len matches the byte range openssl asn1parse reports
#   - sig_bytes is the trailing BIT STRING value
# Plus DNS matcher checks:
#   - x509_match_dns(cert, "test.hamnix.local") == 1
#   - x509_match_dns(cert, "TEST.HAMNIX.LOCAL") == 1  (case-insensitive)
#   - x509_match_dns(cert, "a.hamnix.local") == 1     (wildcard hit)
#   - x509_match_dns(cert, "a.b.hamnix.local") == 0   (wildcard scope: one label)
#   - x509_match_dns(cert, "evil.com") == 0
#
# Driven by scripts/test_x509_walker.sh.

from lib.asn1.asn1 import (
    asn1_init_oids,
    OID_ECDSA_WITH_SHA256,
    OID_ECDSA_WITH_SHA256_LEN,
    OID_EC_PUBLIC_KEY,
    OID_EC_PUBLIC_KEY_LEN,
)
from lib.x509.x509 import (
    X509Cert,
    x509_parse,
    x509_match_dns,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)


# -- tiny printer -----------------------------------------------------------

def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _wstr(s: Ptr[uint8]):
    sys_write(1, s, _strlen(s))


def _wdec(value: uint64):
    if value == 0:
        sys_write(1, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(1, &out[0], i)


# -- failure aggregator -----------------------------------------------------

fail_count: int32 = 0


def _check(cond: int32, label: Ptr[uint8]):
    if cond == 0:
        _wstr("[x509] FAIL: ")
        _wstr(label)
        _wstr("\n")
        fail_count = fail_count + 1


def _check_eq_u64(a: uint64, b: uint64, label: Ptr[uint8]):
    if a != b:
        _wstr("[x509] FAIL: ")
        _wstr(label)
        _wstr(" got=")
        _wdec(a)
        _wstr(" want=")
        _wdec(b)
        _wstr("\n")
        fail_count = fail_count + 1


def _check_eq_i32(a: int32, b: int32, label: Ptr[uint8]):
    if a != b:
        _wstr("[x509] FAIL: ")
        _wstr(label)
        _wstr(" got=")
        _wdec(cast[uint64](a))
        _wstr(" want=")
        _wdec(cast[uint64](b))
        _wstr("\n")
        fail_count = fail_count + 1


def _t_bytes_eq(a: Ptr[uint8], a_len: uint64,
                b: Ptr[uint8], b_len: uint64) -> int32:
    if a_len != b_len:
        return 0
    i: uint64 = 0
    while i < a_len:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


def _t_contains(hay: Ptr[uint8], hay_len: uint64,
              needle: Ptr[uint8], needle_len: uint64) -> int32:
    if needle_len == 0:
        return 1
    if hay_len < needle_len:
        return 0
    end: uint64 = hay_len - needle_len + 1
    i: uint64 = 0
    while i < end:
        j: uint64 = 0
        ok: int32 = 1
        while j < needle_len:
            if hay[i + j] != needle[j]:
                ok = 0
                break
            j = j + 1
        if ok != 0:
            return 1
        i = i + 1
    return 0


# -- synthetic ECDSA-P256 self-signed cert ----------------------------------
#
# 447 DER bytes generated with:
#   openssl req -x509 -newkey ec:<(openssl ecparam -name prime256v1) \
#       -keyout /dev/null -days 30 -nodes -out cert.pem \
#       -subj '/CN=test.hamnix.local' \
#       -addext 'subjectAltName=DNS:test.hamnix.local,DNS:*.hamnix.local'
#   openssl x509 -in cert.pem -outform DER -out cert.der
#
# Layout (per `openssl asn1parse -i`):
#   offset 0   SEQUENCE len=443 (outer Certificate, hl=4)
#   offset 4   SEQUENCE len=354 (TBSCertificate, hl=4 → TBS = [4..362) = 358 bytes)
#   offset 362 SEQUENCE len=10  (outer AlgorithmIdentifier ecdsa-with-SHA256)
#   offset 374 BIT STRING len=71 (signature value, hl=2 → body at +377)

cert_der: Array[512, uint8]
cert_der_len: uint64 = 447


