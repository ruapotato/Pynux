# Top-level struct (kept off the stack — the X509Cert is ~2 KiB).
cert: X509Cert


def main() -> int32:
    _wstr("[x509] start\n")
    asn1_init_oids()
    _init_cert()

    rc: int32 = x509_parse(&cert_der[0], cert_der_len, &cert)
    _check_eq_i32(rc, 0, "x509_parse rc==0")
    if rc != 0:
        _wstr("[x509] failures=")
        _wdec(cast[uint64](fail_count))
        _wstr("\n[x509] FAIL\n")
        return 1

    # --- version, serial ---------------------------------------------------
    _check_eq_i32(cert.version, 3, "version==3")
    _check_eq_u64(cert.serial_len, 20, "serial_len==20")
    # First serial byte from the openssl-generated cert.
    _check_eq_u64(cast[uint64](cert.serial[0]), 0x55, "serial[0]")
    _check_eq_u64(cast[uint64](cert.serial[19]), 0x88, "serial[19]")

    # --- signature algorithm OID (TBS-inner copy) --------------------------
    _check(_t_bytes_eq(&cert.sig_alg_oid[0], cert.sig_alg_oid_len,
                     &OID_ECDSA_WITH_SHA256[0], OID_ECDSA_WITH_SHA256_LEN),
           "sig_alg == ecdsa-with-SHA256")

    # --- pubkey algorithm OID ----------------------------------------------
    _check(_t_bytes_eq(&cert.pubkey_alg_oid[0], cert.pubkey_alg_oid_len,
                     &OID_EC_PUBLIC_KEY[0], OID_EC_PUBLIC_KEY_LEN),
           "pubkey_alg == id-ecPublicKey")

    # --- issuer / subject DN ------------------------------------------------
    # The cert is self-signed, so the two DN blobs are byte-identical.
    _check_eq_u64(cert.issuer_dn_len, cert.subject_dn_len,
                  "issuer_len == subject_len")
    _check(_t_bytes_eq(&cert.issuer_dn[0], cert.issuer_dn_len,
                     &cert.subject_dn[0], cert.subject_dn_len),
           "issuer_dn == subject_dn (self-signed)")

    # ASCII "test.hamnix.local" appears in the subject DN.
    needle: Array[18, uint8]
    needle[0] = 0x74   # t
    needle[1] = 0x65   # e
    needle[2] = 0x73   # s
    needle[3] = 0x74   # t
    needle[4] = 0x2E   # .
    needle[5] = 0x68   # h
    needle[6] = 0x61   # a
    needle[7] = 0x6D   # m
    needle[8] = 0x6E   # n
    needle[9] = 0x69   # i
    needle[10] = 0x78  # x
    needle[11] = 0x2E  # .
    needle[12] = 0x6C  # l
    needle[13] = 0x6F  # o
    needle[14] = 0x63  # c
    needle[15] = 0x61  # a
    needle[16] = 0x6C  # l
    _check(_t_contains(&cert.subject_dn[0], cert.subject_dn_len,
                     &needle[0], cast[uint64](17)),
           "subject_dn contains 'test.hamnix.local'")

    # --- validity ----------------------------------------------------------
    _check_eq_u64(cert.not_before_len, 13, "not_before_len==13 (UTCTime)")
    _check_eq_u64(cert.not_after_len, 13, "not_after_len==13 (UTCTime)")
    # Both end with 'Z'.
    _check_eq_u64(cast[uint64](cert.not_before[12]), 0x5A,
                  "not_before ends 'Z'")
    _check_eq_u64(cast[uint64](cert.not_after[12]), 0x5A,
                  "not_after ends 'Z'")

    # --- public key bytes --------------------------------------------------
    # SEC1 uncompressed P-256 point: 0x04 || X(32) || Y(32) = 65 bytes.
    _check_eq_u64(cert.pubkey_bytes_len, 65, "pubkey_bytes_len==65")
    _check_eq_u64(cast[uint64](cert.pubkey_bytes[0]), 0x04,
                  "pubkey_bytes[0]==0x04 (uncompressed)")

    # --- basicConstraints --------------------------------------------------
    _check_eq_i32(cert.is_ca, 1, "is_ca==1")

    # --- SAN dNSNames ------------------------------------------------------
    _check_eq_i32(cert.san_dns_count, 2, "san_dns_count==2")
    _check_eq_u64(cert.san_dns_lens[0], 17, "san[0] len==17")
    _check_eq_u64(cert.san_dns_lens[1], 14, "san[1] len==14")

    # --- TBS byte range ----------------------------------------------------
    # The openssl asn1parse output above says TBS is at offset 4 with
    # hl=4 + l=354 → 358 bytes total.
    _check_eq_u64(cert.tbs_len, 358, "tbs_len==358")
    # tbs_bytes must point into the original buffer at offset 4.
    expected_tbs: Ptr[uint8] = &cert_der[4]
    if cert.tbs_bytes != expected_tbs:
        _wstr("[x509] FAIL: tbs_bytes pointer mismatch\n")
        fail_count = fail_count + 1
    # First byte of TBS is SEQUENCE tag.
    _check_eq_u64(cast[uint64](cert.tbs_bytes[0]), 0x30, "tbs starts 0x30")

    # --- signature bytes ---------------------------------------------------
    # The BIT STRING wraps `0x00 (unused) || 0x30 0x44 ...` (the ECDSA-Sig
    # SEQUENCE of two INTEGERs). The walker drops the unused-bits byte,
    # so sig_bytes[0] should be 0x30.
    _check_eq_u64(cast[uint64](cert.sig_bytes[0]), 0x30, "sig starts 0x30")
    _check_eq_u64(cert.sig_bytes_len, 70, "sig_bytes_len==70")

    # --- DNS matcher -------------------------------------------------------
    _check_eq_i32(x509_match_dns(&cert, "test.hamnix.local"), 1,
                  "match: test.hamnix.local")
    _check_eq_i32(x509_match_dns(&cert, "TEST.HAMNIX.LOCAL"), 1,
                  "match: case-insensitive")
    _check_eq_i32(x509_match_dns(&cert, "a.hamnix.local"), 1,
                  "match: wildcard one-label hit")
    _check_eq_i32(x509_match_dns(&cert, "a.b.hamnix.local"), 0,
                  "miss: wildcard rejects two-label")
    _check_eq_i32(x509_match_dns(&cert, "evil.com"), 0,
                  "miss: unrelated host")
    _check_eq_i32(x509_match_dns(&cert, "hamnix.local"), 0,
                  "miss: wildcard requires a leading label")

    _wstr("[x509] failures=")
    _wdec(cast[uint64](fail_count))
    _wstr("\n")
    if fail_count == 0:
        _wstr("[x509] PASS\n")
        return 0
    _wstr("[x509] FAIL\n")
    return 1
