# tests/test_9p_realfd.ad
#
# V4.1 — real-fd 9P create/write/read round-trip.
#
# Where tests/test_9p_e2e.ad proved walk + open + READ over a real fd,
# THIS fixture proves the WRITE side of the keystone: the kernel 9P
# client can mount a userland 9P file server over a real fd and drive
# a full walk -> open -> CREATE -> WRITE -> read round-trip against it.
#
#     userspace fixture          kernel                userland server
#     ─────────────────          ──────                ───────────────
#  1. sys_pipe(c2s)  ─────────────────────────────────►  fd 0 (T-msg in)
#  2. sys_pipe(s2c)  ─────────────────────────────────►  fd 1 (R-msg out)
#  3. sys_spawn("/bin/distrofs", stdin=c2s_rfd, stdout=s2c_wfd)
#  4. sys_srv_post("p9rfd", c2s_wfd)
#  5. fd = sys_srv_open("p9rfd")
#  6. sys_mount(fd, -1, "/p9root", MREPL, "p9rx:<s2c_rfd>:")
#                                          │
#                                          ▼
#                            kernel _p9_send/_p9_recv  (Tversion+Tattach
#                            over the real pipe pair)
#  7. wfd = sys_open_write("/p9root/var/lib/dpkg/status")
#                                          │
#                                          ▼
#                  kernel walks /var/lib/dpkg, sees the leaf "status"
#                  is MISSING, issues Tcreate via p9c_walk_create_path
#  8. sys_write(wfd, "deadbeef pkg\n", 13)  -> kernel issues Twrite
#  9. sys_close(wfd)                        -> kernel issues Tclunk
# 10. rfd = sys_open("/p9root/var/lib/dpkg/status")
#                                          │
#                                          ▼
#                  kernel walks the now-created leaf, Topen-OREAD it
# 11. n = sys_read(rfd, buf, 64)            -> kernel issues Tread
# 12. assert buf == "deadbeef pkg\n"
# 13. sys_close(rfd)            kernel issues Tclunk
# 14. sys_kill + sys_waitpid    reap distrofs
#
# distrofs exports a distro-shaped skeleton (/var/lib/dpkg already
# exists as a directory) but creates files only on demand via
# Tcreate/Twrite — so "status" under it is the perfect leaf to
# exercise create-on-write-open.
#
# THE PIPE-PAIR TRANSPORT — identical to test_9p_e2e.ad: Hamnix pipes
# are unidirectional, so we hand the kernel client the rx-side fd via
# the "p9rx:<fd>:" magic prefix in the mount() spec argument
# (9p_client.ad::_parse_rx_prefix strips it before Tversion runs).
#
# MARKERS grepped by scripts/test_9p_realfd.sh:
#
#   [p9_realfd] start
#   [p9_realfd] pipes OK
#   [p9_realfd] spawn OK
#   [p9_realfd] srv_post OK
#   [p9_realfd] srv_open OK
#   [p9_realfd] mount OK
#   [p9_realfd] create OK
#   [p9_realfd] write=13
#   [p9_realfd] write OK
#   [p9_realfd] reopen OK
#   [p9_realfd] read=13
#   [p9_realfd] payload OK
#   [p9_realfd] PASS

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_pipe(fds: Ptr[int32]) -> int32
extern def sys_waitpid(pid: uint64) -> int64
extern def sys_kill(pid: int32, sig: int32) -> int32
extern def sys_exit(code: uint64)
extern def sys_srv_post(name: Ptr[char], srvfd: int32) -> int32
extern def sys_srv_open(name: Ptr[char]) -> int32
extern def sys_errstr(buf: Ptr[uint8], nbuf: uint64) -> int32
extern def sys_spawn(path: Ptr[char], argv: Ptr[uint64],
                     stdin_fd: int32, stdout_fd: int32,
                     envp: Ptr[uint64]) -> int32
extern def sys_mount(srvfd: int32, afd: int32, old: Ptr[char],
                     flag: int32, spec: Ptr[char]) -> int32

MREPL: int32 = 0
SIGKILL: int32 = 9

# Top-level scratch buffers (Adder nested-frame Array bug avoidance).
c2s_fds: Array[2, int32]
s2c_fds: Array[2, int32]
spawn_argv: Array[2, uint64]
read_buf: Array[64, uint8]
err_buf:  Array[128, uint8]
spec_buf: Array[32, uint8]      # holds "p9rx:<NN>:" + NUL
mount_path: Array[16, uint8]    # "/p9root"
file_path:  Array[40, uint8]    # "/p9root/var/lib/dpkg/status"
srv_name:   Array[16, uint8]    # "p9rfd"

# Payload written into the created file: "deadbeef pkg\n" (13 bytes).
payload: Array[16, uint8]
PAYLOAD_LEN: uint64 = 13


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def dump_errstr(label: Ptr[uint8]):
    sys_errstr(&err_buf[0], 128)
    write_str(1, label)
    write_str(1, &err_buf[0])
    write_str(1, "\n")


def write_dec(fd: int32, value: uint64):
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def fill_spec(rx_fd: int32):
    # Build "p9rx:<rx_fd>:" + NUL into spec_buf. Top-level Array so the
    # digits land where 9p_client.ad::_parse_rx_prefix expects them.
    spec_buf[0] = 112    # 'p'
    spec_buf[1] = 57     # '9'
    spec_buf[2] = 114    # 'r'
    spec_buf[3] = 120    # 'x'
    spec_buf[4] = 58     # ':'
    pos: uint64 = 5
    v: uint64 = cast[uint64](rx_fd)
    if v == 0:
        spec_buf[pos] = 48                                # '0'
        pos = pos + 1
    else:
        digits: Array[8, uint8]
        n: uint64 = 0
        while v != 0:
            digits[n] = cast[uint8](v % 10) + 48
            v = v / 10
            n = n + 1
        while n > 0:
            n = n - 1
            spec_buf[pos] = digits[n]
            pos = pos + 1
    spec_buf[pos] = 58                                    # ':'
    spec_buf[pos + 1] = 0


def init_payload():
    # "deadbeef pkg\n"
    payload[0]  = 100   # 'd'
    payload[1]  = 101   # 'e'
    payload[2]  = 97    # 'a'
    payload[3]  = 100   # 'd'
    payload[4]  = 98    # 'b'
    payload[5]  = 101   # 'e'
    payload[6]  = 101   # 'e'
    payload[7]  = 102   # 'f'
    payload[8]  = 32    # ' '
    payload[9]  = 112   # 'p'
    payload[10] = 107   # 'k'
    payload[11] = 103   # 'g'
    payload[12] = 10    # '\n'
    payload[13] = 0


def init_paths():
    # "/p9root" — mount point. As in test_9p_e2e.ad we pick a path NOT
    # under /n/, /srv/, /proc/ etc. so no userspace `init` bind rewrites
    # the prefix before vfs_open's 9P probe runs.
    mount_path[0] = 47    # '/'
    mount_path[1] = 112   # 'p'
    mount_path[2] = 57    # '9'
    mount_path[3] = 114   # 'r'
    mount_path[4] = 111   # 'o'
    mount_path[5] = 111   # 'o'
    mount_path[6] = 116   # 't'
    mount_path[7] = 0
    # "/p9root/var/lib/dpkg/status" — distrofs pre-creates /var/lib/dpkg
    # as a directory; "status" is the missing leaf we create.
    file_path[0]  = 47    # '/'
    file_path[1]  = 112   # 'p'
    file_path[2]  = 57    # '9'
    file_path[3]  = 114   # 'r'
    file_path[4]  = 111   # 'o'
    file_path[5]  = 111   # 'o'
    file_path[6]  = 116   # 't'
    file_path[7]  = 47    # '/'
    file_path[8]  = 118   # 'v'
    file_path[9]  = 97    # 'a'
    file_path[10] = 114   # 'r'
    file_path[11] = 47    # '/'
    file_path[12] = 108   # 'l'
    file_path[13] = 105   # 'i'
    file_path[14] = 98    # 'b'
    file_path[15] = 47    # '/'
    file_path[16] = 100   # 'd'
    file_path[17] = 112   # 'p'
    file_path[18] = 107   # 'k'
    file_path[19] = 103   # 'g'
    file_path[20] = 47    # '/'
    file_path[21] = 115   # 's'
    file_path[22] = 116   # 't'
    file_path[23] = 97    # 'a'
    file_path[24] = 116   # 't'
    file_path[25] = 117   # 'u'
    file_path[26] = 115   # 's'
    file_path[27] = 0
    # "p9rfd"
    srv_name[0] = 112     # 'p'
    srv_name[1] = 57      # '9'
    srv_name[2] = 114     # 'r'
    srv_name[3] = 102     # 'f'
    srv_name[4] = 100     # 'd'
    srv_name[5] = 0


def main() -> int32:
    init_payload()
    init_paths()
    write_str(1, "[p9_realfd] start\n")

    # 1. Pipes. c2s = client->server (T-msgs); s2c = server->client (R).
    if sys_pipe(&c2s_fds[0]) < 0:
        dump_errstr("[p9_realfd] FAIL: sys_pipe c2s errstr=")
        return 1
    if sys_pipe(&s2c_fds[0]) < 0:
        dump_errstr("[p9_realfd] FAIL: sys_pipe s2c errstr=")
        return 2
    c2s_rfd: int32 = c2s_fds[0]                       # server reads T
    c2s_wfd: int32 = c2s_fds[1]                       # kernel writes T
    s2c_rfd: int32 = s2c_fds[0]                       # kernel reads R
    s2c_wfd: int32 = s2c_fds[1]                       # server writes R
    write_str(1, "[p9_realfd] pipes OK\n")

    # 2. Spawn /bin/distrofs with stdin=c2s_rfd, stdout=s2c_wfd.
    spawn_argv[0] = cast[uint64](&"/bin/distrofs"[0])
    spawn_argv[1] = 0
    pid: int32 = sys_spawn("/bin/distrofs", &spawn_argv[0],
                           c2s_rfd, s2c_wfd, cast[Ptr[uint64]](0))
    if pid < 0:
        dump_errstr("[p9_realfd] FAIL: sys_spawn errstr=")
        return 3
    write_str(1, "[p9_realfd] spawn OK\n")

    # Drop the parent-side inherited ends — the child has its own dups.
    sys_close(c2s_rfd)
    sys_close(s2c_wfd)

    # 3. Post c2s_wfd at /srv/p9rfd.
    if sys_srv_post(cast[Ptr[char]](&srv_name[0]), c2s_wfd) < 0:
        dump_errstr("[p9_realfd] FAIL: sys_srv_post errstr=")
        return 4
    write_str(1, "[p9_realfd] srv_post OK\n")

    # 4. srv_open hands back a fresh fd dup'd onto the posted writer end.
    srv_fd: int32 = sys_srv_open(cast[Ptr[char]](&srv_name[0]))
    if srv_fd < 0:
        dump_errstr("[p9_realfd] FAIL: sys_srv_open errstr=")
        return 5
    write_str(1, "[p9_realfd] srv_open OK\n")

    # 5. Mount. spec carries the rx-side srvfd so _p9_recv reads R-msgs
    #    from the correct pipe slot.
    fill_spec(s2c_rfd)
    rc: int32 = sys_mount(srv_fd, -1,
                          cast[Ptr[char]](&mount_path[0]),
                          MREPL,
                          cast[Ptr[char]](&spec_buf[0]))
    if rc < 0:
        dump_errstr("[p9_realfd] FAIL: sys_mount errstr=")
        return 6
    write_str(1, "[p9_realfd] mount OK\n")

    # 6. Create-on-write-open. The leaf "status" does not exist under
    #    the distrofs /var/lib/dpkg directory; vfs_open_write's 9P
    #    probe walks the parent, sees the ENOENT, and routes through
    #    p9c_walk_create_path -> Tcreate. All over the real pipe pair.
    wfd: int32 = sys_open_write(cast[Ptr[char]](&file_path[0]))
    if wfd < 0:
        dump_errstr("[p9_realfd] FAIL: sys_open_write errstr=")
        return 7
    write_str(1, "[p9_realfd] create OK\n")

    # 7. Write the payload. vfs_write routes FD_P9_MARK through
    #    p9c_write -> Twrite.
    wn: int64 = sys_write(wfd, &payload[0], PAYLOAD_LEN)
    if wn < 0:
        dump_errstr("[p9_realfd] FAIL: sys_write errstr=")
        sys_close(wfd)
        return 8
    write_str(1, "[p9_realfd] write=")
    write_dec(1, cast[uint64](wn))
    write_str(1, "\n")
    if cast[uint64](wn) != PAYLOAD_LEN:
        write_str(1, "[p9_realfd] FAIL: short write\n")
        sys_close(wfd)
        return 9
    write_str(1, "[p9_realfd] write OK\n")

    # 8. Close the write fd — vfs_close issues Tclunk over the pipes.
    if sys_close(wfd) < 0:
        dump_errstr("[p9_realfd] FAIL: sys_close wfd errstr=")
        return 10

    # 9. Re-open the (now-created) file for read. The kernel walks the
    #    leaf that now exists on the server and Topen-OREADs it.
    rfd: int32 = sys_open(cast[Ptr[char]](&file_path[0]))
    if rfd < 0:
        dump_errstr("[p9_realfd] FAIL: sys_open (reopen) errstr=")
        return 11
    write_str(1, "[p9_realfd] reopen OK\n")

    # 10. Read it back — kernel issues Tread, copies the Rread payload.
    n: int64 = sys_read(rfd, &read_buf[0], 64)
    if n < 0:
        dump_errstr("[p9_realfd] FAIL: sys_read errstr=")
        sys_close(rfd)
        return 12
    write_str(1, "[p9_realfd] read=")
    write_dec(1, cast[uint64](n))
    write_str(1, "\n")
    if cast[uint64](n) != PAYLOAD_LEN:
        write_str(1, "[p9_realfd] FAIL: read count mismatch\n")
        sys_close(rfd)
        return 13

    # 11. Byte-for-byte payload check — proves the create/write actually
    #     landed on the server and survived the round trip.
    i: uint64 = 0
    while i < PAYLOAD_LEN:
        if read_buf[i] != payload[i]:
            write_str(1, "[p9_realfd] FAIL: payload mismatch at i=")
            write_dec(1, i)
            write_str(1, "\n")
            sys_close(rfd)
            return 14
        i = i + 1
    write_str(1, "[p9_realfd] payload OK\n")

    if sys_close(rfd) < 0:
        dump_errstr("[p9_realfd] FAIL: sys_close rfd errstr=")
        return 15

    # 12. Tear down — close the writer ends so distrofs sees EOF on
    #     stdin, then reap it.
    sys_close(srv_fd)
    sys_close(c2s_wfd)
    sys_close(s2c_rfd)
    sys_kill(pid, SIGKILL)
    sys_waitpid(cast[uint64](pid))

    write_str(1, "[p9_realfd] PASS\n")
    return 0
