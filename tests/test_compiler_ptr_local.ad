# tests/test_compiler_ptr_local.ad
#
# Compiler regression: `Ptr[T]` writes whose target is a stack-local
# taken by `&local` must round-trip the value the callee wrote when
# the caller reads the local back.
#
# Before the fix, codegen miscompiled this pattern:
#
#   def callee(out_a: Ptr[int32], out_b: Ptr[int32]):
#       out_a[0] = 42
#       out_b[0] = 99
#
#   def caller():
#       a: int32 = -1
#       b: int32 = -1
#       callee(&a, &b)
#       # Expected: a == 42, b == 99.
#       # Actual:   the upper 4 bytes of the 8-byte slot still held
#       #           0xFFFFFFFF from the original `-1` init (which the
#       #           VarDecl store wrote as a full `movq`). The callee's
#       #           `movl` through Ptr[int32] only updated the low 4
#       #           bytes; the caller's `movq` readback then saw
#       #           0xFFFFFFFF0000002A != 42.
#
# Multiple kernel sites worked around this by routing the out-params
# through top-level `Array[N, T]` globals (see drivers/nvme/nvme.ad,
# arch/x86/kernel/syscall.ad, fs/vfs.ad). With the fix, &local works
# directly and those scratch globals can be retired.
#
# This fixture covers the exact pattern + a few neighbours:
#   1. The minimal repro (two int32 locals, &locals out-params).
#   2. Same with int16 + int8 (sub-4-byte sizes also go through the
#      sized-store path).
#   3. Mixed int32 + uint64 (the 8-byte slot path must not regress).
#   4. Signed-negative readback (proves we sign-extend on load so
#      `pipe_rc < 0` still works after the fix).
#
# Driven by scripts/test_compiler_ptr_local.sh: builds this .ad as a
# userland x86_64 ELF, plants it at /bin/test_compiler_ptr_local in
# the cpio initramfs, boots QEMU + hamsh, runs the binary, then asserts
# on the serial log for the [ptr_local] PASS banner. Same shape as
# scripts/test_lex_digit_idents.sh / scripts/test_srv_post.sh.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def emit(msg: Ptr[uint8]):
    sys_write(1, msg, strlen(msg))


def fail(msg: Ptr[uint8]):
    emit("[ptr_local] FAIL ")
    emit(msg)
    emit("\n")
    sys_exit(1)


# ----------------------------------------------------------------------
# Case 1: the minimal repro. Two int32 locals, both initialised to -1
# (so the upper 4 bytes of the 8-byte slot are 0xFFFFFFFF under the old
# `movq` store). Callee writes via Ptr[int32]; caller reads back.
def write_two_int32(out_a: Ptr[int32], out_b: Ptr[int32]):
    out_a[0] = 42
    out_b[0] = 99


def case_two_int32():
    a: int32 = -1
    b: int32 = -1
    write_two_int32(&a, &b)
    if a != 42:
        fail("case_two_int32: a != 42")
    if b != 99:
        fail("case_two_int32: b != 99")


# ----------------------------------------------------------------------
# Case 2: int16 and int8 — both narrower than int32, so the sized-store
# path through emit_store_sized writes 2 bytes / 1 byte respectively.
# Same pattern: upper bytes of the slot are dirty 0xFF from the -1 init.
def write_int16(p: Ptr[int16]):
    p[0] = 1234


def write_int8(p: Ptr[int8]):
    p[0] = 77


def case_narrow_scalars():
    x: int16 = -1
    write_int16(&x)
    if x != 1234:
        fail("case_narrow_scalars: x != 1234")

    y: int8 = -1
    write_int8(&y)
    if y != 77:
        fail("case_narrow_scalars: y != 77")


# ----------------------------------------------------------------------
# Case 3: uint64 (8-byte) locals — the slot size already matches the
# store size, so this case is mostly a guard against breaking the
# non-bug path. If sized loads/stores accidentally truncate 8-byte
# locals, this would fail.
def write_u64(p: Ptr[uint64]):
    p[0] = 0xDEADBEEFCAFEBABE


def case_u64():
    v: uint64 = 0
    write_u64(&v)
    if v != 0xDEADBEEFCAFEBABE:
        fail("case_u64: v != 0xDEADBEEFCAFEBABE")


# ----------------------------------------------------------------------
# Case 4: signed-negative readback. Proves we sign-extend on load
# (not zero-extend) — otherwise `pipe_rc < 0` style checks in
# tests/test_srv_post.ad would silently regress.
def write_neg_int32(p: Ptr[int32]):
    p[0] = -7


def case_signed_negative():
    n: int32 = 0
    write_neg_int32(&n)
    if n != -7:
        fail("case_signed_negative: n != -7")
    if n >= 0:
        fail("case_signed_negative: n not < 0")


# ----------------------------------------------------------------------
# Case 5: bare scalar local stored with a non-zero init, taken by &,
# overwritten by callee, read back. This is the "VarDecl init wrote
# full 8 bytes; callee only wrote 4" path in isolation.
def write_int32(p: Ptr[int32]):
    p[0] = 0x11223344


def case_dirty_upper_half():
    a: int32 = -1
    write_int32(&a)
    if a != 0x11223344:
        fail("case_dirty_upper_half: a != 0x11223344")


def main():
    emit("[ptr_local] start\n")
    case_two_int32()
    emit("[ptr_local] case_two_int32 OK\n")
    case_narrow_scalars()
    emit("[ptr_local] case_narrow_scalars OK\n")
    case_u64()
    emit("[ptr_local] case_u64 OK\n")
    case_signed_negative()
    emit("[ptr_local] case_signed_negative OK\n")
    case_dirty_upper_half()
    emit("[ptr_local] case_dirty_upper_half OK\n")
    emit("[ptr_local] PASS\n")
    sys_exit(0)
