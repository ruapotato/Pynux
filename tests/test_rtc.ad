# tests/test_rtc.ad
#
# V5.2 RTC regression. Verifies that drivers/rtc/cmos.ad::rtc_init()
# successfully read the CMOS chip at boot and that the resulting Unix
# epoch is in a plausible range. Closes the V5.1 clock-rollback gap
# (a build-epoch fallback that silently let expired certs validate).
#
# We can't call rtc_read_unix_time() directly from a CPL-3 userspace
# fixture — the CMOS port I/O (in/out at 0x70/0x71) #GP-faults outside
# the kernel — so we exercise the read path indirectly through
# /dev/stat. devstat_read() emits `btime <epoch_seconds>` sourced from
# drivers/rtc/cmos.ad::rtc_boot_epoch_get(), which is the epoch
# rtc_init() snapshotted at boot via the exact same rtc_read_epoch()
# code path tls.ad now calls on every handshake.
#
# Asserts (all pass = `[rtc] PASS unix=<number>`):
#   - /dev/stat opens, reads, contains a "btime " row
#   - the digit run following "btime " parses to an integer
#   - that integer is in [BUILD_EPOCH_MIN, YEAR_3000_MAX] —
#     i.e. between 2026-05-18 00:00:00 UTC and 3000-01-01 UTC.
#     QEMU's emulated RTC tracks the host wall clock, so we expect
#     a value within seconds of today's epoch.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_rtc.ad -o build/user/test_rtc.elf
#
# Driven by scripts/test_rtc.sh.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


# Plausible-epoch window.
#
# Lower bound = 2025-01-01 00:00:00 UTC (`1735689600`). Anything
# earlier on a target we just built today means the chip read 0,
# the BCD conversion is broken, or the days-since-epoch math is
# off. We deliberately set this BELOW the V5.1 build epoch
# (`1779667200` = 2026-05-25) because QEMU's emulated MC146818
# reports the host wall clock, and CI machines may run from any
# date in 2025+ without invalidating the regression.
#
# Upper bound = year 3000 (`32503680000`). Wildly generous; catches
# the "uint32 overflow into the high bits" class of bug where the
# year math runs away to a galactic epoch.
BUILD_EPOCH_MIN: uint64 = 1735689600
YEAR_3000_MAX:   uint64 = 32503680000


def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _wstr(s: Ptr[uint8]):
    sys_write(1, s, _strlen(s))


def _wdec(value: uint64):
    if value == 0:
        sys_write(1, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(1, &out[0], i)


# Locate the byte-position one past "btime " in buf[0..len], or
# return len (i.e. "not found") if the row is absent. We're looking
# for the 6-byte literal at the start of a line — devstat.ad emits
# it preceded by a newline (or it could be at offset 0; the boot
# pipeline always emits earlier rows first but we don't depend on
# that here).
def _find_btime_value_start(buf: Ptr[uint8], n: uint64) -> uint64:
    needle: Array[7, uint8]
    needle[0] = 98     # 'b'
    needle[1] = 116    # 't'
    needle[2] = 105    # 'i'
    needle[3] = 109    # 'm'
    needle[4] = 101    # 'e'
    needle[5] = 32     # ' '
    needle[6] = 0
    if n < 6:
        return n
    last: uint64 = n - 6 + 1
    i: uint64 = 0
    while i < last:
        hit: int32 = 1
        j: uint64 = 0
        while j < 6:
            if buf[i + j] != needle[j]:
                hit = 0
                j = 6
            else:
                j = j + 1
        if hit == 1:
            return i + 6
        i = i + 1
    return n


# Parse a decimal digit run starting at buf[pos], stopping at the
# first non-digit. Returns the parsed value. Caller is responsible
# for first checking that pos < n.
def _parse_decimal(buf: Ptr[uint8], pos: uint64, n: uint64) -> uint64:
    v: uint64 = 0
    i: uint64 = pos
    while i < n:
        b: uint8 = buf[i]
        if b < 48 or b > 57:
            return v
        v = v * 10 + cast[uint64](b - 48)
        i = i + 1
    return v


def main() -> int32:
    _wstr("[rtc] start\n")

    fd: int32 = sys_open("/dev/stat")
    if fd < 0:
        _wstr("[rtc] FAIL: /dev/stat open\n")
        return 1

    buf: Array[512, uint8]
    n: int64 = sys_read(fd, &buf[0], 384)
    sys_close(fd)
    if n <= 0:
        _wstr("[rtc] FAIL: /dev/stat read <= 0\n")
        return 1

    ulen: uint64 = cast[uint64](n)
    pos: uint64 = _find_btime_value_start(&buf[0], ulen)
    if pos >= ulen:
        _wstr("[rtc] FAIL: /dev/stat missing 'btime ' row\n")
        return 1

    epoch: uint64 = _parse_decimal(&buf[0], pos, ulen)
    if epoch == 0:
        _wstr("[rtc] FAIL: btime parsed to 0 (RTC unreadable at boot)\n")
        return 1

    if epoch < BUILD_EPOCH_MIN:
        _wstr("[rtc] FAIL: epoch below 2026-05-18 minimum, got=")
        _wdec(epoch)
        _wstr("\n")
        return 1

    if epoch > YEAR_3000_MAX:
        _wstr("[rtc] FAIL: epoch above year-3000 maximum, got=")
        _wdec(epoch)
        _wstr("\n")
        return 1

    _wstr("[rtc] PASS unix=")
    _wdec(epoch)
    _wstr("\n")
    return 0
