# tests/test_nsrun.ad
#
# Verification fixture for the nsrun shim launcher (user/nsrun.ad).
#
# WHAT THIS PROVES
# ----------------
# `nsrun <program>` runs `<program>` in a private namespace where
# /var, /usr, AND /etc are each served by a distrofs 9P daemon, and
# the parent namespace is NOT affected. We prove BOTH halves with ONE
# binary, run TWO ways by scripts/test_nsrun.sh:
#
#   A. `/bin/test_nsrun write`          (run via `nsrun`)
#      Inside the nsrun-built namespace. /var, /usr, /etc are each
#      distrofs-served. The fixture creates + writes + reads back a
#      file under EACH of /var/lib/dpkg/, /usr/, and /etc/ and asserts
#      the byte-for-byte round trip for all three. A successful round
#      trip means the create/write/read landed on the distrofs daemon
#      (initramfs has no /var/lib/dpkg path — see below — so the only
#      thing that could serve it is the mount).
#
#   B. `/bin/test_nsrun probe`          (run bare, NO nsrun)
#      In the plain shell namespace. /var is whatever the initramfs
#      ships. The initramfs has /var/www/* but NOTHING under
#      /var/lib/dpkg/. The fixture asserts that opening
#      /var/lib/dpkg/nsrun_probe FAILS — proving the file the nsrun
#      run created went to the child's distrofs instance, not to any
#      global tree the parent shares.
#
# Together: A shows the writes work inside the namespace; B shows the
# same path is empty outside it. That is the Plan 9 invariant —
# namespaces are per-process; the child's mounts did not leak.
#
# The /var path is /var/lib/dpkg/nsrun_probe — distrofs pre-creates
# /var/lib/dpkg as a directory (see user/distrofs.ad's init_tree), so
# "nsrun_probe" is the missing leaf the create-on-write-open path
# fills in. /usr and /etc are pre-created as empty directories by
# distrofs, so the probe files land directly under them.
#
# MARKERS grepped by scripts/test_nsrun.sh:
#   [nsrun_test] start
#   [nsrun_test] mode=write          (or mode=probe)
#   [nsrun_test] write OK            (A: create+write succeeded, /var)
#   [nsrun_test] usr OK              (A: create+write+read OK, /usr)
#   [nsrun_test] etc OK              (A: create+write+read OK, /etc)
#   [nsrun_test] readback=<n>
#   [nsrun_test] payload OK          (A: round trip byte-exact, /var)
#   [nsrun_test] isolation OK        (B: parent /var/lib/dpkg empty)
#   [nsrun_test] PASS
#   [nsrun_test] FAIL: ...           (any assertion failure)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_errstr(buf: Ptr[uint8], nbuf: uint64) -> int32
extern def sys_exit(code: uint64)


# Top-level BSS scratch (U9 nested-frame-Array quirk).
read_buf: Array[64, uint8]
err_buf:  Array[128, uint8]

# "/var/lib/dpkg/nsrun_probe" — the leaf under distrofs' pre-made
# /var/lib/dpkg directory.
probe_path: Array[32, uint8]

# "/usr/nsrun_probe" and "/etc/nsrun_probe" — leaves under distrofs'
# pre-made /usr and /etc directories. These prove the /usr and /etc
# mounts (added alongside /var) are distrofs-backed too.
usr_path: Array[24, uint8]
etc_path: Array[24, uint8]

# Payload written into the probe file: "nsrun-ok\n" (9 bytes).
payload: Array[16, uint8]
PAYLOAD_LEN: uint64 = 9


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def write_dec(fd: int32, value: uint64):
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def dump_errstr(label: Ptr[uint8]):
    err_buf[0] = 0
    sys_errstr(&err_buf[0], 128)
    write_str(1, label)
    write_str(1, &err_buf[0])
    write_str(1, "\n")


def init_strings():
    # "/var/lib/dpkg/nsrun_probe"
    probe_path[0]  = 47    # '/'
    probe_path[1]  = 118   # 'v'
    probe_path[2]  = 97    # 'a'
    probe_path[3]  = 114   # 'r'
    probe_path[4]  = 47    # '/'
    probe_path[5]  = 108   # 'l'
    probe_path[6]  = 105   # 'i'
    probe_path[7]  = 98    # 'b'
    probe_path[8]  = 47    # '/'
    probe_path[9]  = 100   # 'd'
    probe_path[10] = 112   # 'p'
    probe_path[11] = 107   # 'k'
    probe_path[12] = 103   # 'g'
    probe_path[13] = 47    # '/'
    probe_path[14] = 110   # 'n'
    probe_path[15] = 115   # 's'
    probe_path[16] = 114   # 'r'
    probe_path[17] = 117   # 'u'
    probe_path[18] = 110   # 'n'
    probe_path[19] = 95    # '_'
    probe_path[20] = 112   # 'p'
    probe_path[21] = 114   # 'r'
    probe_path[22] = 111   # 'o'
    probe_path[23] = 98    # 'b'
    probe_path[24] = 101   # 'e'
    probe_path[25] = 0
    # "/usr/nsrun_probe"
    usr_path[0]  = 47    # '/'
    usr_path[1]  = 117   # 'u'
    usr_path[2]  = 115   # 's'
    usr_path[3]  = 114   # 'r'
    usr_path[4]  = 47    # '/'
    usr_path[5]  = 110   # 'n'
    usr_path[6]  = 115   # 's'
    usr_path[7]  = 114   # 'r'
    usr_path[8]  = 117   # 'u'
    usr_path[9]  = 110   # 'n'
    usr_path[10] = 95    # '_'
    usr_path[11] = 112   # 'p'
    usr_path[12] = 114   # 'r'
    usr_path[13] = 111   # 'o'
    usr_path[14] = 98    # 'b'
    usr_path[15] = 101   # 'e'
    usr_path[16] = 0
    # "/etc/nsrun_probe"
    etc_path[0]  = 47    # '/'
    etc_path[1]  = 101   # 'e'
    etc_path[2]  = 116   # 't'
    etc_path[3]  = 99    # 'c'
    etc_path[4]  = 47    # '/'
    etc_path[5]  = 110   # 'n'
    etc_path[6]  = 115   # 's'
    etc_path[7]  = 114   # 'r'
    etc_path[8]  = 117   # 'u'
    etc_path[9]  = 110   # 'n'
    etc_path[10] = 95    # '_'
    etc_path[11] = 112   # 'p'
    etc_path[12] = 114   # 'r'
    etc_path[13] = 111   # 'o'
    etc_path[14] = 98    # 'b'
    etc_path[15] = 101   # 'e'
    etc_path[16] = 0
    # "nsrun-ok\n"
    payload[0] = 110   # 'n'
    payload[1] = 115   # 's'
    payload[2] = 114   # 'r'
    payload[3] = 117   # 'u'
    payload[4] = 110   # 'n'
    payload[5] = 45    # '-'
    payload[6] = 111   # 'o'
    payload[7] = 107   # 'k'
    payload[8] = 10    # '\n'
    payload[9] = 0


# -- one create/write/read round trip on an arbitrary distrofs path -----
#
# Used to prove the /usr and /etc mounts are distrofs-backed: open for
# write (create-on-write), write the payload, re-open, read it back,
# and compare byte-for-byte. Returns 0 on a clean round trip, 1 on any
# failure (a [nsrun_test] FAIL line is emitted before returning 1).

def roundtrip(path: Ptr[char], label: Ptr[uint8]) -> int32:
    wfd: int32 = sys_open_write(path)
    if wfd < 0:
        dump_errstr("[nsrun_test] FAIL: open_write errstr=")
        return 1
    wn: int64 = sys_write(wfd, &payload[0], PAYLOAD_LEN)
    sys_close(wfd)
    if wn < 0 or cast[uint64](wn) != PAYLOAD_LEN:
        write_str(1, "[nsrun_test] FAIL: short write\n")
        return 1
    rfd: int32 = sys_open(path)
    if rfd < 0:
        dump_errstr("[nsrun_test] FAIL: reopen errstr=")
        return 1
    rn: int64 = sys_read(rfd, &read_buf[0], 64)
    sys_close(rfd)
    if rn < 0 or cast[uint64](rn) != PAYLOAD_LEN:
        write_str(1, "[nsrun_test] FAIL: readback count mismatch\n")
        return 1
    i: uint64 = 0
    while i < PAYLOAD_LEN:
        if read_buf[i] != payload[i]:
            write_str(1, "[nsrun_test] FAIL: payload mismatch\n")
            return 1
        i = i + 1
    write_str(1, label)
    return 0


# -- mode A: write round trip inside the nsrun namespace ----------------

def do_write_mode() -> int32:
    # 1) Create-on-write-open the probe file. /var is distrofs-served
    #    here; vfs_open_write's 9P probe walks the parent dir, sees the
    #    missing leaf, and routes through p9c_walk_create_path ->
    #    Tcreate against the distrofs daemon.
    wfd: int32 = sys_open_write(cast[Ptr[char]](&probe_path[0]))
    if wfd < 0:
        dump_errstr("[nsrun_test] FAIL: open_write probe errstr=")
        return 1
    wn: int64 = sys_write(wfd, &payload[0], PAYLOAD_LEN)
    if wn < 0:
        dump_errstr("[nsrun_test] FAIL: write errstr=")
        sys_close(wfd)
        return 1
    if cast[uint64](wn) != PAYLOAD_LEN:
        write_str(1, "[nsrun_test] FAIL: short write\n")
        sys_close(wfd)
        return 1
    sys_close(wfd)
    write_str(1, "[nsrun_test] write OK\n")

    # 2) Re-open + read back. Proves the bytes really landed on the
    #    distrofs daemon and survived a fresh walk/open/read.
    rfd: int32 = sys_open(cast[Ptr[char]](&probe_path[0]))
    if rfd < 0:
        dump_errstr("[nsrun_test] FAIL: reopen probe errstr=")
        return 1
    n: int64 = sys_read(rfd, &read_buf[0], 64)
    sys_close(rfd)
    if n < 0:
        write_str(1, "[nsrun_test] FAIL: readback failed\n")
        return 1
    write_str(1, "[nsrun_test] readback=")
    write_dec(1, cast[uint64](n))
    write_str(1, "\n")
    if cast[uint64](n) != PAYLOAD_LEN:
        write_str(1, "[nsrun_test] FAIL: readback count mismatch\n")
        return 1
    i: uint64 = 0
    while i < PAYLOAD_LEN:
        if read_buf[i] != payload[i]:
            write_str(1, "[nsrun_test] FAIL: payload mismatch at i=")
            write_dec(1, i)
            write_str(1, "\n")
            return 1
        i = i + 1
    write_str(1, "[nsrun_test] payload OK\n")

    # 3) Same create/write/read round trip under /usr and /etc. These
    #    mounts were added alongside /var (each is its own distrofs
    #    daemon), so a clean round trip proves all THREE subtrees are
    #    distrofs-backed.
    if roundtrip(cast[Ptr[char]](&usr_path[0]),
                 "[nsrun_test] usr OK\n") != 0:
        return 1
    if roundtrip(cast[Ptr[char]](&etc_path[0]),
                 "[nsrun_test] etc OK\n") != 0:
        return 1

    write_str(1, "[nsrun_test] PASS\n")
    return 0


# -- mode B: isolation probe in the parent namespace --------------------

def do_probe_mode() -> int32:
    # Run bare (no nsrun). /var here is the plain initramfs view, which
    # ships /var/www/* but NOTHING under /var/lib/dpkg/. Opening the
    # probe path MUST fail — if it succeeded, the nsrun child's write
    # would have leaked into a tree the parent shares, breaking the
    # per-process namespace invariant.
    rfd: int32 = sys_open(cast[Ptr[char]](&probe_path[0]))
    if rfd >= 0:
        sys_close(rfd)
        write_str(1,
            "[nsrun_test] FAIL: probe file visible in parent namespace\n")
        return 1
    write_str(1, "[nsrun_test] isolation OK\n")
    write_str(1, "[nsrun_test] PASS\n")
    return 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    init_strings()
    write_str(1, "[nsrun_test] start\n")
    # argv[1] selects the mode. Default (no arg) is "probe" so a bare
    # invocation is the isolation check.
    mode_write: int32 = 0
    if argc >= 2:
        m: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        # "write" starts with 'w'; "probe" with 'p'.
        if m[0] == 119:                          # 'w'
            mode_write = 1
    if mode_write != 0:
        write_str(1, "[nsrun_test] mode=write\n")
        return do_write_mode()
    write_str(1, "[nsrun_test] mode=probe\n")
    return do_probe_mode()
