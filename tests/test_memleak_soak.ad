# tests/test_memleak_soak.ad
#
# Memory-leak accounting fixture for test_memleak_soak.sh.
# Opens /dev/meminfo, reads the blob, and prints key leak-accounting
# fields with a unique prefix that the test script greps for.
#
# Output lines:
#   [memleak] PagesInUse=<N>
#   [memleak] VmaNodesLive=<N>
#   [memleak] TasksLive=<N>
#   [memleak] done
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_memleak_soak.ad -o build/user/test_memleak_soak.elf

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _strlen(s))


# Write a decimal uint64 to fd.
def _write_u64(fd: int32, value: uint64):
    if value == 0:
        s: Ptr[uint8] = "0"
        sys_write(fd, s, 1)
        return
    buf: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        buf[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    # Reverse-print.
    i: uint64 = 0
    while i < n:
        c: uint8 = buf[n - 1 - i]
        sys_write(fd, &c, 1)
        i = i + 1


# Find the value (integer) after `key` in `buf[0..n)`.
# key must end with ':'. Skips spaces, reads digits. Returns 0 if not found.
def _find_uint(buf: Ptr[uint8], n: uint64, key: Ptr[uint8]) -> uint64:
    klen: uint64 = _strlen(key)
    if n < klen:
        return 0
    i: uint64 = 0
    while i + klen <= n:
        # Match key at buf[i]?
        k: uint64 = 0
        ok: int32 = 1
        while k < klen:
            if buf[i + k] != key[k]:
                ok = 0
                k = klen
            k = k + 1
        if ok != 0:
            j: uint64 = i + klen
            # Skip spaces.
            while j < n and buf[j] == 32:
                j = j + 1
            # Read digits.
            result: uint64 = 0
            found_digit: int32 = 0
            while j < n and buf[j] >= 48 and buf[j] <= 57:
                result = result * 10 + cast[uint64](buf[j] - 48)
                found_digit = 1
                j = j + 1
            if found_digit != 0:
                return result
            return 0
        i = i + 1
    return 0


def main() -> int32:
    fd: int32 = sys_open("/dev/meminfo")
    if fd < 0:
        _write_str(1, "[memleak] FAIL: open /dev/meminfo failed\n")
        return 1

    buf: Array[512, uint8]
    n: int64 = sys_read(fd, &buf[0], 511)
    sys_close(fd)
    if n <= 0:
        _write_str(1, "[memleak] FAIL: read /dev/meminfo returned <=0\n")
        return 1

    # Null-terminate for safety (not strictly needed but harmless).
    buf[cast[uint64](n)] = 0

    pages_in_use:   uint64 = _find_uint(&buf[0], cast[uint64](n), "PagesInUse:")
    vma_nodes_live: uint64 = _find_uint(&buf[0], cast[uint64](n), "VmaNodesLive:")
    tasks_live:     uint64 = _find_uint(&buf[0], cast[uint64](n), "TasksLive:")
    tasks_spawned:  uint64 = _find_uint(&buf[0], cast[uint64](n), "TasksSpawned:")
    tasks_reaped:   uint64 = _find_uint(&buf[0], cast[uint64](n), "TasksReaped:")

    _write_str(1, "[memleak] PagesInUse=")
    _write_u64(1, pages_in_use)
    _write_str(1, "\n")

    _write_str(1, "[memleak] VmaNodesLive=")
    _write_u64(1, vma_nodes_live)
    _write_str(1, "\n")

    _write_str(1, "[memleak] TasksLive=")
    _write_u64(1, tasks_live)
    _write_str(1, "\n")

    _write_str(1, "[memleak] TasksSpawned=")
    _write_u64(1, tasks_spawned)
    _write_str(1, "\n")

    _write_str(1, "[memleak] TasksReaped=")
    _write_u64(1, tasks_reaped)
    _write_str(1, "\n")

    _write_str(1, "[memleak] done\n")
    return 0
