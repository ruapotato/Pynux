extern def memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64) -> Ptr[uint8]

# _VFS_NR_FDS itself is imported from kernel/sched/core.ad — we keep its
# size in sync so the cast below is meaningful.
_VFS_NR_FDS: uint32 = 16

# Errno constants (small negative; matches Linux's signs).
ENOENT: int32 = -2
EBADF:  int32 = -9
EPIPE:  int32 = -32
ENOSPC: int32 = -28
EINVAL: int32 = -22
EMFILE: int32 = -24
EROFS:  int32 = -30
EISDIR: int32 = -21
EIO:    int32 = -5

# A FAT fd is tagged FD_FAT_MARK; fd_buf normally holds the read
# open-file slot index (0..7). A write-mode FAT open ORs this bit
# into fd_buf so the dispatch can tell a write fd from a read fd
# without a new FD_*_MARK (those live in core.ad, which is off-limits
# here). The low bits still hold the write-slot index.
FAT_FD_WRITE_BIT: uint64 = 0x80000000

# lseek whence
SEEK_SET: int32 = 0
SEEK_CUR: int32 = 1
SEEK_END: int32 = 2


def vfs_init():
    # Per-task fd tables are initialised in create_user_task /
    # kthread_create. The only filesystem-side work is parsing the
    # embedded cpio archive into the in-memory file_table that the
    # initramfs_entry_* accessors consult.
    cpio_init()
    # V2: tmpfs owns both /tmp/* and /var/*. Pre-create the standard
    # /var skeleton (/var/lib/dpkg, /var/cache/apt, /var/www, ...) so
    # apt / dpkg / httpd find canonical writable paths at boot. /var is
    # RAM-backed and volatile — re-created on every boot.
    tmpfs_var_skeleton_init()


# Kernel-internal initramfs lookup. Used during boot to read /init
# BEFORE any user task exists (and therefore before any fd table is
# in scope). Returns 0 on miss.

def initramfs_data_ptr(name: Ptr[char]) -> uint64:
    idx: int32 = _lookup_name(name)
    if idx < 0:
        return 0
    return cast[uint64](initramfs_entry_data(cast[uint64](idx)))


def initramfs_data_size(name: Ptr[char]) -> uint64:
    idx: int32 = _lookup_name(name)
    if idx < 0:
        return 0
    return initramfs_entry_size(cast[uint64](idx))


# §4 — namespace-aware blob lookup for the ELF loader.
#
# initramfs_data_ptr / initramfs_data_size above are namespace-AGNOSTIC:
# they match a path verbatim against the cpio archive. That is correct
# for the bootstrap /init lookup (before any task / Pgrp exists) but
# WRONG for an execve / interpreter / DSO lookup performed on behalf of
# a running process. Hamnix is Plan 9-shaped — there is no global
# filesystem route; a path resolves through the *calling process's*
# namespace (its Pgrp mount table).
#
# These two helpers run the path through resolve_path() first, which
# applies chan_resolve_prefix()'s longest-prefix mount-table rewrite.
# Concretely: a process that did `bind("/lib", backing/lib)` (the
# distrorun distro-shape graft) will have a namespace where
#   ns_blob_ptr("/lib64/ld-linux-x86-64.so.2")
# resolves to e.g. "/var/lib/distros/debian/lib64/ld-linux-x86-64.so.2"
# and finds the interpreter in the distro tree — while a process with
# no such bind still resolves the path verbatim (resolve_path is a
# no-op rewrite when no mount entry matches), so the native initramfs
# layout keeps working unchanged.
#
# The backing store today is still the cpio initramfs (distrorun grafts
# initramfs directories), so the final lookup remains initramfs_*. When
# a real 9P-served distrofs lands, the post-rewrite path will fall
# under a CHAN_KIND_SRV mount and the loader will need a Chan read
# instead — but the resolve_path() seam here is already namespace-
# correct, so that change is localised to this function pair.

def ns_blob_ptr(name: Ptr[char]) -> uint64:
    # Namespace-aware counterpart of initramfs_data_ptr. Returns the
    # in-memory blob pointer for `name` resolved through the calling
    # task's namespace, or 0 on miss.
    resolved: Array[256, uint8]
    rc: int32 = resolve_path(name, &resolved[0], 256)
    if rc != 0:
        # resolve_path failed (path too long) — fall back to the raw
        # verbatim lookup so a pathological long path still has a
        # chance rather than hard-failing the exec.
        return initramfs_data_ptr(name)
    return initramfs_data_ptr(cast[Ptr[char]](&resolved[0]))


def ns_blob_size(name: Ptr[char]) -> uint64:
    # Namespace-aware counterpart of initramfs_data_size.
    resolved: Array[256, uint8]
    rc: int32 = resolve_path(name, &resolved[0], 256)
    if rc != 0:
        return initramfs_data_size(name)
    return initramfs_data_size(cast[Ptr[char]](&resolved[0]))


def _strcmp_cstr(a: Ptr[char], b: Ptr[char]) -> int32:
    i: int32 = 0
    while True:
        ca: int32 = a[i]
        cb: int32 = b[i]
        if ca != cb:
            return 1
        if ca == 0:
            return 0
        i = i + 1


def _lookup_name(name: Ptr[char]) -> int32:
    count: uint64 = initramfs_entry_count()
    i: uint64 = 0
    while i < count:
        candidate: Ptr[char] = initramfs_entry_name(i)
        if _strcmp_cstr(name, candidate) == 0:
            return cast[int32](i)
        i = i + 1
    return -1


def _alloc_fd(task: Ptr[TaskStruct]) -> int32:
    i: uint64 = 0
    while i < cast[uint64](_VFS_NR_FDS):
        if task[0].fd_idx[i] == FD_CLOSED_MARK:
            return cast[int32](i)
        i = i + 1
    return -1


def _cstr_len(s: Ptr[char]) -> uint64:
    i: uint64 = 0
    while s[i] != 0:
        i = i + 1
    return i


def _is_initramfs_dir(name: Ptr[char]) -> int32:
    # True if `name` is an implicit directory in the cpio archive —
    # i.e. some registered file's path begins with name + "/". Linux's
    # initramfs is flat (no D_TYPE entries; directories are inferred
    # from file paths), so this is how we synthesize "is /etc a dir?".
    # Special-case "/" — root is always a directory if anything is
    # registered.
    nlen: uint64 = _cstr_len(name)
    if nlen == 0:
        return 0
    if nlen == 1 and name[0] == 47:                  # "/"
        return 1
    count: uint64 = initramfs_entry_count()
    i: uint64 = 0
    while i < count:
        candidate: Ptr[char] = initramfs_entry_name(i)
        # Prefix-match name then look for '/' immediately after.
        k: uint64 = 0
        while k < nlen and candidate[k] != 0 and candidate[k] == name[k]:
            k = k + 1
        if k == nlen and candidate[k] == 47:         # '/'
            return 1
        i = i + 1
    return 0


def _cpio_listdir(name: Ptr[char], buf: Ptr[uint8],
                  count: uint64) -> int64:
    # Pack immediate children of `name` into buf as "BASENAME\n"
    # lines. `name` is the directory path WITHOUT a trailing slash
    # (e.g. "/etc"), or "/" for the archive root. Recursive
    # grandchildren collapse to their first path component so we
    # don't list "/etc/profile" twice for "/etc". A "NAME" only
    # appears once even if multiple files live below it.
    if count == 0:
        return 0
    nlen: uint64 = _cstr_len(name)
    is_root: int32 = 0
    if nlen == 1 and name[0] == 47:
        is_root = 1
    cnt: uint64 = initramfs_entry_count()
    out: uint64 = 0
    i: uint64 = 0
    while i < cnt:
        candidate: Ptr[char] = initramfs_entry_name(i)
        # Find the start of the basename within the cpio path.
        # For non-root dirs: must start with name + "/".
        # For root: candidate must start with "/" and we want the
        # first path component (everything between the leading "/"
        # and the next "/" or end).
        start: uint64 = 0
        keep: int32 = 0
        if is_root != 0:
            if candidate[0] == 47:
                start = 1
                keep = 1
        else:
            # Prefix match name + "/".
            k: uint64 = 0
            while k < nlen and candidate[k] != 0 \
                    and candidate[k] == name[k]:
                k = k + 1
            if k == nlen and candidate[k] == 47:
                start = nlen + 1
                keep = 1
        if keep != 0:
            # Compute the basename length (up to next '/' or NUL).
            blen: uint64 = 0
            while candidate[start + blen] != 0 \
                    and candidate[start + blen] != 47:
                blen = blen + 1
            if blen > 0:
                # Dedup: skip if we already emitted this name.
                if _dirbuf_contains(buf, out, candidate, start, blen) == 0:
                    if out + blen + 1 >= count:
                        return cast[int64](out)
                    j: uint64 = 0
                    while j < blen:
                        buf[out + j] = cast[uint8](
                            candidate[start + j] & 0xFF)
                        j = j + 1
                    buf[out + blen] = 10              # '\n'
                    out = out + blen + 1
        i = i + 1
    return cast[int64](out)


def _dirbuf_contains(buf: Ptr[uint8], buf_len: uint64,
                     candidate: Ptr[char], start: uint64,
                     blen: uint64) -> int32:
    # Walk buf (already-emitted "NAME\n" lines, length buf_len) and
    # return 1 if any line equals candidate[start..start+blen]. Used
    # by _cpio_listdir to collapse multiple grandchildren of a dir
    # ("/bin/ls" and "/bin/cat" both contribute "bin" under "/").
    p: uint64 = 0
    while p < buf_len:
        line_start: uint64 = p
        while p < buf_len and buf[p] != 10:
            p = p + 1
        line_len: uint64 = p - line_start
        if p < buf_len:
            p = p + 1                                  # skip '\n'
        if line_len == blen:
            k: uint64 = 0
            matched: int32 = 1
            while k < blen:
                if buf[line_start + k] != cast[uint8](
                        candidate[start + k] & 0xFF):
                    matched = 0
                    k = blen                           # break
                k = k + 1
            if matched != 0:
                return 1
    return 0


def vfs_open(name: Ptr[char]) -> int32:
    # V3.5: Plan 9 `#X` device-alias dispatch. Userspace `init` does
    # the boot-time `bind '#s' /srv` etc. so opens of conventional
    # paths arrive here as `#X/...` (post-chan_resolve_prefix rewrite);
    # but the kernel surface also accepts direct `#X` opens for the
    # boot-strapping init itself, which has to call `bind` BEFORE any
    # `/srv` route exists. The dispatch lives at the top of vfs_open
    # so it shadows any conventional path the user might have planted
    # at the same name. See _open_hash_alias for the per-letter routing
    # (#s, #p, #c, #/).
    if name[0] == 35:                                  # '#'
        return _open_hash_alias(name)
    # /dev/null and /dev/zero are matched before any prefix-routed
    # FS — they're synthetic, with no on-disk backing.
    if _path_eq_const(name, "/dev/null", 9) != 0:
        return _open_dev_marked(FD_DEVNULL_MARK)
    if _path_eq_const(name, "/dev/zero", 9) != 0:
        return _open_dev_marked(FD_DEVZERO_MARK)
    # Phase D: the universal namec open path. namec() walks the
    # calling process's Pgrp mount table; if `name` falls under a 9P
    # SRV-kind mount it produces a mounted-9P Chan, and if `name` is a
    # well-known local cdev (/dev/cons, /dev/time, /dev/pid,
    # /dev/random, /dev/mouse, /dev/cpuinfo, /dev/meminfo, /dev/uptime,
    # /dev/loadavg, /dev/version, /dev/hostname, /dev/stat, /dev/mounts,
    # /dev/diskstats) it produces a local-device Chan — the SAME Chan
    # type either way. _namec_open installs ONE FD_CHAN_MARK fd; the
    # consumer (vfs_read / vfs_write) dispatches it back through
    # namec_read / namec_write, which route devtab vs. mountrpc
    # internally. This single probe REPLACES the dozen
    # _open_dev_marked(FD_<NAME>_MARK) cdev arms AND the old
    # _try_open_p9 arm — the Plan 9 inversion. A P9_NO_MOUNT result
    # means namec does not own this path; we fall through to the
    # on-disk routing below.
    #
    # Ordering: this sits AFTER the `#X`-alias and /dev/null,/dev/zero
    # arms (those are not namec devtab entries) but BEFORE every
    # on-disk route, so a mount or a cdev shadows a same-named local
    # file exactly as Plan 9's namec walk does.
    chan_fd: int32 = _namec_open(name, 0)              # OREAD
    if chan_fd != P9_NO_MOUNT:
        return chan_fd
    # V3.5: the V3-era `/srv`, `/srv/<name>`, `/n` direct routing arms
    # are gone. Those paths now come in here as `#s`, `#s/<name>`,
    # `#/` (rewritten by chan_resolve_prefix after the userspace init
    # planted `bind '#s' /srv`, `bind '#/' /n`), and dispatch via the
    # `#`-prefix arm at the top of this function.
    # /proc/<pid>/{cwd,status,stat,ns,note} are per-process introspection
    # files served by sys/src/9/port/devproc.ad. They land BEFORE
    # the static procfs renderer below because the latter would
    # otherwise turn "/proc/1/status" into an _open_proc() call that
    # kmalloc's a buffer and asks procfs_render() to fill it — and
    # procfs_render only knows the static well-known names
    # (/proc/version, /proc/uptime, ...), so it would return -1 and
    # we'd surface -ENOENT for a path that should work.
    if devproc_path_match(name) != 0:
        rc: int64 = devproc_open(name)
        if rc < 0:
            # devproc_open already called set_current_errstr.
            return ENOENT
        # rc is the encoded marker widened to int64 (always fits in
        # uint32; see devproc_open header for why we widen). Truncate
        # the low 32 bits back to uint32 for the fd_idx slot.
        return _install_proc_fd(cast[uint32](rc & 0xFFFFFFFF))
    # /proc/* paths are rendered into a per-fd kmalloc'd snapshot up
    # front; the resulting fd is read-only and walks the buffer.
    # Routed before the cpio lookup so a cpio entry literally named
    # "/proc/version" couldn't shadow the dynamic file (we don't
    # currently ship one, but the layering is the right way round).
    if is_proc_path(name) != 0:
        return _open_proc(name)
    # Phase D: the V1-era 9P SRV-kind mount probe (_try_open_p9 →
    # FD_P9_MARK) is gone — _namec_open above already routes a 9P-
    # mounted path to a Chan via the same chan_find_srv_prefix +
    # p9c_walk_open_path walk, and installs a unified FD_CHAN_MARK fd
    # instead. One open path, one fd kind, for local devices and
    # mounted servers alike.
    # V2: tmpfs owns /tmp/* and /var/*. /tmp is tmpfs-authoritative
    # (cpio has no /tmp). /var, however, can ALSO have cpio-baked
    # entries (e.g. an httpd docroot staged at /var/www in the
    # initramfs), so a /var path that tmpfs does NOT have falls
    # through to the cpio route below — tmpfs shadows cpio per-entry,
    # not the whole /var subtree. The bare "/var" mount point
    # (is_tmpfs_dir_path) always resolves in tmpfs.
    if is_var_path(name) != 0:
        if tmpfs_path_exists(name) != 0:
            return _open_tmpfs_read(name)
    elif is_tmpfs_path(name) != 0 or is_tmpfs_dir_path(name) != 0:
        return _open_tmpfs_read(name)
    if is_fat_path(name) != 0:
        return _open_fat_read(name)
    if is_ext_path(name) != 0:
        return _open_ext4_read(name)
    file_idx: int32 = _lookup_name(name)
    if file_idx < 0:
        # U32: directory-as-fd. Linux's openat(O_DIRECTORY) needs the
        # caller to be able to follow up with getdents64(). cpio is
        # flat (no DT_DIR entries), so we treat any path that's a
        # prefix of a registered file as an implicit directory and
        # snapshot its immediate children into a kmalloc'd NAME\n
        # buffer that FD_DIR_MARK fds walk. FAT / ext4 dirs go the
        # same path so busybox can ls /mnt as well as /etc.
        if _is_initramfs_dir(name) != 0:
            return _open_dir_cpio(name)
        if is_fat_path(name) != 0 or _path_eq_const(name, "/mnt", 4) != 0:
            return _open_dir_fat(name)
        if is_ext_path(name) != 0 or _path_eq_const(name, "/ext", 4) != 0:
            return _open_dir_ext(name)
        return ENOENT
    task: Ptr[TaskStruct] = current_task()
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu] = cast[uint32](file_idx)
    task[0].fd_pos[fdu] = 0
    return fd


DIR_BUF_SIZE: uint64 = 16384


def _open_dir_cpio(name: Ptr[char]) -> int32:
    return _open_dir_with(name, 0)


def _open_dir_fat(name: Ptr[char]) -> int32:
    return _open_dir_with(name, 1)


def _open_dir_ext(name: Ptr[char]) -> int32:
    return _open_dir_with(name, 2)


def _open_dir_with(name: Ptr[char], backend: int32) -> int32:
    # Common allocate-fd / kmalloc / fill / install pattern for the
    # three readdir backends. `backend` selects which listdir fills
    # the buffer (0 = cpio initramfs, 1 = FAT, 2 = ext4).
    task: Ptr[TaskStruct] = current_task()
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    buf: uint64 = kmalloc(DIR_BUF_SIZE)
    if buf == 0:
        return cast[int32](-12)                       # -ENOMEM
    bufp: Ptr[uint8] = cast[Ptr[uint8]](buf)
    n: int64 = 0
    if backend == 0:
        n = _cpio_listdir(name, bufp, DIR_BUF_SIZE)
    elif backend == 1:
        n = fat_listdir(strip_mnt_prefix(name), bufp, DIR_BUF_SIZE)
        if _path_eq_const(name, "/mnt", 4) != 0:
            n = fat_listdir(cast[Ptr[char]](&_empty_str[0]),
                            bufp, DIR_BUF_SIZE)
    else:
        n = ext4_listdir(strip_ext_prefix(name), bufp, DIR_BUF_SIZE)
        if _path_eq_const(name, "/ext", 4) != 0:
            n = ext4_listdir(cast[Ptr[char]](&_empty_str[0]),
                             bufp, DIR_BUF_SIZE)
    if n < 0:
        kfree(buf)
        return ENOENT
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu]    = FD_DIR_MARK
    task[0].fd_pos[fdu]    = 0
    task[0].fd_buf[fdu]    = buf
    task[0].fd_buflen[fdu] = cast[uint64](n)
    return fd


def _open_dir_srv() -> int32:
    # V3/V3.5: `#s` directory listing (formerly `/srv`). Render the
    # devsrv table into a kmalloc'd buffer; install as an FD_DIR_MARK
    # fd so getdents64 + the busybox `ls` path both see the names.
    # Empty table -> n=0, which getdents64 reports as EOF on the
    # first call.
    task: Ptr[TaskStruct] = current_task()
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    buf: uint64 = kmalloc(DIR_BUF_SIZE)
    if buf == 0:
        return cast[int32](-12)                       # -ENOMEM
    n: int64 = devsrv_list(cast[Ptr[uint8]](buf), DIR_BUF_SIZE)
    if n < 0:
        kfree(buf)
        return ENOENT
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu]    = FD_DIR_MARK
    task[0].fd_pos[fdu]    = 0
    task[0].fd_buf[fdu]    = buf
    task[0].fd_buflen[fdu] = cast[uint64](n)
    return fd


def _open_dir_n() -> int32:
    # V3/V3.5: `#/` (formerly `/n`) — root-dir slot. Empty by default;
    # child Pgrps `bind` or `mount` things into subpaths AFTER doing
    # `bind '#/' /n`, and those bindings show up only as resolved
    # rewrites (the prefix matcher routes opens of `/n/<x>` to the
    # bound target). The slot itself has no synthetic children to
    # enumerate today. Same FD_DIR_MARK shape as the other dir-opens
    # so getdents64 / busybox ls don't need a special case.
    task: Ptr[TaskStruct] = current_task()
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    buf: uint64 = kmalloc(DIR_BUF_SIZE)
    if buf == 0:
        return cast[int32](-12)                       # -ENOMEM
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu]    = FD_DIR_MARK
    task[0].fd_pos[fdu]    = 0
    task[0].fd_buf[fdu]    = buf
    task[0].fd_buflen[fdu] = 0
    return fd


def _open_srv_name(name: Ptr[char]) -> int32:
    # V4: `#s/<name>` (or post-bind `/srv/<name>`) open. Look up the
    # posted entry, then copy_fd_entry from the poster's task slot
    # into the caller's fd table so the returned fd is usable in the
    # caller's context. Misses (no such name) and kernel-only entries
    # (poster_slot=-1) both return ENOENT — the latter because we
    # have no source TaskStruct to dup from.
    src_slot: int32 = -1
    src_fd:   int32 = -1
    rc: int32 = devsrv_lookup_full(name, &src_slot, &src_fd)
    if rc < 0:
        return ENOENT
    if src_slot < 0:
        # Kernel-posted entry; no userspace source task to dup from.
        return ENOENT
    src_task: Ptr[TaskStruct] = task_struct_at(src_slot)
    if cast[uint64](src_task) == 0:
        return ENOENT
    src_fdu: uint64 = cast[uint64](src_fd)
    if src_task[0].fd_idx[src_fdu] == FD_CLOSED_MARK:
        # Poster's fd has since been closed — entry is stale. The
        # next devsrv_post on the same name will overwrite it, but
        # in the meantime the lookup fails.
        return ENOENT
    task: Ptr[TaskStruct] = current_task()
    new_fd: int32 = _alloc_fd(task)
    if new_fd < 0:
        return EMFILE
    if copy_fd_entry(task, cast[uint64](new_fd), src_task, src_fdu) < 0:
        return ENOENT
    return new_fd


def _open_hash_alias(name: Ptr[char]) -> int32:
    # V3.5: Plan 9 `#X` device-alias dispatch.
    #
    # Each letter routes opens to a different kernel device. Userspace
    # init (user/init.ad) does the `bind '#X' /<conventional>` calls
    # at boot; subsequent opens of the conventional path arrive here
    # already-rewritten by chan_resolve_prefix to the `#X` form.
    #
    #   '#s'        -> devsrv directory listing (`/srv` semantics).
    #   '#s/<name>' -> devsrv srvfd lookup (`/srv/<name>` semantics).
    #   '#p'        -> ENOENT (no synthetic listing of /proc itself yet).
    #   '#p/<pid>/<file>' -> devproc dispatch (`/proc/<pid>/<file>`).
    #   '#c'        -> /dev/cons-equivalent (read keyboard + UART RX,
    #                  write printk + serial + framebuffer).
    #   '#/'        -> empty-directory "root slot" (`/n` semantics —
    #                  conventional mount-point parent; child Pgrps
    #                  populate via `bind '#/' /n` + `mount srv /n/<x>`).
    #
    # Anything else is ENOENT — extending the alphabet is a V4-or-
    # later question (`#e` envdev, `#d` devdir, etc.).
    if name[1] == 0:
        # Bare '#'.
        return ENOENT
    letter: int32 = name[1]
    # '#s' family — devsrv.
    if letter == 115:                                  # 's'
        if name[2] == 0:
            return _open_dir_srv()
        if name[2] == 47 and name[3] != 0:             # '#s/<...>'
            # devsrv_open expects a NUL-terminated leaf (no slashes);
            # walk the leaf and stop at the next '/' or NUL.
            i: uint64 = 3
            while name[i] != 0:
                if name[i] == 47:
                    return ENOENT                      # nested
                i = i + 1
            # Pass the leaf pointer (name + 3) directly — devsrv_open's
            # internal _srv_streq is NUL-terminated.
            leaf: Ptr[char] = cast[Ptr[char]](
                cast[uint64](name) + 3)
            return _open_srv_name(leaf)
        return ENOENT
    # '#p' family — devproc. Translate to a `/proc/<pid>/<file>`
    # NUL-terminated scratch string and forward to devproc_open. The
    # translation is cheap (8-byte prefix swap) and keeps devproc.ad
    # ignorant of the alias surface — same code path as a literal
    # /proc/<pid>/<file> open from a task that hasn't run init's bind.
    if letter == 112:                                  # 'p'
        if name[2] == 0:
            return ENOENT                              # bare '#p'
        if name[2] != 47:
            return ENOENT
        return _open_hash_proc(name)
    # '#c' — console. Same shape as /dev/cons; FD_CONS_MARK is
    # stateless so the open is just a marked fd. Accepts '#c' bare
    # AND '#c/<leaf>' so future devcons paths (e.g. '#c/cons',
    # '#c/consctl') can land here without a routing change.
    if letter == 99:                                   # 'c'
        if name[2] == 0 or name[2] == 47:
            return _open_dev_marked(FD_CONS_MARK)
        return ENOENT
    # '#/' — root-dir slot. Synthetic empty directory; identical
    # shape to V3's `/n` (V3.5 rename: the concept is "anywhere bind
    # can graft against an empty parent", not specifically /n).
    if letter == 47:                                   # '/'
        if name[2] == 0:
            return _open_dir_n()
        return ENOENT
    # '#d' — HAMSH §7 fd device. `#d/<N>` resolves to the channel
    # bound at the name /fd/<N> in the calling process's Pgrp. The
    # open installs an FD_DEVFD_MARK fd whose fd_buf carries the
    # fd-number N; vfs_read / vfs_write resolve the name through the
    # per-Pgrp devfd table at I/O time. This is the substrate stdio
    # rides on — the Linux integer fd 0/1/2/N is a Layer-2 mapping
    # ONTO the name /fd/N, not the name itself.
    if letter == 100:                                  # 'd'
        if name[2] != 47 or name[3] == 0:              # need '#d/<N>'
            return ENOENT
        # Parse the decimal fd-number after '#d/'.
        fdnum: int32 = 0
        i: uint64 = 3
        while name[i] != 0:
            c: int32 = name[i]
            if c < 48 or c > 57:
                return ENOENT                          # non-digit
            fdnum = fdnum * 10 + (c - 48)
            i = i + 1
        return _open_devfd_marked(fdnum)
    return ENOENT


def _open_devfd_marked(fdnum: int32) -> int32:
    # Install an FD_DEVFD_MARK fd carrying the fd-number N. Stateless
    # at open time — the backing channel is resolved per-read/write
    # against the calling task's Pgrp devfd table, so a child that
    # inherits this fd resolves /fd/N in ITS namespace, not the
    # opener's. fd_pos is the cursor for file-backed channels.
    task: Ptr[TaskStruct] = current_task()
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu] = FD_DEVFD_MARK
    task[0].fd_pos[fdu] = 0
    task[0].fd_buf[fdu] = cast[uint64](cast[uint32](fdnum))
    return fd


def _open_hash_proc(name: Ptr[char]) -> int32:
    # Translate `#p/<pid>/<file>` to `/proc/<pid>/<file>` in a 64-byte
    # scratch and forward to devproc_open. The scratch lives on this
    # frame because devproc_open's _parse_proc_path only reads — it
    # doesn't retain the pointer past return — so a stack buffer is
    # safe.
    scratch: Array[64, uint8]
    scratch[0] = 47                                    # '/'
    scratch[1] = 112                                   # 'p'
    scratch[2] = 114                                   # 'r'
    scratch[3] = 111                                   # 'o'
    scratch[4] = 99                                    # 'c'
    # name[0]='#', name[1]='p', name[2]='/', leaf starts at name[3].
    j: uint64 = 5
    i: uint64 = 2                                      # keep the '/'
    while name[i] != 0:
        if j + 1 >= 64:
            return ENOENT                              # path too long
        scratch[j] = cast[uint8](name[i] & 0xFF)
        j = j + 1
        i = i + 1
    scratch[j] = 0
    rc: int64 = devproc_open(cast[Ptr[char]](&scratch[0]))
    if rc < 0:
        return ENOENT
    return _install_proc_fd(cast[uint32](rc & 0xFFFFFFFF))


def vfs_open_write(name: Ptr[char]) -> int32:
    # Open-or-create for write with O_CREAT | O_WRONLY | O_TRUNC
    # semantics, which is what `> file` shell redirection wants.
    # Writable backends:
    #   - /dev/null   — discards everything
    #   - /dev/zero   — same; writes are no-ops
    #   - tmpfs (in-RAM /tmp/*)
    #   - ext4 root (/ext/*) since M16.64 — single-block files only
    # cpio (initramfs) is read-only baked-in; procfs is read-only by
    # design; FAT writes aren't wired.
    # V3.5: `#X` device aliases route through _open_hash_alias for
    # consistency with the read side. devcons is the only `#X` device
    # with a meaningful write path today (#s posts are sys_srv_post,
    # not file-write), but routing through one place keeps the
    # dispatch logic in lockstep when V4 adds writable srv/proc nodes.
    if name[0] == 35:                                  # '#'
        return _open_hash_alias(name)
    if _path_eq_const(name, "/dev/null", 9) != 0:
        return _open_dev_marked(FD_DEVNULL_MARK)
    if _path_eq_const(name, "/dev/zero", 9) != 0:
        return _open_dev_marked(FD_DEVZERO_MARK)
    # Phase D: the universal namec open path, OWRITE side. The same
    # probe vfs_open uses for reads — namec() walks the Pgrp mount
    # table, produces a local-device Chan for a /dev/<name> cdev or a
    # mounted-9P Chan for a path under a 9P SRV mount, and _namec_open
    # installs ONE FD_CHAN_MARK fd. Read-only cdevs (/dev/time,
    # /dev/version, ...) still open cleanly here; their devtab write
    # arm returns -1 so the rejection surfaces at write(2), exactly as
    # it did through the old FD_<NAME>_MARK arms. /dev/hostname's
    # devtab write arm accepts bytes. A P9_NO_MOUNT result means namec
    # does not own this path — fall through to the FS write routing.
    chan_wfd: int32 = _namec_open(name, 1)             # OWRITE
    if chan_wfd != P9_NO_MOUNT:
        if chan_wfd == ENOENT:
            # The path is under a 9P mount but the file doesn't exist
            # yet — create it through namec_create (Tcreate via the
            # in-kernel 9P client). namec_create returns P9_NO_MOUNT
            # only if the SRV-mount probe somehow misses on the retry
            # (it won't — the prefix matched a line ago); treat that
            # as the original ENOENT to stay deterministic.
            chan_cfd: int32 = _namec_open_create(name)
            if chan_cfd != P9_NO_MOUNT:
                return chan_cfd
            return ENOENT
        return chan_wfd
    # /proc/<pid>/* also opens on the OWRITE path so future note(2)
    # delivery (write("/proc/<pid>/note", ...)) flows through the
    # same dispatch. devproc_write currently returns -1 across the
    # board — userland sees the rejection at write(2), not open(2).
    if devproc_path_match(name) != 0:
        rc: int64 = devproc_open(name)
        if rc < 0:
            return ENOENT
        return _install_proc_fd(cast[uint32](rc & 0xFFFFFFFF))
    # Phase D: the V4.1-era 9P SRV-mount OWRITE probe (_try_open_p9_write
    # / _try_create_p9 → FD_P9_MARK) is gone — the _namec_open OWRITE
    # probe above already routes a 9P-mounted path (walk+Topen, or
    # walk+Tcreate on a miss) to a Chan and installs a unified
    # FD_CHAN_MARK fd.
    if is_tmpfs_path(name) != 0:
        # tmpfs_open_for_write returns a negative TMPFS_E* on failure
        # (-2 missing parent dir, -17 the path is a directory, -20 a
        # parent component is a file, -28 out of slots). Propagate it
        # verbatim so the caller's errstr reflects the real cause.
        slot: int32 = tmpfs_open_for_write(name)
        if slot < 0:
            return slot
        task: Ptr[TaskStruct] = current_task()
        fd: int32 = _alloc_fd(task)
        if fd < 0:
            return EMFILE
        fdu: uint64 = cast[uint64](fd)
        task[0].fd_idx[fdu] = FD_TMPFS_MARK
        task[0].fd_pos[fdu] = 0
        task[0].fd_buf[fdu] = cast[uint64](slot)
        return fd
    if is_ext_path(name) != 0:
        # M16.64 scope: root dir only. strip_ext_prefix gives us the
        # bare leaf name. A subdir-bearing path (e.g. /ext/sub/foo)
        # falls through to create_or_trunc which scans root only and
        # refuses; that's a graceful -EROFS for now.
        eslot: int32 = ext4_open_create_or_trunc(strip_ext_prefix(name))
        if eslot < 0:
            return ENOSPC
        task: Ptr[TaskStruct] = current_task()
        fd: int32 = _alloc_fd(task)
        if fd < 0:
            ext4_close(eslot)
            return EMFILE
        fdu: uint64 = cast[uint64](fd)
        task[0].fd_idx[fdu] = FD_EXT4_MARK
        task[0].fd_pos[fdu] = 0
        task[0].fd_buf[fdu] = cast[uint64](eslot)
        return fd
    if is_fat_path(name) != 0:
        # M16.x §12.5: FAT write path. O_CREAT|O_TRUNC create, then
        # a write-mode slot. The fd is FD_FAT_MARK with the write bit
        # set in fd_buf so the dispatch tells write fds from read fds.
        wslot: int32 = fat_open_write(strip_mnt_prefix(name))
        if wslot < 0:
            return ENOSPC
        task: Ptr[TaskStruct] = current_task()
        fd: int32 = _alloc_fd(task)
        if fd < 0:
            fat_close_write(wslot)
            return EMFILE
        fdu: uint64 = cast[uint64](fd)
        task[0].fd_idx[fdu] = FD_FAT_MARK
        task[0].fd_pos[fdu] = 0
        task[0].fd_buf[fdu] = cast[uint64](wslot) | FAT_FD_WRITE_BIT
        return fd
    return EROFS


def vfs_unlink(name: Ptr[char]) -> int32:
    # Mirrors fs/namei.c::do_unlinkat() at the smallest meaningful
    # scope: route by path prefix to the backing FS.
    #   /tmp/*  →  tmpfs_unlink
    #   /ext/*  →  ext4_unlink (M16.67, root dir + single-block scope)
    # Everything else falls back to -EROFS.
    if is_tmpfs_path(name) != 0:
        return tmpfs_unlink(name)
    if is_ext_path(name) != 0:
        return ext4_unlink(strip_ext_prefix(name))
    if is_fat_path(name) != 0:
        # M16.x §12.5: FAT delete — frees the cluster chain and
        # tombstones the directory entry.
        if fat_delete(strip_mnt_prefix(name)) != 0:
            return ENOENT
        return 0
    return EROFS


def vfs_mkdir(name: Ptr[char]) -> int32:
    # fs/namei.c::do_mkdirat() at the smallest meaningful scope. The
    # caller passes an already-resolved absolute path.
    #   9P-mounted prefix  →  namec_mkdir (Tcreate DMDIR, mkdir -p)
    #   /tmp/*             →  tmpfs_mkdir (creates a dir entry under
    #                         the parent)
    #   else               →  -EROFS
    # The 9P arm comes FIRST: a path under a distrofs (or any 9P SRV)
    # mount must mkdir on the server, not fall through to the local
    # tmpfs/cpio routing. This is what lets `dpkg -i` create nested
    # package directories (/usr/bin, /usr/share/doc/<pkg>, ...) inside
    # an nsrun distrofs namespace. namec_mkdir returns NAMEC_FALLTHROUGH
    # when no 9P mount covers the path — then we fall to tmpfs.
    nm_rc: int32 = namec_mkdir(name)
    if nm_rc != NAMEC_FALLTHROUGH:
        if nm_rc < 0:
            return ENOENT
        return 0
    # tmpfs_mkdir returns 0 / -ENOENT / -EEXIST / -ENOTDIR / -ENOSPC /
    # -ENAMETOOLONG, propagated verbatim.
    if is_tmpfs_path(name) != 0:
        return tmpfs_mkdir(name)
    return EROFS


def vfs_rename(oldname: Ptr[char], newname: Ptr[char]) -> int32:
    # Plan 9 wstat(2)'s "change the name field" leg. tmpfs and ext4
    # are both wired; ext4 does the dirent remove + insert (with
    # overwrite of an existing destination) in fs/ext4.ad. Both names
    # must live in the same backend — cross-backend renames return
    # -EROFS (a copy+unlink would be the userspace fallback).
    if is_tmpfs_path(oldname) != 0:
        if is_tmpfs_path(newname) == 0:
            return EROFS
        return tmpfs_rename(oldname, newname)
    if is_ext_path(oldname) != 0:
        if is_ext_path(newname) == 0:
            return EROFS
        return ext4_rename(strip_ext_prefix(oldname),
                           strip_ext_prefix(newname))
    return EROFS


def vfs_fsync(fd: int32) -> int32:
    # fsync(2) / fdatasync(2): flush the file's dirty data + metadata
    # to durable storage. Our write path is write-through and ordered
    # (data block written before the inode that references it), so
    # the ordering half of fsync's contract is already met when each
    # write returns. fsync's remaining job is the device-cache
    # barrier — ext4_fsync issues blk_flush on the mounted device.
    #
    #   FD_EXT4_MARK  →  ext4_fsync (real device barrier)
    #   FD_TMPFS_MARK →  0 (tmpfs is RAM-backed; nothing to flush)
    #   other fds     →  0 (pipes/sockets/devnull have no durable
    #                       backing — fsync is a successful no-op,
    #                       which is what Linux returns for them too)
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return rc
    task: Ptr[TaskStruct] = current_task()
    fdu: uint64 = cast[uint64](fd)
    file_idx: uint32 = task[0].fd_idx[fdu]
    if file_idx == FD_CLOSED_MARK:
        return EBADF
    if file_idx == FD_EXT4_MARK:
        return ext4_fsync()
    return 0


def vfs_fsync_all() -> int32:
    # sync(2): flush every writable filesystem. Today the only durable
    # mount is ext4 — tmpfs/procfs/pipes have no on-disk backing — so
    # this is ext4_fsync(). Returns 0 always (sync(2) cannot fail);
    # ext4_fsync's -1-when-unmounted is swallowed since "no ext4
    # mount" is not a sync failure.
    ext4_fsync()
    return 0


def vfs_ftruncate(fd: int32, length: uint64) -> int32:
    # ftruncate(2): resize the open file referenced by `fd` to exactly
    # `length` bytes. Routes to the backing FS's truncate.
    #
    #   FD_EXT4_MARK  →  ext4_truncate_inode (frees / zero-fills blocks)
    #   other fds     →  -EINVAL (tmpfs ftruncate is a separate job in
    #                    fs/tmpfs.ad; pipes/sockets are not regular
    #                    files so -EINVAL is the correct refusal)
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return rc
    task: Ptr[TaskStruct] = current_task()
    fdu: uint64 = cast[uint64](fd)
    file_idx: uint32 = task[0].fd_idx[fdu]
    if file_idx == FD_CLOSED_MARK:
        return EBADF
    if file_idx == FD_EXT4_MARK:
        eslot: int32 = cast[int32](task[0].fd_buf[fdu])
        inum: uint32 = ext4_open_inum(eslot)
        if inum == 0:
            return EINVAL
        if ext4_truncate_inode(inum, length) != 0:
            return EIO
        # Keep the cached open-file size coherent for read-back.
        ext4_set_open_size(eslot, length)
        return 0
    return EINVAL


def vfs_truncate(name: Ptr[char], length: uint64) -> int32:
    # truncate(2): resize the file named by an absolute path. Only
    # ext4 has a path-resolved truncate; tmpfs/cpio paths return
    # -EROFS / -EINVAL. ext4_resolve_file walks the path to the
    # file's inum, then ext4_truncate_inode does the resize.
    if is_ext_path(name) != 0:
        inum: uint32 = 0
        fsize: uint64 = 0
        if ext4_resolve_file(strip_ext_prefix(name), &inum,
                             &fsize) == 0:
            return ENOENT
        if ext4_truncate_inode(inum, length) != 0:
            return EIO
        return 0
    if is_tmpfs_path(name) != 0:
        return EINVAL
    return EROFS


def _path_eq_const(name: Ptr[char], expected: Ptr[uint8],
                   length: int32) -> int32:
    # True if name[0..length] matches expected and name[length] == 0.
    i: int32 = 0
    while i < length:
        if name[i] != cast[int32](expected[i]):
            return 0
        i = i + 1
    if name[length] != 0:
        return 0
    return 1


def vfs_listdir(name: Ptr[char], buf: Ptr[uint8],
                count: uint64) -> int64:
    # Path-resolution wrapper. Routes the calling listdir to the
    # right backing FS by path prefix:
    #
    #   /mnt or /mnt/*     →  FAT
    #   /ext or /ext/*     →  EXT4 (root only for now)
    #   /, /etc, /bin, ... →  cpio initramfs (implicit dirs)
    #   anything else      →  -EINVAL
    #
    # The cpio branch is what makes `ls /`, `ls /etc`, and (after
    # `cd /etc`) bare `ls` work — pre-M16.135 those all returned
    # -EINVAL because vfs_listdir only knew about FAT + ext4. The
    # opendir/getdents path in vfs_open already routed cpio via
    # _is_initramfs_dir, so this mirrors that dispatch — the
    # asymmetry was the bug. Discovered on real-hardware GNOME
    # Boxes testing where `ls` (no args) and `ls <any path>`
    # showed "listdir failed".
    if is_fat_path(name) != 0:
        return fat_listdir(strip_mnt_prefix(name), buf, count)
    if is_ext_path(name) != 0:
        return ext4_listdir(strip_ext_prefix(name), buf, count)
    # V1: tmpfs is a tree — `/tmp` and any mkdir'd subdir are real
    # directories. Routed before the cpio fallback (the initramfs has
    # no /tmp entry, so _is_initramfs_dir would never match it).
    # V2: /var is also tmpfs-backed, but a /var path that tmpfs does
    # not own falls through to cpio (per-entry shadow, same rule as
    # the OREAD dispatch) so a cpio-baked /var directory still lists.
    if is_var_path(name) != 0:
        if tmpfs_path_is_dir(name) != 0:
            return tmpfs_listdir(name, buf, count)
    elif is_tmpfs_path(name) != 0 or is_tmpfs_dir_path(name) != 0:
        if tmpfs_path_is_dir(name) != 0:
            return tmpfs_listdir(name, buf, count)
        return cast[int64](EINVAL)
    if _path_eq_const(name, "/mnt", 4) != 0:
        return fat_listdir(cast[Ptr[char]](&_empty_str[0]), buf, count)
    if _path_eq_const(name, "/ext", 4) != 0:
        return ext4_listdir(cast[Ptr[char]](&_empty_str[0]), buf, count)
    # V3.5: Plan 9 `#X` device-alias listing. `#s` renders the
    # devsrv table; `#/` (the root-dir slot, formerly the kernel's
    # synthetic `/n`) renders to 0 bytes because the slot has no
    # synthetic children — its only purpose is to be `bind`-targeted.
    # The V3 `/srv` / `/n` arms here are gone; if a caller really
    # wants `/srv`'s contents and userspace init has run, the path
    # has already been rewritten to `#s` by chan_resolve_prefix
    # before reaching vfs_listdir.
    if name[0] == 35:                                  # '#'
        if name[1] == 115 and name[2] == 0:            # '#s'
            return devsrv_list(buf, count)
        if name[1] == 47 and name[2] == 0:             # '#/'
            return 0
        return cast[int64](EINVAL)
    if _is_initramfs_dir(name) != 0:
        return _cpio_listdir(name, buf, count)
    return cast[int64](EINVAL)


_empty_str: Array[1, uint8]


ENAMETOOLONG: int32 = -36


def _normalize_inplace(buf: Ptr[uint8]):
    # Compact "." and ".." components in-place on an absolute path.
    # buf must start with '/' and be NUL-terminated. After the pass:
    #
    #   "/foo/./bar"      -> "/foo/bar"
    #   "/foo/bar/.."     -> "/foo"
    #   "/.."             -> "/"
    #   "/a//b"           -> "/a/b"
    #
    # In-place is safe because write_pos always moves at most as fast
    # as read_pos; we only ever copy from a higher buffer index to a
    # lower one (or to itself).
    #
    # Bug-fix: the original implementation used `buf[read_pos] != 0`
    # as the outer-loop termination. That breaks on inputs like
    # "/etc/motd" where the second component ends exactly at the
    # buffer NUL: after copying "motd" forward, the body writes
    # buf[write_pos] = '/' at the SAME index the NUL was sitting in.
    # The outer loop then re-reads that fresh '/' as if it were more
    # input and walks off into uninitialised stack bytes — which on
    # an unlucky stack produces /etc/motd/<garbage>\0 in the output.
    # We snapshot the input length first and bound the outer loop on
    # it, so writes can't extend the "live" region the loop reads.
    end: uint64 = 0
    while buf[end] != 0:
        end = end + 1
    read_pos:  uint64 = 1                  # skip leading '/'
    write_pos: uint64 = 1
    while read_pos < end:
        comp_start: uint64 = read_pos
        while read_pos < end and buf[read_pos] != 47:
            read_pos = read_pos + 1
        comp_len: uint64 = read_pos - comp_start
        if read_pos < end and buf[read_pos] == 47:
            read_pos = read_pos + 1
        if comp_len == 0:
            # Empty (consecutive '/' or trailing '/'). Skip.
            continue
        if comp_len == 1 and buf[comp_start] == 46:
            # "." — skip.
            continue
        if comp_len == 2 and buf[comp_start] == 46 \
                and buf[comp_start + 1] == 46:
            # ".." — pop the previous component if any. Walk
            # write_pos back past the previous "/" and the entry
            # before it.
            if write_pos > 1:
                write_pos = write_pos - 1          # drop trailing '/'
                while write_pos > 1 and buf[write_pos - 1] != 47:
                    write_pos = write_pos - 1
            continue
        # Keep component: copy comp_start..comp_start+comp_len to
        # write_pos, then add separator.
        i: uint64 = 0
        while i < comp_len:
            buf[write_pos + i] = buf[comp_start + i]
            i = i + 1
        write_pos = write_pos + comp_len
        buf[write_pos] = 47
        write_pos = write_pos + 1
    # Strip the trailing '/' we appended (unless we're sitting on
    # the root '/').
    if write_pos > 1 and buf[write_pos - 1] == 47:
        write_pos = write_pos - 1
    buf[write_pos] = 0


def _resolve_path_canonical(input: Ptr[char], output: Ptr[uint8],
                            count: uint64) -> int32:
    # Phase C / M16.107: canonicalise step. Produces an absolute,
    # normalised path in `output` from `input`. Pre-M16.105 this WAS
    # resolve_path; we've factored it out so resolve_path can layer
    # a mount-table prefix rewrite on top of the canonical form.
    if count == 0:
        return ENAMETOOLONG
    if input[0] == 47:                         # '/'
        i: uint64 = 0
        while i + 1 < count:
            c: uint8 = cast[uint8](input[i] & 0xFF)
            output[i] = c
            if c == 0:
                _normalize_inplace(output)
                return 0
            i = i + 1
        output[i] = 0
        return ENAMETOOLONG
    # Relative — prepend cwd. Append '/' between cwd and input
    # unless cwd already ends in one.
    cwd: Ptr[uint8] = get_cwd_buf(current_idx_get())
    j: uint64 = 0
    while j + 1 < count and cwd[j] != 0:
        output[j] = cwd[j]
        j = j + 1
    if j == 0:
        return ENAMETOOLONG                    # cwd was empty
    if output[j - 1] != 47:
        if j + 1 >= count:
            return ENAMETOOLONG
        output[j] = 47
        j = j + 1
    i: uint64 = 0
    while j + 1 < count:
        c: uint8 = cast[uint8](input[i] & 0xFF)
        output[j] = c
        if c == 0:
            _normalize_inplace(output)
            return 0
        i = i + 1
        j = j + 1
    output[j] = 0
    return ENAMETOOLONG


def resolve_path(input: Ptr[char], output: Ptr[uint8],
                 count: uint64) -> int32:
    # Produce an absolute, normalised path in `output` from `input`
    # (which may be absolute or relative, with or without "." /
    # ".."). Returns 0 on success, -ENAMETOOLONG if the absolute
    # form (before normalisation) wouldn't fit.
    #
    # Phase C / M16.107: after canonicalisation, consult the per-task
    # mount table via chan_resolve_prefix(). On a longest-prefix
    # match, the bound `from` prefix is rewritten to the entry's
    # `to` prefix and the rewritten path replaces `output[]`. This
    # is what makes `bind("/etc", "/sysroot")` cause subsequent
    # `open("/sysroot/motd")` to land on the cpio-backed /etc/motd.
    # No match: leave `output` as the canonical form — the original
    # behaviour pre-mount-table.
    #
    # V3.5: `#X` device-alias paths bypass canonicalisation +
    # mount-table rewrite entirely. They're a Plan 9-shape direct-
    # to-device reference — there's nothing for `.`/`..`/cwd-prepend
    # to do (the first character isn't `/`), and `chan_resolve_prefix`
    # only rewrites `/`-prefixed paths anyway. Copy the input through
    # verbatim so vfs_open's `#`-prefix dispatch sees the raw alias.
    if input[0] == 35:                                 # '#'
        i: uint64 = 0
        while i + 1 < count:
            c: uint8 = cast[uint8](input[i] & 0xFF)
            output[i] = c
            if c == 0:
                return 0
            i = i + 1
        output[i] = 0
        return ENAMETOOLONG
    rc: int32 = _resolve_path_canonical(input, output, count)
    if rc != 0:
        return rc
    # Mount-table rewrite. The helper writes into a scratch buffer
    # then copies back into `output` on a hit. Doing the copy here
    # (rather than passing `output` as both src and dst) avoids any
    # aliasing risk inside chan_resolve_prefix when the rewritten
    # path is longer than the input.
    scratch: Array[256, uint8]
    hit: int32 = chan_resolve_prefix(output, &scratch[0], count)
    if hit == 1:
        i: uint64 = 0
        while i + 1 < count:
            c: uint8 = scratch[i]
            output[i] = c
            if c == 0:
                return 0
            i = i + 1
        output[i] = 0
        return ENAMETOOLONG
    if hit < 0:
        return ENAMETOOLONG
    return 0


def vfs_pipe(out_fds: Ptr[int32]) -> int32:
    # Allocate a kernel pipe and place its read fd in out_fds[0] and
    # write fd in out_fds[1] in the calling task. Returns 0 on
    # success; -EMFILE if the caller doesn't have two free fd slots,
    # -ENOSPC if the global pipe table is full. We allocate fds in
    # the parent task only — children inherit by dup'ing.
    task: Ptr[TaskStruct] = current_task()
    rfd: int32 = _alloc_fd(task)
    if rfd < 0:
        return EMFILE
    # Provisionally mark rfd used so _alloc_fd skips it when we ask
    # for the second fd, but we haven't routed it anywhere yet.
    task[0].fd_idx[cast[uint64](rfd)] = FD_PIPE_MARK_R
    wfd: int32 = _alloc_fd(task)
    if wfd < 0:
        # Roll back the half-taken read fd before we error out.
        task[0].fd_idx[cast[uint64](rfd)] = FD_CLOSED_MARK
        return EMFILE

    slot: int32 = pipe_alloc()
    if slot < 0:
        task[0].fd_idx[cast[uint64](rfd)] = FD_CLOSED_MARK
        return ENOSPC

    rfdu: uint64 = cast[uint64](rfd)
    wfdu: uint64 = cast[uint64](wfd)
    task[0].fd_idx[rfdu] = FD_PIPE_MARK_R
    task[0].fd_pos[rfdu] = 0
    task[0].fd_buf[rfdu] = cast[uint64](slot)
    task[0].fd_idx[wfdu] = FD_PIPE_MARK_W
    task[0].fd_pos[wfdu] = 0
    task[0].fd_buf[wfdu] = cast[uint64](slot)

    out_fds[0] = rfd
    out_fds[1] = wfd
    return 0


def vfs_socketpair(out_fds: Ptr[int32]) -> int32:
    # V5: allocate a bidirectional socketpair in the calling task. Two
    # fds back the same SocketPair slot — fd[0] is end A, fd[1] is end
    # B. Writes on one fd appear as reads on the other and vice versa.
    # Returns 0 on success; -EMFILE if the caller can't fit two more
    # fds, -ENOSPC if the global SocketPair table is full.
    #
    # Mirrors vfs_pipe's allocation shape (alloc two fds first, then
    # the backing slot, roll back on failure) so the failure paths look
    # the same to the syscall dispatcher.
    task: Ptr[TaskStruct] = current_task()
    afd: int32 = _alloc_fd(task)
    if afd < 0:
        return EMFILE
    task[0].fd_idx[cast[uint64](afd)] = FD_SOCKETPAIR_MARK
    bfd: int32 = _alloc_fd(task)
    if bfd < 0:
        task[0].fd_idx[cast[uint64](afd)] = FD_CLOSED_MARK
        return EMFILE

    slot: int32 = sockpair_alloc()
    if slot < 0:
        task[0].fd_idx[cast[uint64](afd)] = FD_CLOSED_MARK
        return ENOSPC

    afdu: uint64 = cast[uint64](afd)
    bfdu: uint64 = cast[uint64](bfd)
    task[0].fd_idx[afdu] = FD_SOCKETPAIR_MARK
    task[0].fd_pos[afdu] = 0
    task[0].fd_buf[afdu] = sockpair_pack(slot, 0)
    task[0].fd_idx[bfdu] = FD_SOCKETPAIR_MARK
    task[0].fd_pos[bfdu] = 0
    task[0].fd_buf[bfdu] = sockpair_pack(slot, 1)

    out_fds[0] = afd
    out_fds[1] = bfd
    return 0


def vfs_fd_is_socketpair(fd: int32) -> int32:
    # V5: cheap probe so the 9P client (sys/src/9/port/9p_client.ad)
    # can detect a bidirectional transport without importing
    # FD_SOCKETPAIR_MARK directly. Returns 1 if `fd` is a live
    # socketpair endpoint, 0 otherwise.
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return 0
    task: Ptr[TaskStruct] = current_task()
    if task[0].fd_idx[cast[uint64](fd)] == FD_SOCKETPAIR_MARK:
        return 1
    return 0


def vfs_fd_socketpair_packed(fd: int32) -> uint64:
    # V5: accessor for the (slot << 1 | direction) packed in fd_buf.
    # Caller is responsible for vfs_fd_is_socketpair(fd) == 1 before
    # calling; we don't re-validate here because the 9P client has
    # already gated on the probe and re-running _check_fd would
    # double the per-byte overhead of every send/recv.
    task: Ptr[TaskStruct] = current_task()
    return task[0].fd_buf[cast[uint64](fd)]


def vfs_srv_dup_into_current(src_task: Ptr[TaskStruct],
                             src_fdu: uint64) -> int32:
    # V4 / sys_srv_open helper. Allocate the lowest free fd in the
    # CURRENT task, then copy_fd_entry from src_task[src_fdu] into
    # it. Returns the new fd on success, -EBADF if the source slot
    # is closed, -EMFILE if the caller is out of fd slots. Used by
    # arch/x86/kernel/syscall.ad::SYS_SRV_OPEN; lives here so the
    # `_alloc_fd` private helper stays private and the same
    # validation order is used as the rest of the open-family
    # routes (pipe, dup, dup2, FAT/EXT open).
    if cast[uint64](src_task) == 0:
        return EBADF
    if src_task[0].fd_idx[src_fdu] == FD_CLOSED_MARK:
        return EBADF
    task: Ptr[TaskStruct] = current_task()
    new_fd: int32 = _alloc_fd(task)
    if new_fd < 0:
        return EMFILE
    if copy_fd_entry(task, cast[uint64](new_fd), src_task, src_fdu) < 0:
        return EBADF
    return new_fd


def vfs_alloc_socket_fd() -> int32:
    # U35: claim an empty fd-table slot and mark it FD_SOCKET_MARK.
    # Used by the Linux-ABI socket(2) handler — Hamnix has no real
    # network stack, but glibc / busybox paths that probe socket(2)
    # then poll/close still need a valid fd back. fd_buf / fd_pos
    # stay zero; reads return EOF, writes consume bytes silently
    # (see the FD_SOCKET_MARK arms in vfs_read / vfs_write above).
    task: Ptr[TaskStruct] = current_task()
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu]    = FD_SOCKET_MARK
    task[0].fd_pos[fdu]    = 0
    task[0].fd_buf[fdu]    = 0
    task[0].fd_buflen[fdu] = 0
    return fd


def vfs_fd_is_socket(fd: int32) -> int32:
    # U35: cheap probe so poll(2) can recognise socket fds without
    # importing FD_SOCKET_MARK directly into u_syscalls.ad. Returns 1
    # on a live socket fd, 0 otherwise (including out-of-range / closed).
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return 0
    task: Ptr[TaskStruct] = current_task()
    if task[0].fd_idx[cast[uint64](fd)] == FD_SOCKET_MARK:
        return 1
    return 0


def vfs_socket_fd_set_record(fd: int32, fdbuf: uint64) -> int32:
    # U-socket: stash the encoded u_socket_state record id (produced
    # by usock_fdbuf_for_record) into a socket fd's per-task fd_buf.
    # linux_abi/u_syscalls.ad's socket(2) handler calls this after it
    # has allocated both the fd and the backing record — fd_buf can't
    # be reached from u_syscalls.ad directly because the fd table is
    # per-task private state. Returns 0 on success, -EBADF if `fd` is
    # not a live socket fd.
    if vfs_fd_is_socket(fd) == 0:
        return EBADF
    task: Ptr[TaskStruct] = current_task()
    task[0].fd_buf[cast[uint64](fd)] = fdbuf
    return 0


def vfs_socket_fd_get_record(fd: int32) -> uint64:
    # U-socket: read back the encoded record id from a socket fd's
    # fd_buf. Returns 0 (== "no record") for a non-socket / closed fd
    # so the caller's usock_record_for_fdbuf decode yields -1.
    if vfs_fd_is_socket(fd) == 0:
        return 0
    task: Ptr[TaskStruct] = current_task()
    return task[0].fd_buf[cast[uint64](fd)]


def vfs_fd_is_open(fd: int32) -> int32:
    # U35: poll(2) needs to distinguish "valid fd" from "fd not open"
    # (returns POLLNVAL for the latter). Returns 1 if the fd slot is
    # in any open state, 0 otherwise.
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return 0
    task: Ptr[TaskStruct] = current_task()
    if task[0].fd_idx[cast[uint64](fd)] == FD_CLOSED_MARK:
        return 0
    return 1


def vfs_fd_inode(fd: int32) -> uint64:
    # §4: a STABLE, per-FILE-unique inode number for fstat(2).
    #
    # glibc's ld.so identifies an already-loaded shared object by the
    # (st_dev, st_ino) pair fstat returns: _dl_map_object_from_fd
    # fstats the just-opened DSO and, on a (dev,ino) match against an
    # already-mapped object, SKIPS the mmap and reuses the existing
    # link_map. The earlier fstat path keyed st_ino off the FD NUMBER
    # — but fd numbers are recycled across open/close, so a dlopen()ed
    # DSO that happened to land on the same fd slot a previously-
    # mapped DSO (e.g. libc.so.6) had used would collide: ld.so would
    # think the new DSO "is" libc, hand back libc's handle, and never
    # map the new object. dlsym() then failed with libc's name.
    #
    # The fix: derive the inode from the BACKING FILE's identity.
    #   * Regular initramfs file: fd_idx holds the cpio archive index
    #     — a stable per-file id. inode = index + 1 (so index 0 is a
    #     non-zero inode).
    #   * tmpfs / ext4 / FAT / dir-snapshot / pipe / socket / cdev:
    #     fd_idx is a high-bit marker and fd_buf holds the backing
    #     slot / buffer pointer. inode = marker-tagged fd_buf so two
    #     different tmpfs files differ, while staying disjoint from
    #     the initramfs index space (the marker high bits guarantee
    #     no overlap with a plain cpio index).
    # Either way: same file -> same inode, different file -> different
    # inode. That is the whole contract ld.so depends on.
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return 0
    task: Ptr[TaskStruct] = current_task()
    fdu: uint64 = cast[uint64](fd)
    fi: uint32 = task[0].fd_idx[fdu]
    if fi == FD_CLOSED_MARK:
        return 0
    # 0xFE000000 (FD_PROC_MARK_BASE in devproc.ad) is the lowest
    # special fd_idx marker — every cdev / pipe / socket / proc / tmpfs
    # marker sits at or above it. Any fd_idx strictly below it is a
    # real initramfs cpio archive index. Literal here rather than an
    # import to keep vfs.ad's already-large import list stable.
    if cast[uint64](fi) < cast[uint64](0xFE000000):
        return cast[uint64](fi) + 1
    # Special-backed fd: combine the marker with fd_buf (backing slot
    # or buffer address) so distinct tmpfs/ext4/... files get distinct
    # inodes. The 0x4000_0000_0000_0000 bit keeps the whole value out
    # of the initramfs index range.
    return cast[uint64](0x4000000000000000) \
           | (cast[uint64](fi) << 32) \
           | (task[0].fd_buf[fdu] & cast[uint64](0xFFFFFFFF))


def _open_tmpfs_read(name: Ptr[char]) -> int32:
    # V1: tmpfs is a tree. A path resolving to a directory ("/tmp" or
    # a mkdir'd subdir) opens as a FD_DIR_MARK fd whose buffer is a
    # "NAME\n" snapshot of its children — same shape as the cpio /
    # FAT / ext4 directory-open path, so getdents64() / chdir's
    # is-a-dir probe / `ls` all work through it. A path resolving to
    # a file opens as the existing FD_TMPFS_MARK read fd.
    if tmpfs_path_is_dir(name) != 0:
        task: Ptr[TaskStruct] = current_task()
        fd: int32 = _alloc_fd(task)
        if fd < 0:
            return EMFILE
        buf: uint64 = kmalloc(DIR_BUF_SIZE)
        if buf == 0:
            return cast[int32](-12)                   # -ENOMEM
        n: int64 = tmpfs_listdir(name, cast[Ptr[uint8]](buf),
                                 DIR_BUF_SIZE)
        if n < 0:
            kfree(buf)
            return ENOENT
        fdu: uint64 = cast[uint64](fd)
        task[0].fd_idx[fdu]    = FD_DIR_MARK
        task[0].fd_pos[fdu]    = 0
        task[0].fd_buf[fdu]    = buf
        task[0].fd_buflen[fdu] = cast[uint64](n)
        return fd
    slot: int32 = tmpfs_lookup(name)
    if slot < 0:
        return ENOENT
    task: Ptr[TaskStruct] = current_task()
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu] = FD_TMPFS_MARK
    task[0].fd_pos[fdu] = 0
    task[0].fd_buf[fdu] = cast[uint64](slot)
    return fd


def _open_dev_marked(mark: uint32) -> int32:
    # Both /dev/null and /dev/zero are statelessly opened — no slot
    # in any table, no per-fd buffer. Read/write are dispatched on
    # the mark alone.
    task: Ptr[TaskStruct] = current_task()
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu] = mark
    task[0].fd_pos[fdu] = 0
    task[0].fd_buf[fdu] = 0
    return fd


# --- Phase D: the universal namec open path -------------------------
#
# _namec_open is the canonical chan-resolution entry point. It calls
# namec() — which walks the calling process's Pgrp mount table — and
# on a chan result installs ONE FD_CHAN_MARK fd carrying the opaque
# chan id in fd_buf. A local cdev (/dev/cons, /dev/time, ...) and a
# file on a mounted 9P server both arrive here and both produce an
# FD_CHAN_MARK fd; vfs_read / vfs_write / vfs_close dispatch them back
# into namec_read / namec_write / namec_close, which route devtab vs.
# mountrpc internally. The fd layer never learns local-vs-mounted.
#
# Return: a real fd >= 0 on a chan open; the P9_NO_MOUNT sentinel
# (-10000, == namec's NAMEC_FALLTHROUGH) when namec does NOT own the
# path so the caller falls through to its on-disk routing; or an
# errno (ENOENT / EMFILE) when the path IS a chan but the open failed.

def _namec_open(name: Ptr[char], mode: int32) -> int32:
    cid: int32 = namec(name, mode)
    if cid == NAMEC_FALLTHROUGH:
        return P9_NO_MOUNT
    if cid == NAMEC_ENOENT:
        return ENOENT
    if cid == NAMEC_EMFILE:
        return EMFILE
    if cid < 0:
        return ENOENT
    # Phase D proof line: a mounted-9P Chan was resolved + opened
    # purely through namec — no FD_<NAME>_MARK / FD_P9_MARK probe was
    # consulted. test_namec_chan.sh greps this marker to assert the
    # mounted-server open path is the universal namec/devtab path.
    if namec_chan_is_mounted(cid) != 0:
        printk0("[namec] mounted-9P chan opened via namec (DEV_MNT)\n")
    task: Ptr[TaskStruct] = current_task()
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        namec_close(cid)
        return EMFILE
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu]    = FD_CHAN_MARK
    task[0].fd_pos[fdu]    = 0
    task[0].fd_buf[fdu]    = cast[uint64](cast[uint32](cid))
    task[0].fd_buflen[fdu] = 0
    return fd


def _namec_open_create(name: Ptr[char]) -> int32:
    # Create-on-write-open leg routed through namec. Only the 9P-mounted
    # case is creatable; namec_create returns NAMEC_FALLTHROUGH when no
    # mount covers the path.
    cid: int32 = namec_create(name)
    if cid == NAMEC_FALLTHROUGH:
        return P9_NO_MOUNT
    if cid < 0:
        return ENOENT
    task: Ptr[TaskStruct] = current_task()
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        namec_close(cid)
        return EMFILE
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu]    = FD_CHAN_MARK
    task[0].fd_pos[fdu]    = 0
    task[0].fd_buf[fdu]    = cast[uint64](cast[uint32](cid))
    task[0].fd_buflen[fdu] = 0
    return fd


def _fd_chan_id(task: Ptr[TaskStruct], fdu: uint64) -> int32:
    # Recover the namec chan id from an FD_CHAN_MARK fd's fd_buf.
    return cast[int32](cast[uint32](task[0].fd_buf[fdu]))


# --- 9P-mount "no mount" sentinel ---------------------------------
#
# Phase D: the V1-era _try_open_p9 / _try_open_p9_write /
# _try_create_p9 helpers (which installed FD_P9_MARK fds directly)
# are GONE — sys/src/9/port/namec.ad's namec() now owns the 9P-
# mounted open path and installs the unified FD_CHAN_MARK fd. The
# only survivor is the sentinel value: _namec_open returns P9_NO_MOUNT
# (== namec's NAMEC_FALLTHROUGH, -10000) to mean "namec does not own
# this path; fall through to the local-FS routing". It is outside the
# errno range (EROFS=-30 etc.) so callers branch on equality without
# aliasing a real error.

P9_NO_MOUNT: int32 = -10000


def _install_proc_fd(encoded_mark: uint32) -> int32:
    # /proc/<pid>/<file> fds carry the marker tag PLUS the encoded
    # pid + file_kind in their fd_idx slot — devproc_read uses the
    # low 24 bits to recover the target task and which file to
    # render. No per-fd buffer / slot allocation; stateless like the
    # other Plan 9-shape cdevs. The marker value itself comes from
    # devproc_open(), which has already validated the pid exists.
    task: Ptr[TaskStruct] = current_task()
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu] = encoded_mark
    task[0].fd_pos[fdu] = 0
    task[0].fd_buf[fdu] = 0
    return fd


def _open_fat_read(name: Ptr[char]) -> int32:
    basename: Ptr[char] = strip_mnt_prefix(name)
    fat_slot: int32 = fat_open(basename)
    if fat_slot < 0:
        return ENOENT
    task: Ptr[TaskStruct] = current_task()
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        fat_close(fat_slot)
        return EMFILE
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu]    = FD_FAT_MARK
    task[0].fd_pos[fdu]    = 0
    task[0].fd_buf[fdu]    = cast[uint64](fat_slot)
    task[0].fd_buflen[fdu] = fat_open_size(fat_slot)
    return fd


def _open_ext4_read(name: Ptr[char]) -> int32:
    basename: Ptr[char] = strip_ext_prefix(name)
    ext_slot: int32 = ext4_open(basename)
    if ext_slot < 0:
        return ENOENT
    task: Ptr[TaskStruct] = current_task()
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        ext4_close(ext_slot)
        return EMFILE
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu]    = FD_EXT4_MARK
    task[0].fd_pos[fdu]    = 0
    task[0].fd_buf[fdu]    = cast[uint64](ext_slot)
    task[0].fd_buflen[fdu] = ext4_open_size(ext_slot)
    return fd


PROC_BUF_SIZE: uint64 = 4096


def _open_proc(name: Ptr[char]) -> int32:
    task: Ptr[TaskStruct] = current_task()
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    buf: uint64 = kmalloc(PROC_BUF_SIZE)
    if buf == 0:
        return cast[int32](-12)              # -ENOMEM
    n: int64 = proc_render(name, cast[Ptr[uint8]](buf))
    if n < 0:
        kfree(buf)
        return ENOENT
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu]    = FD_BUFFER_MARK
    task[0].fd_pos[fdu]    = 0
    task[0].fd_buf[fdu]    = buf
    task[0].fd_buflen[fdu] = cast[uint64](n)
    return fd


def _check_fd(fd: int32) -> int32:
    if fd < 0 or cast[uint32](fd) >= _VFS_NR_FDS:
        return EBADF
    return 0


def vfs_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64:
    # Non-blocking read backing SYS_READ_NB. Returns >0 bytes ready,
    # 0 if the fd is open but momentarily empty ("would block"), or -1
    # on a true EOF / error. Only the two fd kinds an event-loop daemon
    # actually polls are special-cased — a connected socket and a pipe
    # read-end. Every other fd kind has no would-block notion here, so
    # we just delegate to the blocking vfs_read (a regular file always
    # has data or is at EOF immediately anyway).
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return cast[int64](rc)
    task: Ptr[TaskStruct] = current_task()
    fdu: uint64 = cast[uint64](fd)
    file_idx: uint32 = task[0].fd_idx[fdu]

    if file_idx == FD_CLOSED_MARK:
        return -1
    if file_idx == FD_SOCKET_MARK:
        sk_rec: int32 = usock_record_for_fdbuf(task[0].fd_buf[fdu])
        if sk_rec < 0:
            return -1
        # §10 UDP: a non-blocking read on a datagram socket returns a
        # queued datagram if one is ready, else 0 ("would block" — a
        # UDP socket is never at a true EOF).
        if usock_get_type(sk_rec) == USOCK_SOCK_DGRAM:
            udp_slot_nb: int32 = usock_get_tcp_slot(sk_rec)
            if udp_slot_nb < 0:
                return -1
            if udp_socket_recv_pending(udp_slot_nb) == 0:
                return 0
            ud_nb: int64 = udp_socket_recvfrom(
                udp_slot_nb, buf, count, 1,
                cast[Ptr[uint32]](0), cast[Ptr[uint16]](0))
            if ud_nb < 0:
                return 0
            return ud_nb
        if usock_get_state(sk_rec) != USOCK_CONNECTED:
            return -1
        sk_tcp: int32 = usock_get_tcp_slot(sk_rec)
        if sk_tcp < 0:
            return -1
        # TLS-active sockets have no non-blocking record-layer path;
        # an event-loop daemon over TLS is out of scope here.
        if usock_is_tls(sk_rec) != 0:
            return -1
        n_sk: int64 = tcp_recv_nb(sk_tcp, buf, count)
        if n_sk < 0:
            usock_set_state(sk_rec, USOCK_CLOSED)
        return n_sk
    if file_idx == FD_PIPE_MARK_R:
        # pipe_read is already non-blocking at the fs/pipe.ad layer; a
        # 0 return there means "empty right now". Distinguish a closed
        # pipe (no writers left) as a true EOF (-1).
        slot: int32 = cast[int32](task[0].fd_buf[fdu])
        n_p: int64 = pipe_read(slot, buf, count)
        if n_p > 0:
            return n_p
        if pipe_writers(slot) == 0:
            return -1
        return 0
    # Anything else: no would-block semantics — fall back to the
    # ordinary blocking read.
    return vfs_read(fd, buf, count)


def vfs_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64:
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return cast[int64](rc)
    task: Ptr[TaskStruct] = current_task()
    fdu: uint64 = cast[uint64](fd)
    file_idx: uint32 = task[0].fd_idx[fdu]

    if file_idx == FD_CLOSED_MARK:
        return cast[int64](EBADF)
    if file_idx == FD_CHAN_MARK:
        # Phase D: namec Chan-backed fd. fd_buf carries the opaque
        # chan id. namec_read dispatches devtab (local cdev) vs.
        # mountrpc (9P T-messages over the mounted server) internally
        # — vfs_read does not branch on local-vs-mounted. fd_pos is
        # the byte offset (used only by the DEV_MNT mountrpc leg; an
        # inline cdev ignores it). This single arm REPLACES the dozen
        # FD_<NAME>_MARK cdev read arms below AND the FD_P9_MARK arm.
        chan_id: int32 = _fd_chan_id(task, fdu)
        coff:    uint64 = task[0].fd_pos[fdu]
        nc: int64 = namec_read(chan_id, coff, buf, count)
        if nc > 0:
            task[0].fd_pos[fdu] = coff + cast[uint64](nc)
        return nc
    if file_idx == FD_DEVFD_MARK:
        # HAMSH §7: the integer fd is the Layer-2 mapping onto an
        # /fd/N name. fd_buf carries the fd-number N; resolve it
        # through the CALLING task's Pgrp devfd table. A pipe read
        # end blocks-yields until bytes arrive OR every writer has
        # closed (EOF) — the same model as the FD_PIPE_MARK_R arm.
        # devfd_read routes to a LOCAL backing channel (pipe slot /
        # console / file): zero 9P marshalling (§6).
        df_num: int32 = cast[int32](cast[uint32](task[0].fd_buf[fdu]))
        df_pg:  uint64 = pgrp_current()
        if devfd_slot_kind(df_pg, df_num) == DEVFD_PIPE_R:
            while True:
                dn: int64 = devfd_read(df_pg, df_num, buf, count)
                if dn > 0:
                    return dn
                if devfd_read_pipe_writers(df_pg, df_num) == 0:
                    return 0                       # all writers gone
                yield_to_others()
        return devfd_read(df_pg, df_num, buf, count)
    if file_idx == FD_P9_MARK:
        # V1 legacy 9P-mounted file path — retained as a non-regressing
        # fallback for any FD_P9_MARK fd a not-yet-converted call site
        # might still install. fd_buf packs (srvfd << 32 | fid); fd_pos
        # is the offset. New opens route through FD_CHAN_MARK above.
        p9_packed: uint64 = task[0].fd_buf[fdu]
        srvfd_p9: int32 = p9c_decode_srvfd(p9_packed)
        fid_p9:   int32 = p9c_decode_fid(p9_packed)
        off:      uint64 = task[0].fd_pos[fdu]
        n: int64 = p9c_read(srvfd_p9, fid_p9, off, buf,
                            cast[uint32](count))
        if n > 0:
            task[0].fd_pos[fdu] = off + cast[uint64](n)
        return n
    if file_idx == FD_DEVNULL_MARK:
        # /dev/null reads always return EOF.
        return 0
    if file_idx == FD_SOCKET_MARK:
        # U-socket: a socket fd backed by a live TCP connection routes
        # read(2) into the real stack via tcp_recv. fd_buf carries the
        # u_socket_state record id (encoded +1; 0 == no record). A
        # socket that was created but never connect()'d — or one whose
        # connect() failed, or one already closed — has no TCP slot and
        # reads as immediate EOF (the same answer the U35 stub gave).
        sk_rec: int32 = usock_record_for_fdbuf(task[0].fd_buf[fdu])
        if sk_rec < 0:
            return 0
        # §10 UDP: a datagram socket's read(2) pulls ONE datagram via
        # the UDP socket layer. The udp.ad slot is the record's stack-
        # slot field. A timeout with no data returns 0 (a UDP socket is
        # never at a stream EOF; plain read(2) has no EAGAIN channel).
        if usock_get_type(sk_rec) == USOCK_SOCK_DGRAM:
            udp_slot_r: int32 = usock_get_tcp_slot(sk_rec)
            if udp_slot_r < 0:
                return 0
            ud_rn: int64 = udp_socket_recvfrom(
                udp_slot_r, buf, count, 500,
                cast[Ptr[uint32]](0), cast[Ptr[uint16]](0))
            if ud_rn < 0:
                return 0
            return ud_rn
        if usock_get_state(sk_rec) != USOCK_CONNECTED:
            return 0
        sk_tcp: int32 = usock_get_tcp_slot(sk_rec)
        if sk_tcp < 0:
            return 0
        # U-TLS: if tls_connect(2) ran a handshake on this fd, read(2)
        # pulls the next decrypted application_data record off the wire
        # via the TLS record layer. tls_recv tcp_recv's + AEAD-decrypts
        # internally; it returns >0 plaintext bytes, 0 on close_notify /
        # clean EOF, or -1 on a hard decrypt / protocol error. We latch
        # CLOSED on the EOF/error answers (an error there is genuinely
        # un-recoverable for a stream socket).
        if usock_is_tls(sk_rec) != 0:
            n_tls: int64 = tls_recv(sk_tcp, buf, count, 500)
            if n_tls <= 0:
                usock_set_state(sk_rec, USOCK_CLOSED)
            return n_tls
        # 500 jiffies (~5 s @ HZ=100) blocking budget — generous for a
        # local server, bounded so a dead peer can't wedge the syscall.
        # tcp_recv polls virtio_net internally; on a connected socket
        # it returns >0 bytes, or 0 on EITHER a peer-FIN-with-no-data
        # (true EOF) OR a plain timeout-with-no-data. The two answers
        # are indistinguishable from tcp_recv's return value alone, so
        # we ask the slot directly: latch CLOSED only when the slot has
        # genuinely reached end-of-stream. A bare timeout leaves the
        # socket open so the caller can read again — important for
        # long-lived interactive servers (user/sshd.ad).
        n_sk: int64 = tcp_recv(sk_tcp, buf, count, 500)
        if n_sk < 0:
            usock_set_state(sk_rec, USOCK_CLOSED)
        elif n_sk == 0:
            if tcp_slot_at_eof(sk_tcp) != 0:
                usock_set_state(sk_rec, USOCK_CLOSED)
        return n_sk
    if file_idx == FD_DEVZERO_MARK:
        # /dev/zero hands back `count` zero bytes per request.
        i: uint64 = 0
        while i < count:
            buf[i] = 0
            i = i + 1
        return cast[int64](count)
    if file_idx == FD_CONS_MARK:
        # M16.94: /dev/cons read side. Delegate to the Plan 9 cdev
        # body (sys/src/9/port/devcons.ad) which pops from the same
        # kbd/UART rings the FD_STDIN_MARK arm uses below. Keeping
        # this dispatch a single call preserves the "fs/vfs.ad routes,
        # backends implement" layering — see docs/architecture.md.
        return devcons_read(buf, count)
    if file_idx == FD_TIME_MARK:
        # M16.95: /dev/time read side. devtime_read samples
        # get_jiffies() fresh and emits ns-since-boot as ASCII decimal
        # + '\n'. Stateless — pos/buflen unused for this mark.
        return devtime_read(buf, count)
    if file_idx == FD_PID_MARK:
        # M16.95: /dev/pid read side. devpid_read formats the current
        # task's pid as ASCII decimal + '\n'.
        return devpid_read(buf, count)
    if file_idx == FD_RANDOM_MARK:
        # M16.95: /dev/random read side. xorshift64 placeholder; see
        # the caveat in sys/src/9/port/devrandom.ad — not crypto-grade
        # entropy until the chacha20 + RDRAND backend lands.
        return devrandom_read(buf, count)
    if file_idx == FD_MOUSE_MARK:
        # M16.130: /dev/mouse read side. devmouse_read pops one event
        # off the auxmouse ring and renders "<dx> <dy> <buttons>\n";
        # empty ring -> 0 bytes (non-blocking poll semantics).
        return devmouse_read(buf, count)
    if file_idx == FD_CPUINFO_MARK:
        # /dev/cpuinfo read side. Synthesises a fresh text blob
        # (vendor / family / model / brand / cpus_online / rdrand /
        # rdseed) on every read; stateless.
        return devcpuinfo_read(buf, count)
    if file_idx == FD_MEMINFO_MARK:
        # /dev/meminfo read side. Synthesises a fresh text blob
        # (MemTotal / MemFree / MemUsed / Pages / PagesFree /
        # KmallocLive) on every read; stateless.
        return devmeminfo_read(buf, count)
    if file_idx == FD_UPTIME_MARK:
        # M16.132: /dev/uptime read side. Synthesises
        # "<secs>.<CC> <idle>.<CC>\n" from get_jiffies() on every
        # read; stateless. Idle column is "0.00" until per-task idle
        # accounting lands in kernel/sched/core.ad.
        return devuptime_read(buf, count)
    if file_idx == FD_LOADAVG_MARK:
        # M16.132: /dev/loadavg read side. Scans task_table for
        # RUNNING/READY counts and synthesises
        # "<L1> <L5> <L15> <running>/<total> <lastpid>\n" on every
        # read; stateless. L1/L5/L15 are instantaneous (not EWMA) —
        # see sys/src/9/port/devloadavg.ad header CAVEAT.
        return devloadavg_read(buf, count)
    if file_idx == FD_VERSION_MARK:
        # M16.133: /dev/version read side. Stateless single-line
        # identity blob: "hamnix/0.1 (M16.132+)\n". Every read
        # regenerates the same text.
        return devversion_read(buf, count)
    if file_idx == FD_HOSTNAME_MARK:
        # M16.133: /dev/hostname read side. Emits "<hostname>\n"
        # from the kernel-RAM hostname buffer. The buffer starts as
        # "hamnix" and is mutated by devhostname_write below.
        return devhostname_read(buf, count)
    if file_idx == FD_STAT_MARK:
        # M16.135: /dev/stat read side. Synthesises a /proc/stat-shape
        # blob (cpu / cpu0 / intr / ctxt / btime / processes rows) from
        # get_jiffies() + rtc_boot_epoch_get() + current_task_pid().
        # Stateless; CPU columns are placeholders (everything renders
        # as "user time" — see sys/src/9/port/devstat.ad header CAVEAT).
        return devstat_read(buf, count)
    if file_idx == FD_MOUNTS_MARK:
        # M16.135: /dev/mounts read side. Synthesises a /proc/mounts-
        # shape blob: a synthetic "rootfs / cpio ro 0 0" line followed
        # by one row per live chan.ad mnttab entry. Stateless.
        return devmounts_read(buf, count)
    if file_idx == FD_DISKSTATS_MARK:
        # M16.135: /dev/diskstats read side. Synthesises a
        # /proc/diskstats-shape blob: one 14-field row per registered
        # blockdev_table slot. Counter columns are 0 placeholders
        # until the block layer grows per-slot stats (see TODO.md).
        return devdiskstats_read(buf, count)
    if devproc_is_proc_fd(file_idx) != 0:
        # /proc/<pid>/{status,cwd,...} read side. The marker carries
        # pid + file_kind in its low 24 bits; devproc_read decodes
        # them and renders the one-line text the caller is after.
        # Stateless — no fd_pos / fd_buf tracking; every read
        # samples the target task fresh (matching Plan 9 devproc
        # semantics, and the test_devproc fixture only does a single
        # read per fd anyway).
        return devproc_read(file_idx, buf, count)
    if file_idx == FD_BUFFER_MARK:
        # Snapshot read — same shape as initramfs but the backing
        # store is the per-fd kmalloc'd buffer set up at open time.
        size: uint64 = task[0].fd_buflen[fdu]
        pos:  uint64 = task[0].fd_pos[fdu]
        if pos >= size:
            return 0
        remaining: uint64 = size - pos
        take: uint64 = count
        if take > remaining:
            take = remaining
        src: uint64 = task[0].fd_buf[fdu]
        memcpy(buf, cast[Ptr[uint8]](src + pos), take)
        task[0].fd_pos[fdu] = pos + take
        return cast[int64](take)
    if file_idx == FD_DIR_MARK:
        # Linux returns EISDIR for read(2) on a directory fd. Callers
        # are expected to use getdents64() instead.
        return cast[int64](EISDIR)
    if file_idx == FD_TMPFS_MARK:
        # tmpfs read — fd_buf holds the tmpfs slot index; size moves
        # under us if someone is writing in parallel, but at this
        # scale (uniprocessor, no preempt during fs ops) we just
        # snapshot the current size at each read.
        slot:  int32  = cast[int32](task[0].fd_buf[fdu])
        size:  uint64 = tmpfs_size(slot)
        pos:   uint64 = task[0].fd_pos[fdu]
        if pos >= size:
            return 0
        remaining: uint64 = size - pos
        take: uint64 = count
        if take > remaining:
            take = remaining
        src: Ptr[uint8] = tmpfs_data(slot)
        memcpy(buf, cast[Ptr[uint8]](cast[uint64](src) + pos), take)
        task[0].fd_pos[fdu] = pos + take
        return cast[int64](take)
    if file_idx == FD_PIPE_MARK_R:
        # Blocking read: yield until pipe_read returns >0 OR every
        # writer has closed (EOF). We don't sleep on a wait queue
        # yet — yield_to_others() just rotates the runqueue, and the
        # timer ISR / sibling syscalls eventually push data into us.
        slot: int32 = cast[int32](task[0].fd_buf[fdu])
        while True:
            n: int64 = pipe_read(slot, buf, count)
            if n > 0:
                return n
            if pipe_writers(slot) == 0:
                return 0                       # all writers gone -> EOF
            yield_to_others()
    if file_idx == FD_SOCKETPAIR_MARK:
        # V5: bidirectional read. The packed fd_buf encodes (slot << 1
        # | direction); end A reads ring_b, end B reads ring_a. We
        # block-yield like the pipe path until bytes arrive OR the
        # peer's refs has dropped to 1 (only WE are left, so no future
        # writes are possible — surface EOF).
        sp_packed: uint64 = task[0].fd_buf[fdu]
        sp_slot: int32 = sockpair_unpack_slot(sp_packed)
        sp_dir:  int32 = sockpair_unpack_dir(sp_packed)
        while True:
            n: int64 = sockpair_read(sp_slot, sp_dir, buf, count)
            if n > 0:
                return n
            if sockpair_peer_alive(sp_slot, sp_dir) == 0:
                return 0                       # peer closed -> EOF
            yield_to_others()
    if file_idx == FD_FAT_MARK:
        # FAT read — walk the chain from the open file's first
        # cluster, copying out at fd_pos. A write-mode FAT fd (write
        # bit set in fd_buf) has no read open-file slot — reject it.
        fatbuf_r: uint64 = task[0].fd_buf[fdu]
        if (fatbuf_r & FAT_FD_WRITE_BIT) != 0:
            return cast[int64](EINVAL)
        slot: int32 = cast[int32](fatbuf_r)
        first: uint64 = fat_open_first_cluster(slot)
        size:  uint64 = fat_open_size(slot)
        pos:   uint64 = task[0].fd_pos[fdu]
        n: int64 = fat_read(first, size, pos, count, buf)
        if n > 0:
            task[0].fd_pos[fdu] = pos + cast[uint64](n)
        return n
    if file_idx == FD_EXT4_MARK:
        slot: int32 = cast[int32](task[0].fd_buf[fdu])
        inum: uint32 = ext4_open_inum(slot)
        pos:  uint64 = task[0].fd_pos[fdu]
        n: int64 = ext4_read_file(inum, pos, count, buf)
        if n > 0:
            task[0].fd_pos[fdu] = pos + cast[uint64](n)
        return n
    if file_idx == FD_PIPE_MARK_W:
        return cast[int64](EBADF)              # can't read a write end
    if file_idx == FD_STDIN_MARK:
        # M16.39: read from the software RX FIFO that timer_interrupt
        # drains the UART into. Ctrl-C (0x03) never lands in the FIFO
        # — the timer drain plucks it out and posts SIGINT instead.
        # Block until we see a full line ('\n' / '\r') or fill the
        # caller's buffer. Earlier revs returned early on a
        # transiently-empty FIFO with partial data, which made
        # hamsh treat "/cat /mnt/HELL" + "O.TXT" as TWO separate
        # commands when the host typed faster than the 100 Hz timer
        # could drain the hardware FIFO.
        n: uint64 = 0
        while n < count:
            # M16.75: check the PS/2 keyboard FIFO first, then UART.
            # Either input source feeds stdin transparently — useful
            # for real-hardware boot where the user is typing on a
            # PS/2 keyboard, not piping through serial.
            c: int32 = kbd_rx_pop()
            if c < 0:
                c = uart_rx_pop()
            if c < 0:
                yield_to_others()
                continue
            buf[n] = cast[uint8](c & 0xFF)
            n = n + 1
            if c == 10 or c == 13:
                if c == 13:
                    buf[n - 1] = 10
                early_putc(10)
                return cast[int64](n)
        return cast[int64](n)
    if file_idx == FD_STDOUT_MARK or file_idx == FD_STDERR_MARK:
        return cast[int64](EBADF)           # can't read these

    # initramfs file
    size: uint64 = initramfs_entry_size(cast[uint64](file_idx))
    pos:  uint64 = task[0].fd_pos[fdu]
    if pos >= size:
        return 0
    remaining: uint64 = size - pos
    take: uint64 = count
    if take > remaining:
        take = remaining
    src: Ptr[uint8] = initramfs_entry_data(cast[uint64](file_idx))
    memcpy(buf, cast[Ptr[uint8]](cast[uint64](src) + pos), take)
    task[0].fd_pos[fdu] = pos + take
    return cast[int64](take)


def vfs_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64:
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return cast[int64](rc)
    task: Ptr[TaskStruct] = current_task()
    fdu: uint64 = cast[uint64](fd)
    file_idx: uint32 = task[0].fd_idx[fdu]

    if file_idx == FD_CLOSED_MARK:
        return cast[int64](EBADF)
    if file_idx == FD_CHAN_MARK:
        # Phase D: namec Chan-backed fd. namec_write dispatches devtab
        # (local cdev) vs. mountrpc (9P over the mounted server)
        # internally — vfs_write never branches on local-vs-mounted.
        # Mirrors the FD_CHAN_MARK read arm. This single arm replaces
        # the dozen FD_<NAME>_MARK cdev write arms below + FD_P9_MARK.
        chan_id: int32 = _fd_chan_id(task, fdu)
        coff:    uint64 = task[0].fd_pos[fdu]
        nc: int64 = namec_write(chan_id, coff, buf, count)
        if nc > 0:
            task[0].fd_pos[fdu] = coff + cast[uint64](nc)
        return nc
    if file_idx == FD_P9_MARK:
        # V1 legacy 9P write path — non-regressing fallback for any
        # surviving FD_P9_MARK fd. New opens route via FD_CHAN_MARK.
        p9_packed: uint64 = task[0].fd_buf[fdu]
        srvfd_p9: int32 = p9c_decode_srvfd(p9_packed)
        fid_p9:   int32 = p9c_decode_fid(p9_packed)
        off:      uint64 = task[0].fd_pos[fdu]
        n: int64 = p9c_write(srvfd_p9, fid_p9, off, buf,
                             cast[uint32](count))
        if n > 0:
            task[0].fd_pos[fdu] = off + cast[uint64](n)
        return n
    if file_idx == FD_DEVFD_MARK:
        # HAMSH §7: the integer fd is the Layer-2 mapping onto an
        # /fd/N name. Resolve N through the CALLING task's Pgrp devfd
        # table. A pipe write end blocks-yields, EPIPE on all-readers-
        # gone (same model as the FD_PIPE_MARK_W arm). devfd_write
        # routes to a LOCAL backing channel — zero 9P (§6).
        dfw_num: int32 = cast[int32](cast[uint32](task[0].fd_buf[fdu]))
        dfw_pg:  uint64 = pgrp_current()
        if devfd_slot_kind(dfw_pg, dfw_num) == DEVFD_PIPE_W:
            total: uint64 = 0
            while total < count:
                if devfd_write_pipe_readers(dfw_pg, dfw_num) == 0:
                    if total > 0:
                        return cast[int64](total)
                    return cast[int64](EPIPE)
                chunk: int64 = devfd_write(dfw_pg, dfw_num,
                    cast[Ptr[uint8]](cast[uint64](buf) + total),
                    count - total)
                if chunk > 0:
                    total = total + cast[uint64](chunk)
                else:
                    yield_to_others()
            return cast[int64](total)
        return devfd_write(dfw_pg, dfw_num, buf, count)
    if file_idx == FD_DEVNULL_MARK or file_idx == FD_DEVZERO_MARK:
        # /dev/null and /dev/zero swallow writes silently — the
        # full `count` is returned as bytes-written.
        return cast[int64](count)
    if file_idx == FD_CONS_MARK:
        # M16.94: /dev/cons write side — fan out to UART + VGA/fb +
        # printk via devcons_write → early_putc. Same byte stream
        # FD_STDOUT_MARK produces below; the spec promises writing
        # to /dev/cons is equivalent to the legacy SYS_PUTC.
        return devcons_write(buf, count)
    if file_idx == FD_TIME_MARK:
        # M16.95: /dev/time is read-only; devtime_write returns -1.
        # We propagate that as-is so userland sees the rejection
        # rather than a phantom success.
        return devtime_write(buf, count)
    if file_idx == FD_PID_MARK:
        # M16.95: /dev/pid is read-only; devpid_write returns -1.
        return devpid_write(buf, count)
    if file_idx == FD_RANDOM_MARK:
        # M16.95: /dev/random accepts writes as entropy-mix. The
        # current implementation XOR-folds input into the xorshift64
        # state. Placeholder pending the chacha20 reseed path.
        return devrandom_write(buf, count)
    if file_idx == FD_MOUSE_MARK:
        # M16.130: /dev/mouse is read-only; devmouse_write returns -1.
        return devmouse_write(buf, count)
    if file_idx == FD_CPUINFO_MARK:
        # /dev/cpuinfo is read-only; devcpuinfo_write returns -1.
        return devcpuinfo_write(buf, count)
    if file_idx == FD_MEMINFO_MARK:
        # /dev/meminfo is read-only; devmeminfo_write returns -1.
        return devmeminfo_write(buf, count)
    if file_idx == FD_UPTIME_MARK:
        # M16.132: /dev/uptime is read-only; devuptime_write returns -1.
        return devuptime_write(buf, count)
    if file_idx == FD_LOADAVG_MARK:
        # M16.132: /dev/loadavg is read-only; devloadavg_write returns -1.
        return devloadavg_write(buf, count)
    if file_idx == FD_VERSION_MARK:
        # M16.133: /dev/version is read-only; devversion_write returns -1.
        return devversion_write(buf, count)
    if file_idx == FD_HOSTNAME_MARK:
        # M16.133: /dev/hostname IS writable. devhostname_write
        # truncates to 63 chars, strips trailing whitespace, copies
        # into the kernel-RAM hostname_buf, and returns `count`
        # consumed so userland shells don't retry on a short write.
        return devhostname_write(buf, count)
    if file_idx == FD_STAT_MARK:
        # M16.135: /dev/stat is read-only; devstat_write returns -1.
        return devstat_write(buf, count)
    if file_idx == FD_MOUNTS_MARK:
        # M16.135: /dev/mounts is read-only; devmounts_write returns -1.
        return devmounts_write(buf, count)
    if file_idx == FD_DISKSTATS_MARK:
        # M16.135: /dev/diskstats is read-only; devdiskstats_write
        # returns -1.
        return devdiskstats_write(buf, count)
    if devproc_is_proc_fd(file_idx) != 0:
        # /proc/<pid>/<file> write side. devproc_write currently
        # rejects every write (returns -1 + errstr) because the only
        # meaningful write target is /proc/<pid>/note for note(2)
        # delivery, and notify/noted are -ENOSYS. We forward the
        # buffer regardless so the future write-side body can grow
        # into this seat without another vfs.ad edit.
        return devproc_write(file_idx, buf, count)
    if file_idx == FD_SOCKET_MARK:
        # U-socket: a socket fd backed by a live TCP connection routes
        # write(2) into the real stack via tcp_send. fd_buf carries the
        # u_socket_state record id (+1 encoded). A socket that was
        # never connect()'d has no TCP slot — Linux returns -ENOTCONN
        # for write on an unconnected stream socket; we don't have that
        # errno wired, so -EPIPE is the closest fit (also what a
        # closed-peer write returns). tcp_send truncates each segment
        # at TCP_MSS, so loop until the whole buffer drains.
        sk_rec: int32 = usock_record_for_fdbuf(task[0].fd_buf[fdu])
        if sk_rec < 0:
            return cast[int64](EPIPE)
        # §10 UDP: a datagram socket's write(2) sends one datagram to
        # the connect(2)'d peer. write(2) on an unconnected UDP socket
        # is -EDESTADDRREQ in Linux; we don't have that errno, so
        # -EPIPE is the closest fit. udp_socket_sendto returns the
        # byte count on success.
        if usock_get_type(sk_rec) == USOCK_SOCK_DGRAM:
            udp_slot_w: int32 = usock_get_tcp_slot(sk_rec)
            if udp_slot_w < 0:
                return cast[int64](EPIPE)
            udp_peer: uint32 = usock_get_peer_addr(sk_rec)
            udp_pport: uint32 = usock_get_peer_port(sk_rec)
            if udp_peer == 0:
                # No peer — write(2) on an unconnected datagram socket.
                return cast[int64](EPIPE)
            ud_wn: int64 = udp_socket_sendto(
                udp_slot_w, udp_peer,
                cast[uint16](udp_pport & 0xFFFF), buf, count)
            if ud_wn < 0:
                return cast[int64](EPIPE)
            return ud_wn
        if usock_get_state(sk_rec) != USOCK_CONNECTED:
            return cast[int64](EPIPE)
        sk_tcp: int32 = usock_get_tcp_slot(sk_rec)
        if sk_tcp < 0:
            return cast[int64](EPIPE)
        # U-TLS: a TLS-active fd encrypts each write through the TLS
        # record layer before tcp_send. tls_send's plaintext scratch is
        # a 2048-byte frame (Array[2048]), so it caps one record at
        # ~2026 plaintext bytes; we chunk the user buffer at 2000 bytes
        # per call so a write(2) larger than one TLS record drains as a
        # sequence of records. tls_send returns the byte count sealed
        # on success or -1 on a wire / AEAD error.
        if usock_is_tls(sk_rec) != 0:
            tls_sent: uint64 = 0
            while tls_sent < count:
                tls_chunk: uint64 = count - tls_sent
                if tls_chunk > 2000:
                    tls_chunk = 2000
                tls_ptr: Ptr[uint8] = cast[Ptr[uint8]](
                    cast[uint64](buf) + tls_sent)
                tls_rc: int64 = tls_send(sk_tcp, tls_ptr, tls_chunk)
                if tls_rc <= 0:
                    # Encrypt / transport failure. Latch CLOSED; report
                    # a short count if earlier records made it, else
                    # EPIPE.
                    usock_set_state(sk_rec, USOCK_CLOSED)
                    if tls_sent > 0:
                        return cast[int64](tls_sent)
                    return cast[int64](EPIPE)
                tls_sent = tls_sent + cast[uint64](tls_rc)
            return cast[int64](tls_sent)
        sk_sent: uint64 = 0
        while sk_sent < count:
            chunk_ptr: Ptr[uint8] = cast[Ptr[uint8]](
                cast[uint64](buf) + sk_sent)
            sk_rc: int64 = tcp_send(sk_tcp, chunk_ptr, count - sk_sent)
            if sk_rc <= 0:
                # Transport error / peer gone. Latch CLOSED. Report a
                # short count if some bytes already made it, else EPIPE.
                usock_set_state(sk_rec, USOCK_CLOSED)
                if sk_sent > 0:
                    return cast[int64](sk_sent)
                return cast[int64](EPIPE)
            sk_sent = sk_sent + cast[uint64](sk_rc)
        return cast[int64](sk_sent)
    if file_idx == FD_BUFFER_MARK:
        # procfs files are read-only at this scale; writes here are
        # never meaningful so return -EROFS for parity with how Linux
        # handles writes to most /proc entries the user can open r/w.
        return cast[int64](EROFS)
    if file_idx == FD_DIR_MARK:
        # write(2) on a directory fd is EISDIR in Linux.
        return cast[int64](EISDIR)
    if file_idx == FD_TMPFS_MARK:
        slot: int32 = cast[int32](task[0].fd_buf[fdu])
        pos:  uint64 = task[0].fd_pos[fdu]
        n: uint64 = tmpfs_write(slot, buf, pos, count)
        task[0].fd_pos[fdu] = pos + n
        return cast[int64](n)
    if file_idx == FD_FAT_MARK:
        # A FAT fd with the write bit set in fd_buf is a write-mode
        # open (M16.x §12.5) — forward to the FAT cluster-chain
        # writer. A read-mode FAT fd cannot be written.
        fatbuf: uint64 = task[0].fd_buf[fdu]
        if (fatbuf & FAT_FD_WRITE_BIT) == 0:
            return cast[int64](EROFS)
        wslot: int32 = cast[int32](fatbuf & 0x7FFFFFFF)
        pos: uint64 = task[0].fd_pos[fdu]
        n: int64 = fat_write_slot(wslot, buf, pos, count)
        if n > 0:
            task[0].fd_pos[fdu] = pos + cast[uint64](n)
        return n
    if file_idx == FD_EXT4_MARK:
        # M16.64: ext4 write path. Single-block scope — caps at
        # ext4_block_size bytes per file. Larger writes return the
        # short count (caller's outer loop will see we stopped
        # before count and either give up or retry — they retry,
        # since we return 0 once we've hit the cap).
        eslot: int32 = cast[int32](task[0].fd_buf[fdu])
        pos:   uint64 = task[0].fd_pos[fdu]
        n: int64 = ext4_write_open_file(eslot, buf, pos, count)
        if n > 0:
            task[0].fd_pos[fdu] = pos + cast[uint64](n)
        return n
    if file_idx == FD_PIPE_MARK_W:
        # Blocking write: drain as much as the ring will accept,
        # yielding when full until a reader makes room. EPIPE if
        # every reader has closed (matches Linux's write-after-close
        # error; no SIGPIPE yet — userland sees the errno).
        slot: int32 = cast[int32](task[0].fd_buf[fdu])
        total: uint64 = 0
        while total < count:
            if pipe_readers(slot) == 0:
                if total > 0:
                    return cast[int64](total)
                return cast[int64](EPIPE)
            chunk: int64 = pipe_write(slot,
                cast[Ptr[uint8]](cast[uint64](buf) + total),
                count - total)
            if chunk > 0:
                total = total + cast[uint64](chunk)
            else:
                yield_to_others()
        return cast[int64](total)
    if file_idx == FD_SOCKETPAIR_MARK:
        # V5: bidirectional write. End A writes ring_a, end B writes
        # ring_b. Same blocking shape as the pipe path: yield when the
        # destination ring is full until the peer drains. Peer-gone is
        # surfaced as EPIPE (refs <= 1 means we're the only endpoint
        # left, so no future read will ever happen).
        sp_packed: uint64 = task[0].fd_buf[fdu]
        sp_slot: int32 = sockpair_unpack_slot(sp_packed)
        sp_dir:  int32 = sockpair_unpack_dir(sp_packed)
        total: uint64 = 0
        while total < count:
            if sockpair_peer_alive(sp_slot, sp_dir) == 0:
                if total > 0:
                    return cast[int64](total)
                return cast[int64](EPIPE)
            chunk: int64 = sockpair_write(sp_slot, sp_dir,
                cast[Ptr[uint8]](cast[uint64](buf) + total),
                count - total)
            if chunk > 0:
                total = total + cast[uint64](chunk)
            else:
                yield_to_others()
        return cast[int64](total)
    if file_idx == FD_PIPE_MARK_R:
        return cast[int64](EBADF)              # can't write a read end
    if file_idx == FD_STDOUT_MARK or file_idx == FD_STDERR_MARK:
        # M16.77: mirror every byte to BOTH the UART and the VGA text
        # console. The UART feeds `-nographic` QEMU; the VGA console
        # is what a real-hardware user sees on the monitor. Same byte
        # stream on both. early_putc() already fans out to vga_putc()
        # internally, so a single call here drives both surfaces —
        # calling vga_putc() a second time would double every glyph
        # on the framebuffer.
        i: uint64 = 0
        while i < count:
            ch: int32 = cast[int32](buf[i])
            early_putc(ch)
            i = i + 1
        return cast[int64](count)
    if file_idx == FD_STDIN_MARK:
        return cast[int64](EBADF)

    # initramfs is read-only.
    return cast[int64](EROFS)


def vfs_dup(oldfd: int32) -> int32:
    # Allocate the smallest free fd, copy oldfd's entry into it.
    # Pipe refcounts get bumped via copy_fd_entry, so closing oldfd
    # later doesn't affect the duplicate. Returns the new fd or
    # -EBADF / -EMFILE.
    rc: int32 = _check_fd(oldfd)
    if rc != 0:
        return rc
    task: Ptr[TaskStruct] = current_task()
    oldu: uint64 = cast[uint64](oldfd)
    if task[0].fd_idx[oldu] == FD_CLOSED_MARK:
        return EBADF
    newfd: int32 = _alloc_fd(task)
    if newfd < 0:
        return EMFILE
    # V5: bump socketpair refcount before copy_fd_entry. core.ad's
    # copy_fd_entry only knows about pipe marks; FD_SOCKETPAIR_MARK
    # needs its inc-ref here so a later vfs_close on either fd
    # decrements correctly. Same hook lives in vfs_dup2.
    if task[0].fd_idx[oldu] == FD_SOCKETPAIR_MARK:
        old_pkd: uint64 = task[0].fd_buf[oldu]
        sockpair_inc_ref(sockpair_unpack_slot(old_pkd),
                         sockpair_unpack_dir(old_pkd))
    copy_fd_entry(task, cast[uint64](newfd), task, oldu)
    return newfd


def vfs_dup2(oldfd: int32, newfd: int32) -> int32:
    # Close newfd (if open) and copy oldfd's entry into it. If
    # oldfd == newfd we do nothing — POSIX, and crucially avoids
    # the close-then-copy footgun where closing the only remaining
    # reference to oldfd's resource would free it before we copy.
    rc: int32 = _check_fd(oldfd)
    if rc != 0:
        return rc
    rc = _check_fd(newfd)
    if rc != 0:
        return rc
    task: Ptr[TaskStruct] = current_task()
    oldu: uint64 = cast[uint64](oldfd)
    newu: uint64 = cast[uint64](newfd)
    if task[0].fd_idx[oldu] == FD_CLOSED_MARK:
        return EBADF
    if oldfd == newfd:
        return newfd
    if task[0].fd_idx[newu] != FD_CLOSED_MARK:
        # V5: if newfd was a socketpair endpoint, decrement its
        # refcount before close_fd_in_task wipes the slot (same
        # core.ad-can't-be-touched workaround vfs_close uses).
        if task[0].fd_idx[newu] == FD_SOCKETPAIR_MARK:
            new_pkd: uint64 = task[0].fd_buf[newu]
            sockpair_close(sockpair_unpack_slot(new_pkd),
                           sockpair_unpack_dir(new_pkd))
        close_fd_in_task(task, newu)
    # V5: bump socketpair refcount before copy_fd_entry (see vfs_dup).
    if task[0].fd_idx[oldu] == FD_SOCKETPAIR_MARK:
        old_pkd: uint64 = task[0].fd_buf[oldu]
        sockpair_inc_ref(sockpair_unpack_slot(old_pkd),
                         sockpair_unpack_dir(old_pkd))
    copy_fd_entry(task, newu, task, oldu)
    return newfd


def vfs_close(fd: int32) -> int32:
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return rc
    task: Ptr[TaskStruct] = current_task()
    fdu: uint64 = cast[uint64](fd)
    file_idx: uint32 = task[0].fd_idx[fdu]
    if file_idx == FD_CLOSED_MARK:
        return EBADF
    # V1: 9P fd — issue Tclunk before the slot is reclaimed. We DO
    # fall through to close_fd_in_task afterwards so the per-task
    # slot is zeroed by the same cleanup path every other backend
    # uses (otherwise dup'd FD_P9_MARK fds would double-clunk on
    # second close, since close_fd_in_task doesn't know about the
    # 9P refcounting story yet — V2 lifts that).
    if file_idx == FD_CHAN_MARK:
        # Phase D: namec Chan-backed fd. namec_close releases the Chan
        # — for a DEV_MNT chan it issues Tclunk over the 9P server so
        # the fid is reclaimed; an inline cdev chan has no allocated
        # state so close is a no-op. We DO fall through to
        # close_fd_in_task afterwards so the per-task fd slot is zeroed
        # by the same path every backend uses (close_fd_in_task in
        # core.ad has no FD_CHAN_MARK arm — and must not, core.ad is
        # off-limits — so the clunk has to happen here, exactly the
        # same shape as the FD_P9_MARK arm below).
        namec_close(_fd_chan_id(task, fdu))
    if file_idx == FD_P9_MARK:
        p9_packed: uint64 = task[0].fd_buf[fdu]
        srvfd_p9: int32 = p9c_decode_srvfd(p9_packed)
        fid_p9:   int32 = p9c_decode_fid(p9_packed)
        p9c_clunk(srvfd_p9, fid_p9)
    # V5: socketpair endpoint — decrement the SocketPair's refcount
    # BEFORE close_fd_in_task wipes the slot (it doesn't know about
    # FD_SOCKETPAIR_MARK, since core.ad is off-limits for this
    # milestone). On last close (both ends' refs hit 0) sockpair_close
    # frees the rings. Mirrors the FD_P9_MARK / p9c_clunk shape above.
    if file_idx == FD_SOCKETPAIR_MARK:
        sp_pkd:  uint64 = task[0].fd_buf[fdu]
        sp_slot: int32 = sockpair_unpack_slot(sp_pkd)
        sp_dir:  int32 = sockpair_unpack_dir(sp_pkd)
        sockpair_close(sp_slot, sp_dir)
    # U-socket: an AF_INET socket fd carrying a live TCP connection
    # must tear that connection down (FIN handshake via tcp_close)
    # and release its backing record BEFORE close_fd_in_task wipes the
    # fd_buf that points at the record. close_fd_in_task knows nothing
    # about FD_SOCKET_MARK records (core.ad is off-limits here), same
    # rationale as the FD_P9_MARK / FD_SOCKETPAIR_MARK arms above.
    if file_idx == FD_SOCKET_MARK:
        sk_rec: int32 = usock_record_for_fdbuf(task[0].fd_buf[fdu])
        if sk_rec >= 0:
            sk_tcp: int32 = usock_get_tcp_slot(sk_rec)
            # §10 UDP: a datagram socket's stack slot is a udp.ad socket
            # slot — release it via udp_socket_close (no FIN handshake;
            # UDP is connectionless). Then free the backing record.
            if usock_get_type(sk_rec) == USOCK_SOCK_DGRAM:
                if sk_tcp >= 0:
                    udp_socket_close(sk_tcp)
                usock_free(sk_rec)
            else:
                if sk_tcp >= 0:
                    # U-TLS: a TLS-active fd gets a graceful TLS shutdown
                    # first — send a close_notify alert (best-effort) and
                    # reset the in-kernel TLS session so a later
                    # tls_connect(2) can claim it again. Then the TCP
                    # slot is torn down the same way a plain socket fd
                    # is.
                    if usock_is_tls(sk_rec) != 0:
                        tls_close_notify(sk_tcp)
                        tls_close()
                        usock_set_tls(sk_rec, 0)
                    # A LISTENING socket's tcp slot is a passive TCB
                    # with no peer — tcp_listen_close resets it without
                    # a FIN. A CONNECTED / CLOSED socket gets the full
                    # FIN handshake via tcp_close.
                    if usock_get_state(sk_rec) == USOCK_LISTENING:
                        tcp_listen_close(sk_tcp)
                    else:
                        tcp_close(sk_tcp)
                usock_free(sk_rec)
    # /proc/<pid>/<file> fds carry no per-fd backing — devproc_close
    # is a no-op success today (kept as a hook so future per-fd
    # snapshot support can land without re-plumbing the close path).
    # We still fall through to close_fd_in_task which rewrites the
    # slot to FD_CLOSED_MARK and zeros fd_pos/fd_buf/fd_buflen.
    if devproc_is_proc_fd(file_idx) != 0:
        devproc_close(file_idx)
    # Delegate the release pattern to kernel/sched/core.ad's
    # close_fd_in_task — same helper task_exit_current uses, so
    # explicit-close and implicit-on-exit have identical cleanup
    # (kfree procfs buffer, decrement pipe refcounts, etc).
    close_fd_in_task(task, fdu)
    return 0


def vfs_lseek(fd: int32, offset: int64, whence: int32) -> int64:
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return cast[int64](rc)
    task: Ptr[TaskStruct] = current_task()
    fdu: uint64 = cast[uint64](fd)
    file_idx: uint32 = task[0].fd_idx[fdu]
    if file_idx == FD_CLOSED_MARK:
        return cast[int64](EBADF)
    if file_idx == FD_STDIN_MARK or file_idx == FD_STDOUT_MARK \
            or file_idx == FD_STDERR_MARK or file_idx == FD_BUFFER_MARK \
            or file_idx == FD_PIPE_MARK_R or file_idx == FD_PIPE_MARK_W \
            or file_idx == FD_DEVNULL_MARK or file_idx == FD_DEVZERO_MARK \
            or file_idx == FD_DIR_MARK or file_idx == FD_SOCKET_MARK \
            or file_idx == FD_SOCKETPAIR_MARK \
            or file_idx == FD_CONS_MARK or file_idx == FD_TIME_MARK \
            or file_idx == FD_PID_MARK or file_idx == FD_RANDOM_MARK \
            or file_idx == FD_MOUSE_MARK or file_idx == FD_CPUINFO_MARK \
            or file_idx == FD_MEMINFO_MARK or file_idx == FD_UPTIME_MARK \
            or file_idx == FD_LOADAVG_MARK or file_idx == FD_VERSION_MARK \
            or file_idx == FD_HOSTNAME_MARK or file_idx == FD_STAT_MARK \
            or file_idx == FD_MOUNTS_MARK or file_idx == FD_DISKSTATS_MARK:
        # Linux returns ESPIPE for seek on a pipe / tty / char device;
        # we don't distinguish that errno yet, just say EINVAL. procfs
        # files are seekable in Linux but our snapshot semantics make
        # seek on them less useful — punt on it for now.
        return cast[int64](EINVAL)
    if devproc_is_proc_fd(file_idx) != 0:
        # /proc/<pid>/<file> reads are stateless one-shot renders;
        # there's no buffer to seek over. EINVAL matches the other
        # char-device cases above (Plan 9 devproc.c returns -1 with
        # errstr "no seek on /proc"; we don't have ESPIPE wired up
        # yet so EINVAL is the closest fit).
        return cast[int64](EINVAL)
    if file_idx == FD_TMPFS_MARK:
        slot: int32 = cast[int32](task[0].fd_buf[fdu])
        size: uint64 = tmpfs_size(slot)
        new_pos: int64 = 0
        if whence == SEEK_SET:
            new_pos = offset
        elif whence == SEEK_CUR:
            new_pos = cast[int64](task[0].fd_pos[fdu]) + offset
        elif whence == SEEK_END:
            new_pos = cast[int64](size) + offset
        else:
            return cast[int64](EINVAL)
        if new_pos < 0:
            return cast[int64](EINVAL)
        task[0].fd_pos[fdu] = cast[uint64](new_pos)
        return new_pos
    if file_idx == FD_FAT_MARK:
        fatbuf_s: uint64 = task[0].fd_buf[fdu]
        size: uint64 = 0
        if (fatbuf_s & FAT_FD_WRITE_BIT) != 0:
            # Write-mode FAT fd: size is tracked by the write slot,
            # not the read open-file table. SEEK_END off a write fd
            # is uncommon; SEEK_SET / SEEK_CUR are the usual cases.
            size = 0
        else:
            size = fat_open_size(cast[int32](fatbuf_s))
        new_pos: int64 = 0
        if whence == SEEK_SET:
            new_pos = offset
        elif whence == SEEK_CUR:
            new_pos = cast[int64](task[0].fd_pos[fdu]) + offset
        elif whence == SEEK_END:
            new_pos = cast[int64](size) + offset
        else:
            return cast[int64](EINVAL)
        if new_pos < 0:
            return cast[int64](EINVAL)
        task[0].fd_pos[fdu] = cast[uint64](new_pos)
        return new_pos
    if file_idx == FD_EXT4_MARK:
        slot: int32 = cast[int32](task[0].fd_buf[fdu])
        size: uint64 = ext4_open_size(slot)
        new_pos: int64 = 0
        if whence == SEEK_SET:
            new_pos = offset
        elif whence == SEEK_CUR:
            new_pos = cast[int64](task[0].fd_pos[fdu]) + offset
        elif whence == SEEK_END:
            new_pos = cast[int64](size) + offset
        else:
            return cast[int64](EINVAL)
        if new_pos < 0:
            return cast[int64](EINVAL)
        task[0].fd_pos[fdu] = cast[uint64](new_pos)
        return new_pos
    if file_idx == FD_P9_MARK or file_idx == FD_CHAN_MARK:
        # 9P / namec-Chan seek. SEEK_SET / SEEK_CUR just adjust fd_pos
        # — a subsequent vfs_read passes the new offset through to the
        # DEV_MNT mountrpc leg's Tread (an inline cdev ignores the
        # offset). SEEK_END would need a Tstat round-trip to discover
        # the server-side length; not wired — surface EINVAL so
        # callers fall back cleanly. FD_CHAN_MARK shares this arm
        # because a 9P-mounted Chan is seekable the same way an
        # FD_P9_MARK fd was.
        new_pos: int64 = 0
        if whence == SEEK_SET:
            new_pos = offset
        elif whence == SEEK_CUR:
            new_pos = cast[int64](task[0].fd_pos[fdu]) + offset
        else:
            # SEEK_END or unknown whence.
            return cast[int64](EINVAL)
        if new_pos < 0:
            return cast[int64](EINVAL)
        task[0].fd_pos[fdu] = cast[uint64](new_pos)
        return new_pos

    size: uint64 = initramfs_entry_size(cast[uint64](file_idx))
    new_pos: int64 = 0
    if whence == SEEK_SET:
        new_pos = offset
    elif whence == SEEK_CUR:
        new_pos = cast[int64](task[0].fd_pos[fdu]) + offset
    elif whence == SEEK_END:
        new_pos = cast[int64](size) + offset
    else:
        return cast[int64](EINVAL)

    if new_pos < 0:
        return cast[int64](EINVAL)
    task[0].fd_pos[fdu] = cast[uint64](new_pos)
    return new_pos


# --- U32: directory-fd accessors for getdents64 -----------------------
#
# getdents64() in linux_abi/u_syscalls.ad needs to walk the per-fd
# NAME\n buffer prepared by _open_dir_with(). Rather than reach into
# task_struct fields from u_syscalls.ad, expose three small accessors
# that hide the layout and the FD_DIR_MARK check.

def vfs_fd_is_dir(fd: int32) -> int32:
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return 0
    task: Ptr[TaskStruct] = current_task()
    fdu: uint64 = cast[uint64](fd)
    if task[0].fd_idx[fdu] == FD_DIR_MARK:
        return 1
    return 0


def vfs_fd_mtime(fd: int32) -> int64:
    # Report the file's modification time (Unix epoch seconds) for the
    # stat path. Only ext4 stores a real per-inode mtime today; for
    # every other fd flavour this returns -1 and the stat handler
    # falls back to the jiffies-derived clock. Used so `stat` reports
    # a genuine mtime and make-style "is target newer than source"
    # timestamp logic works against ext4 files.
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return -1
    task: Ptr[TaskStruct] = current_task()
    fdu: uint64 = cast[uint64](fd)
    if task[0].fd_idx[fdu] != FD_EXT4_MARK:
        return -1
    slot: int32 = cast[int32](task[0].fd_buf[fdu])
    inum: uint32 = ext4_open_inum(slot)
    if inum == 0:
        return -1
    inode: Array[256, uint8]
    if ext4_read_inode(cast[uint64](inum), &inode[0]) != 0:
        return -1
    return cast[int64](ext4_inode_mtime(&inode[0]))


def vfs_fd_dir_buf(fd: int32) -> uint64:
    task: Ptr[TaskStruct] = current_task()
    return task[0].fd_buf[cast[uint64](fd)]


def vfs_fd_dir_buflen(fd: int32) -> uint64:
    task: Ptr[TaskStruct] = current_task()
    return task[0].fd_buflen[cast[uint64](fd)]


def vfs_fd_dir_pos(fd: int32) -> uint64:
    task: Ptr[TaskStruct] = current_task()
    return task[0].fd_pos[cast[uint64](fd)]


def vfs_fd_dir_set_pos(fd: int32, pos: uint64):
    task: Ptr[TaskStruct] = current_task()
    task[0].fd_pos[cast[uint64](fd)] = pos
