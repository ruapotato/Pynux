# fs/vfs.py
#
# Mirrors fs/open.c + fs/read_write.c + fs/namei.c at minimum scope.
# As of M16.26 the fd table is PER-TASK (lives inline in task_struct's
# fd_idx[4] / fd_pos[4] arrays); reads come out of the baked-in
# initramfs (M16.21); writes route to the early-console UART for
# stdout/stderr, since the initramfs itself is read-only.
#
# Special fd_idx markers (from kernel/sched/core.py):
#   FD_CLOSED_MARK = 0xFFFFFFFF       slot is free
#   FD_STDIN_MARK  = 0xFFFFFFFC       reads return EOF (no input source yet)
#   FD_STDOUT_MARK = 0xFFFFFFFE       writes route to serial
#   FD_STDERR_MARK = 0xFFFFFFFD       writes route to serial
#   FD_CONS_MARK   = 0xFFFFFFF1       /dev/cons — Plan 9-style r/w console
#   FD_TIME_MARK   = 0xFFFFFFF0       /dev/time — ns-since-boot ASCII
#   FD_PID_MARK    = 0xFFFFFFEF       /dev/pid  — current task pid ASCII
#   FD_RANDOM_MARK = 0xFFFFFFEE       /dev/random — xorshift64 placeholder
#   FD_MOUSE_MARK  = 0xFFFFFFED       /dev/mouse — PS/2 mouse event line
#   FD_CPUINFO_MARK= 0xFFFFFFEC       /dev/cpuinfo — CPU snapshot
#   FD_MEMINFO_MARK= 0xFFFFFFEB       /dev/meminfo — memory snapshot
#   FD_UPTIME_MARK = 0xFFFFFFEA       /dev/uptime — secs-since-boot ASCII
#   FD_LOADAVG_MARK= 0xFFFFFFE9       /dev/loadavg — load + procs ASCII
#   FD_VERSION_MARK= 0xFFFFFFE8       /dev/version — release id string
#   FD_HOSTNAME_MARK=0xFFFFFFE7       /dev/hostname — r/w kernel hostname
#   FD_STAT_MARK   = 0xFFFFFFE6       /dev/stat — Linux /proc/stat shape
#   FD_MOUNTS_MARK = 0xFFFFFFE5       /dev/mounts — Linux /proc/mounts shape
#   FD_DISKSTATS_MARK=0xFFFFFFE4      /dev/diskstats — /proc/diskstats shape
#   FD_PROC_MARK   = 0xFE000000       /proc/<pid>/<file> family
#     (high-byte tag; low 24 bits encode pid<<8 | file_kind — see
#      sys/src/9/port/devproc.ad header for the full layout)
# Anything below 0xFE000000 is a real initramfs file index.
#
# Linux semantics we keep:
#   SEEK_SET / SEEK_CUR / SEEK_END
#   read/write/lseek return -errno on failure (we use small negative
#   ints; no real errno space yet)
#   close on an already-closed fd returns -EBADF (-9)

