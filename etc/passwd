# /etc/passwd — Hamnix Plan-9-shape user table per docs/security.md.
#
# Format: name:uid:gid:home:shell  (no GECOS — KISS)
#
# uid 0 doesn't exist in Hamnix (the "root" idiom is gone). uid 1 is
# the SINGLE hostowner. 2..999 are reserved for system services. 1000+
# are regular users (assigned by the installer or by the hostowner).
#
# /etc/shadow stores password hashes ($6$<salt>$<sha-512-crypt>).
#
# The live ISO ships with hostowner `live` / password `hamnix`; the
# installer replaces this with the user's chosen username + password
# during install (see etc/install.hamsh).
live:1:1:/home/live:/bin/hamsh
sshd:2:2:/var/empty:/bin/false
hamsh-svc:3:3:/var/empty:/bin/false
