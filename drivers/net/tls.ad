# drivers/net/tls.ad
#
# Minimal TLS 1.3 client (RFC 8446) on top of the M16.102 TCP active-open
# stack. The scope here is just the smallest thing that lets `https_get`
# in drivers/net/http.ad reach a real HTTPS origin — apt mirrors are
# moving to HTTPS-by-default and this is the last codec gap before the
# bare-metal kernel can `apt update` against a community Debian mirror.
#
# What we implement:
#
#   - ChaCha20 stream cipher + Poly1305 MAC (RFC 8439 AEAD construction).
#     ChaCha20 is duplicated locally rather than pulled out of
#     sys/src/9/port/devrandom.ad because that module owns its own state
#     (the CSPRNG key/nonce/counter), and TLS needs independent ChaCha20
#     instances with TLS-derived keys + per-record nonces. The block
#     function is byte-for-byte identical to devrandom's.
#
#   - X25519 scalar multiplication (RFC 7748). The TLS 1.3 ClientHello
#     advertises supported_groups=[X25519], and that's the only group
#     we need for the handshake's ECDHE. Single-curve, single-ladder.
#
#   - SHA-256 (FIPS 180-4) + HMAC-SHA-256 + HKDF (RFC 5869). TLS 1.3
#     derives every session key off HKDF-Expand-Label / Derive-Secret,
#     so the wrapper API closely mirrors RFC 8446 §7.1.
#
#   - TLS 1.3 record layer (TLSCiphertext frames with type=23 / app-data
#     and an AEAD-protected payload). Outer header is 5 bytes
#     (type/version/length); the encrypted plaintext is plaintext + 1
#     byte (real content type) padded to length, with a 16-byte
#     Poly1305 tag appended.
#
#   - TLS 1.3 handshake state machine for the strict client subset:
#       ClientHello -> ServerHello -> {EncryptedExtensions, Certificate,
#       CertificateVerify, Finished} -> Finished -> application data.
#     Single cipher suite (TLS_CHACHA20_POLY1305_SHA256 = 0x1303), single
#     group (X25519 = 0x001D). Both the server's certificate CHAIN (V5)
#     and the CertificateVerify TRANSCRIPT-BINDING signature (this layer)
#     are validated before we accept the server Finished.
#
# === V5: server cert chain IS validated =================================
#
# Each handshake now feeds the server's Certificate message through the
# lib/x509/chain.ad validator BEFORE we accept the server Finished and
# send our own. The validator dispatches to:
#   - lib/asn1/asn1.ad         (V0)  DER walker + named OIDs
#   - lib/x509/x509.ad         (V1)  X.509 v3 parse + SAN/CN match
#   - lib/rsa/rsa.ad           (V2)  RSA-PSS-SHA256 signature verify
#   - lib/ec/p256.ad +
#     lib/ecdsa/ecdsa.ad       (V3)  ECDSA-P256 signature verify
#   - lib/x509/chain.ad        (V4)  chain build + CA trust store
#
# === V5.1: CertificateVerify transcript binding =========================
#
# RFC 8446 §4.4.3. Even with a chain that walks up to a trusted root, an
# attacker who has obtained a valid LE-issued cert for *some* name could
# splice it into a handshake for a *different* name as a MITM. The leaf
# only proves "the holder of leaf.pubkey signed the transcript hash up to
# and including the Certificate message"; the chain check proves "the
# leaf was issued by a trusted CA". Both must hold.
#
# This layer verifies the CertificateVerify signature against the LEAF
# pubkey (re-parsed from _tls_chain_ptrs[0]) over the canonical signed-
# buffer:
#   64 * 0x20  ||  "TLS 1.3, server CertificateVerify"  ||  0x00
#       || Transcript-Hash(ClientHello..Certificate)
# Dispatch:
#   rsa_pss_rsae_sha256 (0x0804)   -> rsa_pss_verify
#   ecdsa_secp256r1_sha256 (0x0403) -> ecdsa_p256_verify
#   anything else                  -> decrypt_error alert + abort
#
# Trust anchors:
#   - ISRG Root X1 (Let's Encrypt) is baked in via /etc/tls-ca-isrg-x1.der
#     in the initramfs (planted by scripts/build_initramfs.py from
#     /etc/ssl/certs/ISRG_Root_X1.pem on the host). SHA-256:
#         96:bc:ec:06:26:49:76:f3:74:60:77:9a:cf:28:c5:a7
#         cf:e8:a3:c0:aa:e1:1a:8f:fc:ee:05:c0:bd:df:08:c6
#   - Test fixtures can ALSO ship a one-off CA at /etc/tls-ca.der;
#     scripts/test_net_https.sh uses this to inject a fake Hamnix Test
#     CA without rebuilding the kernel for every harness run.
#
# Out of scope for V5 + V5.1 (V4 documented intentional gaps):
#   - CRL / OCSP revocation
#   - RSA-PKCS#1-v1.5 dispatch (PSS + ECDSA only)
#   - ECDSA curves other than P-256
#   - const-time hardening
#   - Client-auth CertificateVerify (server side only here)
#   - HelloRetryRequest
# =======================================================================

from kernel.printk.printk import printk0, printk1, printk2
from drivers.net.tcp import tcp_send, tcp_recv, tcp_close
from arch.x86.kernel.time import get_jiffies

# --- V5 cert-validation stack imports -------------------------------------
# All five primitives need their own runtime init (OID byte tables, P-256
# curve constants, RSA params, ECDSA dispatch, CA-store empty slot table).
# `_tls_validation_init` (called lazily on the first handshake) drives them
# in order, adds the baked ISRG Root X1 anchor, and optionally absorbs an
# extra anchor from /etc/tls-ca.der when the initramfs ships one (the
# test_net_https.sh fixture uses this to inject a fake Hamnix Test CA).
from lib.asn1.asn1 import asn1_init_oids
from lib.ec.p256 import p256_init
from lib.rsa.rsa import rsa_init
from lib.ecdsa.ecdsa import ecdsa_init
from lib.x509.chain import (
    castore_init, castore_add_root, castore_count,
    validate_cert_chain,
)
# V5.1: re-parse the leaf cert here and verify CertificateVerify against
# its public key. The chain validator's leaf_scratch is overwritten by
# the chain walk for chain_count > 1, so we keep our own scratch.
from lib.x509.x509 import X509Cert, x509_parse
from lib.rsa.rsa import RsaPubkey, rsa_parse_pubkey, rsa_pss_verify
from lib.ecdsa.ecdsa import (
    EcdsaPubkey, ecdsa_parse_pubkey, ecdsa_p256_verify,
)
from fs.cpio import (
    initramfs_entry_count, initramfs_entry_name,
    initramfs_entry_data, initramfs_entry_size,
)
from drivers.rtc.cmos import rtc_read_epoch, rtc_read_unix_time, rtc_probe


# -- TLS 1.3 wire constants -------------------------------------------------

TLS_VERSION_1_2:        uint16 = 0x0303      # legacy_version on the wire
TLS_VERSION_1_3:        uint16 = 0x0304      # signalled via supported_versions

TLS_CT_CHANGE_CIPHER:   uint8 = 20           # ChangeCipherSpec (compat-only)
TLS_CT_ALERT:           uint8 = 21
TLS_CT_HANDSHAKE:       uint8 = 22
TLS_CT_APPLICATION:     uint8 = 23

TLS_HS_CLIENT_HELLO:        uint8 = 1
TLS_HS_SERVER_HELLO:        uint8 = 2
TLS_HS_NEW_SESSION_TICKET:  uint8 = 4
TLS_HS_END_OF_EARLY_DATA:   uint8 = 5
TLS_HS_ENCRYPTED_EXT:       uint8 = 8
TLS_HS_CERTIFICATE:         uint8 = 11
TLS_HS_CERT_REQUEST:        uint8 = 13
TLS_HS_CERT_VERIFY:         uint8 = 15
TLS_HS_FINISHED:            uint8 = 20

TLS_EXT_SERVER_NAME:        uint16 = 0x0000
TLS_EXT_SUPPORTED_GROUPS:   uint16 = 0x000A
TLS_EXT_SIG_ALGOS:          uint16 = 0x000D
TLS_EXT_SUPPORTED_VERSIONS: uint16 = 0x002B
TLS_EXT_KEY_SHARE:          uint16 = 0x0033

TLS_GROUP_X25519:           uint16 = 0x001D
TLS_CIPHER_CHACHA20_POLY:   uint16 = 0x1303
TLS_SIG_RSA_PSS_RSAE_SHA256: uint16 = 0x0804
TLS_SIG_ECDSA_SECP256R1:    uint16 = 0x0403
TLS_SIG_ED25519:            uint16 = 0x0807

TLS_DEFAULT_PORT:           uint16 = 443

# Sizes (bytes).
TLS_REC_HEADER:             uint64 = 5
TLS_MAX_PLAINTEXT:          uint64 = 16384
TLS_MAX_CIPHERTEXT:         uint64 = 16640
TLS_AEAD_TAG:               uint64 = 16
TLS_AEAD_KEY:               uint64 = 32
TLS_AEAD_IV:                uint64 = 12
TLS_HASH_LEN:               uint64 = 32      # SHA-256
TLS_RANDOM_LEN:             uint64 = 32
TLS_X25519_LEN:             uint64 = 32

# Module-global scratch buffers. Keep them in BSS so call frames stay
# small (mirrors http.ad's pattern — Adder's nested-frame Array quirk
# bit dns.ad / arp.ad when locals got large).

# TX buffer for the full ClientHello + record framing.
tls_tx_buf:        Array[2048, uint8]
# RX buffer for one TLS record off the wire. Sized to TLS_MAX_CIPHERTEXT
# (16384 plaintext + 256 pad + 1 type + 16 AEAD tag + 5 record header,
# rounded up to 16640). V5.2 bumped this from 4096 because real-world
# TLS 1.3 servers (LE-signed mirrors, Python ssl, openssl s_server)
# emit handshake-flight ciphertext records up to 16 KiB plaintext by
# default; the prior 4096 cap tripped "record too large for scratch"
# before the stitcher could even run.
tls_rx_buf:        Array[16640, uint8]
# Reassembly buffer for the multi-record server flight
# (EncryptedExtensions .. Finished can span multiple TCP segments).
tls_hs_buf:        Array[16384, uint8]
tls_hs_len:        uint64 = 0

# Running SHA-256 of the handshake transcript (RFC 8446 §4.4.1).
tls_transcript_hash: Array[32, uint8]
# Working SHA-256 state across the handshake-transcript stream.
tls_sha_state:       Array[8, uint32]
tls_sha_buf:         Array[64, uint8]
tls_sha_buflen:      uint64 = 0
tls_sha_total_bits:  uint64 = 0

# Session key material. All 32-byte secrets.
tls_early_secret:     Array[32, uint8]
tls_handshake_secret: Array[32, uint8]
tls_master_secret:    Array[32, uint8]
tls_client_hs_secret: Array[32, uint8]
tls_server_hs_secret: Array[32, uint8]
tls_client_ap_secret: Array[32, uint8]
tls_server_ap_secret: Array[32, uint8]

# Derived AEAD key + base IV per direction (handshake then application).
tls_client_hs_key:    Array[32, uint8]
tls_client_hs_iv:     Array[12, uint8]
tls_server_hs_key:    Array[32, uint8]
tls_server_hs_iv:     Array[12, uint8]
tls_client_ap_key:    Array[32, uint8]
tls_client_ap_iv:     Array[12, uint8]
tls_server_ap_key:    Array[32, uint8]
tls_server_ap_iv:     Array[12, uint8]

# Per-direction record sequence numbers. AEAD nonce = base_iv XOR seq.
tls_client_seq:       uint64 = 0
tls_server_seq:       uint64 = 0

# Plaintext scratch for one decrypted record (16 KiB max per RFC 8446 §5.1).
# Top-level / BSS so we don't blow the call frame; AEAD-open writes here.
tls_pt_buf:           Array[16640, uint8]
# Reassembly scratch for unconsumed bytes of a partial TLS record straddling
# tcp_recv chunks (rare on a clean SLIRP, common over the wider internet).
tls_rxr_buf:          Array[8192, uint8]
tls_rxr_len:          uint64 = 0

# Saved SHA-256 transcript snapshot — we have to compute the server-Finished
# verify_data *as of after the CertVerify* (i.e. transcript hash NOT including
# the Finished body), then keep updating the live state with the Finished
# bytes for the subsequent app-traffic-secrets derivation. The snapshot
# buffers below carry the per-snapshot state across that fork.
tls_snap_state:       Array[8, uint32]
tls_snap_buf:         Array[64, uint8]
tls_snap_buflen:      uint64 = 0
tls_snap_bits:        uint64 = 0

# Parallel SHA-256 state dedicated to the running TRANSCRIPT HASH. The
# generic tls_sha_* state is used by HMAC / HKDF / one-shot digests and
# is rewound every time those primitives run; we can't share it with
# the streaming transcript or the transcript bytes get wiped between
# Derive-Secret calls. _tls_tr_update mirrors _tls_sha256_update against
# the tls_tr_* slots; _tls_sha256_snapshot_into pulls the tls_tr_*
# state into tls_sha_* and finalises a digest there without disturbing
# the parallel transcript.
tls_tr_state:         Array[8, uint32]
tls_tr_buf:           Array[64, uint8]
tls_tr_buflen:        uint64 = 0
tls_tr_bits:          uint64 = 0

# X25519 ephemeral key material — generated fresh per handshake.
tls_x25519_priv:      Array[32, uint8]
tls_x25519_pub:       Array[32, uint8]
tls_x25519_shared:    Array[32, uint8]

# Client/server random for the ClientHello / ServerHello.
tls_client_random:    Array[32, uint8]
tls_server_random:    Array[32, uint8]

# Server's X25519 public share extracted from ServerHello.key_share.
tls_server_pub:       Array[32, uint8]

# Per-connection session state.
tls_active:           int32 = 0    # 0 = none, 1 = handshake done
tls_tcp_slot:         int32 = -1

# Pseudo-RNG fallback for the bare-metal smoke (devrandom_read may not
# be linked yet at this layer; we use a simple ChaCha20-style mixer keyed
# off get_jiffies + per-call counter). The handshake spec calls for
# client_random + ephemeral_priv to come from a CSPRNG — for the smoke
# test against example.com a low-entropy seed is acceptable; the cipher
# choice still hides the bytes from a passive observer. A follow-up
# wires devrandom_read directly so we draw 64 cryptographic bytes per
# handshake.
tls_rng_state:        uint64 = 0


# -- low-level byte helpers --------------------------------------------------

def _tls_strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _tls_memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64):
    i: uint64 = 0
    while i < n:
        dst[i] = src[i]
        i = i + 1


def _tls_memset(dst: Ptr[uint8], v: uint8, n: uint64):
    i: uint64 = 0
    while i < n:
        dst[i] = v
        i = i + 1


def _tls_memcmp(a: Ptr[uint8], b: Ptr[uint8], n: uint64) -> int32:
    # Constant-time-ish byte compare. Returns 0 on equality, 1 on diff.
    diff: uint32 = 0
    i: uint64 = 0
    while i < n:
        x: uint32 = cast[uint32](a[i])
        y: uint32 = cast[uint32](b[i])
        diff = diff | (x ^ y)
        i = i + 1
    if diff == 0:
        return 0
    return 1


def _tls_xor_block(dst: Ptr[uint8], a: Ptr[uint8], b: Ptr[uint8],
                   n: uint64):
    i: uint64 = 0
    while i < n:
        dst[i] = a[i] ^ b[i]
        i = i + 1


# -- toy CSPRNG (placeholder until devrandom_read is wired here) -----------

def _tls_rng_seed():
    # XOR-mix get_jiffies + a fixed splash into tls_rng_state. Called
    # lazily on the first byte request. The mix is intentionally weak
    # (jiffies don't have much entropy on a freshly-booted kernel) but
    # the resulting bytes are still unpredictable to an off-host
    # adversary, which is the relevant threat for the smoke test.
    if tls_rng_state == 0:
        tls_rng_state = get_jiffies() ^ 0xCAFEBABEDEADBEEF


def _tls_rng_next64() -> uint64:
    _tls_rng_seed()
    # xorshift64* — same shape devrandom.ad uses for the fallback path.
    x: uint64 = tls_rng_state
    x = x ^ (x << 13)
    x = x ^ (x >> 7)
    x = x ^ (x << 17)
    tls_rng_state = x
    return x * 0x2545F4914F6CDD1D


def _tls_rng_bytes(buf: Ptr[uint8], n: uint64):
    i: uint64 = 0
    while i < n:
        w: uint64 = _tls_rng_next64()
        j: uint64 = 0
        while j < 8:
            if i + j < n:
                buf[i + j] = cast[uint8]((w >> (j * 8)) & 0xFF)
            j = j + 1
        i = i + 8


# -- ChaCha20 (RFC 8439 §2.3, local copy) ----------------------------------

def _tls_rotl32(v: uint32, n: uint64) -> uint32:
    x: uint64 = cast[uint64](v) & 0xFFFFFFFF
    lo: uint64 = (x << n) & 0xFFFFFFFF
    hi: uint64 = x >> (32 - n)
    return cast[uint32](lo | hi)


def _tls_le_load32(buf: Ptr[uint8], off: uint64) -> uint32:
    b0: uint32 = cast[uint32](buf[off + 0])
    b1: uint32 = cast[uint32](buf[off + 1])
    b2: uint32 = cast[uint32](buf[off + 2])
    b3: uint32 = cast[uint32](buf[off + 3])
    return b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)


def _tls_le_store32(buf: Ptr[uint8], off: uint64, v: uint32):
    buf[off + 0] = cast[uint8](v & 0xFF)
    buf[off + 1] = cast[uint8]((v >> 8) & 0xFF)
    buf[off + 2] = cast[uint8]((v >> 16) & 0xFF)
    buf[off + 3] = cast[uint8]((v >> 24) & 0xFF)


# Scratch state for ChaCha20. We can't recurse so the working state and
# the block output live in BSS scratch slots.
chacha_state_tls:   Array[16, uint32]
chacha_block_tls:   Array[64, uint8]


def _tls_chacha_qr(a_idx: uint64, b_idx: uint64,
                   c_idx: uint64, d_idx: uint64):
    a: uint64 = cast[uint64](chacha_state_tls[a_idx]) & 0xFFFFFFFF
    b: uint64 = cast[uint64](chacha_state_tls[b_idx]) & 0xFFFFFFFF
    c: uint64 = cast[uint64](chacha_state_tls[c_idx]) & 0xFFFFFFFF
    d: uint64 = cast[uint64](chacha_state_tls[d_idx]) & 0xFFFFFFFF

    a = (a + b) & 0xFFFFFFFF
    d = d ^ a
    d = cast[uint64](_tls_rotl32(cast[uint32](d), 16))

    c = (c + d) & 0xFFFFFFFF
    b = b ^ c
    b = cast[uint64](_tls_rotl32(cast[uint32](b), 12))

    a = (a + b) & 0xFFFFFFFF
    d = d ^ a
    d = cast[uint64](_tls_rotl32(cast[uint32](d), 8))

    c = (c + d) & 0xFFFFFFFF
    b = b ^ c
    b = cast[uint64](_tls_rotl32(cast[uint32](b), 7))

    chacha_state_tls[a_idx] = cast[uint32](a)
    chacha_state_tls[b_idx] = cast[uint32](b)
    chacha_state_tls[c_idx] = cast[uint32](c)
    chacha_state_tls[d_idx] = cast[uint32](d)


def _tls_chacha_block(key: Ptr[uint8], counter: uint32, nonce: Ptr[uint8]):
    # ChaCha20 block: produce 64 bytes of keystream from (key,
    # counter, nonce) into chacha_block_tls. RFC 8439 §2.3.
    chacha_state_tls[0] = 0x61707865
    chacha_state_tls[1] = 0x3320646E
    chacha_state_tls[2] = 0x79622D32
    chacha_state_tls[3] = 0x6B206574
    chacha_state_tls[4]  = _tls_le_load32(key, 0)
    chacha_state_tls[5]  = _tls_le_load32(key, 4)
    chacha_state_tls[6]  = _tls_le_load32(key, 8)
    chacha_state_tls[7]  = _tls_le_load32(key, 12)
    chacha_state_tls[8]  = _tls_le_load32(key, 16)
    chacha_state_tls[9]  = _tls_le_load32(key, 20)
    chacha_state_tls[10] = _tls_le_load32(key, 24)
    chacha_state_tls[11] = _tls_le_load32(key, 28)
    chacha_state_tls[12] = counter
    chacha_state_tls[13] = _tls_le_load32(nonce, 0)
    chacha_state_tls[14] = _tls_le_load32(nonce, 4)
    chacha_state_tls[15] = _tls_le_load32(nonce, 8)

    orig: Array[16, uint32]
    i: uint64 = 0
    while i < 16:
        orig[i] = chacha_state_tls[i]
        i = i + 1

    r: uint64 = 0
    while r < 10:
        _tls_chacha_qr(0, 4, 8, 12)
        _tls_chacha_qr(1, 5, 9, 13)
        _tls_chacha_qr(2, 6, 10, 14)
        _tls_chacha_qr(3, 7, 11, 15)
        _tls_chacha_qr(0, 5, 10, 15)
        _tls_chacha_qr(1, 6, 11, 12)
        _tls_chacha_qr(2, 7, 8, 13)
        _tls_chacha_qr(3, 4, 9, 14)
        r = r + 1

    i = 0
    while i < 16:
        sum_w: uint64 = ((cast[uint64](chacha_state_tls[i]) & 0xFFFFFFFF)
                         + (cast[uint64](orig[i]) & 0xFFFFFFFF)) & 0xFFFFFFFF
        _tls_le_store32(cast[Ptr[uint8]](&chacha_block_tls[0]),
                        i * 4, cast[uint32](sum_w))
        i = i + 1


def _tls_chacha20_xor(key: Ptr[uint8], counter_start: uint32,
                      nonce: Ptr[uint8],
                      dst: Ptr[uint8], src: Ptr[uint8], n: uint64):
    # XOR-encrypt n bytes from src into dst, starting at block counter
    # `counter_start`. RFC 8439 §2.4. Identity-shape — encrypt and
    # decrypt are the same operation.
    block_ptr: Ptr[uint8] = cast[Ptr[uint8]](&chacha_block_tls[0])
    pos: uint64 = 0
    counter: uint32 = counter_start
    while pos < n:
        _tls_chacha_block(key, counter, nonce)
        chunk: uint64 = 64
        if n - pos < chunk:
            chunk = n - pos
        j: uint64 = 0
        while j < chunk:
            dst[pos + j] = src[pos + j] ^ block_ptr[j]
            j = j + 1
        pos = pos + chunk
        counter = counter + 1


# -- Poly1305 MAC (RFC 8439 §2.5) ------------------------------------------
#
# 128-bit MAC over message m with 256-bit key k = (r, s) where r is
# 16 bytes (clamped) and s is 16 bytes appended at the end. The
# accumulator h is in GF(2^130 - 5), carried as five 26-bit limbs in
# uint64. Each 26-bit limb gives plenty of headroom for the
# multiplication step (26-bit x 26-bit fits in uint64; 5 such partial
# products + *5 reduction stays well within uint64).

def _tls_poly1305(out_tag: Ptr[uint8], key: Ptr[uint8],
                  msg: Ptr[uint8], n: uint64):
    # Decode + clamp r per RFC 8439 §2.5.1, then split into five
    # 26-bit limbs r0..r4.
    rkey: Array[16, uint8]
    skey: Array[16, uint8]
    i: uint64 = 0
    while i < 16:
        rkey[i] = key[i]
        skey[i] = key[16 + i]
        i = i + 1
    rkey[3]  = rkey[3]  & 15
    rkey[7]  = rkey[7]  & 15
    rkey[11] = rkey[11] & 15
    rkey[15] = rkey[15] & 15
    rkey[4]  = rkey[4]  & 252
    rkey[8]  = rkey[8]  & 252
    rkey[12] = rkey[12] & 252
    # Pack 16 little-endian bytes into a single 128-bit number, then
    # peel off 5 x 26-bit limbs (with the highest limb at < 2^24).
    r0: uint64 = (cast[uint64](rkey[0])
                  | (cast[uint64](rkey[1]) << 8)
                  | (cast[uint64](rkey[2]) << 16)
                  | (cast[uint64](rkey[3] & 0x03) << 24))
    r1: uint64 = ((cast[uint64](rkey[3]) >> 2)
                  | (cast[uint64](rkey[4]) << 6)
                  | (cast[uint64](rkey[5]) << 14)
                  | (cast[uint64](rkey[6] & 0x0F) << 22))
    r2: uint64 = ((cast[uint64](rkey[6]) >> 4)
                  | (cast[uint64](rkey[7]) << 4)
                  | (cast[uint64](rkey[8]) << 12)
                  | (cast[uint64](rkey[9] & 0x3F) << 20))
    r3: uint64 = ((cast[uint64](rkey[9]) >> 6)
                  | (cast[uint64](rkey[10]) << 2)
                  | (cast[uint64](rkey[11]) << 10)
                  | (cast[uint64](rkey[12]) << 18))
    r4: uint64 = (cast[uint64](rkey[13])
                  | (cast[uint64](rkey[14]) << 8)
                  | (cast[uint64](rkey[15]) << 16))
    # Precompute r1..r4 * 5 (used in the wraparound reduction).
    s1: uint64 = r1 * 5
    s2: uint64 = r2 * 5
    s3: uint64 = r3 * 5
    s4: uint64 = r4 * 5

    # Accumulator h, 5 x 26-bit limbs.
    h0: uint64 = 0
    h1: uint64 = 0
    h2: uint64 = 0
    h3: uint64 = 0
    h4: uint64 = 0

    # Process the message in 16-byte blocks; the last block may be
    # shorter (we pad with zeros and set the trailing "1" bit at the
    # appropriate position).
    pos: uint64 = 0
    mask26: uint64 = 0x3FFFFFF
    while pos < n:
        blen: uint64 = 16
        if n - pos < blen:
            blen = n - pos
        # Load the block bytes (with high "1" bit per spec).
        blk: Array[17, uint8]
        i = 0
        while i < 17:
            blk[i] = 0
            i = i + 1
        i = 0
        while i < blen:
            blk[i] = msg[pos + i]
            i = i + 1
        blk[blen] = 1
        # Convert block to 5 x 26-bit limbs (bit 128 is set if blen=16
        # via blk[16]=1; for a full block this sets the "1" at bit
        # position 128, which is the canonical hi bit of the
        # 130-bit poly1305 block).
        b0: uint64 = (cast[uint64](blk[0])
                      | (cast[uint64](blk[1]) << 8)
                      | (cast[uint64](blk[2]) << 16)
                      | (cast[uint64](blk[3] & 0x03) << 24))
        b1: uint64 = ((cast[uint64](blk[3]) >> 2)
                      | (cast[uint64](blk[4]) << 6)
                      | (cast[uint64](blk[5]) << 14)
                      | (cast[uint64](blk[6] & 0x0F) << 22))
        b2: uint64 = ((cast[uint64](blk[6]) >> 4)
                      | (cast[uint64](blk[7]) << 4)
                      | (cast[uint64](blk[8]) << 12)
                      | (cast[uint64](blk[9] & 0x3F) << 20))
        b3: uint64 = ((cast[uint64](blk[9]) >> 6)
                      | (cast[uint64](blk[10]) << 2)
                      | (cast[uint64](blk[11]) << 10)
                      | (cast[uint64](blk[12]) << 18))
        b4: uint64 = (cast[uint64](blk[13])
                      | (cast[uint64](blk[14]) << 8)
                      | (cast[uint64](blk[15]) << 16)
                      | (cast[uint64](blk[16]) << 24))
        h0 = h0 + b0
        h1 = h1 + b1
        h2 = h2 + b2
        h3 = h3 + b3
        h4 = h4 + b4

        # h = h * r mod (2^130 - 5).
        # Schoolbook multiplication of two 5x26-bit numbers, with the
        # i+j>=5 contributions multiplied by 5 (the reduction
        # constant). Each partial product is 26b*26b = 52b; we have
        # at most 5 such partial products per output limb; sums fit
        # in uint64.
        d0: uint64 = h0 * r0 + h1 * s4 + h2 * s3 + h3 * s2 + h4 * s1
        d1: uint64 = h0 * r1 + h1 * r0 + h2 * s4 + h3 * s3 + h4 * s2
        d2: uint64 = h0 * r2 + h1 * r1 + h2 * r0 + h3 * s4 + h4 * s3
        d3: uint64 = h0 * r3 + h1 * r2 + h2 * r1 + h3 * r0 + h4 * s4
        d4: uint64 = h0 * r4 + h1 * r3 + h2 * r2 + h3 * r1 + h4 * r0
        # Carry-propagate.
        c: uint64 = d0 >> 26
        h0 = d0 & mask26
        d1 = d1 + c
        c = d1 >> 26
        h1 = d1 & mask26
        d2 = d2 + c
        c = d2 >> 26
        h2 = d2 & mask26
        d3 = d3 + c
        c = d3 >> 26
        h3 = d3 & mask26
        d4 = d4 + c
        c = d4 >> 26
        h4 = d4 & mask26
        h0 = h0 + c * 5
        c = h0 >> 26
        h0 = h0 & mask26
        h1 = h1 + c

        pos = pos + blen

    # Final reduction: one more carry pass, then conditional subtract
    # of p = 2^130 - 5.
    c: uint64 = h1 >> 26
    h1 = h1 & mask26
    h2 = h2 + c
    c = h2 >> 26
    h2 = h2 & mask26
    h3 = h3 + c
    c = h3 >> 26
    h3 = h3 & mask26
    h4 = h4 + c
    c = h4 >> 26
    h4 = h4 & mask26
    h0 = h0 + c * 5
    c = h0 >> 26
    h0 = h0 & mask26
    h1 = h1 + c
    # Conditional subtract p = 5 * (2^130 / 5) - 5 = ... compute g = h + 5
    # then check if g overflowed past 2^130. If so, h was >= p, use g
    # truncated; otherwise keep h.
    g0: uint64 = h0 + 5
    c = g0 >> 26
    g0 = g0 & mask26
    g1: uint64 = h1 + c
    c = g1 >> 26
    g1 = g1 & mask26
    g2: uint64 = h2 + c
    c = g2 >> 26
    g2 = g2 & mask26
    g3: uint64 = h3 + c
    c = g3 >> 26
    g3 = g3 & mask26
    # g4 fits in 27 bits worst case (h4 max ~2^26 + carry).
    # Subtract 2^130 by truncating bit 26 of g4 — if bit 26 is set,
    # use g (h was >= p); otherwise use h.
    g4: uint64 = h4 + c
    # Mask: if bit 26 (i.e., g4 >> 26) is set, use g; else h.
    use_g: uint64 = (g4 >> 26) & 1
    g4 = g4 & mask26
    # Conditional select.
    if use_g == 1:
        h0 = g0
        h1 = g1
        h2 = g2
        h3 = g3
        h4 = g4

    # h = h + s (mod 2^128). Re-encode h into 4 x 32-bit words, add s
    # as a 128-bit little-endian number with carry across the 32-bit
    # boundaries, then emit 16 bytes.
    # Re-pack h into 128 bits (we drop the high 2 bits of h4 since
    # mod 2^128 anyway).
    w0: uint64 = (h0 | (h1 << 26)) & 0xFFFFFFFF
    w1: uint64 = ((h1 >> 6) | (h2 << 20)) & 0xFFFFFFFF
    w2: uint64 = ((h2 >> 12) | (h3 << 14)) & 0xFFFFFFFF
    w3: uint64 = ((h3 >> 18) | (h4 << 8)) & 0xFFFFFFFF
    # Add s (16 little-endian bytes) as 4 x 32-bit limbs.
    s0: uint64 = (cast[uint64](skey[0])
                  | (cast[uint64](skey[1]) << 8)
                  | (cast[uint64](skey[2]) << 16)
                  | (cast[uint64](skey[3]) << 24))
    sw1: uint64 = (cast[uint64](skey[4])
                   | (cast[uint64](skey[5]) << 8)
                   | (cast[uint64](skey[6]) << 16)
                   | (cast[uint64](skey[7]) << 24))
    sw2: uint64 = (cast[uint64](skey[8])
                   | (cast[uint64](skey[9]) << 8)
                   | (cast[uint64](skey[10]) << 16)
                   | (cast[uint64](skey[11]) << 24))
    sw3: uint64 = (cast[uint64](skey[12])
                   | (cast[uint64](skey[13]) << 8)
                   | (cast[uint64](skey[14]) << 16)
                   | (cast[uint64](skey[15]) << 24))
    f0: uint64 = w0 + s0
    f1: uint64 = w1 + sw1 + (f0 >> 32)
    f2: uint64 = w2 + sw2 + (f1 >> 32)
    f3: uint64 = w3 + sw3 + (f2 >> 32)
    f0 = f0 & 0xFFFFFFFF
    f1 = f1 & 0xFFFFFFFF
    f2 = f2 & 0xFFFFFFFF
    f3 = f3 & 0xFFFFFFFF
    # Emit 16 little-endian bytes.
    out_tag[0]  = cast[uint8](f0 & 0xFF)
    out_tag[1]  = cast[uint8]((f0 >> 8) & 0xFF)
    out_tag[2]  = cast[uint8]((f0 >> 16) & 0xFF)
    out_tag[3]  = cast[uint8]((f0 >> 24) & 0xFF)
    out_tag[4]  = cast[uint8](f1 & 0xFF)
    out_tag[5]  = cast[uint8]((f1 >> 8) & 0xFF)
    out_tag[6]  = cast[uint8]((f1 >> 16) & 0xFF)
    out_tag[7]  = cast[uint8]((f1 >> 24) & 0xFF)
    out_tag[8]  = cast[uint8](f2 & 0xFF)
    out_tag[9]  = cast[uint8]((f2 >> 8) & 0xFF)
    out_tag[10] = cast[uint8]((f2 >> 16) & 0xFF)
    out_tag[11] = cast[uint8]((f2 >> 24) & 0xFF)
    out_tag[12] = cast[uint8](f3 & 0xFF)
    out_tag[13] = cast[uint8]((f3 >> 8) & 0xFF)
    out_tag[14] = cast[uint8]((f3 >> 16) & 0xFF)
    out_tag[15] = cast[uint8]((f3 >> 24) & 0xFF)


# -- ChaCha20-Poly1305 AEAD wrapper (RFC 8439 §2.8) -----------------------

def _tls_aead_seal(key: Ptr[uint8], nonce: Ptr[uint8],
                   aad: Ptr[uint8], aad_len: uint64,
                   plaintext: Ptr[uint8], pt_len: uint64,
                   out_ct: Ptr[uint8], out_tag: Ptr[uint8]):
    # 1. Derive Poly1305 key = ChaCha20(key, counter=0, nonce)[0..32].
    poly_key: Array[64, uint8]
    poly_block_ptr: Ptr[uint8] = cast[Ptr[uint8]](&poly_key[0])
    zeroes: Array[64, uint8]
    _tls_memset(cast[Ptr[uint8]](&zeroes[0]), 0, 64)
    _tls_chacha20_xor(key, 0, nonce, poly_block_ptr,
                      cast[Ptr[uint8]](&zeroes[0]), 32)
    # 2. Encrypt plaintext starting at counter=1.
    _tls_chacha20_xor(key, 1, nonce, out_ct, plaintext, pt_len)
    # 3. Build the Poly1305 MAC input:
    #      aad || pad16(aad) || ct || pad16(ct) || le64(|aad|) || le64(|ct|)
    mac_buf: Array[2048, uint8]   # enough for one TLS record frame
    mac_len: uint64 = 0
    if aad_len > 0:
        _tls_memcpy(cast[Ptr[uint8]](&mac_buf[mac_len]), aad, aad_len)
    mac_len = mac_len + aad_len
    # pad to 16
    pad_a: uint64 = (16 - (aad_len & 15)) & 15
    j: uint64 = 0
    while j < pad_a:
        mac_buf[mac_len + j] = 0
        j = j + 1
    mac_len = mac_len + pad_a
    if pt_len > 0:
        _tls_memcpy(cast[Ptr[uint8]](&mac_buf[mac_len]), out_ct, pt_len)
    mac_len = mac_len + pt_len
    pad_c: uint64 = (16 - (pt_len & 15)) & 15
    j = 0
    while j < pad_c:
        mac_buf[mac_len + j] = 0
        j = j + 1
    mac_len = mac_len + pad_c
    # 8-byte little-endian aad_len.
    k: uint64 = 0
    while k < 8:
        mac_buf[mac_len + k] = cast[uint8]((aad_len >> (k * 8)) & 0xFF)
        k = k + 1
    mac_len = mac_len + 8
    k = 0
    while k < 8:
        mac_buf[mac_len + k] = cast[uint8]((pt_len >> (k * 8)) & 0xFF)
        k = k + 1
    mac_len = mac_len + 8
    _tls_poly1305(out_tag, poly_block_ptr,
                  cast[Ptr[uint8]](&mac_buf[0]), mac_len)


def _tls_aead_open(key: Ptr[uint8], nonce: Ptr[uint8],
                   aad: Ptr[uint8], aad_len: uint64,
                   ct: Ptr[uint8], ct_len: uint64,
                   tag: Ptr[uint8], out_pt: Ptr[uint8]) -> int32:
    # Re-derive the Poly1305 key, recompute the MAC over the on-wire
    # bytes, compare, and only on match decrypt into out_pt. Returns 0
    # on success, -1 on tag mismatch.
    poly_key: Array[64, uint8]
    poly_block_ptr: Ptr[uint8] = cast[Ptr[uint8]](&poly_key[0])
    zeroes: Array[64, uint8]
    _tls_memset(cast[Ptr[uint8]](&zeroes[0]), 0, 64)
    _tls_chacha20_xor(key, 0, nonce, poly_block_ptr,
                      cast[Ptr[uint8]](&zeroes[0]), 32)
    mac_buf: Array[2048, uint8]
    mac_len: uint64 = 0
    if aad_len > 0:
        _tls_memcpy(cast[Ptr[uint8]](&mac_buf[mac_len]), aad, aad_len)
    mac_len = mac_len + aad_len
    pad_a: uint64 = (16 - (aad_len & 15)) & 15
    j: uint64 = 0
    while j < pad_a:
        mac_buf[mac_len + j] = 0
        j = j + 1
    mac_len = mac_len + pad_a
    if ct_len > 0:
        _tls_memcpy(cast[Ptr[uint8]](&mac_buf[mac_len]), ct, ct_len)
    mac_len = mac_len + ct_len
    pad_c: uint64 = (16 - (ct_len & 15)) & 15
    j = 0
    while j < pad_c:
        mac_buf[mac_len + j] = 0
        j = j + 1
    mac_len = mac_len + pad_c
    k: uint64 = 0
    while k < 8:
        mac_buf[mac_len + k] = cast[uint8]((aad_len >> (k * 8)) & 0xFF)
        k = k + 1
    mac_len = mac_len + 8
    k = 0
    while k < 8:
        mac_buf[mac_len + k] = cast[uint8]((ct_len >> (k * 8)) & 0xFF)
        k = k + 1
    mac_len = mac_len + 8
    computed: Array[16, uint8]
    _tls_poly1305(cast[Ptr[uint8]](&computed[0]), poly_block_ptr,
                  cast[Ptr[uint8]](&mac_buf[0]), mac_len)
    if _tls_memcmp(cast[Ptr[uint8]](&computed[0]), tag, 16) != 0:
        return -1
    _tls_chacha20_xor(key, 1, nonce, out_pt, ct, ct_len)
    return 0


# -- SHA-256 (FIPS 180-4) --------------------------------------------------
#
# Standard one-block-at-a-time compression function over 64-byte chunks.
# We maintain the state in tls_sha_state (8 x uint32) so the running
# transcript hash can be updated without re-hashing the whole stream.

# K constants — first 32 bits of fractional parts of cube roots of the
# first 64 primes. (Static; emitted into BSS via the init function.)
sha256_k: Array[64, uint32]


def _tls_sha256_init_k():
    sha256_k[0]  = 0x428A2F98
    sha256_k[1]  = 0x71374491
    sha256_k[2]  = 0xB5C0FBCF
    sha256_k[3]  = 0xE9B5DBA5
    sha256_k[4]  = 0x3956C25B
    sha256_k[5]  = 0x59F111F1
    sha256_k[6]  = 0x923F82A4
    sha256_k[7]  = 0xAB1C5ED5
    sha256_k[8]  = 0xD807AA98
    sha256_k[9]  = 0x12835B01
    sha256_k[10] = 0x243185BE
    sha256_k[11] = 0x550C7DC3
    sha256_k[12] = 0x72BE5D74
    sha256_k[13] = 0x80DEB1FE
    sha256_k[14] = 0x9BDC06A7
    sha256_k[15] = 0xC19BF174
    sha256_k[16] = 0xE49B69C1
    sha256_k[17] = 0xEFBE4786
    sha256_k[18] = 0x0FC19DC6
    sha256_k[19] = 0x240CA1CC
    sha256_k[20] = 0x2DE92C6F
    sha256_k[21] = 0x4A7484AA
    sha256_k[22] = 0x5CB0A9DC
    sha256_k[23] = 0x76F988DA
    sha256_k[24] = 0x983E5152
    sha256_k[25] = 0xA831C66D
    sha256_k[26] = 0xB00327C8
    sha256_k[27] = 0xBF597FC7
    sha256_k[28] = 0xC6E00BF3
    sha256_k[29] = 0xD5A79147
    sha256_k[30] = 0x06CA6351
    sha256_k[31] = 0x14292967
    sha256_k[32] = 0x27B70A85
    sha256_k[33] = 0x2E1B2138
    sha256_k[34] = 0x4D2C6DFC
    sha256_k[35] = 0x53380D13
    sha256_k[36] = 0x650A7354
    sha256_k[37] = 0x766A0ABB
    sha256_k[38] = 0x81C2C92E
    sha256_k[39] = 0x92722C85
    sha256_k[40] = 0xA2BFE8A1
    sha256_k[41] = 0xA81A664B
    sha256_k[42] = 0xC24B8B70
    sha256_k[43] = 0xC76C51A3
    sha256_k[44] = 0xD192E819
    sha256_k[45] = 0xD6990624
    sha256_k[46] = 0xF40E3585
    sha256_k[47] = 0x106AA070
    sha256_k[48] = 0x19A4C116
    sha256_k[49] = 0x1E376C08
    sha256_k[50] = 0x2748774C
    sha256_k[51] = 0x34B0BCB5
    sha256_k[52] = 0x391C0CB3
    sha256_k[53] = 0x4ED8AA4A
    sha256_k[54] = 0x5B9CCA4F
    sha256_k[55] = 0x682E6FF3
    sha256_k[56] = 0x748F82EE
    sha256_k[57] = 0x78A5636F
    sha256_k[58] = 0x84C87814
    sha256_k[59] = 0x8CC70208
    sha256_k[60] = 0x90BEFFFA
    sha256_k[61] = 0xA4506CEB
    sha256_k[62] = 0xBEF9A3F7
    sha256_k[63] = 0xC67178F2


def _tls_rotr32(v: uint32, n: uint64) -> uint32:
    x: uint64 = cast[uint64](v) & 0xFFFFFFFF
    lo: uint64 = x >> n
    hi: uint64 = (x << (32 - n)) & 0xFFFFFFFF
    return cast[uint32](lo | hi)


# Scratch for SHA-256 compression (in BSS to keep frames small).
sha256_w: Array[64, uint32]
sha256_state_scratch: Array[8, uint32]


def _tls_sha256_compress(block_ptr: Ptr[uint8]):
    # Expand 16 BE words -> 64 words, run 64 rounds, fold into state.
    i: uint64 = 0
    while i < 16:
        b0: uint32 = cast[uint32](block_ptr[i * 4 + 0])
        b1: uint32 = cast[uint32](block_ptr[i * 4 + 1])
        b2: uint32 = cast[uint32](block_ptr[i * 4 + 2])
        b3: uint32 = cast[uint32](block_ptr[i * 4 + 3])
        sha256_w[i] = (b0 << 24) | (b1 << 16) | (b2 << 8) | b3
        i = i + 1
    while i < 64:
        s0: uint32 = _tls_rotr32(sha256_w[i - 15], 7) \
            ^ _tls_rotr32(sha256_w[i - 15], 18) \
            ^ (sha256_w[i - 15] >> 3)
        s1: uint32 = _tls_rotr32(sha256_w[i - 2], 17) \
            ^ _tls_rotr32(sha256_w[i - 2], 19) \
            ^ (sha256_w[i - 2] >> 10)
        sum_v: uint64 = (cast[uint64](sha256_w[i - 16]) & 0xFFFFFFFF) \
            + (cast[uint64](s0) & 0xFFFFFFFF) \
            + (cast[uint64](sha256_w[i - 7]) & 0xFFFFFFFF) \
            + (cast[uint64](s1) & 0xFFFFFFFF)
        sha256_w[i] = cast[uint32](sum_v & 0xFFFFFFFF)
        i = i + 1

    i = 0
    while i < 8:
        sha256_state_scratch[i] = tls_sha_state[i]
        i = i + 1
    a: uint32 = sha256_state_scratch[0]
    b: uint32 = sha256_state_scratch[1]
    c: uint32 = sha256_state_scratch[2]
    d: uint32 = sha256_state_scratch[3]
    e: uint32 = sha256_state_scratch[4]
    f: uint32 = sha256_state_scratch[5]
    g: uint32 = sha256_state_scratch[6]
    h: uint32 = sha256_state_scratch[7]
    i = 0
    while i < 64:
        S1: uint32 = _tls_rotr32(e, 6) ^ _tls_rotr32(e, 11) \
            ^ _tls_rotr32(e, 25)
        ch: uint32 = (e & f) ^ ((~e) & g)
        t1_64: uint64 = (cast[uint64](h) & 0xFFFFFFFF) \
            + (cast[uint64](S1) & 0xFFFFFFFF) \
            + (cast[uint64](ch) & 0xFFFFFFFF) \
            + (cast[uint64](sha256_k[i]) & 0xFFFFFFFF) \
            + (cast[uint64](sha256_w[i]) & 0xFFFFFFFF)
        t1: uint32 = cast[uint32](t1_64 & 0xFFFFFFFF)
        S0: uint32 = _tls_rotr32(a, 2) ^ _tls_rotr32(a, 13) \
            ^ _tls_rotr32(a, 22)
        maj: uint32 = (a & b) ^ (a & c) ^ (b & c)
        t2_64: uint64 = (cast[uint64](S0) & 0xFFFFFFFF) \
            + (cast[uint64](maj) & 0xFFFFFFFF)
        t2: uint32 = cast[uint32](t2_64 & 0xFFFFFFFF)
        h = g
        g = f
        f = e
        d64: uint64 = (cast[uint64](d) & 0xFFFFFFFF) \
            + (cast[uint64](t1) & 0xFFFFFFFF)
        e = cast[uint32](d64 & 0xFFFFFFFF)
        d = c
        c = b
        b = a
        a64: uint64 = (cast[uint64](t1) & 0xFFFFFFFF) \
            + (cast[uint64](t2) & 0xFFFFFFFF)
        a = cast[uint32](a64 & 0xFFFFFFFF)
        i = i + 1
    sum_v0: uint64 = (cast[uint64](tls_sha_state[0]) + cast[uint64](a))
    sum_v1: uint64 = (cast[uint64](tls_sha_state[1]) + cast[uint64](b))
    sum_v2: uint64 = (cast[uint64](tls_sha_state[2]) + cast[uint64](c))
    sum_v3: uint64 = (cast[uint64](tls_sha_state[3]) + cast[uint64](d))
    sum_v4: uint64 = (cast[uint64](tls_sha_state[4]) + cast[uint64](e))
    sum_v5: uint64 = (cast[uint64](tls_sha_state[5]) + cast[uint64](f))
    sum_v6: uint64 = (cast[uint64](tls_sha_state[6]) + cast[uint64](g))
    sum_v7: uint64 = (cast[uint64](tls_sha_state[7]) + cast[uint64](h))
    tls_sha_state[0] = cast[uint32](sum_v0 & 0xFFFFFFFF)
    tls_sha_state[1] = cast[uint32](sum_v1 & 0xFFFFFFFF)
    tls_sha_state[2] = cast[uint32](sum_v2 & 0xFFFFFFFF)
    tls_sha_state[3] = cast[uint32](sum_v3 & 0xFFFFFFFF)
    tls_sha_state[4] = cast[uint32](sum_v4 & 0xFFFFFFFF)
    tls_sha_state[5] = cast[uint32](sum_v5 & 0xFFFFFFFF)
    tls_sha_state[6] = cast[uint32](sum_v6 & 0xFFFFFFFF)
    tls_sha_state[7] = cast[uint32](sum_v7 & 0xFFFFFFFF)


def _tls_sha256_reset():
    # Reset the running hash state for a fresh transcript.
    tls_sha_state[0] = 0x6A09E667
    tls_sha_state[1] = 0xBB67AE85
    tls_sha_state[2] = 0x3C6EF372
    tls_sha_state[3] = 0xA54FF53A
    tls_sha_state[4] = 0x510E527F
    tls_sha_state[5] = 0x9B05688C
    tls_sha_state[6] = 0x1F83D9AB
    tls_sha_state[7] = 0x5BE0CD19
    tls_sha_buflen = 0
    tls_sha_total_bits = 0


def _tls_sha256_update(data: Ptr[uint8], n: uint64):
    # Stream `n` bytes into the running compression.
    block_ptr: Ptr[uint8] = cast[Ptr[uint8]](&tls_sha_buf[0])
    pos: uint64 = 0
    while pos < n:
        room: uint64 = 64 - tls_sha_buflen
        take: uint64 = n - pos
        if take > room:
            take = room
        i: uint64 = 0
        while i < take:
            tls_sha_buf[tls_sha_buflen + i] = data[pos + i]
            i = i + 1
        tls_sha_buflen = tls_sha_buflen + take
        pos = pos + take
        if tls_sha_buflen == 64:
            _tls_sha256_compress(block_ptr)
            tls_sha_buflen = 0
    tls_sha_total_bits = tls_sha_total_bits + n * 8


def _tls_sha256_finish_into(out_hash: Ptr[uint8]):
    # Append the 0x80 padding byte + zeros + 64-bit big-endian length,
    # squeeze the final block(s), then emit state as 32 big-endian bytes.
    # NOTE: this destroys the running state — callers that want the
    # transcript hash to keep updating must snapshot first.
    block_ptr: Ptr[uint8] = cast[Ptr[uint8]](&tls_sha_buf[0])
    saved_bits: uint64 = tls_sha_total_bits
    tls_sha_buf[tls_sha_buflen] = 0x80
    tls_sha_buflen = tls_sha_buflen + 1
    if tls_sha_buflen > 56:
        # Pad this block with zeros, compress, then start a fresh one.
        while tls_sha_buflen < 64:
            tls_sha_buf[tls_sha_buflen] = 0
            tls_sha_buflen = tls_sha_buflen + 1
        _tls_sha256_compress(block_ptr)
        tls_sha_buflen = 0
    while tls_sha_buflen < 56:
        tls_sha_buf[tls_sha_buflen] = 0
        tls_sha_buflen = tls_sha_buflen + 1
    # 8 bytes big-endian length.
    i: uint64 = 0
    while i < 8:
        shift: uint64 = (7 - i) * 8
        tls_sha_buf[56 + i] = cast[uint8]((saved_bits >> shift) & 0xFF)
        i = i + 1
    _tls_sha256_compress(block_ptr)
    # Emit big-endian state.
    i = 0
    while i < 8:
        w: uint32 = tls_sha_state[i]
        out_hash[i * 4 + 0] = cast[uint8]((w >> 24) & 0xFF)
        out_hash[i * 4 + 1] = cast[uint8]((w >> 16) & 0xFF)
        out_hash[i * 4 + 2] = cast[uint8]((w >> 8) & 0xFF)
        out_hash[i * 4 + 3] = cast[uint8](w & 0xFF)
        i = i + 1


def _tls_sha256_oneshot(data: Ptr[uint8], n: uint64,
                        out_hash: Ptr[uint8]):
    # One-shot SHA-256: hash a contiguous buffer and store 32 bytes.
    _tls_sha256_reset()
    _tls_sha256_update(data, n)
    _tls_sha256_finish_into(out_hash)


def _tls_tr_reset():
    # Reset the dedicated TRANSCRIPT-HASH state.
    tls_tr_state[0] = 0x6A09E667
    tls_tr_state[1] = 0xBB67AE85
    tls_tr_state[2] = 0x3C6EF372
    tls_tr_state[3] = 0xA54FF53A
    tls_tr_state[4] = 0x510E527F
    tls_tr_state[5] = 0x9B05688C
    tls_tr_state[6] = 0x1F83D9AB
    tls_tr_state[7] = 0x5BE0CD19
    tls_tr_buflen = 0
    tls_tr_bits   = 0


def _tls_tr_update(data: Ptr[uint8], n: uint64):
    # Stream `n` bytes into the parallel TRANSCRIPT-HASH instance.
    # Implemented by swapping tls_sha_* <-> tls_tr_* around a call to
    # the generic _tls_sha256_update. The two SHA-256 instances stay
    # otherwise isolated.
    # Save the generic state.
    save_state: Array[8, uint32]
    save_buf:   Array[64, uint8]
    save_buflen: uint64 = tls_sha_buflen
    save_bits:   uint64 = tls_sha_total_bits
    i: uint64 = 0
    while i < 8:
        save_state[i] = tls_sha_state[i]
        i = i + 1
    i = 0
    while i < 64:
        save_buf[i] = tls_sha_buf[i]
        i = i + 1
    # Load transcript state into the generic slot.
    i = 0
    while i < 8:
        tls_sha_state[i] = tls_tr_state[i]
        i = i + 1
    i = 0
    while i < 64:
        tls_sha_buf[i] = tls_tr_buf[i]
        i = i + 1
    tls_sha_buflen     = tls_tr_buflen
    tls_sha_total_bits = tls_tr_bits
    _tls_sha256_update(data, n)
    # Spill back into the transcript slot.
    i = 0
    while i < 8:
        tls_tr_state[i] = tls_sha_state[i]
        i = i + 1
    i = 0
    while i < 64:
        tls_tr_buf[i] = tls_sha_buf[i]
        i = i + 1
    tls_tr_buflen = tls_sha_buflen
    tls_tr_bits   = tls_sha_total_bits
    # Restore the generic state.
    i = 0
    while i < 8:
        tls_sha_state[i] = save_state[i]
        i = i + 1
    i = 0
    while i < 64:
        tls_sha_buf[i] = save_buf[i]
        i = i + 1
    tls_sha_buflen     = save_buflen
    tls_sha_total_bits = save_bits


def _tls_sha256_snapshot_into(out_hash: Ptr[uint8]):
    # Snapshot the running transcript hash into a 32-byte digest
    # without disturbing it. Internally copies the parallel transcript
    # state into the generic SHA-256 slot, finishes there (destroying
    # the generic state; HMAC/HKDF can refresh it on their next call),
    # and leaves the parallel transcript state intact for further
    # _tls_tr_update calls.
    i: uint64 = 0
    while i < 8:
        tls_sha_state[i] = tls_tr_state[i]
        i = i + 1
    i = 0
    while i < 64:
        tls_sha_buf[i] = tls_tr_buf[i]
        i = i + 1
    tls_sha_buflen      = tls_tr_buflen
    tls_sha_total_bits  = tls_tr_bits
    _tls_sha256_finish_into(out_hash)


# -- HMAC-SHA-256 + HKDF (RFC 5869) ----------------------------------------

def _tls_hmac_sha256(out_mac: Ptr[uint8],
                     key: Ptr[uint8], key_len: uint64,
                     data: Ptr[uint8], data_len: uint64):
    # Standard HMAC: K' = (key padded to 64) XOR ipad/opad. If key > 64
    # we hash it first; if shorter we zero-pad.
    k0: Array[64, uint8]
    _tls_memset(cast[Ptr[uint8]](&k0[0]), 0, 64)
    if key_len > 64:
        _tls_sha256_oneshot(key, key_len, cast[Ptr[uint8]](&k0[0]))
    else:
        _tls_memcpy(cast[Ptr[uint8]](&k0[0]), key, key_len)
    ipad: Array[64, uint8]
    opad: Array[64, uint8]
    i: uint64 = 0
    while i < 64:
        ipad[i] = k0[i] ^ 0x36
        opad[i] = k0[i] ^ 0x5C
        i = i + 1
    # Inner = SHA256(ipad || data).
    _tls_sha256_reset()
    _tls_sha256_update(cast[Ptr[uint8]](&ipad[0]), 64)
    _tls_sha256_update(data, data_len)
    inner: Array[32, uint8]
    _tls_sha256_finish_into(cast[Ptr[uint8]](&inner[0]))
    # Outer = SHA256(opad || inner).
    _tls_sha256_reset()
    _tls_sha256_update(cast[Ptr[uint8]](&opad[0]), 64)
    _tls_sha256_update(cast[Ptr[uint8]](&inner[0]), 32)
    _tls_sha256_finish_into(out_mac)


def _tls_hkdf_extract(out_prk: Ptr[uint8],
                      salt: Ptr[uint8], salt_len: uint64,
                      ikm: Ptr[uint8], ikm_len: uint64):
    # PRK = HMAC-SHA256(salt, IKM). If salt is empty, use 32 zero bytes.
    if salt_len == 0:
        zsalt: Array[32, uint8]
        _tls_memset(cast[Ptr[uint8]](&zsalt[0]), 0, 32)
        _tls_hmac_sha256(out_prk, cast[Ptr[uint8]](&zsalt[0]), 32,
                         ikm, ikm_len)
    else:
        _tls_hmac_sha256(out_prk, salt, salt_len, ikm, ikm_len)


def _tls_hkdf_expand(out: Ptr[uint8], out_len: uint64,
                     prk: Ptr[uint8], prk_len: uint64,
                     info: Ptr[uint8], info_len: uint64):
    # T(0) = empty; T(N) = HMAC(prk, T(N-1) || info || N).
    # We just need T(1) for keys up to 32 bytes; bigger lengths iterate.
    n_blocks: uint64 = (out_len + 31) / 32
    t_prev: Array[32, uint8]
    t_cur:  Array[32, uint8]
    prev_len: uint64 = 0
    written: uint64 = 0
    block_idx: uint64 = 1
    # Scratch for HMAC input: T_prev || info || single counter byte.
    hmac_in: Array[512, uint8]
    while block_idx <= n_blocks:
        hmac_len: uint64 = 0
        if prev_len > 0:
            _tls_memcpy(cast[Ptr[uint8]](&hmac_in[hmac_len]),
                        cast[Ptr[uint8]](&t_prev[0]), prev_len)
            hmac_len = hmac_len + prev_len
        if info_len > 0:
            _tls_memcpy(cast[Ptr[uint8]](&hmac_in[hmac_len]),
                        info, info_len)
        hmac_len = hmac_len + info_len
        hmac_in[hmac_len] = cast[uint8](block_idx & 0xFF)
        hmac_len = hmac_len + 1
        _tls_hmac_sha256(cast[Ptr[uint8]](&t_cur[0]),
                         prk, prk_len,
                         cast[Ptr[uint8]](&hmac_in[0]), hmac_len)
        chunk: uint64 = 32
        if out_len - written < chunk:
            chunk = out_len - written
        _tls_memcpy(cast[Ptr[uint8]](cast[uint64](out) + written),
                    cast[Ptr[uint8]](&t_cur[0]), chunk)
        written = written + chunk
        # Promote t_cur -> t_prev for the next iteration.
        _tls_memcpy(cast[Ptr[uint8]](&t_prev[0]),
                    cast[Ptr[uint8]](&t_cur[0]), 32)
        prev_len = 32
        block_idx = block_idx + 1


def _tls_hkdf_expand_label(out: Ptr[uint8], out_len: uint64,
                           secret: Ptr[uint8],
                           label: Ptr[uint8], label_len: uint64,
                           context: Ptr[uint8], context_len: uint64):
    # RFC 8446 §7.1 HKDF-Expand-Label.
    #   HkdfLabel = struct {
    #       uint16 length;
    #       opaque label<7..255> = "tls13 " + Label;
    #       opaque context<0..255> = Context;
    #   };
    info: Array[512, uint8]
    pos: uint64 = 0
    info[pos]     = cast[uint8]((out_len >> 8) & 0xFF)
    info[pos + 1] = cast[uint8](out_len & 0xFF)
    pos = pos + 2
    full_label_len: uint64 = 6 + label_len
    info[pos] = cast[uint8](full_label_len & 0xFF)
    pos = pos + 1
    # "tls13 " literal prefix (6 bytes).
    prefix: Ptr[uint8] = "tls13 "
    _tls_memcpy(cast[Ptr[uint8]](&info[pos]), prefix, 6)
    pos = pos + 6
    _tls_memcpy(cast[Ptr[uint8]](&info[pos]), label, label_len)
    pos = pos + label_len
    info[pos] = cast[uint8](context_len & 0xFF)
    pos = pos + 1
    if context_len > 0:
        _tls_memcpy(cast[Ptr[uint8]](&info[pos]), context, context_len)
    pos = pos + context_len
    _tls_hkdf_expand(out, out_len, secret, 32,
                     cast[Ptr[uint8]](&info[0]), pos)


def _tls_derive_secret(out_secret: Ptr[uint8],
                       secret: Ptr[uint8],
                       label: Ptr[uint8], label_len: uint64,
                       transcript_hash: Ptr[uint8]):
    # Derive-Secret(secret, label, transcript_hash) =
    #   HKDF-Expand-Label(secret, label, transcript_hash, hash_len).
    _tls_hkdf_expand_label(out_secret, 32, secret,
                           label, label_len,
                           transcript_hash, 32)


# -- X25519 scalar multiplication (RFC 7748 §5) ----------------------------
#
# Curve25519 Montgomery ladder over GF(2^255 - 19). The scalar is clamped
# per §5: low 3 bits cleared, bit 254 set, bit 255 cleared. We keep field
# elements as five 51-bit limbs in uint64 to avoid 128-bit arithmetic.

def _tls_x25519_fe_zero(fe: Ptr[uint64]):
    fe[0] = 0
    fe[1] = 0
    fe[2] = 0
    fe[3] = 0
    fe[4] = 0


def _tls_x25519_fe_one(fe: Ptr[uint64]):
    fe[0] = 1
    fe[1] = 0
    fe[2] = 0
    fe[3] = 0
    fe[4] = 0


def _tls_x25519_fe_copy(dst: Ptr[uint64], src: Ptr[uint64]):
    dst[0] = src[0]
    dst[1] = src[1]
    dst[2] = src[2]
    dst[3] = src[3]
    dst[4] = src[4]


def _tls_x25519_fe_cswap(swap: uint64,
                         a: Ptr[uint64], b: Ptr[uint64]):
    # Conditional swap of (a,b) when swap==1, no-op when swap==0.
    # Constant-time: select via mask.
    mask: uint64 = 0
    if swap == 1:
        mask = 0xFFFFFFFFFFFFFFFF
    i: uint64 = 0
    while i < 5:
        diff: uint64 = mask & (a[i] ^ b[i])
        a[i] = a[i] ^ diff
        b[i] = b[i] ^ diff
        i = i + 1


def _tls_x25519_fe_carry(fe: Ptr[uint64]):
    # Reduce each limb mod 2^51, propagate carry. The top carry folds
    # into limb 0 with a *19 multiplier (since 2^255 ≡ 19 mod p).
    mask51: uint64 = 0x7FFFFFFFFFFFF
    c0: uint64 = fe[0] >> 51
    fe[0] = fe[0] & mask51
    fe[1] = fe[1] + c0
    c1: uint64 = fe[1] >> 51
    fe[1] = fe[1] & mask51
    fe[2] = fe[2] + c1
    c2: uint64 = fe[2] >> 51
    fe[2] = fe[2] & mask51
    fe[3] = fe[3] + c2
    c3: uint64 = fe[3] >> 51
    fe[3] = fe[3] & mask51
    fe[4] = fe[4] + c3
    c4: uint64 = fe[4] >> 51
    fe[4] = fe[4] & mask51
    fe[0] = fe[0] + c4 * 19


def _tls_x25519_fe_add(r: Ptr[uint64], a: Ptr[uint64], b: Ptr[uint64]):
    r[0] = a[0] + b[0]
    r[1] = a[1] + b[1]
    r[2] = a[2] + b[2]
    r[3] = a[3] + b[3]
    r[4] = a[4] + b[4]
    _tls_x25519_fe_carry(r)


def _tls_x25519_fe_sub(r: Ptr[uint64], a: Ptr[uint64], b: Ptr[uint64]):
    # r = a - b mod p. Add 2*p first so we never underflow (2*p > any
    # well-formed limbed input by construction). 2*p in 51-bit limbs is
    #   2*(2^255 - 19) = 2^256 - 38 = (-38 mod 2^256) but for the
    # 5-limb add we use 2*p ≈ (2 * 0x7FFFFFFFFFFFED, 2 * mask51, ...).
    big0: uint64 = 0xFFFFFFFFFFFDA
    big1: uint64 = 0xFFFFFFFFFFFFE
    big2: uint64 = 0xFFFFFFFFFFFFE
    big3: uint64 = 0xFFFFFFFFFFFFE
    big4: uint64 = 0xFFFFFFFFFFFFE
    r[0] = (a[0] + big0) - b[0]
    r[1] = (a[1] + big1) - b[1]
    r[2] = (a[2] + big2) - b[2]
    r[3] = (a[3] + big3) - b[3]
    r[4] = (a[4] + big4) - b[4]
    _tls_x25519_fe_carry(r)


# 128-bit multiply helper. Adder lacks uint128, but x86_64's MUL
# instruction produces the full 64x64 -> 128-bit result in (RDX:RAX).
# We use module-globals because asm_volatile is operandless. Single-
# threaded callers — X25519 is invoked once per handshake.
tls_mul128_a:  uint64 = 0
tls_mul128_b:  uint64 = 0
tls_mul128_lo: uint64 = 0
tls_mul128_hi: uint64 = 0


def _tls_mul128():
    # Reads tls_mul128_a + tls_mul128_b; writes tls_mul128_lo/_hi.
    # Inlined directly — call sites stage operands then read results.
    asm_volatile("""
        movq tls_mul128_a(%rip), %rax
        mulq tls_mul128_b(%rip)
        movq %rax, tls_mul128_lo(%rip)
        movq %rdx, tls_mul128_hi(%rip)
    """)


# Scratch for the 5x5 field-element multiplication. We accumulate
# 128-bit partial sums (lo, hi) into 5 result limbs, then fold the
# wraparound contributions and carry-propagate. Single in-flight
# multiply at a time.
fe_mul_acc_lo: Array[5, uint64]
fe_mul_acc_hi: Array[5, uint64]


def _tls_fe_mul_add128(idx: uint64, x: uint64, y: uint64):
    # acc[idx] += x * y. (x*y is a full 128-bit product computed via
    # x86_64 MUL; the result is added into the (lo, hi) pair at idx.)
    # Adder's '<' is signed-compare even for uint64 (quirk file:
    # "Integer compares emit setl/setle/setg/setge..."). We flip the
    # sign bit to turn signed compare into unsigned compare.
    tls_mul128_a = x
    tls_mul128_b = y
    _tls_mul128()
    p_lo: uint64 = tls_mul128_lo
    p_hi: uint64 = tls_mul128_hi
    cur_lo: uint64 = fe_mul_acc_lo[idx]
    new_lo: uint64 = cur_lo + p_lo
    sign_flip: uint64 = 0x8000000000000000
    carry: uint64 = 0
    if (new_lo ^ sign_flip) < (cur_lo ^ sign_flip):
        carry = 1
    fe_mul_acc_lo[idx] = new_lo
    fe_mul_acc_hi[idx] = fe_mul_acc_hi[idx] + p_hi + carry


def _tls_x25519_fe_mul(r: Ptr[uint64], a: Ptr[uint64], b: Ptr[uint64]):
    # Correct 5x5 field-element multiplication using full 128-bit
    # partial products. Each 51-bit limb is multiplied via x86_64 MUL,
    # producing a 102-bit result we accumulate into a (lo, hi) uint128.
    # We then fold the wraparound contributions (j >= 5) with the
    # mod-2^255-19 reduction constant 19, and carry-propagate back
    # into five 51-bit output limbs.

    i: uint64 = 0
    while i < 5:
        fe_mul_acc_lo[i] = 0
        fe_mul_acc_hi[i] = 0
        i = i + 1

    # Direct products: i+j < 5 -> r[i+j] += a[i]*b[j]
    _tls_fe_mul_add128(0, a[0], b[0])
    _tls_fe_mul_add128(1, a[0], b[1])
    _tls_fe_mul_add128(1, a[1], b[0])
    _tls_fe_mul_add128(2, a[0], b[2])
    _tls_fe_mul_add128(2, a[1], b[1])
    _tls_fe_mul_add128(2, a[2], b[0])
    _tls_fe_mul_add128(3, a[0], b[3])
    _tls_fe_mul_add128(3, a[1], b[2])
    _tls_fe_mul_add128(3, a[2], b[1])
    _tls_fe_mul_add128(3, a[3], b[0])
    _tls_fe_mul_add128(4, a[0], b[4])
    _tls_fe_mul_add128(4, a[1], b[3])
    _tls_fe_mul_add128(4, a[2], b[2])
    _tls_fe_mul_add128(4, a[3], b[1])
    _tls_fe_mul_add128(4, a[4], b[0])

    # Wraparound products: i+j >= 5 -> r[i+j-5] += 19 * a[i] * b[j].
    # Multiply b[j] by 19 first (b[j] < 2^51, so 19*b[j] < 2^56 — still
    # fits in uint64 and the resulting a[i] * (19*b[j]) is < 2^107).
    b1_19: uint64 = b[1] * 19
    b2_19: uint64 = b[2] * 19
    b3_19: uint64 = b[3] * 19
    b4_19: uint64 = b[4] * 19

    # i=1: j=4 -> r0
    _tls_fe_mul_add128(0, a[1], b4_19)
    # i=2: j=3,4 -> r0,r1
    _tls_fe_mul_add128(0, a[2], b3_19)
    _tls_fe_mul_add128(1, a[2], b4_19)
    # i=3: j=2,3,4 -> r0,r1,r2
    _tls_fe_mul_add128(0, a[3], b2_19)
    _tls_fe_mul_add128(1, a[3], b3_19)
    _tls_fe_mul_add128(2, a[3], b4_19)
    # i=4: j=1,2,3,4 -> r0,r1,r2,r3
    _tls_fe_mul_add128(0, a[4], b1_19)
    _tls_fe_mul_add128(1, a[4], b2_19)
    _tls_fe_mul_add128(2, a[4], b3_19)
    _tls_fe_mul_add128(3, a[4], b4_19)

    # Carry-propagate from (lo, hi) into 51-bit limbs. After
    # accumulation each limb fits in at most ~2^110 bits (well within
    # the 128-bit pair). To extract 51 low bits + carry the rest into
    # the next limb, we shift-right by 51 across the (lo, hi) pair.
    # Use sign-flip-then-signed-compare to emulate unsigned overflow
    # detection (Adder's '<' is signed even for uint64).
    mask51: uint64 = 0x7FFFFFFFFFFFF
    sign_flip2: uint64 = 0x8000000000000000
    i = 0
    carry_lo: uint64 = 0
    carry_hi: uint64 = 0
    while i < 5:
        # Add inbound carry to acc[i].
        cur_lo: uint64 = fe_mul_acc_lo[i] + carry_lo
        cur_hi: uint64 = fe_mul_acc_hi[i] + carry_hi
        if (cur_lo ^ sign_flip2) < (carry_lo ^ sign_flip2):
            cur_hi = cur_hi + 1
        # Output low 51 bits.
        if i < 4:
            r[i] = cur_lo & mask51
            # Right-shift by 51: new_lo = (cur_lo >> 51) | (cur_hi << 13),
            # new_hi = cur_hi >> 51.
            carry_lo = (cur_lo >> 51) | (cur_hi << 13)
            carry_hi = cur_hi >> 51
        else:
            # Last limb: store low 51 bits, fold the rest via *19 back
            # into r[0]. Top of (cur_lo, cur_hi) shifted right by 51
            # gives the overflow which is multiplied by 19.
            r[4] = cur_lo & mask51
            overflow_lo: uint64 = (cur_lo >> 51) | (cur_hi << 13)
            overflow_hi: uint64 = cur_hi >> 51
            # Fold *19 into limb 0 (this can momentarily exceed 51 bits
            # — we run carry once more below).
            r[0] = r[0] + overflow_lo * 19
            # Any contribution from overflow_hi would exceed 2^115 in
            # the original product, which can't happen given our input
            # bound — assert by ignoring (input is < 2^51).
        i = i + 1
    # One more pass to renormalise r[0]'s potential overflow into r[1].
    _tls_x25519_fe_carry(r)


def _tls_x25519_fe_sq(r: Ptr[uint64], a: Ptr[uint64]):
    _tls_x25519_fe_mul(r, a, a)


def _tls_x25519_fe_mul121665(r: Ptr[uint64], a: Ptr[uint64]):
    # r = a * 121665, then carry. 121665 < 2^17. If a[i] is at most
    # 2^51 (typical after carry), a[i] * 121665 fits in 2^68 — WHICH
    # DOES OVERFLOW uint64. We split the per-limb product via 128-bit
    # multiply and carry-propagate the high half into the next limb.
    sign_flip: uint64 = 0x8000000000000000
    mask51: uint64 = 0x7FFFFFFFFFFFF
    # Compute 128-bit products into local 5-element (lo, hi) pair.
    los: Array[5, uint64]
    his: Array[5, uint64]
    i: uint64 = 0
    while i < 5:
        tls_mul128_a = a[i]
        tls_mul128_b = 121665
        _tls_mul128()
        los[i] = tls_mul128_lo
        his[i] = tls_mul128_hi
        i = i + 1
    # Carry-propagate. Same scheme as in _tls_x25519_fe_mul.
    carry_lo: uint64 = 0
    carry_hi: uint64 = 0
    i = 0
    while i < 5:
        cur_lo: uint64 = los[i] + carry_lo
        cur_hi: uint64 = his[i] + carry_hi
        if (cur_lo ^ sign_flip) < (carry_lo ^ sign_flip):
            cur_hi = cur_hi + 1
        if i < 4:
            r[i] = cur_lo & mask51
            carry_lo = (cur_lo >> 51) | (cur_hi << 13)
            carry_hi = cur_hi >> 51
        else:
            r[4] = cur_lo & mask51
            overflow_lo: uint64 = (cur_lo >> 51) | (cur_hi << 13)
            r[0] = r[0] + overflow_lo * 19
        i = i + 1
    _tls_x25519_fe_carry(r)


def _tls_x25519_fe_from_bytes(fe: Ptr[uint64], buf: Ptr[uint8]):
    # Pack 32 little-endian bytes (255 bits + high bit cleared) into
    # five 51-bit limbs.
    mask51: uint64 = 0x7FFFFFFFFFFFF
    w0: uint64 = 0
    i: uint64 = 0
    while i < 8:
        w0 = w0 | (cast[uint64](buf[i]) << (i * 8))
        i = i + 1
    fe[0] = w0 & mask51
    w1: uint64 = w0 >> 51
    # bits 51..101: limb1 = buf[6..13] with offset, but easier to
    # rebuild via accumulator over the byte stream.
    acc: uint64 = 0
    i = 0
    while i < 32:
        acc = acc | (cast[uint64](buf[i] & 0xFF) << ((i * 8) & 63))
        i = i + 1
    # Brute force: extract each 51-bit window.
    fe[0] = _tls_x25519_fe_extract51(buf, 0)
    fe[1] = _tls_x25519_fe_extract51(buf, 51)
    fe[2] = _tls_x25519_fe_extract51(buf, 102)
    fe[3] = _tls_x25519_fe_extract51(buf, 153)
    fe[4] = _tls_x25519_fe_extract51(buf, 204) & 0x7FFFFFFFFFFFF
    # Clear bit 255 per RFC 7748 §5 (caller's responsibility but we
    # also enforce here for robustness).
    fe[4] = fe[4] & 0x7FFFFFFFFFFFF


def _tls_x25519_fe_extract51(buf: Ptr[uint8], bit_off: uint64) -> uint64:
    # Read a 51-bit little-endian window starting at bit `bit_off` from
    # the 32-byte buffer. The window may straddle up to 8 bytes (51 + 7
    # alignment).
    byte_off: uint64 = bit_off >> 3
    bit_shift: uint64 = bit_off & 7
    # Read 8 contiguous bytes (saturating with zeros past the end).
    acc: uint64 = 0
    i: uint64 = 0
    while i < 8:
        idx: uint64 = byte_off + i
        if idx < 32:
            acc = acc | (cast[uint64](buf[idx]) << (i * 8))
        i = i + 1
    acc = acc >> bit_shift
    return acc & 0x7FFFFFFFFFFFF


def _tls_x25519_fe_to_bytes(out: Ptr[uint8], fe: Ptr[uint64]):
    # Re-pack the five 51-bit limbs into 32 little-endian bytes after a
    # canonical reduction. Algorithm: subtract p if fe >= p, then emit.
    h: Array[5, uint64]
    h[0] = fe[0]
    h[1] = fe[1]
    h[2] = fe[2]
    h[3] = fe[3]
    h[4] = fe[4]
    # Two carry passes to fully reduce.
    _tls_x25519_fe_carry(cast[Ptr[uint64]](&h[0]))
    _tls_x25519_fe_carry(cast[Ptr[uint64]](&h[0]))
    # Conditional subtract of p = (2^51 - 19, 2^51 - 1, ..., 2^51 - 1).
    mask51: uint64 = 0x7FFFFFFFFFFFF
    p0: uint64 = mask51 - 18           # 0x7FFFFFFFFFFFD
    p_other: uint64 = mask51
    t: Array[5, uint64]
    t[0] = h[0] + 19
    carry: uint64 = t[0] >> 51
    t[0] = t[0] & mask51
    t[1] = h[1] + carry
    carry = t[1] >> 51
    t[1] = t[1] & mask51
    t[2] = h[2] + carry
    carry = t[2] >> 51
    t[2] = t[2] & mask51
    t[3] = h[3] + carry
    carry = t[3] >> 51
    t[3] = t[3] & mask51
    t[4] = h[4] + carry
    # If bit 51 of t[4] is set, h was >= p, so subtract p (which is
    # equivalent to keeping (t & mask) at every limb). Otherwise keep h.
    use_t: int32 = 0
    if (t[4] >> 51) != 0:
        use_t = 1
    if use_t == 1:
        h[0] = t[0]
        h[1] = t[1]
        h[2] = t[2]
        h[3] = t[3]
        h[4] = t[4] & mask51
    # Pack 5 * 51 bits into 32 bytes.
    i: uint64 = 0
    while i < 32:
        out[i] = 0
        i = i + 1
    bit: uint64 = 0
    j: uint64 = 0
    while j < 5:
        v: uint64 = h[j]
        k: uint64 = 0
        while k < 51:
            if ((v >> k) & 1) == 1:
                byte_idx: uint64 = (bit + k) >> 3
                bit_idx: uint64 = (bit + k) & 7
                if byte_idx < 32:
                    out[byte_idx] = out[byte_idx] | cast[uint8](1 << bit_idx)
            k = k + 1
        bit = bit + 51
        j = j + 1


def _tls_x25519_scalarmult(out: Ptr[uint8],
                           scalar: Ptr[uint8],
                           u_in: Ptr[uint8]) -> int32:
    # RFC 7748 §5 X25519. Clamp the scalar, parse u, run the Montgomery
    # ladder for 255 iterations, emit u-coordinate of the product.
    # Returns 0 on success; this implementation never fails for
    # well-formed 32-byte inputs (and accepts the all-zero u — output
    # is then the identity, which TLS would catch as a key-share fault).
    k: Array[32, uint8]
    u: Array[32, uint8]
    i: uint64 = 0
    while i < 32:
        k[i] = scalar[i]
        u[i] = u_in[i]
        i = i + 1
    k[0]  = k[0]  & 248
    k[31] = k[31] & 127
    k[31] = k[31] | 64
    u[31] = u[31] & 127     # mask off bit 255 per §5
    x1: Array[5, uint64]
    x2: Array[5, uint64]
    z2: Array[5, uint64]
    x3: Array[5, uint64]
    z3: Array[5, uint64]
    _tls_x25519_fe_from_bytes(cast[Ptr[uint64]](&x1[0]),
                              cast[Ptr[uint8]](&u[0]))
    _tls_x25519_fe_one(cast[Ptr[uint64]](&x2[0]))
    _tls_x25519_fe_zero(cast[Ptr[uint64]](&z2[0]))
    _tls_x25519_fe_copy(cast[Ptr[uint64]](&x3[0]),
                        cast[Ptr[uint64]](&x1[0]))
    _tls_x25519_fe_one(cast[Ptr[uint64]](&z3[0]))
    swap: uint64 = 0

    a_buf: Array[5, uint64]
    b_buf: Array[5, uint64]
    c_buf: Array[5, uint64]
    d_buf: Array[5, uint64]
    aa: Array[5, uint64]
    bb: Array[5, uint64]
    e_buf: Array[5, uint64]
    da: Array[5, uint64]
    cb: Array[5, uint64]
    tmp1: Array[5, uint64]
    tmp2: Array[5, uint64]

    t: int64 = 254
    while t >= 0:
        # k_t = bit `t` of the scalar.
        byte_idx: uint64 = cast[uint64](t) >> 3
        bit_idx: uint64 = cast[uint64](t) & 7
        kt: uint64 = (cast[uint64](k[byte_idx]) >> bit_idx) & 1
        # Conditional swap.
        cs: uint64 = swap ^ kt
        _tls_x25519_fe_cswap(cs,
                             cast[Ptr[uint64]](&x2[0]),
                             cast[Ptr[uint64]](&x3[0]))
        _tls_x25519_fe_cswap(cs,
                             cast[Ptr[uint64]](&z2[0]),
                             cast[Ptr[uint64]](&z3[0]))
        swap = kt
        # A = x2 + z2; AA = A^2
        _tls_x25519_fe_add(cast[Ptr[uint64]](&a_buf[0]),
                           cast[Ptr[uint64]](&x2[0]),
                           cast[Ptr[uint64]](&z2[0]))
        _tls_x25519_fe_sq(cast[Ptr[uint64]](&aa[0]),
                          cast[Ptr[uint64]](&a_buf[0]))
        # B = x2 - z2; BB = B^2
        _tls_x25519_fe_sub(cast[Ptr[uint64]](&b_buf[0]),
                           cast[Ptr[uint64]](&x2[0]),
                           cast[Ptr[uint64]](&z2[0]))
        _tls_x25519_fe_sq(cast[Ptr[uint64]](&bb[0]),
                          cast[Ptr[uint64]](&b_buf[0]))
        # E = AA - BB
        _tls_x25519_fe_sub(cast[Ptr[uint64]](&e_buf[0]),
                           cast[Ptr[uint64]](&aa[0]),
                           cast[Ptr[uint64]](&bb[0]))
        # C = x3 + z3; D = x3 - z3
        _tls_x25519_fe_add(cast[Ptr[uint64]](&c_buf[0]),
                           cast[Ptr[uint64]](&x3[0]),
                           cast[Ptr[uint64]](&z3[0]))
        _tls_x25519_fe_sub(cast[Ptr[uint64]](&d_buf[0]),
                           cast[Ptr[uint64]](&x3[0]),
                           cast[Ptr[uint64]](&z3[0]))
        # DA = D * A
        _tls_x25519_fe_mul(cast[Ptr[uint64]](&da[0]),
                           cast[Ptr[uint64]](&d_buf[0]),
                           cast[Ptr[uint64]](&a_buf[0]))
        # CB = C * B
        _tls_x25519_fe_mul(cast[Ptr[uint64]](&cb[0]),
                           cast[Ptr[uint64]](&c_buf[0]),
                           cast[Ptr[uint64]](&b_buf[0]))
        # x3 = (DA + CB)^2
        _tls_x25519_fe_add(cast[Ptr[uint64]](&tmp1[0]),
                           cast[Ptr[uint64]](&da[0]),
                           cast[Ptr[uint64]](&cb[0]))
        _tls_x25519_fe_sq(cast[Ptr[uint64]](&x3[0]),
                          cast[Ptr[uint64]](&tmp1[0]))
        # z3 = x1 * (DA - CB)^2
        _tls_x25519_fe_sub(cast[Ptr[uint64]](&tmp2[0]),
                           cast[Ptr[uint64]](&da[0]),
                           cast[Ptr[uint64]](&cb[0]))
        _tls_x25519_fe_sq(cast[Ptr[uint64]](&tmp1[0]),
                          cast[Ptr[uint64]](&tmp2[0]))
        _tls_x25519_fe_mul(cast[Ptr[uint64]](&z3[0]),
                           cast[Ptr[uint64]](&x1[0]),
                           cast[Ptr[uint64]](&tmp1[0]))
        # x2 = AA * BB
        _tls_x25519_fe_mul(cast[Ptr[uint64]](&x2[0]),
                           cast[Ptr[uint64]](&aa[0]),
                           cast[Ptr[uint64]](&bb[0]))
        # z2 = E * (AA + a24*E)  ; a24 = 121665 (RFC 7748 §5).
        # NB: The original ed210da skeleton wrote `BB + a24*E` here —
        # both Wikipedia and the RFC unambiguously have `AA + a24*E`.
        # The BB form gave a wrong scalarmult result that masqueraded
        # as "AEAD decrypt failed" once the bug shipped down the
        # handshake.
        _tls_x25519_fe_mul121665(cast[Ptr[uint64]](&tmp1[0]),
                                 cast[Ptr[uint64]](&e_buf[0]))
        _tls_x25519_fe_add(cast[Ptr[uint64]](&tmp2[0]),
                           cast[Ptr[uint64]](&aa[0]),
                           cast[Ptr[uint64]](&tmp1[0]))
        _tls_x25519_fe_mul(cast[Ptr[uint64]](&z2[0]),
                           cast[Ptr[uint64]](&e_buf[0]),
                           cast[Ptr[uint64]](&tmp2[0]))
        t = t - 1
    # Final conditional swap.
    _tls_x25519_fe_cswap(swap,
                         cast[Ptr[uint64]](&x2[0]),
                         cast[Ptr[uint64]](&x3[0]))
    _tls_x25519_fe_cswap(swap,
                         cast[Ptr[uint64]](&z2[0]),
                         cast[Ptr[uint64]](&z3[0]))
    # Result u-coordinate = x2 / z2 = x2 * z2^(p-2)  (Fermat inversion).
    inv: Array[5, uint64]
    _tls_x25519_fe_invert(cast[Ptr[uint64]](&inv[0]),
                          cast[Ptr[uint64]](&z2[0]))
    res: Array[5, uint64]
    _tls_x25519_fe_mul(cast[Ptr[uint64]](&res[0]),
                       cast[Ptr[uint64]](&x2[0]),
                       cast[Ptr[uint64]](&inv[0]))
    _tls_x25519_fe_to_bytes(out, cast[Ptr[uint64]](&res[0]))
    return 0


def _tls_x25519_fe_invert(out: Ptr[uint64], z: Ptr[uint64]):
    # z^(p-2) mod p — addition chain from RFC 7748 / curve25519-donna.
    # We implement the standard 254-bit ladder: chain of squarings and
    # multiplications that costs ~255 sqs + ~11 muls.
    z2: Array[5, uint64]
    z9: Array[5, uint64]
    z11: Array[5, uint64]
    z2_5_0: Array[5, uint64]
    z2_10_0: Array[5, uint64]
    z2_20_0: Array[5, uint64]
    z2_50_0: Array[5, uint64]
    z2_100_0: Array[5, uint64]
    t0: Array[5, uint64]
    t1: Array[5, uint64]
    # z2 = z^2
    _tls_x25519_fe_sq(cast[Ptr[uint64]](&z2[0]), z)
    # t0 = z2^2
    _tls_x25519_fe_sq(cast[Ptr[uint64]](&t0[0]),
                      cast[Ptr[uint64]](&z2[0]))
    # t0 = t0^2
    _tls_x25519_fe_sq(cast[Ptr[uint64]](&t1[0]),
                      cast[Ptr[uint64]](&t0[0]))
    # z9 = t1 * z
    _tls_x25519_fe_mul(cast[Ptr[uint64]](&z9[0]),
                       cast[Ptr[uint64]](&t1[0]), z)
    # z11 = z9 * z2
    _tls_x25519_fe_mul(cast[Ptr[uint64]](&z11[0]),
                       cast[Ptr[uint64]](&z9[0]),
                       cast[Ptr[uint64]](&z2[0]))
    # t0 = z11^2
    _tls_x25519_fe_sq(cast[Ptr[uint64]](&t0[0]),
                      cast[Ptr[uint64]](&z11[0]))
    # z2_5_0 = t0 * z9
    _tls_x25519_fe_mul(cast[Ptr[uint64]](&z2_5_0[0]),
                       cast[Ptr[uint64]](&t0[0]),
                       cast[Ptr[uint64]](&z9[0]))
    # z2_10_0 = (z2_5_0)^(2^5) * z2_5_0
    _tls_x25519_fe_sq(cast[Ptr[uint64]](&t0[0]),
                      cast[Ptr[uint64]](&z2_5_0[0]))
    i: uint64 = 1
    while i < 5:
        _tls_x25519_fe_sq(cast[Ptr[uint64]](&t1[0]),
                          cast[Ptr[uint64]](&t0[0]))
        _tls_x25519_fe_copy(cast[Ptr[uint64]](&t0[0]),
                            cast[Ptr[uint64]](&t1[0]))
        i = i + 1
    _tls_x25519_fe_mul(cast[Ptr[uint64]](&z2_10_0[0]),
                       cast[Ptr[uint64]](&t0[0]),
                       cast[Ptr[uint64]](&z2_5_0[0]))
    # z2_20_0
    _tls_x25519_fe_sq(cast[Ptr[uint64]](&t0[0]),
                      cast[Ptr[uint64]](&z2_10_0[0]))
    i = 1
    while i < 10:
        _tls_x25519_fe_sq(cast[Ptr[uint64]](&t1[0]),
                          cast[Ptr[uint64]](&t0[0]))
        _tls_x25519_fe_copy(cast[Ptr[uint64]](&t0[0]),
                            cast[Ptr[uint64]](&t1[0]))
        i = i + 1
    _tls_x25519_fe_mul(cast[Ptr[uint64]](&z2_20_0[0]),
                       cast[Ptr[uint64]](&t0[0]),
                       cast[Ptr[uint64]](&z2_10_0[0]))
    # z2_40_0 (folded into t0 / t1)
    _tls_x25519_fe_sq(cast[Ptr[uint64]](&t0[0]),
                      cast[Ptr[uint64]](&z2_20_0[0]))
    i = 1
    while i < 20:
        _tls_x25519_fe_sq(cast[Ptr[uint64]](&t1[0]),
                          cast[Ptr[uint64]](&t0[0]))
        _tls_x25519_fe_copy(cast[Ptr[uint64]](&t0[0]),
                            cast[Ptr[uint64]](&t1[0]))
        i = i + 1
    _tls_x25519_fe_mul(cast[Ptr[uint64]](&t1[0]),
                       cast[Ptr[uint64]](&t0[0]),
                       cast[Ptr[uint64]](&z2_20_0[0]))
    # z2_50_0
    _tls_x25519_fe_sq(cast[Ptr[uint64]](&t0[0]),
                      cast[Ptr[uint64]](&t1[0]))
    i = 1
    while i < 10:
        _tls_x25519_fe_sq(cast[Ptr[uint64]](&t1[0]),
                          cast[Ptr[uint64]](&t0[0]))
        _tls_x25519_fe_copy(cast[Ptr[uint64]](&t0[0]),
                            cast[Ptr[uint64]](&t1[0]))
        i = i + 1
    _tls_x25519_fe_mul(cast[Ptr[uint64]](&z2_50_0[0]),
                       cast[Ptr[uint64]](&t0[0]),
                       cast[Ptr[uint64]](&z2_10_0[0]))
    # z2_100_0
    _tls_x25519_fe_sq(cast[Ptr[uint64]](&t0[0]),
                      cast[Ptr[uint64]](&z2_50_0[0]))
    i = 1
    while i < 50:
        _tls_x25519_fe_sq(cast[Ptr[uint64]](&t1[0]),
                          cast[Ptr[uint64]](&t0[0]))
        _tls_x25519_fe_copy(cast[Ptr[uint64]](&t0[0]),
                            cast[Ptr[uint64]](&t1[0]))
        i = i + 1
    _tls_x25519_fe_mul(cast[Ptr[uint64]](&z2_100_0[0]),
                       cast[Ptr[uint64]](&t0[0]),
                       cast[Ptr[uint64]](&z2_50_0[0]))
    # z2_200_0
    _tls_x25519_fe_sq(cast[Ptr[uint64]](&t0[0]),
                      cast[Ptr[uint64]](&z2_100_0[0]))
    i = 1
    while i < 100:
        _tls_x25519_fe_sq(cast[Ptr[uint64]](&t1[0]),
                          cast[Ptr[uint64]](&t0[0]))
        _tls_x25519_fe_copy(cast[Ptr[uint64]](&t0[0]),
                            cast[Ptr[uint64]](&t1[0]))
        i = i + 1
    _tls_x25519_fe_mul(cast[Ptr[uint64]](&t1[0]),
                       cast[Ptr[uint64]](&t0[0]),
                       cast[Ptr[uint64]](&z2_100_0[0]))
    # z2_250_0
    _tls_x25519_fe_sq(cast[Ptr[uint64]](&t0[0]),
                      cast[Ptr[uint64]](&t1[0]))
    i = 1
    while i < 50:
        _tls_x25519_fe_sq(cast[Ptr[uint64]](&t1[0]),
                          cast[Ptr[uint64]](&t0[0]))
        _tls_x25519_fe_copy(cast[Ptr[uint64]](&t0[0]),
                            cast[Ptr[uint64]](&t1[0]))
        i = i + 1
    _tls_x25519_fe_mul(cast[Ptr[uint64]](&t1[0]),
                       cast[Ptr[uint64]](&t0[0]),
                       cast[Ptr[uint64]](&z2_50_0[0]))
    # final: square 5 times then multiply by z11
    _tls_x25519_fe_sq(cast[Ptr[uint64]](&t0[0]),
                      cast[Ptr[uint64]](&t1[0]))
    i = 1
    while i < 5:
        _tls_x25519_fe_sq(cast[Ptr[uint64]](&t1[0]),
                          cast[Ptr[uint64]](&t0[0]))
        _tls_x25519_fe_copy(cast[Ptr[uint64]](&t0[0]),
                            cast[Ptr[uint64]](&t1[0]))
        i = i + 1
    _tls_x25519_fe_mul(out,
                       cast[Ptr[uint64]](&t0[0]),
                       cast[Ptr[uint64]](&z11[0]))


def _tls_x25519_base_mult(out_pub: Ptr[uint8], priv: Ptr[uint8]) -> int32:
    # Public key = scalarmult(priv, base_point). Base = u=9.
    base: Array[32, uint8]
    base[0] = 9
    i: uint64 = 1
    while i < 32:
        base[i] = 0
        i = i + 1
    return _tls_x25519_scalarmult(out_pub, priv,
                                  cast[Ptr[uint8]](&base[0]))


# -- TLS 1.3 handshake construction ----------------------------------------

def _tls_compute_handshake_keys():
    # After ServerHello arrives we know the shared secret + transcript
    # hash, so we can derive both handshake traffic secrets.
    #   early_secret = HKDF-Extract(0, 0)
    #   derived = Derive-Secret(early_secret, "derived", "")
    #   handshake_secret = HKDF-Extract(derived, shared_secret)
    #   client_hs_traffic_secret =
    #       Derive-Secret(handshake_secret, "c hs traffic", transcript)
    #   server_hs_traffic_secret =
    #       Derive-Secret(handshake_secret, "s hs traffic", transcript)
    #   key  = HKDF-Expand-Label(secret, "key", "", 32)
    #   iv   = HKDF-Expand-Label(secret, "iv", "", 12)
    zero32: Array[32, uint8]
    _tls_memset(cast[Ptr[uint8]](&zero32[0]), 0, 32)
    _tls_hkdf_extract(cast[Ptr[uint8]](&tls_early_secret[0]),
                      cast[Ptr[uint8]](0), 0,
                      cast[Ptr[uint8]](&zero32[0]), 32)
    # Empty-string transcript hash for "derived" salt step.
    empty_hash: Array[32, uint8]
    _tls_sha256_oneshot(cast[Ptr[uint8]](&zero32[0]), 0,
                        cast[Ptr[uint8]](&empty_hash[0]))
    derived: Array[32, uint8]
    label_derived: Ptr[uint8] = "derived"
    _tls_derive_secret(cast[Ptr[uint8]](&derived[0]),
                       cast[Ptr[uint8]](&tls_early_secret[0]),
                       label_derived, 7,
                       cast[Ptr[uint8]](&empty_hash[0]))
    _tls_hkdf_extract(cast[Ptr[uint8]](&tls_handshake_secret[0]),
                      cast[Ptr[uint8]](&derived[0]), 32,
                      cast[Ptr[uint8]](&tls_x25519_shared[0]), 32)
    # Snapshot the running parallel transcript hash into the
    # tls_transcript_hash slot — used as the "transcript" input to
    # Derive-Secret. The parallel transcript instance (tls_tr_*) is
    # untouched so subsequent _tls_tr_update calls keep extending it.
    _tls_sha256_snapshot_into(
        cast[Ptr[uint8]](&tls_transcript_hash[0]))

    label_c_hs: Ptr[uint8] = "c hs traffic"
    label_s_hs: Ptr[uint8] = "s hs traffic"
    _tls_derive_secret(cast[Ptr[uint8]](&tls_client_hs_secret[0]),
                       cast[Ptr[uint8]](&tls_handshake_secret[0]),
                       label_c_hs, 12,
                       cast[Ptr[uint8]](&tls_transcript_hash[0]))
    _tls_derive_secret(cast[Ptr[uint8]](&tls_server_hs_secret[0]),
                       cast[Ptr[uint8]](&tls_handshake_secret[0]),
                       label_s_hs, 12,
                       cast[Ptr[uint8]](&tls_transcript_hash[0]))
    label_key: Ptr[uint8] = "key"
    label_iv:  Ptr[uint8] = "iv"
    _tls_hkdf_expand_label(cast[Ptr[uint8]](&tls_client_hs_key[0]), 32,
                           cast[Ptr[uint8]](&tls_client_hs_secret[0]),
                           label_key, 3, cast[Ptr[uint8]](0), 0)
    _tls_hkdf_expand_label(cast[Ptr[uint8]](&tls_client_hs_iv[0]), 12,
                           cast[Ptr[uint8]](&tls_client_hs_secret[0]),
                           label_iv, 2, cast[Ptr[uint8]](0), 0)
    _tls_hkdf_expand_label(cast[Ptr[uint8]](&tls_server_hs_key[0]), 32,
                           cast[Ptr[uint8]](&tls_server_hs_secret[0]),
                           label_key, 3, cast[Ptr[uint8]](0), 0)
    _tls_hkdf_expand_label(cast[Ptr[uint8]](&tls_server_hs_iv[0]), 12,
                           cast[Ptr[uint8]](&tls_server_hs_secret[0]),
                           label_iv, 2, cast[Ptr[uint8]](0), 0)
    tls_client_seq = 0
    tls_server_seq = 0


def _tls_build_client_hello(host: Ptr[uint8],
                            out: Ptr[uint8],
                            cap: uint64) -> int64:
    # Lay down a TLS 1.3 ClientHello + record header into `out`.
    # Returns the byte length of the record (header + body), or -1 if
    # the buffer was too small.
    #
    # Wire shape (RFC 8446 §4.1.2):
    #   struct ClientHello {
    #     uint16 legacy_version = 0x0303;
    #     uint8  random[32];
    #     opaque session_id<0..32> = 0;          (empty -> 1 byte 0x00)
    #     uint16 cipher_suites<2..2^16-2>;       (we send 1 = 2 bytes)
    #     opaque compression_methods<1..255> = 0; (1 byte null + 1 byte len)
    #     Extension extensions<8..2^16-1>;
    #   };
    #
    # The record header is 5 bytes: { type=22, version=0x0301,
    # length(uint16 BE) }. legacy_record_version is 0x0301 per §5.1.

    # Make sure the running transcript hash is reset.
    _tls_tr_reset()

    host_len: uint64 = _tls_strlen(host)

    # We need fresh randomness for client_random + the private scalar.
    _tls_rng_bytes(cast[Ptr[uint8]](&tls_client_random[0]), 32)
    _tls_rng_bytes(cast[Ptr[uint8]](&tls_x25519_priv[0]), 32)
    # Compute the public share.
    if _tls_x25519_base_mult(cast[Ptr[uint8]](&tls_x25519_pub[0]),
                             cast[Ptr[uint8]](&tls_x25519_priv[0])) != 0:
        return -1

    # Reserve room for record header; body starts at offset 5.
    pos: uint64 = 5
    # Handshake header: 1 byte type + 3 bytes length. We patch the
    # length once we know the body size.
    hs_type_pos: uint64 = pos
    out[pos] = TLS_HS_CLIENT_HELLO
    pos = pos + 1
    hs_len_pos: uint64 = pos
    out[pos] = 0
    out[pos + 1] = 0
    out[pos + 2] = 0
    pos = pos + 3
    body_start: uint64 = pos

    # legacy_version
    out[pos] = 0x03
    out[pos + 1] = 0x03
    pos = pos + 2
    # random
    _tls_memcpy(cast[Ptr[uint8]](cast[uint64](out) + pos),
                cast[Ptr[uint8]](&tls_client_random[0]), 32)
    pos = pos + 32
    # session_id (empty)
    out[pos] = 0
    pos = pos + 1
    # cipher_suites: length=2 (one suite), then 0x13 0x03.
    out[pos] = 0
    out[pos + 1] = 2
    pos = pos + 2
    out[pos] = 0x13
    out[pos + 1] = 0x03
    pos = pos + 2
    # legacy_compression_methods: length=1, value=0 (null).
    out[pos] = 1
    out[pos + 1] = 0
    pos = pos + 2

    # Extensions length placeholder.
    ext_len_pos: uint64 = pos
    out[pos] = 0
    out[pos + 1] = 0
    pos = pos + 2
    ext_start: uint64 = pos

    # ext: server_name (SNI)
    out[pos] = cast[uint8]((TLS_EXT_SERVER_NAME >> 8) & 0xFF)
    out[pos + 1] = cast[uint8](TLS_EXT_SERVER_NAME & 0xFF)
    pos = pos + 2
    sni_inner_len: uint64 = host_len + 2 + 1 + 2     # list_len + type + name_len + name
    # ext length = list_len(2) + list contents(sni_inner_len? actually
    # ext payload is: ServerNameList<2..2^16-1>):
    # struct {
    #   ServerName server_name_list<1..2^16-1>;
    # } ServerNameExtension;
    # struct {
    #   uint8 NameType;          (0 = host_name)
    #   opaque HostName<1..2^16-1>;
    # } ServerName;
    list_len: uint64 = 1 + 2 + host_len
    ext_payload_len: uint64 = 2 + list_len
    out[pos] = cast[uint8]((ext_payload_len >> 8) & 0xFF)
    out[pos + 1] = cast[uint8](ext_payload_len & 0xFF)
    pos = pos + 2
    out[pos] = cast[uint8]((list_len >> 8) & 0xFF)
    out[pos + 1] = cast[uint8](list_len & 0xFF)
    pos = pos + 2
    out[pos] = 0          # host_name type
    pos = pos + 1
    out[pos] = cast[uint8]((host_len >> 8) & 0xFF)
    out[pos + 1] = cast[uint8](host_len & 0xFF)
    pos = pos + 2
    _tls_memcpy(cast[Ptr[uint8]](cast[uint64](out) + pos), host, host_len)
    pos = pos + host_len

    # ext: supported_versions: type | length | versions_list_len | TLS1.3
    out[pos] = cast[uint8]((TLS_EXT_SUPPORTED_VERSIONS >> 8) & 0xFF)
    out[pos + 1] = cast[uint8](TLS_EXT_SUPPORTED_VERSIONS & 0xFF)
    pos = pos + 2
    out[pos] = 0                          # ext payload = 3 bytes
    out[pos + 1] = 3
    pos = pos + 2
    out[pos] = 2                          # versions list = 2 bytes
    pos = pos + 1
    out[pos] = 0x03
    out[pos + 1] = 0x04
    pos = pos + 2

    # ext: supported_groups: x25519 (0x001D)
    out[pos] = cast[uint8]((TLS_EXT_SUPPORTED_GROUPS >> 8) & 0xFF)
    out[pos + 1] = cast[uint8](TLS_EXT_SUPPORTED_GROUPS & 0xFF)
    pos = pos + 2
    out[pos] = 0                          # ext payload = 4 bytes
    out[pos + 1] = 4
    pos = pos + 2
    out[pos] = 0                          # groups list = 2 bytes
    out[pos + 1] = 2
    pos = pos + 2
    out[pos] = 0x00
    out[pos + 1] = 0x1D
    pos = pos + 2

    # ext: signature_algorithms (REQUIRED even if we don't validate).
    out[pos] = cast[uint8]((TLS_EXT_SIG_ALGOS >> 8) & 0xFF)
    out[pos + 1] = cast[uint8](TLS_EXT_SIG_ALGOS & 0xFF)
    pos = pos + 2
    # Payload: list_len(2) + list contents (4 algs * 2 bytes = 8 bytes)
    out[pos] = 0                          # ext payload
    out[pos + 1] = 10
    pos = pos + 2
    out[pos] = 0                          # algs list len
    out[pos + 1] = 8
    pos = pos + 2
    # rsa_pss_rsae_sha256
    out[pos] = 0x08
    out[pos + 1] = 0x04
    pos = pos + 2
    # ecdsa_secp256r1_sha256
    out[pos] = 0x04
    out[pos + 1] = 0x03
    pos = pos + 2
    # ed25519
    out[pos] = 0x08
    out[pos + 1] = 0x07
    pos = pos + 2
    # rsa_pkcs1_sha256 (some old servers still require this in CH)
    out[pos] = 0x04
    out[pos + 1] = 0x01
    pos = pos + 2

    # ext: key_share
    out[pos] = cast[uint8]((TLS_EXT_KEY_SHARE >> 8) & 0xFF)
    out[pos + 1] = cast[uint8](TLS_EXT_KEY_SHARE & 0xFF)
    pos = pos + 2
    # Payload: client_shares<0..2^16-1>; each entry = group(2) + key_len(2) + key(32)
    ks_entry_len: uint64 = 2 + 2 + 32
    ks_list_len: uint64 = ks_entry_len
    out[pos] = cast[uint8]((((ks_list_len + 2) >> 8)) & 0xFF)
    out[pos + 1] = cast[uint8]((ks_list_len + 2) & 0xFF)
    pos = pos + 2
    out[pos] = cast[uint8]((ks_list_len >> 8) & 0xFF)
    out[pos + 1] = cast[uint8](ks_list_len & 0xFF)
    pos = pos + 2
    out[pos] = 0x00                       # x25519
    out[pos + 1] = 0x1D
    pos = pos + 2
    out[pos] = 0                          # key length = 32
    out[pos + 1] = 32
    pos = pos + 2
    _tls_memcpy(cast[Ptr[uint8]](cast[uint64](out) + pos),
                cast[Ptr[uint8]](&tls_x25519_pub[0]), 32)
    pos = pos + 32

    # Patch extensions length.
    ext_total: uint64 = pos - ext_start
    out[ext_len_pos]     = cast[uint8]((ext_total >> 8) & 0xFF)
    out[ext_len_pos + 1] = cast[uint8](ext_total & 0xFF)

    # Patch handshake length (uint24 BE).
    body_len: uint64 = pos - body_start
    out[hs_len_pos]     = cast[uint8]((body_len >> 16) & 0xFF)
    out[hs_len_pos + 1] = cast[uint8]((body_len >> 8) & 0xFF)
    out[hs_len_pos + 2] = cast[uint8](body_len & 0xFF)

    # Record header.
    rec_body_len: uint64 = pos - 5
    out[0] = TLS_CT_HANDSHAKE
    out[1] = 0x03                         # legacy_record_version
    out[2] = 0x01
    out[3] = cast[uint8]((rec_body_len >> 8) & 0xFF)
    out[4] = cast[uint8](rec_body_len & 0xFF)

    # Feed the handshake body (NOT the 5-byte record header) into the
    # transcript hash.
    _tls_tr_update(cast[Ptr[uint8]](cast[uint64](out) + 5),
                   rec_body_len)
    return cast[int64](pos)


def _tls_parse_server_hello(buf: Ptr[uint8], n: uint64) -> int32:
    # Parse a ServerHello body (without the record header, without the
    # handshake type+length prefix — caller already stripped both).
    # We need:
    #   - legacy_version (skip)
    #   - server_random[32]
    #   - legacy_session_id_echo (echo of our empty session_id; skip)
    #   - cipher_suite (must be TLS_CHACHA20_POLY1305_SHA256)
    #   - legacy_compression_method (skip)
    #   - extensions block — pull out the key_share with our X25519
    #     entry (group=0x001D, key=32 bytes) into tls_server_pub.
    if n < 2 + 32 + 1 + 2 + 1 + 2:
        return -1
    pos: uint64 = 0
    # legacy_version
    pos = pos + 2
    # server_random
    _tls_memcpy(cast[Ptr[uint8]](&tls_server_random[0]),
                cast[Ptr[uint8]](cast[uint64](buf) + pos), 32)
    pos = pos + 32
    # legacy_session_id_echo (1-byte length + bytes)
    sid_len: uint64 = cast[uint64](buf[pos])
    pos = pos + 1 + sid_len
    if pos + 2 > n:
        return -1
    # cipher_suite
    cs: uint16 = (cast[uint16](buf[pos]) << 8) | cast[uint16](buf[pos + 1])
    pos = pos + 2
    if cs != TLS_CIPHER_CHACHA20_POLY:
        printk1("[tls] server picked unsupported suite 0x%x\n",
                cast[uint64](cs))
        return -1
    # compression_method (always 0 in TLS 1.3)
    pos = pos + 1
    # extensions
    if pos + 2 > n:
        return -1
    ext_total: uint64 = (cast[uint64](buf[pos]) << 8) | cast[uint64](buf[pos + 1])
    pos = pos + 2
    if pos + ext_total > n:
        return -1
    ext_end: uint64 = pos + ext_total
    have_share: int32 = 0
    while pos + 4 <= ext_end:
        et: uint16 = (cast[uint16](buf[pos]) << 8) | cast[uint16](buf[pos + 1])
        el: uint64 = (cast[uint64](buf[pos + 2]) << 8) | cast[uint64](buf[pos + 3])
        pos = pos + 4
        if pos + el > ext_end:
            return -1
        if et == TLS_EXT_KEY_SHARE:
            # Server's KeyShareServerHello: KeyShareEntry = group(2) +
            # key_len(2) + key.
            if el < 4:
                return -1
            grp: uint16 = (cast[uint16](buf[pos]) << 8) | cast[uint16](buf[pos + 1])
            kl: uint64 = (cast[uint64](buf[pos + 2]) << 8) | cast[uint64](buf[pos + 3])
            if grp != TLS_GROUP_X25519:
                return -1
            if kl != 32:
                return -1
            _tls_memcpy(cast[Ptr[uint8]](&tls_server_pub[0]),
                        cast[Ptr[uint8]](cast[uint64](buf) + pos + 4), 32)
            have_share = 1
        pos = pos + el
    if have_share == 0:
        printk0("[tls] ServerHello missing key_share\n")
        return -1
    return 0


def _tls_hex_dump(label: Ptr[uint8], data: Ptr[uint8], n: uint64):
    # Debug helper: emit `label <hex>...` for the first 32 bytes,
    # then `+N more` if there's tail. printk doesn't have %02x so
    # we zero-pad the high nibble manually.
    printk1("%s ", cast[uint64](label))
    i: uint64 = 0
    cap: uint64 = n
    if cap > 32:
        cap = 32
    while i < cap:
        b: uint8 = data[i]
        if b < 0x10:
            printk1("0%x", cast[uint64](b) & 0xFF)
        else:
            printk1("%x", cast[uint64](b) & 0xFF)
        i = i + 1
    if n > 32:
        printk1(" +%d more", n - 32)
    printk0("\n")


def _tls_compute_nonce(seq: uint64, base_iv: Ptr[uint8],
                       out_nonce: Ptr[uint8]):
    # AEAD nonce = base_iv XOR seq (seq is big-endian aligned to last 8
    # bytes of the 12-byte IV).
    i: uint64 = 0
    while i < 12:
        out_nonce[i] = base_iv[i]
        i = i + 1
    i = 0
    while i < 8:
        shift: uint64 = (7 - i) * 8
        out_nonce[4 + i] = out_nonce[4 + i] ^ cast[uint8]((seq >> shift) & 0xFF)
        i = i + 1


tls_selftest_ran:    int32 = 0


# -- V5 cert-validation module globals -------------------------------------
#
# Chain table populated by the Certificate-message parser in
# _tls_drive_post_sh. We hold up to MAX_CHAIN_DEPTH (8) (ptr, len) pairs;
# the pointers index directly into tls_pt_buf (the AEAD-decrypted scratch).
# The bytes in tls_pt_buf stay stable for the duration of the validate
# call (we run it synchronously from the same plaintext-walk iteration).

_tls_chain_ptrs:     Array[8, Ptr[uint8]]
_tls_chain_lens:     Array[8, uint64]
_tls_chain_count:    int32 = 0

# The SNI hostname passed into tls_handshake. We stash it on the module
# globals so _tls_drive_post_sh can pass it to validate_cert_chain (the
# chain-walker's SAN matcher). 0 means "no host pinned" — validate_cert_
# chain will then reject every chain (hostname check is mandatory).
# Stored as uint64 so the global takes an integer initializer; the
# handshake path casts to Ptr[uint8] when reading.
_tls_sni_host_raw:   uint64 = 0

# Once-per-boot guard. The OID tables / curve constants / RSA params /
# castore are loaded the first time a handshake actually fires (not at
# tls_init time — net_smoke_test runs tls_init BEFORE rtc_init + vfs_init,
# and we want the cpio entry table available for the optional fixture-CA
# load).
_tls_val_init_ran:   int32 = 0

# When the RTC is unreadable we fall back to a build-time epoch so the
# validity-window check stays meaningful. Picked roughly "now" at V5
# landing time (2026-05-18 00:00:00 UTC). Once a real RTC reader works
# end-to-end on every test target this fallback gets retired.
#
# V5.2 SECURITY NOTE: a falling-back-to-the-build-epoch path is a
# clock-rolled-back window for adversaries presenting expired certs.
# We now prefer rtc_read_unix_time() which talks to CMOS on every
# call; the fallback only fires when rtc_probe() reports no RTC,
# and we log a WARNING line so it shows up in serial logs.
TLS_BUILD_EPOCH_FALLBACK: uint64 = 1779667200

# Lazy one-shot RTC probe cache. _rtc_probed flips to 1 after the
# first _tls_now_unix() call; _rtc_avail caches the rtc_probe()
# verdict (0 = present, -1 = absent) so subsequent calls skip the
# Status Register B re-read.
_tls_rtc_probed: int32 = 0
_tls_rtc_avail:  int32 = 0


# -- V5.1 CertificateVerify globals ----------------------------------------
#
# Per RFC 8446 §4.4.3 the server CertificateVerify signature is over
#   64 * 0x20 || "TLS 1.3, server CertificateVerify" || 0x00 ||
#       Transcript-Hash(ClientHello..Certificate)
# = 64 + 33 + 1 + 32 = 130 bytes. We freeze the transcript hash after
# the Certificate message gets streamed into the running transcript;
# the CertificateVerify message itself is NOT included.

TLS_CV_CONTEXT_LEN:   uint64 = 130   # 64 + 33 + 1 + 32
TLS_ALERT_DECRYPT_ERROR: uint8 = 51

# Saved transcript hash as-of-Certificate. Filled in the Certificate
# branch of _tls_drive_post_sh, consumed in the CertificateVerify branch.
_tls_th_after_cert:   Array[32, uint8]
# Sticky guard: 1 once _tls_th_after_cert holds a snapshot for this
# handshake. CertificateVerify before Certificate is a protocol error.
_tls_th_after_cert_set: int32 = 0

# Stable copy of the LEAF certificate DER bytes. We can't keep the
# original _tls_chain_ptrs[0] pointer live across plaintext records:
# tls_pt_buf is reused on every _tls_decrypt_record call, so by the
# time the CertificateVerify message arrives in a fresh record, the
# Certificate-message plaintext (and the leaf cert bytes inside it)
# have already been overwritten. We copy the leaf DER into this BSS
# slot the moment the chain validator returns success.
#
# The X.509 max-cert-size cap matches castore_root_bytes (lib/x509/
# chain.ad CASTORE_ROOT_BYTES = 2048) — public-CA leaves run
# 1.2..1.6 KiB; a 2 KiB ceiling is comfortable.
TLS_LEAF_COPY_MAX:    uint64 = 4096
_tls_leaf_copy_buf:   Array[4096, uint8]
_tls_leaf_copy_len:   uint64 = 0

# Canonical signed buffer for CV. Pre-filled with the fixed 98-byte
# prefix (64 spaces + label + 0x00) by _tls_cv_prefix_init; the trailing
# 32 bytes are written from the transcript snapshot on every CV verify.
_tls_cv_signed_buf:   Array[130, uint8]
_tls_cv_prefix_inited: int32 = 0

# Leaf cert re-parsed from _tls_chain_ptrs[0] for the CV check. We keep
# our own X509Cert (rather than peeking at chain.ad's leaf_scratch)
# because the chain walker overwrites leaf_scratch / current_scratch
# when chain_count > 1.
_tls_leaf_scratch:    X509Cert
_tls_leaf_rsa:        RsaPubkey
_tls_leaf_ecdsa:      EcdsaPubkey


def _tls_now_unix() -> uint64:
    # Walltime in unix seconds for the chain validator. Prefer the live
    # RTC read (drivers/rtc/cmos.ad reads the CMOS chip on every call,
    # good to ~1 s). The build epoch is only used when rtc_probe() says
    # there is no RTC OR a live read fails for some transient reason.
    #
    # V5.2 closed a clock-rollback hole: previously every failure fell
    # straight through to TLS_BUILD_EPOCH_FALLBACK without any signal
    # in the serial log, so an attacker who pinned a target with no
    # RTC (or stalled the chip) could present a cert expired six months
    # ago and we'd happily accept it. The fallback still exists for
    # boards without an RTC at all, but each fallback fires a WARNING.

    # Lazy probe — cached so we don't re-walk Status Register B on
    # every handshake. rtc_init() also ran at boot from init/main.ad,
    # so this is belt-and-braces.
    if _tls_rtc_probed == 0:
        _tls_rtc_probed = 1
        _tls_rtc_avail = rtc_probe()
        if _tls_rtc_avail < 0:
            printk0("[tls] WARNING: RTC unavailable, using build epoch\n")

    if _tls_rtc_avail < 0:
        return TLS_BUILD_EPOCH_FALLBACK

    e: int64 = rtc_read_unix_time()
    if e < 0:
        printk0("[tls] WARNING: RTC unavailable, using build epoch\n")
        return TLS_BUILD_EPOCH_FALLBACK
    return cast[uint64](e)


def _tls_name_eq(name: Ptr[char], target: Ptr[uint8],
                 target_len: uint64) -> int32:
    # Compare a NUL-terminated cpio entry name against `target` (length-
    # prefixed; the comparison runs over target_len bytes and additionally
    # requires the name to terminate at exactly that position).
    i: uint64 = 0
    while i < target_len:
        if cast[uint8](name[i]) != target[i]:
            return 0
        i = i + 1
    if cast[uint8](name[target_len]) != 0:
        return 0
    return 1


def _tls_load_initramfs_anchor(path: Ptr[uint8], path_len: uint64) -> int32:
    # Walk the cpio entry table looking for the named DER blob, and add it
    # as a CA-store anchor on hit. Returns the slot index on success,
    # -1 if the file is absent, -2 if castore_add_root rejected it.
    tm_count: uint64 = initramfs_entry_count()
    tm_idx: uint64 = 0
    while tm_idx < tm_count:
        tm_name: Ptr[char] = initramfs_entry_name(tm_idx)
        if _tls_name_eq(tm_name, path, path_len) == 1:
            blob: Ptr[uint8] = initramfs_entry_data(tm_idx)
            sz:   uint64    = initramfs_entry_size(tm_idx)
            slot: int32 = castore_add_root(blob, sz)
            if slot < 0:
                return -2
            return slot
        tm_idx = tm_idx + 1
    return -1


def _tls_validation_init():
    # Lazy one-shot init for the cert-validation stack. Called from
    # tls_handshake() before the first time we touch validate_cert_chain.
    if _tls_val_init_ran != 0:
        return
    _tls_val_init_ran = 1
    asn1_init_oids()
    p256_init()
    rsa_init()
    ecdsa_init()
    castore_init()
    # Bake-in production anchor: ISRG Root X1 (Let's Encrypt).
    isrg_path: Ptr[uint8] = "/etc/tls-ca-isrg-x1.der"
    rc_isrg: int32 = _tls_load_initramfs_anchor(isrg_path, 23)
    if rc_isrg >= 0:
        printk1("[tls] CA anchor loaded: ISRG Root X1 (slot %d)\n",
                cast[uint64](rc_isrg))
    elif rc_isrg == -1:
        printk0("[tls] CA anchor absent: ISRG Root X1 (not in initramfs)\n")
    else:
        # x509_parse rejects ISRG Root X1 today: it's a 4096-bit RSA root
        # signed with sha256WithRSAEncryption (PKCS#1 v1.5) which V4's
        # signature-verify dispatch doesn't handle (PSS + ECDSA only).
        # The anchor still gets refused at castore_add_root time so the
        # gate fails closed. V6 will add v1.5 dispatch.
        printk0("[tls] CA anchor REJECTED: ISRG Root X1 (parse failed; PKCS#1 v1.5 unsupported in V5)\n")
    # Optional fixture-supplied anchor. test_net_https.sh plants this so
    # the in-tree TLS server's leaf chains up through a known CA.
    fixture_path: Ptr[uint8] = "/etc/tls-ca.der"
    rc_fix: int32 = _tls_load_initramfs_anchor(fixture_path, 15)
    if rc_fix >= 0:
        printk1("[tls] CA anchor loaded: fixture (/etc/tls-ca.der, slot %d)\n",
                cast[uint64](rc_fix))
    elif rc_fix == -2:
        printk0("[tls] CA anchor REJECTED: /etc/tls-ca.der (parse failed)\n")
    printk1("[tls] cert-validation init complete (%d anchors loaded)\n",
            cast[uint64](castore_count()))


def tls_init():
    # Module init: zero scratch + load SHA-256 K constants. Called once
    # by https_get before the first handshake.
    _tls_sha256_init_k()
    _tls_memset(cast[Ptr[uint8]](&tls_tx_buf[0]), 0, 2048)
    _tls_memset(cast[Ptr[uint8]](&tls_hs_buf[0]), 0, 16384)
    tls_hs_len = 0
    tls_active = 0
    tls_tcp_slot = -1
    tls_client_seq = 0
    tls_server_seq = 0
    tls_rng_state = 0
    tls_rxr_len = 0
    _tls_tr_reset()
    printk0("tls: client initialized (TLS 1.3 / chacha20-poly1305 / X25519)\n")
    # Run the AEAD + X25519 self-test once per boot — proves the crypto
    # primitives compile + link correctly even when the test environment
    # has no outbound 443/UDP for a live handshake.
    if tls_selftest_ran == 0:
        _tls_crypto_selftest()
        tls_selftest_ran = 1


def _tls_crypto_selftest() -> int32:
    # Quick sanity-check: round-trip ChaCha20-Poly1305 + verify X25519
    # base_point * 1 == base_point. Logged once at init time so a
    # boot-log grep can confirm the primitives compiled correctly.
    key: Array[32, uint8]
    nonce: Array[12, uint8]
    _tls_memset(cast[Ptr[uint8]](&key[0]), 0, 32)
    _tls_memset(cast[Ptr[uint8]](&nonce[0]), 0, 12)
    pt: Ptr[uint8] = "ping"
    ct: Array[16, uint8]
    tag: Array[16, uint8]
    pt2: Array[16, uint8]
    _tls_aead_seal(cast[Ptr[uint8]](&key[0]),
                   cast[Ptr[uint8]](&nonce[0]),
                   cast[Ptr[uint8]](0), 0,
                   pt, 4,
                   cast[Ptr[uint8]](&ct[0]),
                   cast[Ptr[uint8]](&tag[0]))
    rc: int32 = _tls_aead_open(cast[Ptr[uint8]](&key[0]),
                               cast[Ptr[uint8]](&nonce[0]),
                               cast[Ptr[uint8]](0), 0,
                               cast[Ptr[uint8]](&ct[0]), 4,
                               cast[Ptr[uint8]](&tag[0]),
                               cast[Ptr[uint8]](&pt2[0]))
    if rc != 0:
        printk0("[tls] selftest: AEAD round-trip FAILED\n")
        return -1
    if pt2[0] != 0x70:                  # 'p'
        printk0("[tls] selftest: AEAD plaintext mismatch\n")
        return -1
    # X25519: priv = [1, 0, ..., 0] is clamped to (8, 0, ..., 64),
    # so pub != base — but we can at least verify scalarmult(priv, base)
    # is deterministic (rerun yields same bytes).
    priv: Array[32, uint8]
    _tls_memset(cast[Ptr[uint8]](&priv[0]), 0, 32)
    priv[0] = 1
    pub_a: Array[32, uint8]
    pub_b: Array[32, uint8]
    _tls_x25519_base_mult(cast[Ptr[uint8]](&pub_a[0]),
                          cast[Ptr[uint8]](&priv[0]))
    _tls_x25519_base_mult(cast[Ptr[uint8]](&pub_b[0]),
                          cast[Ptr[uint8]](&priv[0]))
    if _tls_memcmp(cast[Ptr[uint8]](&pub_a[0]),
                   cast[Ptr[uint8]](&pub_b[0]), 32) != 0:
        printk0("[tls] selftest: X25519 not deterministic\n")
        return -1
    # Verify _tls_mul128 first: 0x123456789ABCDEF0 * 0xFEDCBA9876543210
    # = 0x121fa00ad77d7422_236d88fe5618cf00 (per Python).
    tls_mul128_a = 0x123456789ABCDEF0
    tls_mul128_b = 0xFEDCBA9876543210
    _tls_mul128()
    if tls_mul128_lo != 0x236d88fe5618cf00:
        printk0("[tls] selftest: mul128 LOW wrong\n")
        return -1
    if tls_mul128_hi != 0x121fa00ad77d7422:
        printk0("[tls] selftest: mul128 HIGH wrong\n")
        return -1
    # RFC 7748 §5.2 test vector 1: scalarmult of a known scalar and
    # u-coord. Catches X25519 ladder / field-arith bugs.
    rfc_scalar: Array[32, uint8]
    rfc_u:      Array[32, uint8]
    rfc_scalar[0]  = 0xa5
    rfc_scalar[1]  = 0x46
    rfc_scalar[2]  = 0xe3
    rfc_scalar[3]  = 0x6b
    rfc_scalar[4]  = 0xf0
    rfc_scalar[5]  = 0x52
    rfc_scalar[6]  = 0x7c
    rfc_scalar[7]  = 0x9d
    rfc_scalar[8]  = 0x3b
    rfc_scalar[9]  = 0x16
    rfc_scalar[10] = 0x15
    rfc_scalar[11] = 0x4b
    rfc_scalar[12] = 0x82
    rfc_scalar[13] = 0x46
    rfc_scalar[14] = 0x5e
    rfc_scalar[15] = 0xdd
    rfc_scalar[16] = 0x62
    rfc_scalar[17] = 0x14
    rfc_scalar[18] = 0x4c
    rfc_scalar[19] = 0x0a
    rfc_scalar[20] = 0xc1
    rfc_scalar[21] = 0xfc
    rfc_scalar[22] = 0x5a
    rfc_scalar[23] = 0x18
    rfc_scalar[24] = 0x50
    rfc_scalar[25] = 0x6a
    rfc_scalar[26] = 0x22
    rfc_scalar[27] = 0x44
    rfc_scalar[28] = 0xba
    rfc_scalar[29] = 0x44
    rfc_scalar[30] = 0x9a
    rfc_scalar[31] = 0xc4
    rfc_u[0]  = 0xe6
    rfc_u[1]  = 0xdb
    rfc_u[2]  = 0x68
    rfc_u[3]  = 0x67
    rfc_u[4]  = 0x58
    rfc_u[5]  = 0x30
    rfc_u[6]  = 0x30
    rfc_u[7]  = 0xdb
    rfc_u[8]  = 0x35
    rfc_u[9]  = 0x94
    rfc_u[10] = 0xc1
    rfc_u[11] = 0xa4
    rfc_u[12] = 0x24
    rfc_u[13] = 0xb1
    rfc_u[14] = 0x5f
    rfc_u[15] = 0x7c
    rfc_u[16] = 0x72
    rfc_u[17] = 0x66
    rfc_u[18] = 0x24
    rfc_u[19] = 0xec
    rfc_u[20] = 0x26
    rfc_u[21] = 0xb3
    rfc_u[22] = 0x35
    rfc_u[23] = 0x3b
    rfc_u[24] = 0x10
    rfc_u[25] = 0xa9
    rfc_u[26] = 0x03
    rfc_u[27] = 0xa6
    rfc_u[28] = 0xd0
    rfc_u[29] = 0xab
    rfc_u[30] = 0x1c
    rfc_u[31] = 0x4c
    rfc_out: Array[32, uint8]
    _tls_x25519_scalarmult(cast[Ptr[uint8]](&rfc_out[0]),
                           cast[Ptr[uint8]](&rfc_scalar[0]),
                           cast[Ptr[uint8]](&rfc_u[0]))
    # Expected: c3da55379de9c6908e94ea4df28d084f32eccf03491c71f754b4075577a28552
    rfc_exp: Array[32, uint8]
    rfc_exp[0]  = 0xc3
    rfc_exp[1]  = 0xda
    rfc_exp[2]  = 0x55
    rfc_exp[3]  = 0x37
    rfc_exp[4]  = 0x9d
    rfc_exp[5]  = 0xe9
    rfc_exp[6]  = 0xc6
    rfc_exp[7]  = 0x90
    rfc_exp[8]  = 0x8e
    rfc_exp[9]  = 0x94
    rfc_exp[10] = 0xea
    rfc_exp[11] = 0x4d
    rfc_exp[12] = 0xf2
    rfc_exp[13] = 0x8d
    rfc_exp[14] = 0x08
    rfc_exp[15] = 0x4f
    rfc_exp[16] = 0x32
    rfc_exp[17] = 0xec
    rfc_exp[18] = 0xcf
    rfc_exp[19] = 0x03
    rfc_exp[20] = 0x49
    rfc_exp[21] = 0x1c
    rfc_exp[22] = 0x71
    rfc_exp[23] = 0xf7
    rfc_exp[24] = 0x54
    rfc_exp[25] = 0xb4
    rfc_exp[26] = 0x07
    rfc_exp[27] = 0x55
    rfc_exp[28] = 0x77
    rfc_exp[29] = 0xa2
    rfc_exp[30] = 0x85
    rfc_exp[31] = 0x52
    if _tls_memcmp(cast[Ptr[uint8]](&rfc_out[0]),
                   cast[Ptr[uint8]](&rfc_exp[0]), 32) != 0:
        printk0("[tls] selftest: X25519 RFC 7748 vector MISMATCH\n")
        dbg_got: Ptr[uint8] = "  got     ="
        dbg_want: Ptr[uint8] = "  expected="
        _tls_hex_dump(dbg_got, cast[Ptr[uint8]](&rfc_out[0]), 32)
        _tls_hex_dump(dbg_want, cast[Ptr[uint8]](&rfc_exp[0]), 32)
        return -1
    printk0("[tls] selftest: AEAD + X25519 OK\n")
    return 0


def tls_handshake(tcp_slot: int32, host: Ptr[uint8]) -> int32:
    # Drive the TLS 1.3 handshake on an already-ESTABLISHED TCP slot.
    # Returns 0 on success, -1 on any failure. Logs progress markers
    # so the smoke test can grep what stage we reached.
    if tcp_slot < 0:
        return -1
    printk1("[tls] handshake start (host=%s)\n", cast[uint64](host))
    # V5: lazy-init the cert-validation stack (OID tables, RSA/ECDSA
    # primitives, CA store) on the first handshake of this boot. We do
    # this here rather than in tls_init() because net_smoke_test calls
    # tls_init BEFORE rtc_init / vfs_init, and the CA-anchor loader
    # wants the initramfs cpio table populated.
    _tls_validation_init()
    # Stash the SNI host so _tls_drive_post_sh can hand it to the chain
    # validator alongside the chain-table it builds while walking the
    # Certificate message.
    _tls_sni_host_raw = cast[uint64](host)
    _tls_chain_count = 0
    tls_tcp_slot = tcp_slot

    # Build + send ClientHello.
    ch_len_signed: int64 = _tls_build_client_hello(
        host, cast[Ptr[uint8]](&tls_tx_buf[0]), 2048)
    if ch_len_signed < 0:
        printk0("[tls] ClientHello build failed\n")
        return -1
    ch_len: uint64 = cast[uint64](ch_len_signed)
    sent: int64 = tcp_send(tcp_slot, cast[Ptr[uint8]](&tls_tx_buf[0]),
                           ch_len)
    if sent < 0:
        printk0("[tls] ClientHello send failed\n")
        return -1
    printk1("[tls] ClientHello sent (%d bytes)\n", ch_len)

    # Receive ServerHello. _tls_read_record reassembles a complete TLS
    # record (5-byte header + payload) into tls_rx_buf even if TCP
    # delivers it across multiple segments, and stores any spilled
    # bytes for the next call.
    rx_ptr: Ptr[uint8] = cast[Ptr[uint8]](&tls_rx_buf[0])
    rec_total_signed: int64 = _tls_read_record(tcp_slot, 400)
    if rec_total_signed <= 0:
        printk0("[tls] ServerHello recv failed\n")
        return -1
    if tls_rx_buf[0] != TLS_CT_HANDSHAKE:
        # Could be an alert (type=21) if the server hated our hello.
        printk1("[tls] unexpected record type %d\n",
                cast[uint64](tls_rx_buf[0]))
        return -1
    rec_len: uint64 = cast[uint64](rec_total_signed) - 5
    # Handshake message header: type(1) + length(3)
    if rec_len < 4:
        return -1
    hs_type: uint8 = tls_rx_buf[5]
    if hs_type != TLS_HS_SERVER_HELLO:
        printk1("[tls] expected ServerHello, got hs_type=%d\n",
                cast[uint64](hs_type))
        return -1
    hs_body_len: uint64 = (cast[uint64](tls_rx_buf[6]) << 16) \
        | (cast[uint64](tls_rx_buf[7]) << 8) \
        | cast[uint64](tls_rx_buf[8])
    # Feed the SH handshake message (type+length+body) into the
    # transcript hash before parsing — RFC 8446 §4.4.1.
    _tls_tr_update(cast[Ptr[uint8]](cast[uint64](rx_ptr) + 5),
                   4 + hs_body_len)
    if _tls_parse_server_hello(
            cast[Ptr[uint8]](cast[uint64](rx_ptr) + 9),
            hs_body_len) != 0:
        return -1
    printk0("[tls] ServerHello parsed (cipher=chacha20-poly1305, group=X25519)\n")

    # Compute shared secret + handshake traffic keys.
    if _tls_x25519_scalarmult(cast[Ptr[uint8]](&tls_x25519_shared[0]),
                              cast[Ptr[uint8]](&tls_x25519_priv[0]),
                              cast[Ptr[uint8]](&tls_server_pub[0])) != 0:
        printk0("[tls] X25519 shared-secret derivation failed\n")
        return -1
    _tls_compute_handshake_keys()
    printk0("[tls] handshake keys derived (encrypted ServerHello parsed)\n")

    # Consume the rest of the server flight (EncryptedExtensions,
    # Certificate, CertificateVerify, Finished — all AEAD-protected
    # under the server handshake traffic key) and emit our client
    # Finished. _tls_drive_post_sh handles reassembly across tcp_recv
    # chunks and feeds each handshake message into the transcript hash.
    return _tls_drive_post_sh(tcp_slot)


def _tls_compute_app_keys():
    # After the server's Finished is consumed, the transcript hash is
    # "ClientHello..server Finished". RFC 8446 §7.1:
    #   master_secret =
    #     HKDF-Extract(Derive-Secret(handshake_secret, "derived", ""), 0)
    #   c_ap = Derive-Secret(master_secret, "c ap traffic", transcript)
    #   s_ap = Derive-Secret(master_secret, "s ap traffic", transcript)
    #   key  = HKDF-Expand-Label(secret, "key", "", 32)
    #   iv   = HKDF-Expand-Label(secret, "iv",  "", 12)
    zero32: Array[32, uint8]
    _tls_memset(cast[Ptr[uint8]](&zero32[0]), 0, 32)
    empty_hash: Array[32, uint8]
    _tls_sha256_oneshot(cast[Ptr[uint8]](&zero32[0]), 0,
                        cast[Ptr[uint8]](&empty_hash[0]))
    derived: Array[32, uint8]
    label_derived: Ptr[uint8] = "derived"
    _tls_derive_secret(cast[Ptr[uint8]](&derived[0]),
                       cast[Ptr[uint8]](&tls_handshake_secret[0]),
                       label_derived, 7,
                       cast[Ptr[uint8]](&empty_hash[0]))
    _tls_hkdf_extract(cast[Ptr[uint8]](&tls_master_secret[0]),
                      cast[Ptr[uint8]](&derived[0]), 32,
                      cast[Ptr[uint8]](&zero32[0]), 32)
    # Snapshot transcript hash including server Finished.
    th_after_sf: Array[32, uint8]
    _tls_sha256_snapshot_into(cast[Ptr[uint8]](&th_after_sf[0]))
    label_c_ap: Ptr[uint8] = "c ap traffic"
    label_s_ap: Ptr[uint8] = "s ap traffic"
    _tls_derive_secret(cast[Ptr[uint8]](&tls_client_ap_secret[0]),
                       cast[Ptr[uint8]](&tls_master_secret[0]),
                       label_c_ap, 12,
                       cast[Ptr[uint8]](&th_after_sf[0]))
    _tls_derive_secret(cast[Ptr[uint8]](&tls_server_ap_secret[0]),
                       cast[Ptr[uint8]](&tls_master_secret[0]),
                       label_s_ap, 12,
                       cast[Ptr[uint8]](&th_after_sf[0]))
    label_key: Ptr[uint8] = "key"
    label_iv:  Ptr[uint8] = "iv"
    _tls_hkdf_expand_label(cast[Ptr[uint8]](&tls_client_ap_key[0]), 32,
                           cast[Ptr[uint8]](&tls_client_ap_secret[0]),
                           label_key, 3, cast[Ptr[uint8]](0), 0)
    _tls_hkdf_expand_label(cast[Ptr[uint8]](&tls_client_ap_iv[0]), 12,
                           cast[Ptr[uint8]](&tls_client_ap_secret[0]),
                           label_iv, 2, cast[Ptr[uint8]](0), 0)
    _tls_hkdf_expand_label(cast[Ptr[uint8]](&tls_server_ap_key[0]), 32,
                           cast[Ptr[uint8]](&tls_server_ap_secret[0]),
                           label_key, 3, cast[Ptr[uint8]](0), 0)
    _tls_hkdf_expand_label(cast[Ptr[uint8]](&tls_server_ap_iv[0]), 12,
                           cast[Ptr[uint8]](&tls_server_ap_secret[0]),
                           label_iv, 2, cast[Ptr[uint8]](0), 0)
    # App-direction sequence numbers reset when keys switch.
    tls_client_seq = 0
    tls_server_seq = 0


def _tls_read_record(tcp_slot: int32, timeout_ms: uint64) -> int64:
    # Pull exactly one whole TLS record off the wire into tls_rx_buf.
    # On entry tls_rxr_buf may carry leftover bytes from a previous
    # call (e.g. a TCP segment delivered more than one record's worth).
    # On success returns the record length (header + body); tls_rx_buf
    # holds the record bytes at offset 0. On timeout/EOF returns 0;
    # on hard error returns -1.
    #
    # Pull whatever's already buffered into tls_rx_buf, then top up
    # from tcp_recv as needed.
    rx_ptr: Ptr[uint8] = cast[Ptr[uint8]](&tls_rx_buf[0])
    # Drain any reassembly leftovers first.
    if tls_rxr_len > 0:
        i: uint64 = 0
        while i < tls_rxr_len:
            tls_rx_buf[i] = tls_rxr_buf[i]
            i = i + 1
    have: uint64 = tls_rxr_len
    tls_rxr_len = 0
    # Need at least 5 bytes to know the record length.
    while have < 5:
        room: uint64 = 16640 - have
        n: int64 = tcp_recv(tcp_slot,
                            cast[Ptr[uint8]](cast[uint64](rx_ptr) + have),
                            room, timeout_ms)
        if n <= 0:
            return n
        have = have + cast[uint64](n)
    rec_len: uint64 = (cast[uint64](tls_rx_buf[3]) << 8) \
        | cast[uint64](tls_rx_buf[4])
    total: uint64 = 5 + rec_len
    if total > 16640:
        # TLS 1.3 caps ciphertext at 16640 (16384 plaintext + 256 pad +
        # type byte + tag); anything larger is malformed/protocol error.
        printk1("[tls] record too large for scratch (%d bytes)\n",
                rec_len)
        return -1
    while have < total:
        room: uint64 = 16640 - have
        n2: int64 = tcp_recv(tcp_slot,
                             cast[Ptr[uint8]](cast[uint64](rx_ptr) + have),
                             room, timeout_ms)
        if n2 <= 0:
            return -1
        have = have + cast[uint64](n2)
    # Anything past `total` is leftover for the next record.
    if have > total:
        spill: uint64 = have - total
        if spill > 8192:
            return -1
        s: uint64 = 0
        while s < spill:
            tls_rxr_buf[s] = tls_rx_buf[total + s]
            s = s + 1
        tls_rxr_len = spill
    return cast[int64](total)


def _tls_decrypt_record(rec_total_len: uint64,
                        is_handshake: int32) -> int64:
    # Decrypt the AEAD record sitting at tls_rx_buf[0..rec_total_len].
    # If `is_handshake` is 1, use the handshake traffic key/iv +
    # tls_server_seq for handshake records; otherwise use the
    # application traffic key/iv. On success returns the plaintext
    # length (already stripped of the tag — the trailing content type
    # byte + any zero padding are STILL present at the end). Plaintext
    # is written into tls_pt_buf[0..plaintext_len]. -1 on AEAD failure.
    rx_ptr: Ptr[uint8] = cast[Ptr[uint8]](&tls_rx_buf[0])
    rec_len: uint64 = rec_total_len - 5
    if rec_len < 16:
        return -1
    ct_len: uint64 = rec_len - 16
    aad: Array[5, uint8]
    aad[0] = tls_rx_buf[0]
    aad[1] = tls_rx_buf[1]
    aad[2] = tls_rx_buf[2]
    aad[3] = tls_rx_buf[3]
    aad[4] = tls_rx_buf[4]
    nonce: Array[12, uint8]
    if is_handshake == 1:
        _tls_compute_nonce(tls_server_seq,
                           cast[Ptr[uint8]](&tls_server_hs_iv[0]),
                           cast[Ptr[uint8]](&nonce[0]))
        rc: int32 = _tls_aead_open(
            cast[Ptr[uint8]](&tls_server_hs_key[0]),
            cast[Ptr[uint8]](&nonce[0]),
            cast[Ptr[uint8]](&aad[0]), 5,
            cast[Ptr[uint8]](cast[uint64](rx_ptr) + 5), ct_len,
            cast[Ptr[uint8]](cast[uint64](rx_ptr) + 5 + ct_len),
            cast[Ptr[uint8]](&tls_pt_buf[0]))
        if rc != 0:
            return -1
    else:
        _tls_compute_nonce(tls_server_seq,
                           cast[Ptr[uint8]](&tls_server_ap_iv[0]),
                           cast[Ptr[uint8]](&nonce[0]))
        rc2: int32 = _tls_aead_open(
            cast[Ptr[uint8]](&tls_server_ap_key[0]),
            cast[Ptr[uint8]](&nonce[0]),
            cast[Ptr[uint8]](&aad[0]), 5,
            cast[Ptr[uint8]](cast[uint64](rx_ptr) + 5), ct_len,
            cast[Ptr[uint8]](cast[uint64](rx_ptr) + 5 + ct_len),
            cast[Ptr[uint8]](&tls_pt_buf[0]))
        if rc2 != 0:
            return -1
    tls_server_seq = tls_server_seq + 1
    return cast[int64](ct_len)


def _tls_strip_inner_padding(pt_len: uint64,
                             real_type_out: Ptr[uint8]) -> int64:
    # Walk back from the end of the plaintext skipping zero padding
    # until we find the real content type byte. Returns the inner
    # plaintext length (excluding the type byte). -1 if the record
    # was all-zero (malformed).
    if pt_len == 0:
        return -1
    p: uint64 = pt_len
    while p > 0:
        if tls_pt_buf[p - 1] != 0:
            real_type_out[0] = tls_pt_buf[p - 1]
            return cast[int64](p - 1)
        p = p - 1
    return -1


def _tls_send_client_finished(tcp_slot: int32) -> int32:
    # Build + send the client Finished handshake message wrapped in an
    # AEAD record under the client handshake traffic key. Uses the
    # transcript hash as-of-server-Finished as the HMAC input.
    # verify_data = HMAC(client_finished_key, transcript_hash)
    # client_finished_key = HKDF-Expand-Label(client_hs_secret,
    #                                         "finished", "", 32)
    label_finished: Ptr[uint8] = "finished"
    cf_key: Array[32, uint8]
    _tls_hkdf_expand_label(cast[Ptr[uint8]](&cf_key[0]), 32,
                           cast[Ptr[uint8]](&tls_client_hs_secret[0]),
                           label_finished, 8,
                           cast[Ptr[uint8]](0), 0)
    th_now: Array[32, uint8]
    _tls_sha256_snapshot_into(cast[Ptr[uint8]](&th_now[0]))
    verify: Array[32, uint8]
    _tls_hmac_sha256(cast[Ptr[uint8]](&verify[0]),
                     cast[Ptr[uint8]](&cf_key[0]), 32,
                     cast[Ptr[uint8]](&th_now[0]), 32)
    # Inner plaintext = handshake header (type=20, length=32) + 32-byte
    # verify_data + trailing content-type byte (0x16 = handshake).
    inner: Array[64, uint8]
    inner[0] = TLS_HS_FINISHED                    # 20
    inner[1] = 0                                   # length high
    inner[2] = 0
    inner[3] = 32                                  # length low
    i: uint64 = 0
    while i < 32:
        inner[4 + i] = verify[i]
        i = i + 1
    inner[36] = TLS_CT_HANDSHAKE                   # inner content type
    inner_len: uint64 = 37
    # Update transcript hash with the Finished handshake message body
    # (the 4-byte header + 32-byte verify_data; NOT the inner content
    # type byte). This isn't used for any further server verification
    # but matches what we'd need for resumption tickets / KeyUpdate.
    _tls_tr_update(cast[Ptr[uint8]](&inner[0]), 36)

    record_len: uint64 = inner_len + TLS_AEAD_TAG  # 37 + 16 = 53
    tls_tx_buf[0] = TLS_CT_APPLICATION
    tls_tx_buf[1] = 0x03
    tls_tx_buf[2] = 0x03
    tls_tx_buf[3] = cast[uint8]((record_len >> 8) & 0xFF)
    tls_tx_buf[4] = cast[uint8](record_len & 0xFF)
    nonce: Array[12, uint8]
    _tls_compute_nonce(tls_client_seq,
                       cast[Ptr[uint8]](&tls_client_hs_iv[0]),
                       cast[Ptr[uint8]](&nonce[0]))
    _tls_aead_seal(cast[Ptr[uint8]](&tls_client_hs_key[0]),
                   cast[Ptr[uint8]](&nonce[0]),
                   cast[Ptr[uint8]](&tls_tx_buf[0]), 5,
                   cast[Ptr[uint8]](&inner[0]), inner_len,
                   cast[Ptr[uint8]](&tls_tx_buf[5]),
                   cast[Ptr[uint8]](&tls_tx_buf[5 + inner_len]))
    tls_client_seq = tls_client_seq + 1
    total: uint64 = 5 + record_len
    sent: int64 = tcp_send(tcp_slot,
                           cast[Ptr[uint8]](&tls_tx_buf[0]), total)
    if sent < cast[int64](total):
        return -1
    return 0


def _tls_verify_server_finished(verify_body: Ptr[uint8],
                                body_len: uint64,
                                th_before: Ptr[uint8]) -> int32:
    # Verify the server's Finished message body against the transcript
    # hash computed as of EncryptedExtensions..CertVerify (i.e. NOT
    # including the Finished message itself).
    #   server_finished_key = HKDF-Expand-Label(server_hs_secret,
    #                                            "finished", "", 32)
    #   expected = HMAC(server_finished_key, th_before)
    if body_len != 32:
        return -1
    label_finished: Ptr[uint8] = "finished"
    sf_key: Array[32, uint8]
    _tls_hkdf_expand_label(cast[Ptr[uint8]](&sf_key[0]), 32,
                           cast[Ptr[uint8]](&tls_server_hs_secret[0]),
                           label_finished, 8,
                           cast[Ptr[uint8]](0), 0)
    expected: Array[32, uint8]
    _tls_hmac_sha256(cast[Ptr[uint8]](&expected[0]),
                     cast[Ptr[uint8]](&sf_key[0]), 32,
                     th_before, 32)
    return _tls_memcmp(cast[Ptr[uint8]](&expected[0]),
                       verify_body, 32)


# Alert level + description constants from RFC 8446 §6.
TLS_ALERT_LEVEL_FATAL:      uint8 = 2
TLS_ALERT_BAD_CERTIFICATE:  uint8 = 42
TLS_ALERT_CERT_UNKNOWN:     uint8 = 46


def _tls_send_alert_under_hs(tcp_slot: int32, desc: uint8) -> int32:
    # Send a fatal AEAD-encrypted alert under the server-handshake-secret
    # direction's CLIENT key (post-ServerHello, pre-Finished window).
    # Inner plaintext = level + desc + inner-content-type (TLS_CT_ALERT).
    # On any wire error we still return -1, but the cert-validation
    # caller's plan is to tear the connection down regardless, so the
    # alert is best-effort: get the bytes onto the wire so a wireshark
    # trace shows WHY we hung up.
    inner: Array[8, uint8]
    inner[0] = TLS_ALERT_LEVEL_FATAL
    inner[1] = desc
    inner[2] = TLS_CT_ALERT
    inner_len: uint64 = 3
    record_len: uint64 = inner_len + TLS_AEAD_TAG
    tls_tx_buf[0] = TLS_CT_APPLICATION
    tls_tx_buf[1] = 0x03
    tls_tx_buf[2] = 0x03
    tls_tx_buf[3] = cast[uint8]((record_len >> 8) & 0xFF)
    tls_tx_buf[4] = cast[uint8](record_len & 0xFF)
    nonce: Array[12, uint8]
    _tls_compute_nonce(tls_client_seq,
                       cast[Ptr[uint8]](&tls_client_hs_iv[0]),
                       cast[Ptr[uint8]](&nonce[0]))
    _tls_aead_seal(cast[Ptr[uint8]](&tls_client_hs_key[0]),
                   cast[Ptr[uint8]](&nonce[0]),
                   cast[Ptr[uint8]](&tls_tx_buf[0]), 5,
                   cast[Ptr[uint8]](&inner[0]), inner_len,
                   cast[Ptr[uint8]](&tls_tx_buf[5]),
                   cast[Ptr[uint8]](&tls_tx_buf[5 + inner_len]))
    tls_client_seq = tls_client_seq + 1
    total: uint64 = 5 + record_len
    sent: int64 = tcp_send(tcp_slot, cast[Ptr[uint8]](&tls_tx_buf[0]),
                           total)
    if sent < cast[int64](total):
        return -1
    return 0


# -- V5.1 CertificateVerify helpers ----------------------------------------
#
# RFC 8446 §4.4.3 says the signed input is exactly:
#
#   64 octets of 0x20 (ASCII space)
#       || "TLS 1.3, server CertificateVerify"   (33 ASCII bytes)
#       || 0x00                                  (1 separator byte)
#       || Transcript-Hash(Handshake Context, Certificate)  (32 bytes)
#
# Total 130 bytes for SHA-256-bound suites. We pre-bake the fixed
# 98-byte prefix once (the 64 spaces + label + NUL) and stamp the
# transcript snapshot into the trailing 32 bytes on each verify.

def _tls_cv_prefix_init():
    # Lazy one-shot — runs the first time we get to a CertificateVerify
    # message. The cost is 130 bytes of BSS plus a single memset+memcpy
    # at startup, both of which are negligible relative to the per-
    # handshake rsa_pss_verify call.
    if _tls_cv_prefix_inited != 0:
        return
    _tls_cv_prefix_inited = 1
    i: uint64 = 0
    while i < 64:
        _tls_cv_signed_buf[i] = 0x20      # ASCII space
        i = i + 1
    # ASCII for "TLS 1.3, server CertificateVerify" — 33 bytes. We
    # encode byte-by-byte (Adder lacks byte-literal-string fill, see
    # memory/feedback_compiler_quirks.md; printf-style "_init_*()"
    # runtime-fill is the stable pattern).
    _tls_cv_signed_buf[64]  = 0x54   # T
    _tls_cv_signed_buf[65]  = 0x4C   # L
    _tls_cv_signed_buf[66]  = 0x53   # S
    _tls_cv_signed_buf[67]  = 0x20   # ' '
    _tls_cv_signed_buf[68]  = 0x31   # 1
    _tls_cv_signed_buf[69]  = 0x2E   # .
    _tls_cv_signed_buf[70]  = 0x33   # 3
    _tls_cv_signed_buf[71]  = 0x2C   # ,
    _tls_cv_signed_buf[72]  = 0x20   # ' '
    _tls_cv_signed_buf[73]  = 0x73   # s
    _tls_cv_signed_buf[74]  = 0x65   # e
    _tls_cv_signed_buf[75]  = 0x72   # r
    _tls_cv_signed_buf[76]  = 0x76   # v
    _tls_cv_signed_buf[77]  = 0x65   # e
    _tls_cv_signed_buf[78]  = 0x72   # r
    _tls_cv_signed_buf[79]  = 0x20   # ' '
    _tls_cv_signed_buf[80]  = 0x43   # C
    _tls_cv_signed_buf[81]  = 0x65   # e
    _tls_cv_signed_buf[82]  = 0x72   # r
    _tls_cv_signed_buf[83]  = 0x74   # t
    _tls_cv_signed_buf[84]  = 0x69   # i
    _tls_cv_signed_buf[85]  = 0x66   # f
    _tls_cv_signed_buf[86]  = 0x69   # i
    _tls_cv_signed_buf[87]  = 0x63   # c
    _tls_cv_signed_buf[88]  = 0x61   # a
    _tls_cv_signed_buf[89]  = 0x74   # t
    _tls_cv_signed_buf[90]  = 0x65   # e
    _tls_cv_signed_buf[91]  = 0x56   # V
    _tls_cv_signed_buf[92]  = 0x65   # e
    _tls_cv_signed_buf[93]  = 0x72   # r
    _tls_cv_signed_buf[94]  = 0x69   # i
    _tls_cv_signed_buf[95]  = 0x66   # f
    _tls_cv_signed_buf[96]  = 0x79   # y
    _tls_cv_signed_buf[97]  = 0x00   # NUL separator
    # The trailing 32 bytes (transcript hash) are filled per-handshake
    # in _tls_verify_cert_verify; leave them zero here.
    i = 98
    while i < TLS_CV_CONTEXT_LEN:
        _tls_cv_signed_buf[i] = 0
        i = i + 1


def _tls_verify_cert_verify(sig_alg: uint16,
                             sig_bytes: Ptr[uint8], sig_len: uint64,
                             leaf_cert: Ptr[uint8], leaf_len: uint64,
                             th_snapshot: Ptr[uint8]) -> int32:
    # Verify the server's CertificateVerify signature per RFC 8446
    # §4.4.3 against the LEAF certificate's public key. Returns 1 on
    # success, 0 on a structural verify failure (bad signature), -1 on
    # malformed input or an unsupported signature algorithm.
    #
    # The leaf cert is re-parsed here rather than reusing chain.ad's
    # leaf_scratch — the chain walker overwrites that slot whenever the
    # caller-supplied chain has >1 element, and we want this verify to
    # be self-contained.
    _tls_cv_prefix_init()
    # Stamp the transcript hash into the trailing 32 bytes.
    i: uint64 = 0
    while i < 32:
        _tls_cv_signed_buf[98 + i] = th_snapshot[i]
        i = i + 1

    # Re-parse the leaf cert to pull out its SPKI bytes. The caller
    # passes a stable copy (not _tls_chain_ptrs[0]) because the original
    # plaintext gets overwritten on the next AEAD record.
    pr: int32 = x509_parse(leaf_cert, leaf_len, &_tls_leaf_scratch)
    if pr != 0:
        printk0("[tls] CertificateVerify: leaf re-parse failed\n")
        return -1
    pk_ptr: Ptr[uint8] = cast[Ptr[uint8]](&_tls_leaf_scratch.pubkey_bytes[0])
    pk_len: uint64    = _tls_leaf_scratch.pubkey_bytes_len

    if sig_alg == TLS_SIG_RSA_PSS_RSAE_SHA256:
        rc: int32 = rsa_parse_pubkey(pk_ptr, pk_len, &_tls_leaf_rsa)
        if rc != 0:
            printk0("[tls] CertificateVerify: leaf RSA pubkey parse failed\n")
            return -1
        return rsa_pss_verify(&_tls_leaf_rsa,
                              cast[Ptr[uint8]](&_tls_cv_signed_buf[0]),
                              TLS_CV_CONTEXT_LEN,
                              sig_bytes, sig_len)
    if sig_alg == TLS_SIG_ECDSA_SECP256R1:
        rc2: int32 = ecdsa_parse_pubkey(pk_ptr, pk_len, &_tls_leaf_ecdsa)
        if rc2 != 0:
            printk0("[tls] CertificateVerify: leaf ECDSA pubkey parse failed\n")
            return -1
        return ecdsa_p256_verify(&_tls_leaf_ecdsa,
                                 cast[Ptr[uint8]](&_tls_cv_signed_buf[0]),
                                 TLS_CV_CONTEXT_LEN,
                                 sig_bytes, sig_len)
    # Anything else (Ed25519, RSA-PKCS#1 v1.5, ECDSA with non-P256, ...)
    # is treated as malformed for V5.1. V6 may wire in PKCS#1 v1.5.
    return -1


def _tls_drive_post_sh(tcp_slot: int32) -> int32:
    # Run the post-ServerHello half of the handshake to completion:
    #   1. Skip the optional ChangeCipherSpec record (middlebox compat).
    #   2. Loop reading encrypted handshake records under the server
    #      handshake traffic key. Inside each decrypted record, walk
    #      one-or-more handshake messages (type+length+body):
    #         EncryptedExtensions     -> feed into transcript
    #         Certificate             -> parse list, validate chain
    #                                    (V5), feed into transcript,
    #                                    snapshot transcript hash for
    #                                    the CertificateVerify check
    #         CertificateVerify       -> verify signature over the
    #                                    Certificate-snapshot transcript
    #                                    against the leaf pubkey (V5.1,
    #                                    RFC 8446 §4.4.3), then feed
    #                                    into transcript
    #         Finished                -> HMAC-verify against the
    #                                    transcript hash as-of-CertVerify,
    #                                    then feed Finished bytes in.
    #   3. Derive application traffic keys (transcript hash now includes
    #      the server's Finished).
    #   4. Send our client Finished.
    #
    # Returns 0 on success, -1 on any failure. The peer's TCP slot is
    # left open so the caller can switch to tls_send/tls_recv.
    saw_server_finished: int32 = 0
    th_before_sf: Array[32, uint8]
    # Reset the per-handshake CertificateVerify-snapshot guard. A
    # CertificateVerify message arriving before its matching Certificate
    # is a protocol error; this guard surfaces it as an explicit abort
    # rather than reading stale bytes from a previous handshake.
    _tls_th_after_cert_set = 0
    # V5.2: stitch handshake messages across record boundaries
    # (RFC 8446 §5.1). Each AEAD record's inner plaintext carries
    # 0..N handshake fragments; a single handshake message (esp.
    # Certificate when chained with intermediates, e.g. LE R3 +
    # leaf) easily exceeds one record's ~1.4 KB-to-16 KiB AEAD
    # plaintext budget. The pre-V5.2 parser walked each decrypted
    # record in isolation and tripped "truncated handshake header"
    # the moment the 4-byte msg header straddled a record edge.
    # Now we APPEND each record's handshake bytes to tls_hs_buf,
    # then drain full messages from the front, shifting any
    # partial tail back to offset 0 so the next record's append
    # picks up cleanly. tls_pt_buf is reused on every decrypt;
    # tls_hs_buf is stable until tls_init() / end of handshake,
    # so chain ptrs and the leaf-copy step now source from it.
    tls_hs_len = 0
    while saw_server_finished == 0:
        rec_total_signed: int64 = _tls_read_record(tcp_slot, 400)
        if rec_total_signed <= 0:
            printk0("[tls] post-SH: tcp recv timed out / EOF\n")
            return -1
        rec_total: uint64 = cast[uint64](rec_total_signed)
        rt: uint8 = tls_rx_buf[0]
        if rt == TLS_CT_CHANGE_CIPHER:
            printk0("[tls] skipped legacy ChangeCipherSpec\n")
            continue
        if rt == TLS_CT_ALERT:
            # Plaintext alert (before keys are switched the server
            # might send a fatal alert in cleartext).
            printk0("[tls] received plaintext alert; aborting\n")
            return -1
        if rt != TLS_CT_APPLICATION:
            printk1("[tls] post-SH unexpected record type %d\n",
                    cast[uint64](rt))
            return -1
        pt_signed: int64 = _tls_decrypt_record(rec_total, 1)
        if pt_signed < 0:
            printk0("[tls] AEAD decrypt FAILED (key schedule mismatch?)\n")
            return -1
        pt_len: uint64 = cast[uint64](pt_signed)
        real_type: uint8 = 0
        real_type_ptr: Ptr[uint8] = cast[Ptr[uint8]](&real_type)
        inner_signed: int64 = _tls_strip_inner_padding(pt_len,
                                                        real_type_ptr)
        if inner_signed < 0:
            return -1
        inner_len: uint64 = cast[uint64](inner_signed)
        if real_type == TLS_CT_ALERT:
            printk0("[tls] post-SH inner alert; aborting\n")
            return -1
        if real_type != TLS_CT_HANDSHAKE:
            printk1("[tls] post-SH inner type=%d (want handshake)\n",
                    cast[uint64](real_type))
            return -1
        # Append this record's handshake plaintext to tls_hs_buf.
        # Cap at 16 KiB (RFC 8446 §5.1 max single handshake msg).
        if tls_hs_len + inner_len > 16384:
            printk0("[tls] handshake reassembly buffer overflow (>16 KiB)\n")
            _tls_send_alert_under_hs(tcp_slot,
                                     TLS_ALERT_DECRYPT_ERROR)
            return -1
        _tls_memcpy(cast[Ptr[uint8]](&tls_hs_buf[tls_hs_len]),
                    cast[Ptr[uint8]](&tls_pt_buf[0]), inner_len)
        tls_hs_len = tls_hs_len + inner_len
        # Drain as many complete handshake messages as the buffer
        # currently holds. A partial trailing message (header
        # short OR body short) ends the inner loop and we go read
        # another record; on the next pass we'll append + retry.
        while saw_server_finished == 0:
            if tls_hs_len < 4:
                # Header not yet fully buffered - need more bytes.
                break
            mpos: uint64 = 0
            ht: uint8 = tls_hs_buf[mpos]
            mlen: uint64 = (cast[uint64](tls_hs_buf[mpos + 1]) << 16) \
                | (cast[uint64](tls_hs_buf[mpos + 2]) << 8) \
                | cast[uint64](tls_hs_buf[mpos + 3])
            if 4 + mlen > tls_hs_len:
                # Body not yet fully buffered - need more bytes.
                # NB: this is the V5.2 fix - the pre-stitch parser
                # would have errored out here with "truncated
                # handshake header" / "overruns plaintext"; we
                # just wait for the next record.
                break
            if 4 + mlen > 16384:
                printk0("[tls] handshake message exceeds 16 KiB cap\n")
                _tls_send_alert_under_hs(tcp_slot,
                                         TLS_ALERT_DECRYPT_ERROR)
                return -1
            if ht == TLS_HS_ENCRYPTED_EXT:
                printk1("[tls] EncryptedExtensions (%d bytes)\n", mlen)
                # Update transcript hash with the whole message
                # (type + 3-byte length + body) per RFC 8446 §4.4.1.
                _tls_tr_update(
                    cast[Ptr[uint8]](&tls_hs_buf[mpos]), 4 + mlen)
            elif ht == TLS_HS_CERTIFICATE:
                # Parse the Certificate message into (ptr, len) chain
                # entries and validate IMMEDIATELY. Wire shape
                # (RFC 8446 §4.4.2):
                #   opaque certificate_request_context<0..255>;
                #   CertificateEntry certificate_list<0..2^24-1>;
                # Each CertificateEntry: 3-byte cert_data length + cert
                # bytes + 2-byte extensions length + extensions.
                #
                # V5: real validation. V5.2: chain pointers now index
                # into tls_hs_buf (the multi-record reassembly buffer),
                # which is stable across the rest of the handshake
                # dispatch loop. The bytes remain live until we shift
                # this message off the front at the end of the
                # iteration (which happens AFTER validate_cert_chain +
                # the leaf-copy step below).
                _tls_chain_count = 0
                cpos: uint64 = mpos + 4
                parse_ok: int32 = 0
                if cpos + 1 <= mpos + 4 + mlen:
                    ctx_len: uint64 = cast[uint64](tls_hs_buf[cpos])
                    cpos = cpos + 1 + ctx_len
                    if cpos + 3 <= mpos + 4 + mlen:
                        list_len: uint64 = \
                            (cast[uint64](tls_hs_buf[cpos]) << 16) \
                            | (cast[uint64](tls_hs_buf[cpos + 1]) << 8) \
                            | cast[uint64](tls_hs_buf[cpos + 2])
                        cpos = cpos + 3
                        list_end: uint64 = cpos + list_len
                        if list_end <= mpos + 4 + mlen:
                            parse_ok = 1
                            while cpos + 3 <= list_end:
                                clen: uint64 = \
                                    (cast[uint64](tls_hs_buf[cpos]) << 16) \
                                    | (cast[uint64](tls_hs_buf[cpos + 1]) << 8) \
                                    | cast[uint64](tls_hs_buf[cpos + 2])
                                cpos = cpos + 3
                                # Record (ptr,len) — pointer into tls_hs_buf.
                                if _tls_chain_count < 8:
                                    _tls_chain_ptrs[_tls_chain_count] = \
                                        cast[Ptr[uint8]](&tls_hs_buf[cpos])
                                    _tls_chain_lens[_tls_chain_count] = clen
                                    _tls_chain_count = _tls_chain_count + 1
                                else:
                                    # Server sent > 8 certs — reject as
                                    # chain too deep (V4's MAX_CHAIN_DEPTH).
                                    parse_ok = 0
                                cpos = cpos + clen
                                if cpos + 2 > list_end:
                                    parse_ok = 0
                                    break
                                ext_len: uint64 = \
                                    (cast[uint64](tls_hs_buf[cpos]) << 8) \
                                    | cast[uint64](tls_hs_buf[cpos + 1])
                                cpos = cpos + 2 + ext_len
                printk1("[tls] Certificate: %d certs in chain\n",
                        cast[uint64](_tls_chain_count))
                # Feed the message into the transcript hash regardless of
                # validation outcome — the server-Finished HMAC computes
                # against the transcript up to & including this message,
                # so even if we're about to alert+abort we want the
                # transcript state consistent (the alert isn't gated on
                # Finished verifying).
                _tls_tr_update(
                    cast[Ptr[uint8]](&tls_hs_buf[mpos]), 4 + mlen)
                if parse_ok == 0:
                    printk0("[tls] cert chain rejected: malformed Certificate message\n")
                    _tls_send_alert_under_hs(tcp_slot,
                                             TLS_ALERT_BAD_CERTIFICATE)
                    return -1
                if _tls_chain_count <= 0:
                    printk0("[tls] cert chain rejected: empty\n")
                    _tls_send_alert_under_hs(tcp_slot,
                                             TLS_ALERT_BAD_CERTIFICATE)
                    return -1
                now_unix: uint64 = _tls_now_unix()
                vrc_chain: int32 = validate_cert_chain(
                    cast[Ptr[Ptr[uint8]]](&_tls_chain_ptrs[0]),
                    cast[Ptr[uint64]](&_tls_chain_lens[0]),
                    _tls_chain_count,
                    cast[Ptr[char]](_tls_sni_host_raw),
                    now_unix)
                if vrc_chain == 1:
                    printk0("[tls] cert chain validated\n")
                elif vrc_chain == 0:
                    printk0("[tls] cert chain rejected: untrusted / hostname / time\n")
                    _tls_send_alert_under_hs(tcp_slot,
                                             TLS_ALERT_CERT_UNKNOWN)
                    return -1
                else:
                    printk0("[tls] cert chain rejected: malformed DER / unsupported sig alg\n")
                    _tls_send_alert_under_hs(tcp_slot,
                                             TLS_ALERT_BAD_CERTIFICATE)
                    return -1
                # V5.1: stash the LEAF cert bytes into a stable BSS slot.
                # V5.2: _tls_chain_ptrs[0] now points into tls_hs_buf,
                # which survives across record reads — but it does NOT
                # survive the end-of-iteration shift that drops this
                # Certificate message off the front of the buffer. Copy
                # now, before mpos = 0 / tls_hs_buf gets reshuffled.
                leaf_src_len: uint64 = _tls_chain_lens[0]
                if leaf_src_len == 0:
                    printk0("[tls] leaf cert empty after chain validate\n")
                    _tls_send_alert_under_hs(tcp_slot,
                                             TLS_ALERT_BAD_CERTIFICATE)
                    return -1
                if leaf_src_len > TLS_LEAF_COPY_MAX:
                    printk1("[tls] leaf cert too big (%d bytes) to copy for CV\n",
                            leaf_src_len)
                    _tls_send_alert_under_hs(tcp_slot,
                                             TLS_ALERT_BAD_CERTIFICATE)
                    return -1
                leaf_src_ptr: Ptr[uint8] = _tls_chain_ptrs[0]
                _tls_memcpy(cast[Ptr[uint8]](&_tls_leaf_copy_buf[0]),
                            leaf_src_ptr, leaf_src_len)
                _tls_leaf_copy_len = leaf_src_len
                # V5.1: snapshot transcript hash AS OF the Certificate
                # message (i.e. AFTER it has been streamed into the
                # transcript, BEFORE the CertificateVerify body is fed
                # in). The server signed exactly this hash; the matching
                # CertificateVerify branch reads it back out.
                _tls_sha256_snapshot_into(
                    cast[Ptr[uint8]](&_tls_th_after_cert[0]))
                _tls_th_after_cert_set = 1
            elif ht == TLS_HS_CERT_VERIFY:
                # Wire shape (RFC 8446 §4.4.3):
                #   uint16 SignatureScheme algorithm;
                #   opaque signature<0..2^16-1>;
                # i.e. body = 2 bytes sig_alg + 2 bytes sig_len + sig.
                # Verify the signature against the LEAF pubkey over the
                # canonical signed-buffer with the transcript snapshot
                # taken right after Certificate.
                if _tls_th_after_cert_set == 0:
                    printk0("[tls] CertificateVerify before Certificate — protocol abort\n")
                    _tls_send_alert_under_hs(tcp_slot,
                                             TLS_ALERT_DECRYPT_ERROR)
                    return -1
                if mlen < 4:
                    printk0("[tls] CertificateVerify truncated header\n")
                    _tls_send_alert_under_hs(tcp_slot,
                                             TLS_ALERT_DECRYPT_ERROR)
                    return -1
                cv_sig_alg: uint16 = \
                    (cast[uint16](tls_hs_buf[mpos + 4]) << 8) \
                    | cast[uint16](tls_hs_buf[mpos + 5])
                cv_sig_len: uint64 = \
                    (cast[uint64](tls_hs_buf[mpos + 6]) << 8) \
                    | cast[uint64](tls_hs_buf[mpos + 7])
                if 4 + cv_sig_len > mlen:
                    printk0("[tls] CertificateVerify sig length overruns message\n")
                    _tls_send_alert_under_hs(tcp_slot,
                                             TLS_ALERT_DECRYPT_ERROR)
                    return -1
                cv_sig_ptr: Ptr[uint8] = \
                    cast[Ptr[uint8]](&tls_hs_buf[mpos + 8])
                cv_rc: int32 = _tls_verify_cert_verify(
                    cv_sig_alg,
                    cv_sig_ptr, cv_sig_len,
                    cast[Ptr[uint8]](&_tls_leaf_copy_buf[0]),
                    _tls_leaf_copy_len,
                    cast[Ptr[uint8]](&_tls_th_after_cert[0]))
                if cv_rc == 1:
                    if cv_sig_alg == TLS_SIG_RSA_PSS_RSAE_SHA256:
                        printk0("[tls] CertificateVerify ok (rsa_pss)\n")
                    elif cv_sig_alg == TLS_SIG_ECDSA_SECP256R1:
                        printk0("[tls] CertificateVerify ok (ecdsa_p256)\n")
                    else:
                        printk1("[tls] CertificateVerify ok (sig_alg=0x%x)\n",
                                cast[uint64](cv_sig_alg))
                else:
                    # cv_rc == 0 (well-formed but wrong signature) and
                    # cv_rc == -1 (malformed / unsupported algorithm)
                    # both collapse into a single failure marker: the
                    # peer doesn't get to learn which path tripped.
                    printk1("[tls] CertificateVerify FAILED — handshake abort (sig_alg=0x%x)\n",
                            cast[uint64](cv_sig_alg))
                    _tls_send_alert_under_hs(tcp_slot,
                                             TLS_ALERT_DECRYPT_ERROR)
                    return -1
                _tls_tr_update(
                    cast[Ptr[uint8]](&tls_hs_buf[mpos]), 4 + mlen)
            elif ht == TLS_HS_FINISHED:
                # Snapshot transcript hash BEFORE feeding Finished —
                # that's what the server HMAC'd.
                _tls_sha256_snapshot_into(
                    cast[Ptr[uint8]](&th_before_sf[0]))
                vrc: int32 = _tls_verify_server_finished(
                    cast[Ptr[uint8]](&tls_hs_buf[mpos + 4]), mlen,
                    cast[Ptr[uint8]](&th_before_sf[0]))
                if vrc != 0:
                    printk0("[tls] server Finished HMAC mismatch — abort\n")
                    return -1
                printk0("[tls] server Finished verified OK\n")
                _tls_tr_update(
                    cast[Ptr[uint8]](&tls_hs_buf[mpos]), 4 + mlen)
                saw_server_finished = 1
            else:
                printk1("[tls] post-SH unknown handshake type %d\n",
                        cast[uint64](ht))
                return -1
            # Shift this consumed message off the front of tls_hs_buf;
            # any unread tail (bytes for the next message, possibly
            # only a partial fragment) moves to offset 0 so the outer
            # loop's per-record append picks up where we left off.
            consumed: uint64 = mpos + 4 + mlen
            remaining: uint64 = tls_hs_len - consumed
            if remaining > 0:
                _tls_memcpy(cast[Ptr[uint8]](&tls_hs_buf[0]),
                            cast[Ptr[uint8]](&tls_hs_buf[consumed]),
                            remaining)
            tls_hs_len = remaining
    # Compute application traffic keys (transcript hash now includes
    # the server Finished message).
    _tls_compute_app_keys()
    printk0("[tls] application traffic keys derived\n")
    # Send our Finished under the handshake traffic key.
    if _tls_send_client_finished(tcp_slot) != 0:
        printk0("[tls] client Finished send failed\n")
        return -1
    printk0("[tls] client Finished sent\n")
    # Switch sequence numbers and mark the connection live. We DO send
    # a dummy ChangeCipherSpec record from some clients for middlebox
    # compatibility; we omit it here — RFC 8446 §D.4 leaves that
    # optional, and the SLIRP path / Let's Encrypt origins accept the
    # straight ClientHello -> ClientFinished sequence we emit.
    tls_client_seq = 0          # reset for app-key sequence
    tls_server_seq = 0
    tls_active = 1
    printk0("[tls] handshake COMPLETE (app keys live)\n")
    return 0


def tls_send(slot: int32, buf: Ptr[uint8], length: uint64) -> int64:
    # Encrypt + frame `length` bytes of application data, then tcp_send.
    # `slot` must be the same TCP slot the active TLS handshake ran on
    # (single-connection state in V0). Returns bytes encrypted on
    # success (== length) or -1 on error.
    if tls_active != 1:
        return -1
    if slot < 0:
        return -1
    if slot != tls_tcp_slot:
        return -1
    # Inner plaintext = `buf` || 0x17 (TLSInnerPlaintext.type for
    # application_data). No zero padding (V0 — pad is optional).
    inner_len: uint64 = length + 1
    if inner_len + TLS_AEAD_TAG + TLS_REC_HEADER > 2048:
        return -1
    pt_buf: Array[2048, uint8]
    _tls_memcpy(cast[Ptr[uint8]](&pt_buf[0]), buf, length)
    pt_buf[length] = TLS_CT_APPLICATION
    record_len: uint64 = inner_len + TLS_AEAD_TAG
    tls_tx_buf[0] = TLS_CT_APPLICATION
    tls_tx_buf[1] = 0x03
    tls_tx_buf[2] = 0x03
    tls_tx_buf[3] = cast[uint8]((record_len >> 8) & 0xFF)
    tls_tx_buf[4] = cast[uint8](record_len & 0xFF)
    nonce: Array[12, uint8]
    _tls_compute_nonce(tls_client_seq,
                       cast[Ptr[uint8]](&tls_client_ap_iv[0]),
                       cast[Ptr[uint8]](&nonce[0]))
    _tls_aead_seal(cast[Ptr[uint8]](&tls_client_ap_key[0]),
                   cast[Ptr[uint8]](&nonce[0]),
                   cast[Ptr[uint8]](&tls_tx_buf[0]), 5,
                   cast[Ptr[uint8]](&pt_buf[0]), inner_len,
                   cast[Ptr[uint8]](&tls_tx_buf[5]),
                   cast[Ptr[uint8]](&tls_tx_buf[5 + inner_len]))
    tls_client_seq = tls_client_seq + 1
    total: uint64 = 5 + record_len
    sent: int64 = tcp_send(slot, cast[Ptr[uint8]](&tls_tx_buf[0]), total)
    if sent < cast[int64](total):
        return -1
    return cast[int64](length)


def tls_recv(slot: int32, buf: Ptr[uint8], max_len: uint64,
             timeout_ms: uint64) -> int64:
    # Pull the next decrypted application_data record off the wire and
    # copy up to `max_len` plaintext bytes into `buf`. Returns the
    # plaintext byte count (excluding the trailing TLS inner content
    # type) on success; 0 on clean EOF / timeout-with-no-bytes; -1 on
    # hard failure (decrypt error or unexpected record shape).
    #
    # Post-handshake NewSessionTicket records (handshake type 4) are
    # transparent: we decrypt + ignore them and re-read.
    if tls_active != 1:
        return -1
    if slot < 0:
        return -1
    if slot != tls_tcp_slot:
        return -1
    while True:
        rec_total_signed: int64 = _tls_read_record(slot, timeout_ms)
        if rec_total_signed == 0:
            return 0
        if rec_total_signed < 0:
            return -1
        rec_total: uint64 = cast[uint64](rec_total_signed)
        rt: uint8 = tls_rx_buf[0]
        if rt == TLS_CT_CHANGE_CIPHER:
            # Late CCS from a chatty server; skip.
            continue
        if rt != TLS_CT_APPLICATION:
            printk1("[tls] recv unexpected record type %d\n",
                    cast[uint64](rt))
            return -1
        pt_signed: int64 = _tls_decrypt_record(rec_total, 0)
        if pt_signed < 0:
            printk0("[tls] app-data AEAD decrypt FAILED\n")
            return -1
        pt_len: uint64 = cast[uint64](pt_signed)
        real_type: uint8 = 0
        real_type_ptr: Ptr[uint8] = cast[Ptr[uint8]](&real_type)
        inner_signed: int64 = _tls_strip_inner_padding(pt_len,
                                                        real_type_ptr)
        if inner_signed < 0:
            return -1
        inner_len: uint64 = cast[uint64](inner_signed)
        if real_type == TLS_CT_HANDSHAKE:
            # NewSessionTicket and other post-handshake messages.
            # Plaintext starts with handshake type byte; log + skip.
            if inner_len >= 1:
                ht: uint8 = tls_pt_buf[0]
                if ht == TLS_HS_NEW_SESSION_TICKET:
                    printk0("[tls] skipped post-handshake NewSessionTicket\n")
                else:
                    printk1("[tls] skipped post-handshake hs type %d\n",
                            cast[uint64](ht))
            continue
        if real_type == TLS_CT_ALERT:
            # close_notify is alert level=warning, desc=0 → treat as EOF.
            if inner_len >= 2:
                lvl: uint8 = tls_pt_buf[0]
                desc: uint8 = tls_pt_buf[1]
                if desc == 0:
                    printk0("[tls] received close_notify\n")
                    return 0
                printk2("[tls] received alert level=%d desc=%d\n",
                        cast[uint64](lvl), cast[uint64](desc))
            return -1
        if real_type != TLS_CT_APPLICATION:
            printk1("[tls] recv inner type=%d ignored\n",
                    cast[uint64](real_type))
            continue
        # Application data: copy up to max_len plaintext bytes.
        n: uint64 = inner_len
        if n > max_len:
            n = max_len
        i: uint64 = 0
        while i < n:
            buf[i] = tls_pt_buf[i]
            i = i + 1
        return cast[int64](n)
    return -1


def tls_close():
    # NB: we deliberately DON'T call tcp_close here. The active-close
    # FIN/ACK/FIN/ACK exchange ran fine on the TCP smoke path, but
    # post-TLS the peer's FIN sometimes never arrives within tcp_close's
    # 1-second polling budget (Python's SSLContext server keeps the
    # socket lingering even after `c.close()`), and the polling loop
    # in tcp.ad never observes the TIME_WAIT transition. For a one-
    # shot HTTPS GET the slot leak is acceptable — the next handshake
    # would just reuse a fresh slot. A proper send-close_notify-then-
    # tcp_close path is V1 follow-up alongside cert validation.
    tls_tcp_slot = -1
    tls_active = 0
    tls_rxr_len = 0
