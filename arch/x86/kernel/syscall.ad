# arch/x86/kernel/syscall.ad
#
# Mirrors arch/x86/kernel/cpu/common.c::syscall_init() and the
# arch/x86/entry/common.c::do_syscall_64() handler in Linux at minimal
# scale: configures the SYSCALL/SYSRET MSRs once at boot, and provides
# the C-side dispatch that the asm stub (syscall_64.S) tail-calls.
#
# MSRs touched:
#
#   IA32_EFER   0xC0000080   bit 0 SCE  - enable SYSCALL/SYSRET at all
#   IA32_STAR   0xC0000081   bits 47:32 SYSCALL CS:SS base
#                            bits 63:48 SYSRET CS:SS base
#   IA32_LSTAR  0xC0000082   64-bit SYSCALL entry RIP
#   IA32_FMASK  0xC0000084   RFLAGS bits to clear on SYSCALL entry
#
# STAR encoding chosen for our boot GDT:
#   SYSCALL CS = 0x08 (kernel code), SS = 0x10 (kernel data)
#   SYSRET  CS = 0x20 + RPL(3) = 0x23 (user code)
#           SS = 0x18 + RPL(3) = 0x1B (user data)
# That means STAR[47:32] = 0x08 and STAR[63:48] = 0x10 — verified by
# the SYSRET hardware-imposed offsets (CS = base+16, SS = base+8).
#
# FMASK = 0x0200 (only IF) so SYSCALL entry runs with interrupts off.
# Linux additionally clears DF and a few others; we'll add as needed.

from drivers.tty.serial.early_8250 import early_putc
from kernel.printk.printk import printk0, printk1, printk2
from arch.x86.kernel.time import get_jiffies
from kernel.sched.core import (
    TaskStruct, current_task,
    create_user_task, create_user_task_argv, create_user_thread,
    task_exit_current,
    current_task_pid, task_lookup_by_pid, task_state, task_exit_code,
    task_pid_at, task_reap, yield_to_others, STATE_EXITED,
    get_task_term_sig, copy_sig_state_to_child,
    dup_fd_to_child,
    signal_post, signal_check_and_handle, signal_deliver_on_return,
    get_cwd_buf, set_task_cwd, current_idx_get,
    set_linux_userspace_mode,
    task_vfork_done, set_task_vfork_done,
    set_task_fs_base, set_task_clear_child_tid,
    task_pml4, set_task_cr3,
    set_current_errstr,
    # Per-process address space (fork). do_execve records the loaded
    # image span + user-stack region; do_clone copies them into the
    # child's private pages.
    set_task_image_range, set_task_ustack_range,
    task_image_lo, task_image_hi, task_ustack_lo, task_ustack_sz,
    task_brk_base, task_brk_end, task_brk_max, set_task_brk_range,
    # V4: srv_open needs a Ptr[TaskStruct] for the poster's slot so
    # vfs_srv_dup_into_current can copy_fd_entry from the poster's
    # table to the caller's. task_struct_at returns 0 (NULL) for
    # out-of-range slot indices — the syscall body bails with errstr
    # "srv: kernel-only" in that case.
    task_struct_at,
    # SYS_SPAWN namespace inheritance — task_pgrp / set_task_pgrp
    # read/write the per-task Pgrp pointer. sys_spawn has two cases:
    #  - SPAWN_STDIO_NS (the shell spawning a command): the child gets
    #    its OWN Pgrp — a COW copy of the caller's ambient namespace
    #    (HAMSH §7/§9), so it has a private /fd-name table (pgrp_clone).
    #  - legacy path (apt/dpkg/nsrun/sshd, real integer fds): the child
    #    shares the parent's Pgrp so a process spawned inside an
    #    nsrun/distrorun distro-shape namespace sees the mounted
    #    distrofs trees (pgrp_ref_inc bumps the share refcount).
    task_pgrp, set_task_pgrp,
)
from fs.vfs import (
    vfs_open, vfs_open_write, vfs_pipe, vfs_read, vfs_read_nb, vfs_write,
    vfs_close, vfs_lseek, vfs_dup, vfs_dup2, vfs_listdir,
    vfs_unlink, vfs_mkdir, vfs_fd_is_dir, vfs_fd_is_open,
    resolve_path,
    # §4: namespace-aware blob lookup — execve / spawn resolve the
    # target binary through the calling process's Pgrp mount table
    # (resolve_path's chan_resolve_prefix rewrite) so a binary launched
    # inside a distro-shaped namespace finds its image in the distro
    # tree. ns_blob_* is a verbatim lookup when no mount entry matches.
    ns_blob_ptr, ns_blob_size,
    # V4: cross-task fd dup helper. sys_srv_open hands it the
    # poster's Ptr[TaskStruct] and the poster-relative srvfd; it
    # returns a new fd in the caller's table or -errno.
    vfs_srv_dup_into_current,
    # V5: bidirectional socketpair. SYS_SOCKETPAIR (Linux number 53)
    # returns two bidirectional endpoints — the transport rio + future
    # 9P clients want instead of two unidirectional pipes.
    vfs_socketpair,
    # distrofs persistent backing: snapshot the userland distrofs 9P
    # server's RAM tables to / from a single file on the ext4 volume.
    vfs_distrofs_save, vfs_distrofs_load,
)
from fs.elf import (
    elf_load_blob, elf_last_was_linux,
    elf_last_load_base, elf_last_phoff, elf_last_phnum,
    elf_apply_last_user_mapping,
    # U42: dynamic-ELF interpreter. The kernel still receives the
    # ENTRY (user-mode RIP) from elf_load_blob — for static binaries
    # that's the app's e_entry; for dynamic binaries that's the
    # INTERPRETER's e_entry. Auxv plants AT_ENTRY = app e_entry
    # (elf_last_app_entry_user) and AT_BASE = interp base
    # (elf_last_interp_base, = 0 on the static path).
    elf_last_interp_base, elf_last_app_entry_user,
    # Per-process address space (fork): the loaded ELF image span +
    # the private-copy machinery do_clone uses to give a forked child
    # its own physical pages remapped at the same virtual addresses.
    elf_last_img_lo_get, elf_last_img_hi_get,
    vm_cow_share_all,
)
from mm.page_alloc import alloc_page, alloc_pages
# U42 follow-up: per-task VMA list. do_execve clears the outgoing
# image's mappings before ELF-loading the incoming image so the new
# program starts with a clean vma_list. Subsequent mmap() calls from
# the new image extend the list via mm/vma.ad::vma_alloc.
from mm.vma import vma_clear, vma_fork_copy
from linux_abi.loader import kmod_linux_load, kmod_linux_unload
from linux_abi.u_syscalls import (
    linux_u_syscall_dispatch,
    # U-socket: the socket(2)/connect(2) bridge bodies. They are
    # ABI-agnostic — they touch only vfs_*, usock_* and tcp_connect,
    # never Linux-task state — so the native do_syscall() arms for
    # SYS_SOCKET (41) / SYS_CONNECT (42) can call them directly,
    # giving native Adder user binaries (user/apt.ad) the same TCP
    # client path the musl Linux-ABI fixtures already use. read/write/
    # close on the resulting socket fd already work via the
    # FD_SOCKET_MARK arms in fs/vfs.ad's vfs_read/vfs_write/vfs_close.
    #
    # U-socket server side: _u_bind / _u_listen / _u_accept are wired
    # the same way — the native server arms (SYS_BIND_SOCK 49 /
    # SYS_LISTEN_SOCK 50 / SYS_ACCEPT_SOCK 43) call them directly so a
    # native Adder server binary can bind a port, listen, and accept a
    # TCP connection.
    _u_socket, _u_connect, _u_bind, _u_listen, _u_accept,
    # U-TLS: tls_connect(2) body. Takes a connected socket fd through
    # the in-kernel TLS 1.3 handshake (drivers/net/tls.ad), marks the
    # fd TLS-active, and from then on read/write/close route through
    # the TLS record layer (the FD_SOCKET_MARK arms in fs/vfs.ad).
    _u_tls_connect,
)
# U-resolve: the in-kernel DNS resolver (drivers/net/dns.ad). The
# native SYS_RESOLVE (269) arm in do_syscall() hands a userland
# hostname straight to dns_lookup so user binaries (user/apt.ad) can
# connect to a host by name. dns_lookup is the same blocking,
# virtio_net_poll-driven body init/main.ad's boot smoke and
# drivers/net/http.ad already call — so it is safe from syscall
# context (apt already does blocking TCP from a syscall the same way).
from drivers.net.dns import dns_lookup, dns_set_static_server, \
    dns_get_server
from drivers.net.ip import ip_our_ip_b, ip_gateway_b, ip_netmask_b, \
    ip_have_our_ip, ip_have_gateway, ip_have_netmask, \
    ip_cfg_source_get, ip_apply_static_addr, ip_apply_static_gw
from drivers.net.dhcp import dhcp_get_mask
# Phase B / M16.93: Plan 9-shape errstr body. Lives at
# sys/src/9/port/error.ad on disk (mirrors 9front's layout); imported
# here via the sys/src/port9 -> 9 directory alias because Adder
# identifiers must start with a letter or underscore (the literal
# directory name `9` is not a valid Python-style module-path component).
from sys.src.port9.port.error import _u_errstr
# Phase C / M16.98: rfork body lives in sys/src/9/port/sysproc.ad —
# mirrors 9front's /sys/src/9/port/sysproc.c. Imported through the
# port9 directory alias for the same identifier reason as error.ad.
from sys.src.port9.port.sysproc import do_rfork
# Phase C / M16.101: Plan 9 file-operations cluster lives in
# sys/src/9/port/sysfile.ad — mirrors 9front's /sys/src/9/port/sysfile.c.
# Imported through the port9 directory alias for the same identifier
# reason as error.ad / sysproc.ad.
from sys.src.port9.port.sysfile import (
    do_create, do_stat, do_fstat, do_remove, do_fd2path,
    do_wstat, do_fwstat,
)
# Phase C / M16.107: Plan 9 namespace primitives. Bodies in
# sys/src/9/port/syschan.ad, channel + mount-table skeleton in
# sys/src/9/port/chan.ad. Replace the M16.93 -ENOSYS stubs for
# SYS_BIND (257) / SYS_MOUNT (258) / SYS_UNMOUNT (259).
from sys.src.port9.port.syschan import (
    do_bind, do_mount, do_unmount,
    do_fdbind, do_pipechan, do_openchan,
    do_nslabel,
)
# SYS_SPAWN namespace inheritance: pgrp_current resolves the caller's
# Pgrp (collapsing the BSS-default 0 onto the root Pgrp). The
# SPAWN_STDIO_NS path uses pgrp_clone (private COW Pgrp, HAMSH §7/§9);
# the legacy path uses pgrp_ref_inc to share the parent's Pgrp. The
# child's SPAWN_STDIO_NS stdio fds 0/1/2 are FD_DEVFD_MARK — the
# Layer-2 mapping onto the names /fd/0,1,2.
from sys.src.port9.port.chan import pgrp_clone, pgrp_ref_inc, pgrp_current
from sys.src.port9.port.devfd import FD_DEVFD_MARK, devfd_bind_cons
# Phase C / M16.109: Plan 9 note (signal) primitives. Bodies live in
# sys/src/9/port/sysnote.ad — mirrors 9front's notify(2)/noted(2) shape.
# Imported through the port9 directory alias for the same identifier
# reason as error.ad / sysproc.ad above.
from sys.src.port9.port.sysnote import do_notify, do_noted
# Phase D / V4: devsrv post + structured lookup. devsrv_post_from
# records the poster's task_table slot index so sys_srv_open (276)
# can later copy_fd_entry the underlying file/pipe into the opener's
# fd table. Body lives in sys/src/9/port/devsrv.ad.
from sys.src.port9.port.devsrv import (
    devsrv_post_from, devsrv_lookup_full,
)

extern def do_execve_finish(new_rip: uint64, new_rsp: uint64,
                            argc: uint64, argv: uint64)

extern def write_msr(index: uint32, value: uint64)
extern def read_msr(index: uint32) -> uint64
extern def set_efer_sce()
extern def syscall_entry()
extern def enter_user_mode(entry: uint64, stack: uint64)
extern def user_demo_entry()
extern def local_irq_disable()
extern def memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64) -> Ptr[uint8]
extern def load_cr3(value: uint64)

IA32_STAR:  uint32 = 0xC0000081
IA32_LSTAR: uint32 = 0xC0000082
IA32_FMASK: uint32 = 0xC0000084

# Syscall numbers — kept tiny and demo-focused.
SYS_PUTC:        uint64 = 0
SYS_EXIT:        uint64 = 1
SYS_GET_JIFFIES: uint64 = 2
SYS_CLONE:       uint64 = 3                    # a0 = entry, returns new pid
SYS_GETPID:      uint64 = 4
SYS_OPEN:        uint64 = 5                    # a0 = name ptr, returns fd
SYS_READ:        uint64 = 6                    # a0=fd, a1=buf, a2=count
SYS_CLOSE:       uint64 = 7
SYS_WRITE:       uint64 = 8                    # a0=fd, a1=buf, a2=count
SYS_LSEEK:       uint64 = 9                    # a0=fd, a1=offset, a2=whence
SYS_EXECVE:      uint64 = 10                   # a0=path, a1=argv, a2=envp (Linux ABI only); never returns on success
SYS_SPAWN:       uint64 = 11                   # a0=path, a1=argv, a2=stdin_fd, a3=stdout_fd, a4=envp (Linux ABI only); returns child pid
SYS_WAITPID:     uint64 = 12                   # a0=pid; returns child exit_code
SYS_OPEN_WRITE:  uint64 = 13                   # a0=path; creates/truncates, returns fd
SYS_PIPE:        uint64 = 14                   # a0=Ptr[int32 fds[2]]; returns 0 on success
SYS_KILL:        uint64 = 15                   # a0=pid, a1=sig; returns 0 / -ESRCH
SYS_DUP:         uint64 = 16                   # a0=oldfd; returns newfd
SYS_DUP2:        uint64 = 17                   # a0=oldfd, a1=newfd; returns newfd
SYS_LISTDIR:     uint64 = 18                   # a0=path, a1=buf, a2=count; returns bytes
SYS_CHDIR:       uint64 = 19                   # a0=path; returns 0 / -E2BIG
SYS_GETCWD:      uint64 = 20                   # a0=buf, a1=count; returns bytes (incl NUL)
SYS_UNLINK:      uint64 = 21                   # a0=path; returns 0 / -errno
SYS_MKDIR:       uint64 = 22                   # a0=path; real for tmpfs (V1 tree)
SYS_READ_NB:     uint64 = 23                   # a0=fd, a1=buf, a2=count; non-blocking read: >0 bytes, 0 would-block, -1 EOF/error
SYS_YIELD:       uint64 = 24                   # cooperative yield: drop the CPU to any other ready task; returns 0

# Phase B / M16.93: Plan 9-shape native syscall number block. Reserved
# 256..274 in docs/native-api.md (Phase B). All but SYS_ERRSTR are
# stubs that return -ENOSYS at this milestone; Phase C lands real
# implementations one at a time. The numbers themselves are stable
# from here — userland binaries can write `syscall6(265, ...)` for
# errstr today and the call site won't shift when rfork/bind/mount
# land their bodies.
SYS_RFORK:       uint64 = 256                  # Phase C: stub -ENOSYS
SYS_BIND:        uint64 = 257                  # Phase C: stub -ENOSYS
SYS_MOUNT:       uint64 = 258                  # Phase C: stub -ENOSYS
SYS_UNMOUNT:     uint64 = 259                  # Phase C: stub -ENOSYS
SYS_CREATE:      uint64 = 260                  # Phase C: stub -ENOSYS
# SYS_STAT_P9 / SYS_FSTAT_P9 are suffixed _P9 to avoid colliding with
# any future Linux-shape SYS_STAT we'd want to reserve. The native
# binary calls them by literal number 261 / 262 either way.
SYS_STAT_P9:     uint64 = 261                  # Phase C: stub -ENOSYS
SYS_FSTAT_P9:    uint64 = 262                  # Phase C: stub -ENOSYS
SYS_REMOVE:      uint64 = 263                  # Phase C: stub -ENOSYS
SYS_FD2PATH:     uint64 = 264                  # Phase C: stub -ENOSYS
SYS_ERRSTR:      uint64 = 265                  # a0=buf, a1=nbuf; read/install error string
# Phase C / native wstat: the last two Plan 9 reserved syscalls in the
# 256..271 block. Bodies live in sys/src/9/port/sysfile.ad as
# do_wstat / do_fwstat. wstat honours the `name` field (rename) and
# accepts `mode` as a successful no-op (no per-inode mode storage
# yet); length / mtime / gid / muid stay sentinel-only.
SYS_WSTAT:       uint64 = 266                  # a0=path, a1=buf, a2=nbuf
SYS_FWSTAT:      uint64 = 267                  # a0=fd, a1=buf, a2=nbuf
# Phase C / M16.109: Plan 9 note (signal) primitives. Reserved numbers
# 270 / 271 in docs/native-api.md; bodies in sys/src/9/port/sysnote.ad.
SYS_NOTIFY:      uint64 = 270                  # a0=handler RIP (0 = clear); returns 0
SYS_NOTED:       uint64 = 271                  # a0=action (NCONT/NDFLT/NSAVE/NRSTR); returns 0
# U-resolve: native-ABI hostname -> IPv4 resolver. Number 269 is the
# one free slot in the Plan 9 reserved block (268 = fauth reserved,
# 270/271 = notify/noted). a0 = Ptr to a NUL-terminated hostname,
# a1 = hostname byte length (excl NUL; advisory bound). Returns the
# resolved IPv4 packed big-endian into the low 32 bits — octet 0 in
# bits 31:24 — so a positive return is always a valid address and a
# negative return is an errno. -2 (-ENOENT) means "cannot resolve".
SYS_RESOLVE:     uint64 = 269                  # a0=hostname ptr, a1=len; returns packed IPv4 / -errno
# Phase D / V4: Plan 9 `srv` post/open. Numbers 272..274 are reserved
# in docs/native-api.md (awake/segattach/segdetach — none implemented),
# so SYS_SRV_POST / SYS_SRV_OPEN pick the next two free slots above
# the reserved block. Bodies live inline below (validation + a thin
# wrapper around sys/src/9/port/devsrv.ad). This is the userspace
# surface that unblocks V4 — without it /srv stays empty, hamwd has
# no way to publish itself, and `mount` over a posted srvfd is
# bootstrap-only.
SYS_SRV_POST:    uint64 = 275                  # a0=name, a1=srvfd; returns 0/-1
SYS_SRV_OPEN:    uint64 = 276                  # a0=name; returns new fd / -1
# U-TLS: native-ABI tls_connect(2). Number 277 is the next free slot
# above the SYS_SRV_OPEN (276) block — outside the 272..274 reserved
# range (awake/segattach/segdetach). a0 = socket fd (already
# connect(2)'d), a1 = Ptr to a NUL-terminated hostname (SNI + leaf-cert
# name check), a2 = hostname byte length. Runs the in-kernel TLS 1.3
# handshake (drivers/net/tls.ad) over the socket's TCP slot and marks
# the fd TLS-active so subsequent read/write transparently use the TLS
# record layer. Returns 0 on success or a negative errno. Body shared
# with the Linux-ABI dispatcher would need a non-stock number, so this
# is native-only for now (apt is native Adder — the priority consumer).
SYS_TLS_CONNECT: uint64 = 277                  # a0=fd, a1=hostname ptr, a2=hostlen; returns 0/-errno
# HAMSH §7: the `#d`-fd-device namespace primitives. /fd/N is a name
# in a process's Pgrp; pipe / redirect / dup all reduce to "bind a
# Chan at /fd/N". 278..280 are the next free slots above SYS_TLS_CONNECT.
SYS_FDBIND:      uint64 = 278  # a0=pid(0=self), a1=fdnum, a2=kind, a3=arg; THE bind primitive (pipe/redirect/dup)
SYS_PIPECHAN:    uint64 = 280  # returns a pipe SLOT id (not fds); the chan ends for an /fd bind
SYS_OPENCHAN:    uint64 = 281  # a0=path, a1=write; opens a file as a channel, returns the tmpfs slot
SYS_NSID:        uint64 = 282  # returns an opaque per-Pgrp namespace identity (the Pgrp pointer)
# distrofs persistent backing: snapshot the userland distrofs 9P
# server's RAM node/data tables to a durable file on the ext4 volume
# so an installed package survives a reboot. 283/284 are the next two
# free slots above SYS_NSID. These are distrofs's PRIVATE backing-store
# primitives — not a global filesystem route: the kernel owns the
# backing-file name; userland passes only a small instance id (0..15,
# one distrofs daemon per id), never a path.
#   SYS_DFS_LOAD  a0=inst, a1=dst buf, a2=max_len; bytes read / 0 / -1
#   SYS_DFS_SAVE  a0=inst, a1=src buf, a2=length;  bytes written / -1
SYS_DFS_LOAD:    uint64 = 283
SYS_DFS_SAVE:    uint64 = 284
SYS_NSLABEL:     uint64 = 285  # a0=op(0=stamp,1=unmount), a1=label, a2=to_path, a3=from_path; HAMSH §14 mount handles
# Network-config syscall. The `ifconfig` command reads and writes the
# IPv4 stack's current address / netmask / gateway / DNS through this
# single multiplexed entry point. a0 selects the operation:
#   op 0 (GET)      a1 = Ptr to a 24-byte buffer; the kernel fills it
#                   with the current config (see do_netcfg for the
#                   byte layout). Returns 0.
#   op 1 (SET_ADDR) a1..a4 unused; the 4 address + 4 mask octets are
#                   packed: a1 = addr (octet0<<24..octet3), a2 = mask
#                   (same packing). Latches a static config. Returns 0.
#   op 2 (SET_GW)   a1 = gateway packed octet0<<24..octet3. Returns 0.
#   op 3 (SET_DNS)  a1 = DNS server packed octet0<<24..octet3. Returns 0.
# A static SET_* pins ip_cfg_source / dns_server_static so a racing
# DHCP ACK can't clobber the operator's config. 286 is the next free
# slot above SYS_NSLABEL.
SYS_NETCFG:      uint64 = 286
# HAMSH §7: sys_spawn's stdin_fd / stdout_fd sentinel. When the caller
# passes SPAWN_STDIO_NS, the child's standard streams are NAMES in its
# namespace (/fd/0,1,2 via the `#d` device), not dup'd integer fds —
# the caller wires them via SYS_FDBIND. -2 is outside the [0,16) valid-
# fd band and distinct from the -1 "inherit" sentinel.
SPAWN_STDIO_NS:  int32  = -2

# Linux-numbered syscalls (L-track, linux_abi/). We use the stock
# Linux 6.12 x86_64 numbers so userspace tools built against Linux's
# unistd_64.h can call them by literal number.
# U-socket: native-ABI socket(2)/connect(2). The numbers match
# Linux's so a binary that hard-codes the Linux socket syscall numbers
# lands here unchanged; the bodies are shared with the Linux-ABI
# dispatcher (linux_abi/u_syscalls.ad::_u_socket / _u_connect).
SYS_SOCKET:         uint64 = 41                 # a0=domain, a1=type, a2=protocol; returns socket fd
SYS_CONNECT:        uint64 = 42                 # a0=fd, a1=Ptr sockaddr_in, a2=addrlen; returns 0/-errno
SYS_SOCKETPAIR:     uint64 = 53                 # a0=domain, a1=type, a2=protocol, a3=Ptr[int32 sv[2]]; returns 0/-1
# U-socket server side: native-ABI accept/bind/listen. Numbers match
# Linux's socket-syscall numbering (accept=43, bind=49, listen=50) so a
# native Adder server binary built against runtime.S reaches the same
# _u_accept / _u_bind / _u_listen bodies the Linux-ABI dispatcher uses.
# These are SUFFIXED _SOCK to keep them distinct from the Plan 9
# SYS_BIND (257, namespace bind) constant above — same name collision
# the runtime.S wrappers resolve by picking distinct symbol names.
SYS_ACCEPT_SOCK:    uint64 = 43                 # a0=fd, a1=Ptr sockaddr, a2=Ptr addrlen; returns new fd/-errno
SYS_BIND_SOCK:      uint64 = 49                 # a0=fd, a1=Ptr sockaddr_in, a2=addrlen; returns 0/-errno
SYS_LISTEN_SOCK:    uint64 = 50                 # a0=fd, a1=backlog; returns 0/-errno
SYS_INIT_MODULE:    uint64 = 175                # a0=image, a1=size, a2=params
SYS_DELETE_MODULE:  uint64 = 176                # a0=name, a1=flags

# M16.35: the previous user_rsp_save / kernel_rsp globals were
# retired in favour of a per-task syscall stack. syscall_entry now
# reads the current task's kstack_top out of TSS.RSP0 (which
# schedule() keeps current on every context switch) and parks the
# user RSP on that stack instead of in a shared global. That lets
# SYS_WAITPID yield to another task mid-syscall without a sibling
# syscall clobbering the saved slot.


# Maximum argv we'll honour. Picked to comfortably exceed a shell's
# typical needs while keeping the user-stack reservation small (each
# pointer is 8 bytes, each string capped at MAX_ARG_BYTES). Tight
# fixed caps are fine until hamsh asks for more.
MAX_ARGV:      uint64 = 16
MAX_ARG_BYTES: uint64 = 256

# U17: matching caps for envp[] on the Linux process init-stack.
# Each env string is the literal "NAME=VALUE\0" bytes; both name and
# value share the per-string byte budget. 64 entries comfortably
# covers anything hamsh can stuff into its 8-slot variable table plus
# headroom for what future export semantics might add.
MAX_ENVP:      uint64 = 64
MAX_ENV_BYTES: uint64 = 256

# Linux ELF user stack: 256 KiB (64 pages = buddy order 6). Big enough
# for glibc's static-PIE startup AND a forked child unwinding through
# the fork epilogue + atexit + _IO_cleanup on its own private stack.
# do_clone eager-copies this whole region on fork().
LINUX_USTACK_ORDER: int32  = 6
LINUX_USTACK_SIZE:  uint64 = 262144      # 64 * 4096


def _argv_strlen(s: uint64) -> uint64:
    n: uint64 = 0
    while cast[Ptr[uint8]](s + n)[0] != 0 and n < MAX_ARG_BYTES:
        n = n + 1
    return n


def _argv_count(argv: uint64) -> uint64:
    # Walk a NULL-terminated array of 8-byte pointers, capped at
    # MAX_ARGV so a malformed argv can't run away. argv == 0 means
    # "no argv" — count is 0.
    if argv == 0:
        return 0
    n: uint64 = 0
    while n < MAX_ARGV:
        p: uint64 = cast[Ptr[uint64]](argv + n * 8)[0]
        if p == 0:
            return n
        n = n + 1
    return n


def _envp_strlen(s: uint64) -> uint64:
    n: uint64 = 0
    while cast[Ptr[uint8]](s + n)[0] != 0 and n < MAX_ENV_BYTES:
        n = n + 1
    return n


def _envp_count(envp: uint64) -> uint64:
    # Same shape as _argv_count but uses the env-side caps so a
    # malformed envp can't run away. envp == 0 (caller passed no
    # environment) means "empty env" — count is 0.
    if envp == 0:
        return 0
    n: uint64 = 0
    while n < MAX_ENVP:
        p: uint64 = cast[Ptr[uint64]](envp + n * 8)[0]
        if p == 0:
            return n
        n = n + 1
    return n


def _build_user_argv(ustack_top: uint64, argv_user: uint64,
                     out_argc: Ptr[uint64],
                     out_argv: Ptr[uint64]) -> uint64:
    # Native-Hamnix-ABI argv layout. Strings + NULL-terminated pointer
    # array at the top of the user stack; out_argc / out_argv get the
    # values _start should see in %rdi / %rsi.
    #
    # Layout (growing down from ustack_top):
    #
    #   high:  "arg0\0arg1\0..."        each NUL-terminated string
    #          [pad to 8 bytes]
    #          argv[0]  -> &"arg0"
    #          argv[1]  -> &"arg1"
    #          ...
    #          argv[N]  = 0             NULL terminator
    #          [pad to 16 bytes]        SysV stack alignment for _start
    #   low:   <new RSP>
    #
    # Native-Hamnix binaries read argc / argv from %rdi / %rsi (set up
    # by the SYS_EXECVE / SYS_SPAWN plumbing); they never look at *rsp.
    # Linux binaries (musl, glibc) ignore the SysV register handoff and
    # read directly from *rsp per the Linux process init-stack ABI —
    # see _build_user_argv_linux below for that path.
    argc: uint64 = _argv_count(argv_user)

    # Copy strings down from ustack_top. Track the bottom of the
    # string region; that's where the argv pointer array begins.
    str_sp: uint64 = ustack_top
    str_addrs: Array[16, uint64]
    i: uint64 = 0
    while i < argc:
        src: uint64 = cast[Ptr[uint64]](argv_user + i * 8)[0]
        n:   uint64 = _argv_strlen(src) + 1            # incl. NUL
        str_sp = str_sp - n
        memcpy(cast[Ptr[uint8]](str_sp),
               cast[Ptr[uint8]](src), n)
        str_addrs[i] = str_sp
        i = i + 1

    # 8-byte align the pointer array.
    str_sp = str_sp & ~cast[uint64](7)

    # Write argv[N] = NULL then argv[N-1] .. argv[0] (top-down).
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = 0
    i = argc
    while i > 0:
        i = i - 1
        str_sp = str_sp - 8
        cast[Ptr[uint64]](str_sp)[0] = str_addrs[i]

    argv_addr: uint64 = str_sp

    # 16-byte align RSP for SysV. The argv array is already 8-aligned;
    # mask to a 16-byte boundary by potentially dropping 8 bytes of pad
    # below it. After _start's `call main` the stack is again 16-aligned.
    str_sp = str_sp & ~cast[uint64](15)

    out_argc[0] = argc
    out_argv[0] = argv_addr
    return str_sp


# Auxv type numbers (Linux include/uapi/linux/auxvec.h subset).
AT_NULL:    uint64 = 0
AT_PHDR:    uint64 = 3
AT_PHENT:   uint64 = 4
AT_PHNUM:   uint64 = 5
AT_PAGESZ:  uint64 = 6
AT_BASE:    uint64 = 7
AT_ENTRY:   uint64 = 9
AT_RANDOM:  uint64 = 25


def _build_user_argv_linux(ustack_top: uint64, argv_user: uint64,
                           envp_user: uint64,
                           entry_addr: uint64, region: uint64) -> uint64:
    # Linux process init-stack layout. musl's _start does
    # `mov %rsp,%rdi; call _start_c`; _start_c then reads
    # `argc = *(int*)rdi`, `argv = rdi+8`, walks envp from there, and
    # finally reads auxv. So *rsp at user-mode entry MUST be argc.
    #
    # Layout (growing down from ustack_top):
    #
    #   high:  "arg0\0arg1\0..."          NUL-terminated argv strings
    #          "ENV0=VAL\0ENV1=VAL\0..."  NUL-terminated env strings
    #          [16-byte AT_RANDOM blob]   zeroes — no entropy source yet
    #          [pad to 16-byte alignment]
    #          AT_NULL pair  (0, 0)
    #          AT_RANDOM pair (25, &random_blob)
    #          AT_ENTRY pair  (9, region + e_entry - lowest_v)
    #          AT_BASE pair   (7, 0)
    #          AT_PAGESZ pair (6, 4096)
    #          AT_PHNUM pair  (5, e_phnum)
    #          AT_PHENT pair  (4, 56)
    #          AT_PHDR pair   (3, region + e_phoff)
    #          NULL                       envp terminator
    #          envp[envc-1] -> &"NAMEn-1=VAL"
    #          ...
    #          envp[0]      -> &"NAME0=VAL"
    #          NULL                       argv terminator
    #          argv[argc-1] -> &"argN-1"
    #          ...
    #          argv[0]      -> &"arg0"
    #          argc
    #   low:   <new RSP>
    #
    # SysV requires *rsp to be 16-byte aligned at function entry for
    # musl's _start. _start_c is called via `call`, which pushes 8
    # bytes of return address, so it sees rsp at 8 mod 16 — fine. We
    # achieve the 16-byte alignment for *rsp by counting the variable
    # part (argc-cell + argv-pointers + 2 NULLs + envp-pointers + 6
    # auxv pairs) and padding the string-region bottom appropriately.
    #
    # U17 extends the U16 layout with a real envp[] block populated
    # from envp_user (a user-side NUL-terminated array of pointers to
    # "NAME=VALUE\0" strings). envp_user == 0 still works — yields the
    # exact U16 layout (envp = [NULL]).
    argc: uint64 = _argv_count(argv_user)
    envc: uint64 = _envp_count(envp_user)

    # 1. Copy argv strings down from ustack_top.
    str_sp: uint64 = ustack_top
    str_addrs: Array[16, uint64]
    i: uint64 = 0
    while i < argc:
        src: uint64 = cast[Ptr[uint64]](argv_user + i * 8)[0]
        n:   uint64 = _argv_strlen(src) + 1            # incl. NUL
        str_sp = str_sp - n
        memcpy(cast[Ptr[uint8]](str_sp),
               cast[Ptr[uint8]](src), n)
        str_addrs[i] = str_sp
        i = i + 1

    # 1b. Copy envp strings just below the argv strings. Each entry
    #     is "NAME=VALUE\0" verbatim — we don't reparse it. envp_user
    #     pointers point into the parent's address space; we own the
    #     copy now, so subsequent edits to the parent's env table
    #     can't disturb the child's view.
    env_addrs: Array[64, uint64]
    i = 0
    while i < envc:
        src: uint64 = cast[Ptr[uint64]](envp_user + i * 8)[0]
        n:   uint64 = _envp_strlen(src) + 1            # incl. NUL
        str_sp = str_sp - n
        memcpy(cast[Ptr[uint8]](str_sp),
               cast[Ptr[uint8]](src), n)
        env_addrs[i] = str_sp
        i = i + 1

    # 2. 16 bytes of AT_RANDOM material. Hamnix has no entropy source
    #    yet so we leave the bytes zero. glibc seeds its stack-protector
    #    canary from these (resulting in a zero canary), which is a
    #    weakness, not a correctness issue — every saved canary on the
    #    stack and every live TCB canary compare 0==0. A non-zero
    #    canary would only be needed once a real RNG lands.
    str_sp = str_sp - 16
    cast[Ptr[uint64]](str_sp)[0]     = 0
    cast[Ptr[uint64]](str_sp + 8)[0] = 0
    random_addr: uint64 = str_sp

    # 3. Compute *rsp = argc cell address after every fixed-size cell
    #    is accounted for, so we can pre-align the bottom of the string
    #    region to land *rsp on a 16-byte boundary.
    #
    #    Variable contents below the strings/random blob (each 8 bytes):
    #      - 8 auxv pairs * 2 cells   = 16 cells   = 128 bytes
    #      - envp NULL                 =  1 cell   =  8 bytes
    #      - envp pointers (envc)      =  envc     = envc*8 bytes
    #      - argv NULL                 =  1 cell   =  8 bytes
    #      - argv pointers (argc)      =  argc     = argc*8 bytes
    #      - argc cell                 =  1 cell   =  8 bytes
    #    Total = (19 + argc + envc) * 8 bytes
    #
    #    For *rsp (= argc cell) to be 16-aligned, ((19 + argc + envc) *
    #    8) aligned-from str_sp must satisfy that bottom = 16-aligned.
    #    We pre-bump str_sp down 0 or 8 bytes to make it so.
    str_sp = str_sp & ~cast[uint64](7)
    fixed_bytes: uint64 = (cast[uint64](19) + argc + envc) * 8
    bottom: uint64 = str_sp - fixed_bytes
    if (bottom & cast[uint64](15)) != 0:
        str_sp = str_sp - 8                            # align pad

    # 4. Push auxv from top down: AT_NULL first (highest addr), then
    #    each (type, value) pair top-down so that the resulting in-
    #    memory order — low to high — is the canonical Linux order.
    #
    #    U20: AT_PHDR / AT_PHNUM / AT_ENTRY are populated from the
    #    just-loaded ELF (passed in by the caller as region + phoff
    #    plus entry_addr). glibc / musl's _start reads these to drive
    #    its own _dl_relocate_static_pie pass — without them static-
    #    PIE binaries can't fix up RELATIVE / IRELATIVE / GLOB_DAT
    #    slots. AT_BASE=0 says "no dynamic linker"; static-PIE doesn't
    #    use it but glibc reads the cell unconditionally.
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = 0                   # AT_NULL.value
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = AT_NULL             # AT_NULL.type

    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = random_addr         # AT_RANDOM.value
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = AT_RANDOM

    # U42: AT_ENTRY is the APPLICATION's e_entry — what ld.so finally
    # jumps to once it's done relocating. For static binaries that's
    # the same as entry_addr (the user-mode RIP we'll SYSRETQ to); for
    # dynamic binaries entry_addr is the interpreter's entry and
    # elf_last_app_entry_user holds the app's. fs/elf.ad mirrors
    # entry_addr into elf_last_app_entry_user on the static path so
    # this expression evaluates correctly in both cases.
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = elf_last_app_entry_user  # AT_ENTRY.value
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = AT_ENTRY

    # U42: AT_BASE is the interpreter's load base (the kernel-chosen
    # memblock region for ld.so's image). glibc / musl's ld.so reads
    # this to compute "where am I?" — its own _start needs to know
    # its load address to walk its own DT_RELA, fix up its own GOT,
    # and then process the application's DT_DYNAMIC. For static
    # binaries fs/elf.ad pins elf_last_interp_base = 0, matching the
    # pre-U42 hardcoded "no dyn-linker" semantics — static-PIE glibc
    # tolerates AT_BASE = 0 and uses AT_PHDR/AT_ENTRY exclusively.
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = elf_last_interp_base    # AT_BASE.value
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = AT_BASE

    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = 4096                # AT_PAGESZ.value
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = AT_PAGESZ

    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = cast[uint64](elf_last_phnum)  # AT_PHNUM.value
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = AT_PHNUM

    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = 56                  # AT_PHENT.value
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = AT_PHENT

    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = region + elf_last_phoff  # AT_PHDR.value
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = AT_PHDR

    # 5. envp array: NULL terminator then envp[envc-1] .. envp[0].
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = 0
    i = envc
    while i > 0:
        i = i - 1
        str_sp = str_sp - 8
        cast[Ptr[uint64]](str_sp)[0] = env_addrs[i]

    # 6. argv array: NULL terminator then argv[N-1] .. argv[0].
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = 0
    i = argc
    while i > 0:
        i = i - 1
        str_sp = str_sp - 8
        cast[Ptr[uint64]](str_sp)[0] = str_addrs[i]

    # 7. argc — the user's new *rsp.
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = argc

    return str_sp


def do_execve(a0: uint64, a1: uint64, a2: uint64) -> int64:
    # The actual execve mechanics, shared by the native SYS_EXECVE
    # branch in do_syscall() and the Linux-ABI SYS_execve (59) handler
    # in linux_abi/u_syscalls.ad::_u_execve. Adder merges all modules
    # into one global symbol table, so u_syscalls.ad can call this
    # directly without any explicit cross-module import.
    #
    # Look up `path` in the initramfs, ELF-load, build argv on a
    # fresh user stack, and SYSRETQ directly to the new entry. The
    # current task's task_struct and per-task fd table are preserved
    # (no fork+exec races at this scale; we behave more like a Linux
    # exec() that replaces the user image but keeps the kernel-side
    # context). a1 = argv (Ptr[uint64] NULL-terminated array of
    # cstring pointers), or 0 for none. a2 = envp (same shape) or 0.
    # Only honoured on the Linux-ABI path — native binaries get
    # argc/argv via %rdi/%rsi and have no env concept yet.
    #
    # Return: negative Linux errno on failure (-ENOENT / -ENOEXEC).
    # On success do_execve_finish() does the SYSRETQ and we never
    # return here at all. The return type matches the Linux ABI
    # convention so _u_execve can just forward the int64 unchanged.
    # §4: resolve the target binary through the calling process's
    # namespace (Pgrp mount table) rather than a verbatim initramfs
    # match. A binary launched inside a distrorun distro-shape
    # namespace finds its image in the grafted distro tree; a native
    # process resolves the path verbatim (no matching mount entry).
    path: Ptr[char] = cast[Ptr[char]](a0)
    blob: uint64 = ns_blob_ptr(path)
    if blob == 0:
        printk1("execve: '%s' not in namespace\n", a0)
        set_current_errstr("execve: file does not exist")
        return cast[int64](-2)            # -ENOENT
    sz: uint64 = ns_blob_size(path)
    # U42 VMA: drop the outgoing image's mappings BEFORE we load the
    # new ELF. Without this, the new program would inherit the parent
    # image's stack/heap/mmap VMAs and a subsequent mprotect or munmap
    # could touch addresses that no longer belong to the new image's
    # address-space namespace. We do this after the initramfs lookup
    # (so a failed execve doesn't destroy the caller's address space)
    # but before elf_load_blob — the new PT_LOAD-derived VMAs land on
    # the cleared list. Note: at this scale (single Linux task at a
    # time, no per-process pagetables enforcing isolation between
    # tasks) the backing-page free here is what matters for
    # bookkeeping; the actual ELF-image pages were memblock-allocated
    # via elf_load_blob's allocator path and aren't tracked through
    # vma_list yet, so they leak across execve same as before. The
    # VMAs being cleared here are anonymous + file-backed mmaps the
    # OUTGOING program made (glibc-malloc arenas, mmap'd libc DSOs)
    # — those are correctly freed.
    vma_clear(current_idx_get())
    entry: uint64 = elf_load_blob(cast[Ptr[uint8]](blob), sz)
    if entry == 0:
        printk1("execve: ELF load of '%s' failed\n", a0)
        set_current_errstr("execve: bad ELF image")
        return cast[int64](-8)            # -ENOEXEC
    # U5: exec replaces current image. If the loaded image is a
    # Linux-ABI ELF, flip the current task's is_linux_userspace
    # flag so subsequent syscalls dispatch via u_syscalls. If the
    # caller was already in Linux-ABI mode (U25 path: glibc calling
    # SYS_execve(59) into another Linux binary), this is a no-op;
    # if a native binary is exec-ing into a Linux ELF, this flip is
    # what activates the u_syscalls dispatcher for the new image.
    is_linux: int32 = elf_last_was_linux
    if is_linux != 0:
        set_linux_userspace_mode(
            cast[int32](current_idx_get()), 1)
    # U30: ET_EXEC binaries (busybox-static, etc.) need their
    # link-time vaddr range mapped to the physical region we just
    # copied them into. ET_DYN (PIE) leaves this a no-op. We install
    # into the CURRENT task's PML4 because execve replaces this task's
    # image in place. Force a TLB flush afterwards by reloading the
    # same CR3 — the BSP identity map for [0x400000, 0x600000) is
    # still cached as a 1 GiB entry and would shadow the new finer
    # mapping otherwise.
    # The collision guard in elf_install_user_mapping refuses BEFORE
    # mutating the PML4, so a < 0 return here leaves cur_pml4 intact —
    # the current task survives the -ENOEXEC return instead of the box
    # freezing on a half-built address space.
    cur_pml4: uint64 = task_pml4(cast[int32](current_idx_get()))
    if elf_apply_last_user_mapping(cur_pml4) < 0:
        printk0("execve: user-mapping install failed (kernel-image collision?)\n")
        set_current_errstr("execve: cannot map binary")
        return cast[int64](-8)             # -ENOEXEC
    load_cr3(cur_pml4)
    # Fresh user stack for the new program. The previous user
    # stack page is leaked for now (no per-task ustack tracking
    # in this code path); proper teardown comes with mm_struct.
    # U38: 16 KiB was enough for glibc's static-PIE startup. The
    # per-process-address-space fork (this commit) eager-copies the
    # whole user stack on fork(); a child that returns from fork()
    # then unwinds through glibc's fork epilogue + atexit + _IO_cleanup
    # on its private stack. 256 KiB (64 pages, buddy order 6) gives
    # that call tower comfortable headroom and matches the floor the
    # mission set for the Linux user stack.
    new_ustack_base: uint64 = alloc_pages(LINUX_USTACK_ORDER)
    new_ustack_top:  uint64 = new_ustack_base + LINUX_USTACK_SIZE
    # Record the loaded image span + the user stack region on THIS
    # task so a later fork() can give the child a private copy of
    # each, remapped at the same virtual address.
    set_task_image_range(current_idx_get(),
                         elf_last_img_lo_get(),
                         elf_last_img_hi_get())
    set_task_ustack_range(current_idx_get(),
                          new_ustack_base, LINUX_USTACK_SIZE)
    argc_out: uint64 = 0
    argv_out: uint64 = 0
    new_rsp: uint64 = 0
    if is_linux != 0:
        # U16: Linux process init-stack — *rsp points to argc;
        # argv/envp/auxv all reachable from rsp+8. musl ignores
        # %rdi/%rsi, so we pass argc=0/argv=0 in the SysV slots.
        # U17: forward envp (a2) into the init-stack builder so
        # getenv() works in musl-built binaries.
        # U20: pass entry + load base so the auxv carries
        # AT_ENTRY / AT_PHDR / AT_PHNUM for glibc/musl's own
        # _dl_relocate_static_pie pass.
        new_rsp = _build_user_argv_linux(new_ustack_top, a1, a2,
                                         entry, elf_last_load_base)
    else:
        new_rsp = _build_user_argv(new_ustack_top, a1,
                                   &argc_out, &argv_out)
    printk2("execve: jumping to %p with stack %p\n",
            entry, new_rsp)
    # U26: if this task is a vfork-style child still sharing its
    # parent's user image, signal the parent that we've replaced the
    # image and it's safe to resume. The parent is spinning on
    # task_vfork_done in do_clone; setting this here is the last
    # moment before SYSRETQ swaps to the new user RIP/RSP. A regular
    # (non-forked) execve still sets this — harmless, nobody's polling.
    set_task_vfork_done(cast[int32](current_idx_get()), 1)
    do_execve_finish(entry, new_rsp, argc_out, argv_out)
    # Not reached.
    return 0


# U27: clone-flag bits we branch on. Numerically identical to the
# Linux <linux/sched.h> values — kept local so the kernel surface
# doesn't depend on the linux_abi headers just for a constant.
CLONE_VM:                uint64 = 0x100
CLONE_FS:                uint64 = 0x200
CLONE_FILES:             uint64 = 0x400
CLONE_SIGHAND:           uint64 = 0x800
CLONE_THREAD:            uint64 = 0x10000
CLONE_SETTLS:            uint64 = 0x80000
CLONE_PARENT_SETTID:     uint64 = 0x100000
CLONE_CHILD_CLEARTID:    uint64 = 0x200000


def do_clone(flags: uint64, child_stack: uint64,
             ptid: uint64, ctid: uint64, tls: uint64,
             user_r9: uint64,
             user_rdx: uint64, user_r8: uint64) -> int64:
    # Branches on CLONE_VM | CLONE_THREAD:
    #
    #   * Thread path  (CLONE_VM | CLONE_THREAD set): the caller is
    #     musl's pthread_create / glibc's pthread_create. It already
    #     mmap'd a thread stack and populated `child_stack` with the
    #     entry-point trampoline frame; we use that pointer verbatim
    #     as the child's RSP, do NOT copy the parent's stack page,
    #     schedule the child STATE_READY, and return immediately.
    #     Parent and child run concurrently from here. CLONE_SETTLS
    #     plants `tls` into the child's per-task fs_base so the next
    #     context switch restores it. PARENT_SETTID writes the new
    #     pid into *ptid; CHILD_CLEARTID stashes ctid in the child's
    #     clear_child_tid slot so task_exit_current zeroes it +
    #     futex-wakes a joiner on the way out. user_r9 propagates the
    #     parent's syscall-entry %r9 because musl's __clone wrapper
    #     parks the worker function there and the child does
    #     `call *%r9` after the syscall returns.
    #
    #   * Fork path  (no CLONE_VM): the legacy U26 vfork-style behaviour
    #     — deep-copy the parent's user stack page onto a fresh page,
    #     create a child whose RIP/RSP resume at the parent's syscall
    #     return, BLOCK the parent until the child execve's or exits.
    #     This is what plain fork() and vfork() pass us (SIGCHLD only).
    parent: Ptr[TaskStruct] = current_task()
    kstack_top: uint64 = parent[0].kstack_top
    # syscall_64.S parks (user_rsp - 8) at kstack_top-8 (the user's
    # original RSP minus the bytes pushq %r12 consumed), r11/RFLAGS at
    # -16, and rcx/user_RIP at -24. We undo the r12 push so the
    # child resumes at the parent's natural user RSP.
    parent_user_rsp: uint64 = cast[Ptr[uint64]](kstack_top - 8)[0] + 8
    parent_user_rip: uint64 = cast[Ptr[uint64]](kstack_top - 24)[0]

    # --- thread path -----------------------------------------------
    is_thread: int32 = 0
    if (flags & CLONE_VM) != 0 and (flags & CLONE_THREAD) != 0:
        is_thread = 1

    if is_thread != 0:
        # Caller-supplied stack — must be non-zero for a real
        # pthread_create. Honour it verbatim: musl/glibc has already
        # laid out the trampoline (return-to-__clone_func then
        # start_routine) at the top of the mmap'd thread stack and
        # handed us a pointer just below it. We don't allocate a new
        # page or copy from the parent — that would corrupt the
        # trampoline the libc just wrote.
        if child_stack == 0:
            set_current_errstr("clone: thread needs child stack")
            return cast[int64](-22)           # -EINVAL
        # create_user_thread plants user_r9 into the iret frame's r9
        # slot. musl's __clone wrapper saves the worker function in
        # %r9 across the syscall and the child does `call *%r9` after
        # the syscall returns. Without preserving user_r9 here, the
        # child calls into NULL.
        child_slot: int32 = create_user_thread(parent_user_rip,
                                               0x5f5f7468725f5f5f,    # "__thr___"
                                               child_stack, 0, 0,
                                               user_r9,
                                               user_rdx, user_r8)
        if child_slot < 0:
            set_current_errstr("clone: out of tasks")
            return cast[int64](-11)           # -EAGAIN
        # CLONE_VM: the thread SHARES the creator's address space, so
        # it must run on the SAME PML4 — not the fresh BSP-clone that
        # create_user_thread allocated. Without this, per-task page-
        # table overlays (mm/vma.ad's multi-chunk VMA backing for an
        # >4 MiB mmap such as the 8 MiB glibc pthread stack) live only
        # in the creator's PML4 and the thread #UDs on its own stack.
        set_task_cr3(child_slot,
                     task_pml4(cast[int32](current_idx_get())))
        # Inherit Linux-ABI mode (pthread_create only happens in
        # Linux user binaries; defensive against future native callers).
        if parent[0].is_linux_userspace != 0:
            set_linux_userspace_mode(child_slot, 1)
        # Share fd table — CLONE_FILES is the conventional bit; we
        # always do this on the thread path since the alternative
        # (a thread with its own fd table) makes no semantic sense.
        i: uint64 = 0
        while i < 16:
            dup_fd_to_child(child_slot, i, parent, i)
            i = i + 1
        # Share cwd (CLONE_FS). Hamnix tracks cwd per-task by value, not
        # by reference, so technically threads have independent cwd
        # views — fixing that is a separate refactor. Most pthread code
        # doesn't chdir, so the divergence is harmless at this scale.
        set_task_cwd(cast[uint64](child_slot),
                     get_cwd_buf(current_idx_get()))
        # CLONE_SETTLS: child's fs_base = tls. Schedule()'s wrmsr
        # restores this when it next picks the thread; we don't
        # write MSR_FS_BASE here because the parent is still
        # running and a wrmsr would clobber HER %fs.
        if (flags & CLONE_SETTLS) != 0:
            set_task_fs_base(child_slot, tls)
        # CLONE_PARENT_SETTID: write the new tid into *ptid for the
        # parent to read on syscall return. The parent passes a
        # pointer into ITS own thread descriptor; the address is in
        # the shared address space so it's reachable from kernel mode.
        child_pid: uint64 = task_pid_at(child_slot)
        if (flags & CLONE_PARENT_SETTID) != 0 and ptid != 0:
            cast[Ptr[int32]](ptid)[0] = cast[int32](child_pid)
        # CLONE_CHILD_CLEARTID: stash ctid in the child so its
        # task_exit_current zeros *ctid + futex-wakes pthread_join.
        if (flags & CLONE_CHILD_CLEARTID) != 0 and ctid != 0:
            set_task_clear_child_tid(child_slot, ctid)
        # vfork_done is irrelevant on the thread path — set it to 1 so
        # nothing in a future audit can spin-wait on it. The parent
        # never reads this for a thread because we don't enter the
        # blocking yield loop below.
        set_task_vfork_done(child_slot, 1)
        # Child is STATE_READY by create_user_thread. We return the
        # tid (which is the pid at this scale) to the libc and let
        # the next timer tick (or this task's next yield) hand the
        # CPU to it. Parent and child run concurrently from here.
        printk1("clone: thread created, child_pid=%d\n",
                cast[int32](child_pid))
        return cast[int64](child_pid)

    # --- fork path: real per-process address space ------------------
    #
    # Hamnix runs ET_DYN binaries identity-mapped, so a forked child
    # MUST get a PRIVATE physical copy of every writable region the
    # parent has, each remapped at the SAME virtual address in the
    # child's own PML4. Then the child runs at identical virtual
    # addresses but on private physical memory — every absolute
    # pointer it inherited (saved %rbp chain, return addresses,
    # glibc's _IO_2_1_stdout_ FILE struct, the TCB at fs_base) stays
    # valid, and parent and child no longer trample each other's
    # heap / stack / .data.
    #
    # Regions copied (each at the same vaddr in the child's PML4):
    #   * the whole loaded ELF image (code + rodata + data + bss),
    #   * the brk heap [brk_base, brk_end),
    #   * the user stack [ustack_lo, ustack_lo + ustack_sz),
    #   * every anonymous / file-backed mmap VMA.
    #
    # The child's RSP is IDENTICAL to the parent's user RSP — the
    # stack is copied byte-for-byte to the same virtual address, so
    # every saved-rbp / return-address in it is already correct from
    # the child's point of view. We pass parent_user_rsp straight
    # into create_user_task_argv; the non-zero value tells it to skip
    # the fresh-stack allocation and plant our RSP into the iret frame.
    parent_idx: uint64 = current_idx_get()
    slot: int32 = create_user_task_argv(parent_user_rip,
                                        0x5f5f666f726b5f5f,        # "__fork__"
                                        parent_user_rsp, 0, 0)
    if slot < 0:
        set_current_errstr("fork: out of tasks")
        return cast[int64](-11)               # -EAGAIN
    child_pml4: uint64 = task_pml4(slot)
    parent_pml4: uint64 = task_pml4(cast[int32](parent_idx))
    cslot: uint64 = cast[uint64](slot)

    # Copy-on-write the three fixed writable regions. Instead of
    # eager-copying ~33 MiB of pages, vm_cow_share_all marks every
    # writable user page READ-ONLY + COW in BOTH the parent's and the
    # child's PML4, pointing both at the SAME physical pages. The first
    # write by either side faults into do_page_fault, which copies (or
    # just unshares) exactly that one 4 KiB page. Regions covered:
    #
    #   * the loaded ELF image (code + rodata + data + bss) — the
    #     read-only .text pages stay shared forever; only writable
    #     .data / .bss ever get copied, lazily, on first write;
    #   * the brk heap across its ENTIRE reserved window
    #     [brk_base, brk_max) — glibc-malloc's sysmalloc grows the
    #     arena PAST the current break, so the whole reservation must
    #     be COW-shared (the static-PIE glibc TLS/TCB block is
    #     sbrk-allocated, so this also covers the child's private TCB);
    #   * the user stack — the whole recorded region.
    img_lo: uint64 = task_image_lo(parent_idx)
    img_hi: uint64 = task_image_hi(parent_idx)
    brk_lo: uint64 = task_brk_base(parent_idx)
    brk_mx: uint64 = task_brk_max(parent_idx)
    ust_lo: uint64 = task_ustack_lo(parent_idx)
    ust_sz: uint64 = task_ustack_sz(parent_idx)
    if vm_cow_share_all(parent_pml4, child_pml4, img_lo, img_hi,
                        brk_lo, brk_mx, ust_lo, ust_sz,
                        parent_user_rsp) < 0:
        set_current_errstr("fork: address-space COW share OOM")
        return cast[int64](-12)               # -ENOMEM

    # Copy 4: anonymous + file-backed mmap VMAs (glibc-malloc arenas,
    # ld.so DSO maps). vma_fork_copy COW-shares each VMA's pages between
    # parent and child — read-only + COW-marked in both PML4s, the first
    # write by either side faults into do_page_fault and copies just
    # that page — and lands a mirrored VmaNode on the child's list so
    # the child's own munmap / mremap stays honest. This makes the WHOLE
    # address space (image + brk + stack + mmap) copy-on-write on fork.
    if vma_fork_copy(cslot, parent_idx, child_pml4) < 0:
        set_current_errstr("fork: vma copy OOM")
        return cast[int64](-12)               # -ENOMEM

    # Propagate the address-space bookkeeping so a GRANDCHILD fork
    # finds the same regions to copy.
    set_task_image_range(cslot, img_lo, img_hi)
    set_task_ustack_range(cslot, ust_lo, ust_sz)
    # brk cursors: the child's heap is a private copy at the same
    # vaddrs, so the cursors carry over unchanged. base/end track the
    # used heap; max bounds the reserved window.
    set_task_brk_range(cslot, brk_lo, task_brk_end(parent_idx), brk_mx)
    printk1("fork: child pid=%d given a private address space\n",
            cast[int32](task_pid_at(slot)))

    # Inherit parent's fs_base so the child's first syscall sees the
    # same TLS the parent had — and because copy 2 gave the child a
    # private heap, that same fs_base value resolves into the child's
    # own TCB copy, not the parent's.
    set_task_fs_base(slot, parent[0].fs_base)
    # Make the child's first read of the wake flag explicit. It's also
    # zeroed by bss/_find_free_slot reuse, but defensive setting here
    # keeps the contract obvious.
    set_task_vfork_done(slot, 0)
    # Mirror the parent's Linux-ABI mode onto the child so the child's
    # first syscall (likely _exit / execve) routes through u_syscalls.
    if parent[0].is_linux_userspace != 0:
        set_linux_userspace_mode(slot, 1)
    # §3: POSIX signal inheritance — the fork child inherits the
    # parent's signal handlers, sa_flags, and blocked-signal mask, but
    # NOT the pending-signal set (cleared in the child). This lets a
    # daemon fork workers that keep its SIGTERM / SIGCHLD dispositions.
    copy_sig_state_to_child(slot, parent_idx)
    # Copy parent's fd table into the child. The fresh slot already
    # has stdin/stdout/stderr pre-opened by _init_fd_table; overwrite
    # those plus walk the rest of the table so opened files / pipes /
    # FAT entries propagate. dup_fd_to_child bumps refcounts on
    # FD_PIPE_MARK_* entries so closing the parent's end doesn't
    # punch the channel out from under the child.
    i: uint64 = 0
    while i < 16:
        dup_fd_to_child(slot, i, parent, i)
        i = i + 1
    # cwd inheritance: _inherit_cwd_from_parent was already called
    # inside create_user_task_argv (it reads current_idx's cwd). Make
    # it explicit here too so future refactors of that helper don't
    # silently break fork(). set_task_cwd is idempotent.
    set_task_cwd(cast[uint64](slot), get_cwd_buf(current_idx_get()))
    child_pid: uint64 = task_pid_at(slot)
    # U38: parent returns immediately; parent + child run concurrently.
    # Earlier U26..U37 code blocked here on task_vfork_done to approximate
    # POSIX vfork — that worked for the simple system() / posix_spawn()
    # pattern (fork → immediate exec) but breaks pipelines. A shell
    # building `echo a | grep a` needs the read end of the pipe to have
    # a live reader BEFORE the writer fills it; with vfork-style blocking,
    # the parent shell can't fork the second stage until the first has
    # exec'd, so the pipeline never gets both ends wired up concurrently
    # and the first stage either deadlocks (pipe write to a not-yet-read
    # reader) or its post-fork bookkeeping aborts (glibc fork-epilogue
    # stack canary checks fail when the child wakes on a different RSP).
    # With concurrent execution, both tasks are STATE_READY and the
    # scheduler picks the next one on every timer tick / yield. The
    # child now has a fully PRIVATE address space (image + heap +
    # stack + VMAs were eager-copied above into its own physical
    # pages, each remapped at the same virtual address in the child's
    # PML4) — parent and child no longer share any writable memory, so
    # both can run glibc fork-epilogue / atexit / _IO_cleanup
    # concurrently without trampling each other. wait4 still uses the
    # vfork_done / STATE_EXITED transition for waitpid bookkeeping.
    return cast[int64](child_pid)


# §3: scan for any reapable child of `parent_pid`. Returns the slot
# index of an EXITED child, or -1 if none is currently a zombie.
def _wait_any_zombie_child(parent_pid: uint64) -> int32:
    i: uint64 = 0
    while i < 16:
        t: Ptr[TaskStruct] = task_struct_at(cast[int32](i))
        if cast[uint64](t) != 0:
            if task_state(cast[int32](i)) == STATE_EXITED \
                    and t[0].parent_pid == parent_pid:
                return cast[int32](i)
        i = i + 1
    return -1


# §3: does `parent_pid` still have at least one live (non-exited,
# non-free) child? Used to decide -ECHILD vs "keep blocking".
def _has_live_child(parent_pid: uint64) -> int32:
    i: uint64 = 0
    while i < 16:
        t: Ptr[TaskStruct] = task_struct_at(cast[int32](i))
        if cast[uint64](t) != 0:
            st: uint64 = task_state(cast[int32](i))
            if t[0].parent_pid == parent_pid \
                    and (st == 1 or st == 2 or st == STATE_EXITED):
                return 1
        i = i + 1
    return 0


# §3: encode a Linux wait-status word. WIFSIGNALED if the child was
# killed by a signal (low 7 bits = signal); else WIFEXITED (bits 15:8
# = exit code, low byte 0). glibc/musl W* macros decode this directly.
def _encode_wstatus(slot: int32) -> int32:
    su: uint64 = cast[uint64](slot)
    tsig: uint64 = get_task_term_sig(su)
    if tsig != 0:
        # WIFSIGNALED: (status & 0x7f) is the signal, non-zero and
        # != 0x7f. WTERMSIG(status) == status & 0x7f.
        return cast[int32](tsig & 0x7F)
    code: int64 = task_exit_code(slot)
    return cast[int32]((code & 0xFF) << 8)


# WNOHANG — wait4 option bit 0. Return immediately (0) if no child is
# reapable, instead of blocking.
WNOHANG: uint64 = 1


def do_wait4(pid: uint64, wstatus_ptr: uint64,
             options: uint64, rusage: uint64) -> int64:
    # Linux-shape waitpid / wait4. Writes the result into *wstatus_ptr
    # using the Linux wait-status encoding (WIFEXITED / WIFSIGNALED).
    #
    # §3: two waiting modes —
    #   * pid == (pid_t)-1  (0xFFFFFFFFFFFFFFFF, or 0): reap ANY child
    #     of the caller. This is the form a SIGCHLD handler / daemon
    #     reap loop uses (`while (waitpid(-1, &st, WNOHANG) > 0)`).
    #   * pid > 0: reap that specific child.
    # WNOHANG is honoured: with no reapable child it returns 0 rather
    # than blocking. `rusage` is accepted for ABI compatibility but
    # not filled (Hamnix has no per-task rusage accounting yet).
    my_pid: uint64 = current_task_pid()
    wait_any: int32 = 0
    if pid == cast[uint64](-1) or pid == 0:
        wait_any = 1

    do:
        target: int32 = -1
        if wait_any != 0:
            target = _wait_any_zombie_child(my_pid)
            if target < 0 and _has_live_child(my_pid) == 0:
                set_current_errstr("wait: no children")
                return cast[int64](-10)       # -ECHILD
        else:
            target = task_lookup_by_pid(pid)
            if target < 0:
                set_current_errstr("wait: no such child")
                return cast[int64](-10)       # -ECHILD
            if task_state(target) != STATE_EXITED:
                target = -1                   # not reapable yet
        if target >= 0:
            if wstatus_ptr != 0:
                cast[Ptr[int32]](wstatus_ptr)[0] = _encode_wstatus(target)
            reaped_pid: uint64 = task_pid_at(target)
            task_reap(target)
            return cast[int64](reaped_pid)
        # No reapable child this pass.
        if (options & WNOHANG) != 0:
            return 0                          # POSIX: WNOHANG → 0
        yield_to_others()
    while 1
    # Unreachable — the loop only exits via an explicit return.
    return 0


def syscall_init():
    # M16.35: no longer takes a stack arg — the entry stub reads the
    # current task's kernel stack from TSS.RSP0 each time it's called,
    # so there is no single boot-time slot to install. Linux's
    # syscall_init() reads from cpu_tss_rw.x86_tss.sp0 in exactly the
    # same way.
    #
    # Diagnostic printks (May 2026): one Asus laptop wedges silently
    # between "parent task PML4 = ..." and "syscall MSRs armed" on
    # legacy BIOS only — QEMU and UEFI both reach the second line
    # cleanly. Each side-effecting write in this body now sandwiches
    # itself between `pre-<step>` and `post-<step>` lines so the next
    # real-hw run pin-points the offending wrmsr. The pre line also
    # echoes the value about to be written for canonicality checks
    # (LSTAR must be canonical or wrmsr #GPs on real CPUs).

    printk0("Hamnix: syscall_init: entry\n")

    # IA32_STAR encoding:
    #   bits 31:0  reserved
    #   bits 47:32 = 0x08  (SYSCALL kernel CS; SS = +8 = 0x10)
    #   bits 63:48 = 0x10  (SYSRET base; user CS = +16, SS = +8)
    star: uint64 = (cast[uint64](0x10) << 48) | (cast[uint64](0x08) << 32)
    printk1("Hamnix: syscall_init: pre-wrmsr STAR  = %p\n", star)
    write_msr(IA32_STAR, star)
    printk0("Hamnix: syscall_init: post-wrmsr STAR\n")

    # SYSCALL entry point: %rip after SYSCALL = IA32_LSTAR.
    lstar_val: uint64 = cast[uint64](&syscall_entry)
    printk1("Hamnix: syscall_init: pre-wrmsr LSTAR = %p\n", lstar_val)
    write_msr(IA32_LSTAR, lstar_val)
    printk0("Hamnix: syscall_init: post-wrmsr LSTAR\n")

    # FMASK = 0x0200 clears IF on entry. SYSCALL hands off with
    # interrupts off until the stub explicitly re-enables them (we
    # don't; preemption while servicing a syscall is deferred work).
    printk0("Hamnix: syscall_init: pre-wrmsr FMASK\n")
    write_msr(IA32_FMASK, 0x0200)
    printk0("Hamnix: syscall_init: post-wrmsr FMASK\n")

    # EFER current value — useful if the rdmsr/wrmsr pair inside
    # set_efer_sce blows up: we want to know what we read so future
    # patches can either short-circuit (already-set) or apply a CPU
    # quirk before flipping SCE.
    efer_before: uint64 = read_msr(0xC0000080)
    printk1("Hamnix: syscall_init: EFER before SCE = %p\n", efer_before)

    # Finally flip IA32_EFER.SCE so SYSCALL stops being #UD.
    printk0("Hamnix: syscall_init: pre-set_efer_sce\n")
    set_efer_sce()
    printk0("Hamnix: syscall_init: post-set_efer_sce\n")

    efer_after: uint64 = read_msr(0xC0000080)
    printk1("Hamnix: syscall_init: EFER after  SCE = %p\n", efer_after)

    printk0("Hamnix: syscall MSRs armed (SYSCALL/SYSRET enabled)\n")


def _srv_name_valid(name: Ptr[char]) -> int32:
    # V4: validate `/srv/<leaf>` candidates from userspace. Rules
    # match docs/native-api.md's `/srv/<name>` reserved-path entry:
    #   * non-NUL first byte (no empty name)
    #   * <= 32 bytes including NUL
    #   * ASCII printable only (32 < c < 127); excludes control chars
    #   * no '/' (would collide with path traversal in fs/vfs.ad's
    #     _open_srv_name nested-path bail)
    #   * not "." or "..", and no leading '.' (those would land at the
    #     same path as the directory itself / parent in the future
    #     namespace-aware open path)
    # Returns 1 on accept, 0 on reject.
    if cast[uint64](name) == 0:
        return 0
    c0: int32 = name[0]
    if c0 == 0:
        return 0
    if c0 == 46:                                    # '.'
        return 0
    i: uint64 = 0
    while i < 33:
        c: int32 = name[i]
        if c == 0:
            if i == 0:
                return 0
            return 1
        if c <= 32 or c >= 127:
            return 0
        if c == 47:                                 # '/'
            return 0
        i = i + 1
    # 33 bytes scanned without NUL — name is too long (>32 incl NUL).
    return 0


def do_syscall(nr: uint64, a0: uint64, a1: uint64, a2: uint64,
               a3: uint64, a4: uint64, a5: uint64) -> uint64:
    # Tail of the syscall entry path. nr is the user's %rax; a0..a5
    # are the user's %rdi/%rsi/%rdx/%r10/%r8/%r9 (the syscall ABI; the
    # entry stub already shuffles them into SysV positions — a0..a4
    # arrive in regs and a5 spills onto the stack per SysV).
    #
    # M16.39: a pending signal terminates the task before the syscall
    # runs. Catches Ctrl-C arrivals between user-mode bursts and any
    # other async post (SYS_KILL on self, etc.). Mid-syscall yields
    # check their own pending state in yield_to_others.
    signal_check_and_handle()
    # U1: per-task syscall ABI fork. Tasks created by the Linux ELF
    # loader have task_struct.is_linux_userspace==1 and route to
    # linux_u_syscall_dispatch, which interprets `nr` using Linux
    # x86_64 numbering (read=0, write=1, ...). Hamnix-native binaries
    # — everything currently in initramfs except the host-built
    # /bin/u_* fixtures — leave the field at 0 and fall through to
    # the existing 0..22 + 175/176 ladder unchanged.
    #
    # U7: the entry stub was widened to forward all 6 args (a0..a5)
    # so Linux's 6-arg syscalls (mmap, mremap, etc.) see %r8 / %r9.
    # Native syscalls only use a0..a3 so a4/a5 are simply ignored on
    # that branch.
    task: Ptr[TaskStruct] = current_task()
    if task[0].is_linux_userspace != 0:
        rc: int64 = linux_u_syscall_dispatch(nr, a0, a1, a2, a3, a4, a5)
        # §3: exit-side signal delivery. This is the ONLY place that
        # may build a user-handler rt_sigframe, because it knows the
        # syscall's return value (rc) and stashes it into the frame's
        # %rax slot so rt_sigreturn restores the interrupted code's
        # %rax correctly. Catches signals posted by the syscall itself
        # (kill(getpid()), write→SIGPIPE) so the handler runs at THIS
        # sysretq. signal_deliver_on_return returns rc unchanged.
        return cast[uint64](signal_deliver_on_return(cast[uint64](rc)))
    if nr == SYS_PUTC:
        early_putc(cast[int32](a0 & 0xFF))
        return 0
    if nr == SYS_EXIT:
        # Mark current task EXITED with the user-supplied exit code,
        # then yield. task_exit_current halts the box if there are
        # no other live tasks. M16.35: a0 carries the exit code so
        # SYS_WAITPID can return something meaningful to the parent.
        task_exit_current(cast[int64](a0))
        # Not reached unless schedule() somehow returns. Be defensive.
        local_irq_disable()
        while True:
            asm_volatile("hlt")
    if nr == SYS_GET_JIFFIES:
        return get_jiffies()
    if nr == SYS_CLONE:
        # a0 = entry point address of new user task. We don't have a
        # real binary loader yet, so callers pass the address of a
        # pre-existing user-mode function baked into the kernel image.
        # The child is a brand-new task; when schedule() picks it up
        # the iretq lands in `entry` directly (not in this syscall
        # return path) — so the child never sees this return value.
        # The parent gets back the child's slot index + 1 as a stand-
        # in pid.
        slot: int32 = create_user_task(a0, 0x5f5f636c6f6e655f)
        if slot < 0:
            set_current_errstr("clone: out of tasks")
            return cast[uint64](-1)
        return cast[uint64](slot) + 1
    if nr == SYS_GETPID:
        return current_task_pid()
    if nr == SYS_OPEN:
        abs_path: Array[256, uint8]
        rc: int32 = resolve_path(cast[Ptr[char]](a0), &abs_path[0], 256)
        if rc != 0:
            set_current_errstr("open: path too long")
            return cast[uint64](rc)
        rc = vfs_open(cast[Ptr[char]](&abs_path[0]))
        # Phase B / M16.93: integrate Plan 9 errstr so SYS_ERRSTR (265)
        # has something to report. vfs_open returns -ENOENT (-2) on
        # lookup miss; -EACCES on permission denied; we install fixed
        # human-readable strings so user code surfaces the cause.
        if rc == -2:
            set_current_errstr("file does not exist")
        elif rc < 0:
            set_current_errstr("open: failed")
        return cast[uint64](rc)
    if nr == SYS_OPEN_WRITE:
        abs_path: Array[256, uint8]
        rc: int32 = resolve_path(cast[Ptr[char]](a0), &abs_path[0], 256)
        if rc != 0:
            set_current_errstr("open for write: path too long")
            return cast[uint64](rc)
        rc = vfs_open_write(cast[Ptr[char]](&abs_path[0]))
        if rc < 0:
            set_current_errstr("open for write: failed")
        return cast[uint64](rc)
    if nr == SYS_READ:
        n: int64 = vfs_read(cast[int32](a0),
                            cast[Ptr[uint8]](a1), a2)
        if n < 0:
            set_current_errstr("read: bad fd")
        return cast[uint64](n)
    if nr == SYS_READ_NB:
        # Non-blocking read. Used by single-threaded event-loop daemons
        # (user/sshd.ad) that must poll a socket fd and a pipe fd in one
        # task. Returns >0 bytes ready now, 0 if the fd is open but has
        # no data this instant ("would block"), or -1 on a true EOF /
        # error. Unlike SYS_READ this never yields-and-spins; the caller
        # owns the poll cadence.
        n: int64 = vfs_read_nb(cast[int32](a0),
                               cast[Ptr[uint8]](a1), a2)
        return cast[uint64](n)
    if nr == SYS_YIELD:
        # Cooperative yield. Hamnix multitasks COOPERATIVELY: a task
        # only gives up the CPU inside a blocking syscall (SYS_WAITPID,
        # a blocking pipe / stdin read) — there is no working timer
        # preemption to rotate the runqueue underneath a task that
        # never blocks. A single-threaded non-blocking event-loop
        # daemon (user/sshd.ad's SSH<->hamsh bridge) therefore MUST
        # call SYS_YIELD explicitly on every idle poll iteration, or
        # it monopolises the CPU and the very task it is bridging to
        # (hamsh, and every command hamsh spawns) is starved forever —
        # STATE_READY but never scheduled. yield_to_others() rotates
        # to any other ready task and, when nobody else wants the CPU,
        # does an sti/hlt/cli so interrupts (UART RX, virtio-net) can
        # still make progress. Returns 0 unconditionally.
        yield_to_others()
        return 0
    if nr == SYS_CLOSE:
        rc: int32 = vfs_close(cast[int32](a0))
        if rc < 0:
            set_current_errstr("close: bad fd")
        return cast[uint64](rc)
    if nr == SYS_WRITE:
        n: int64 = vfs_write(cast[int32](a0),
                             cast[Ptr[uint8]](a1), a2)
        if n < 0:
            set_current_errstr("write: bad fd")
        return cast[uint64](n)
    if nr == SYS_LSEEK:
        n: int64 = vfs_lseek(cast[int32](a0),
                             cast[int64](a1), cast[int32](a2))
        if n < 0:
            set_current_errstr("seek: not seekable")
        return cast[uint64](n)
    if nr == SYS_EXECVE:
        return cast[uint64](do_execve(a0, a1, a2))
    if nr == SYS_SPAWN:
        # Like SYS_EXECVE but creates a NEW user task and returns its
        # pid to the caller. M16.38: a2 / a3 carry optional stdin /
        # stdout fds from the parent that should be dup'd into the
        # child's fd 0 / fd 1 before the task ever runs. -1 (read as
        # int32) means "inherit the default (serial)". The parent
        # owns its end of any pipe — closing it after spawn doesn't
        # affect the child, because dup_fd_to_child bumped refcounts.
        # U17: a4 = envp (Ptr[uint64] NULL-terminated array of
        # cstring pointers to "NAME=VALUE\0", or 0 for empty env).
        # Only honoured on the Linux-ABI path; native spawns still
        # inherit nothing because native binaries have no envp.
        # §4: namespace-aware lookup — see do_execve above. hamsh
        # spawns every Linux ELF through SYS_SPAWN, so this is the
        # path a `deb <cmd>` distro-namespace launch flows through.
        path: Ptr[char] = cast[Ptr[char]](a0)
        blob: uint64 = ns_blob_ptr(path)
        if blob == 0:
            set_current_errstr("spawn: file does not exist")
            return cast[uint64](-2)            # -ENOENT
        sz: uint64 = ns_blob_size(path)
        entry: uint64 = elf_load_blob(cast[Ptr[uint8]](blob), sz)
        if entry == 0:
            set_current_errstr("spawn: bad ELF image")
            return cast[uint64](-8)            # -ENOEXEC
        # 256 KiB user stack (64 contiguous pages, buddy order 6).
        # Earlier U26..U37 gave SYS_SPAWN'd tasks a single 4 KiB page,
        # then U38 bumped to 16 KiB. The per-process-address-space fork
        # (this commit) eager-copies the whole user stack on fork(); a
        # forked child unwinding through glibc's fork epilogue + atexit
        # + _IO_cleanup on its private stack wants comfortable headroom.
        ustack: uint64 = alloc_pages(LINUX_USTACK_ORDER)
        if ustack == 0:
            set_current_errstr("spawn: out of memory")
            return cast[uint64](-12)           # -ENOMEM
        ustack_top: uint64 = ustack + LINUX_USTACK_SIZE
        argc_out: uint64 = 0
        argv_out: uint64 = 0
        new_rsp: uint64 = 0
        # U16: branch on ABI before laying out the stack. Linux tasks
        # need argc + argv[] + envp + auxv at *rsp; native tasks get
        # argc/argv via %rdi/%rsi (planted in the iret frame inside
        # create_user_task_argv).
        is_linux: int32 = elf_last_was_linux
        if is_linux != 0:
            # U17: forward parent's envp (a4) into the child's init
            # stack. _build_user_argv_linux deep-copies each
            # "NAME=VALUE\0" so later parent edits don't disturb the
            # child's view.
            # U20: pass entry + load base so the child's auxv carries
            # AT_ENTRY / AT_PHDR / AT_PHNUM (glibc/musl _start needs
            # them to run _dl_relocate_static_pie).
            new_rsp = _build_user_argv_linux(ustack_top, a1, a4,
                                             entry, elf_last_load_base)
        else:
            new_rsp = _build_user_argv(ustack_top, a1,
                                       &argc_out, &argv_out)
        slot: int32 = create_user_task_argv(
            entry, 0x5f5f7370776e5f5f,         # "__spwn__"
            new_rsp, argc_out, argv_out,
        )
        if slot < 0:
            set_current_errstr("spawn: out of tasks")
            return cast[uint64](-1)
        # Per-process address space: record the loaded image span +
        # the user-stack region on the NEW task so that if the spawned
        # program later fork()s, do_clone can give the grandchild a
        # private copy of each. SYS_SPAWN is the path hamsh uses to
        # launch every Linux ELF, so without this every fork() from a
        # hamsh-spawned binary would find image_lo == 0 and fail to
        # copy glibc's writable .data/.bss.
        set_task_image_range(cast[uint64](slot),
                             elf_last_img_lo_get(),
                             elf_last_img_hi_get())
        set_task_ustack_range(cast[uint64](slot),
                              ustack, LINUX_USTACK_SIZE)
        # U30: install the ET_EXEC user-vaddr mapping into the child's
        # PML4 (cloned from BSP inside create_user_task_argv). The
        # child hasn't been scheduled yet, so its CR3 has never been
        # loaded — no explicit TLB flush needed; the load_cr3 in
        # schedule() will do it when the child first runs. ET_DYN
        # binaries make this a 0-return no-op.
        #
        # A < 0 return means the overlay was refused — either OOM, or
        # (the common case for fixed-address ET_EXEC binaries linked at
        # 0x400000) a collision with the kernel image. The task slot was
        # ALREADY created above and is STATE_READY: if we just returned
        # the error, schedule() would still pick the half-built task,
        # load_cr3 to its broken PML4, and freeze the box. Reap the slot
        # back to STATE_FREE first so the failure is clean + survivable.
        if elf_apply_last_user_mapping(task_pml4(slot)) < 0:
            printk0("spawn: user-mapping install failed; task slot reaped\n")
            task_reap(slot)
            set_current_errstr("spawn: cannot map binary (kernel-image collision?)")
            return cast[uint64](-8)            # -ENOEXEC
        # U5: SYS_SPAWN runs in the parent's context. If the loaded
        # image is a Linux-ABI ELF, flip is_linux_userspace on the
        # *child* slot (not current) so the new task's syscalls route
        # through u_syscalls. Doing this here instead of inside
        # elf_load_blob avoids mis-flagging the parent (hamsh).
        if is_linux != 0:
            set_linux_userspace_mode(slot, 1)
        parent: Ptr[TaskStruct] = current_task()
        sin:  int32 = cast[int32](a2)
        sout: int32 = cast[int32](a3)
        # HAMSH §7: stdio-as-named-channels mode. When the caller
        # passes SPAWN_STDIO_NS (-2) for stdin / stdout, the child's
        # standard streams are NAMES in its namespace — /fd/0,1,2,
        # served by the `#d` device — not dup'd integer fds. The child
        # gets a private COW copy of the caller's Pgrp (§9: an
        # external command gets a COW private namespace), which
        # carries a COW copy of the caller's /fd-name table. The
        # child's integer fds 0/1/2 are FD_DEVFD_MARK fds — the
        # Layer-2 mapping onto /fd/0,1,2 — so a Linux binary's
        # write(1,...) resolves the name /fd/1 through the child's own
        # namespace. The shell wires the child's /fd/N (pipe /
        # redirect / dup) via SYS_FDBIND before yielding to it. This
        # is the §7 model: one bind over channels.
        #
        # Any other sin/sout value keeps the legacy integer-fd dup
        # path (apt / sshd / distrofs / nsrun still pass real parent
        # fds): a value in [0,16) names a specific parent fd to dup
        # in; -1 means "inherit the parent's fd 0 / fd 1".
        if sin == SPAWN_STDIO_NS or sout == SPAWN_STDIO_NS:
            # Give the child a private COW Pgrp (clone of the caller's
            # ambient namespace, including its /fd-name table).
            cpidx: int32 = cast[int32](current_idx_get())
            caller_pg: uint64 = task_pgrp(cpidx)
            if caller_pg == 0:
                caller_pg = pgrp_current()
                set_task_pgrp(cpidx, caller_pg)
            child_pg: uint64 = pgrp_clone(caller_pg)
            if child_pg != 0:
                set_task_pgrp(slot, child_pg)
            else:
                # OOM on the clone — share the caller's Pgrp rather
                # than fail the spawn. The child still runs; its /fd
                # binds would be visible to the caller, an acceptable
                # degradation under memory pressure.
                set_task_pgrp(slot, caller_pg)
            # The child's integer fds 0/1/2 become FD_DEVFD_MARK fds
            # carrying fd-numbers 0/1/2 — the Layer-2 mapping onto the
            # names /fd/0,1,2. fd_buf holds the fd-number; vfs_read /
            # vfs_write resolve it through the child's devfd table.
            childp: Ptr[TaskStruct] = task_struct_at(slot)
            if cast[uint64](childp) != 0:
                childp[0].fd_idx[0] = FD_DEVFD_MARK
                childp[0].fd_buf[0] = 0
                childp[0].fd_pos[0] = 0
                childp[0].fd_idx[1] = FD_DEVFD_MARK
                childp[0].fd_buf[1] = 1
                childp[0].fd_pos[1] = 0
                childp[0].fd_idx[2] = FD_DEVFD_MARK
                childp[0].fd_buf[2] = 2
                childp[0].fd_pos[2] = 0
            return task_pid_at(slot)
        if sin >= 0 and sin < 16:
            dup_fd_to_child(slot, 0, parent, cast[uint64](sin))
        else:
            dup_fd_to_child(slot, 0, parent, cast[uint64](0))
        if sout >= 0 and sout < 16:
            dup_fd_to_child(slot, 1, parent, cast[uint64](sout))
        else:
            dup_fd_to_child(slot, 1, parent, cast[uint64](1))
        # Namespace inheritance: the spawned child SHARES the parent's
        # Pgrp (mount table) — POSIX fork+exec, and the Plan 9 rule that
        # a child inherits the parent's namespace unless it rforks.
        # create_user_task_argv wrote 0 (BSS default) into the child's
        # pgrp slot; we overwrite it with the parent's resolved Pgrp and
        # bump the refcount so child + parent both holding it is
        # accounted for. Without this, a dpkg/apt spawned from inside an
        # nsrun distro-shape namespace would run in the ROOT namespace
        # and its writes to /usr would miss the mounted distrofs trees.
        cur_idx: int32 = cast[int32](current_idx_get())
        parent_pg: uint64 = task_pgrp(cur_idx)
        if parent_pg == 0:
            parent_pg = pgrp_current()
            set_task_pgrp(cur_idx, parent_pg)
        set_task_pgrp(slot, parent_pg)
        pgrp_ref_inc(parent_pg)
        return task_pid_at(slot)
    if nr == SYS_PIPE:
        # Hand a pair of (rfd, wfd) back to the calling task. The
        # fds are stored at *(int32*)a0[0..1] — the caller passes
        # a Ptr[int32] to a two-element buffer.
        rc: int32 = vfs_pipe(cast[Ptr[int32]](a0))
        if rc < 0:
            set_current_errstr("pipe: out of fds")
        return cast[uint64](rc)
    if nr == SYS_SOCKET:
        # U-socket: native-ABI socket(2). a0=domain, a1=type,
        # a2=protocol. V0 supports AF_INET + SOCK_STREAM only;
        # _u_socket rejects everything else with a faithful errno and
        # sets the per-task errstr. The returned fd is a real
        # FD_SOCKET_MARK fd whose read/write/close already route
        # through the in-kernel TCP stack (fs/vfs.ad). Body is shared
        # verbatim with the Linux-ABI dispatcher.
        return cast[uint64](_u_socket(a0, a1, a2, a3, a4, a5))
    if nr == SYS_CONNECT:
        # U-socket: native-ABI connect(2). a0=socket fd, a1=Ptr to a
        # 16-byte struct sockaddr_in, a2=addrlen. Drives a real TCP
        # active open through drivers/net/tcp.ad; returns 0 on success
        # or a negative errno. Body shared with the Linux-ABI path.
        return cast[uint64](_u_connect(a0, a1, a2, a3, a4, a5))
    if nr == SYS_BIND_SOCK:
        # U-socket server side: native-ABI bind(2). a0=socket fd,
        # a1=Ptr struct sockaddr_in, a2=addrlen. Records the bound port
        # on the socket's backing record so listen(2) can pass it to
        # tcp_listen. Body shared with the Linux-ABI dispatcher.
        return cast[uint64](_u_bind(a0, a1, a2, a3, a4, a5))
    if nr == SYS_LISTEN_SOCK:
        # U-socket server side: native-ABI listen(2). a0=socket fd,
        # a1=backlog. Calls the in-kernel tcp_listen for the bound port
        # and moves the socket into the LISTENING state.
        return cast[uint64](_u_listen(a0, a1, a2, a3, a4, a5))
    if nr == SYS_ACCEPT_SOCK:
        # U-socket server side: native-ABI accept(2). a0=listening
        # socket fd, a1=Ptr sockaddr (peer, may be NULL), a2=Ptr
        # addrlen. Blocks (bounded) on tcp_accept; returns a fresh
        # socket fd for the accepted connection or a negative errno.
        return cast[uint64](_u_accept(a0, a1, a2, a3, a4, a5))
    if nr == SYS_TLS_CONNECT:
        # U-TLS: native-ABI tls_connect(2). a0=socket fd (already
        # connect(2)'d), a1=Ptr to a NUL-terminated hostname,
        # a2=hostname length. Runs the in-kernel TLS 1.3 handshake
        # (drivers/net/tls.ad) over the socket's TCP slot — including
        # server cert-chain validation against the CA store — and on
        # success marks the fd TLS-active so subsequent write(2)/
        # read(2) transparently encrypt / decrypt via the TLS record
        # layer (fs/vfs.ad's FD_SOCKET_MARK arms). Returns 0 or a
        # negative errno (-EPROTO on handshake / cert-validation
        # failure, so the caller never gets an un-validated channel).
        return cast[uint64](_u_tls_connect(a0, a1, a2, a3, a4, a5))
    if nr == SYS_SOCKETPAIR:
        # V5: Linux socketpair(2). Hand back two bidirectional fds in
        # *(int32*)a3[0..1]. Domain (a0) and protocol (a2) are
        # ignored at this scope (caller passes AF_UNIX=1, 0). Type
        # (a1) must be SOCK_STREAM (1) or SOCK_DGRAM (2); anything
        # else is EINVAL. Mirrors the SYS_PIPE failure-path shape
        # above.
        sp_type: uint64 = a1
        if sp_type != 1 and sp_type != 2:
            set_current_errstr("socketpair: bad type")
            return cast[uint64](-22)           # -EINVAL
        if a3 == 0:
            set_current_errstr("socketpair: NULL sv")
            return cast[uint64](-14)           # -EFAULT
        rc: int32 = vfs_socketpair(cast[Ptr[int32]](a3))
        if rc < 0:
            set_current_errstr("socketpair: out of fds")
        return cast[uint64](rc)
    if nr == SYS_KILL:
        # a0 = target pid, a1 = signal number. Post into the target's
        # sig_pending bitmap; delivery happens on the target's next
        # syscall return or yield. Returns 0 or -ESRCH if no such pid.
        tgt: int32 = task_lookup_by_pid(a0)
        if tgt < 0:
            set_current_errstr("kill: no such pid")
            return cast[uint64](-3)            # -ESRCH
        signal_post(cast[uint64](tgt), a1)
        return 0
    if nr == SYS_DUP:
        rc: int32 = vfs_dup(cast[int32](a0))
        if rc < 0:
            set_current_errstr("dup: bad fd")
        return cast[uint64](rc)
    if nr == SYS_DUP2:
        rc: int32 = vfs_dup2(cast[int32](a0), cast[int32](a1))
        if rc < 0:
            set_current_errstr("dup2: bad fd")
        return cast[uint64](rc)
    if nr == SYS_LISTDIR:
        abs_path: Array[256, uint8]
        rc: int32 = resolve_path(cast[Ptr[char]](a0), &abs_path[0], 256)
        if rc != 0:
            set_current_errstr("listdir: path too long")
            return cast[uint64](rc)
        n: int64 = vfs_listdir(cast[Ptr[char]](&abs_path[0]),
                               cast[Ptr[uint8]](a1), a2)
        if n < 0:
            set_current_errstr("listdir: not a directory")
        return cast[uint64](n)
    if nr == SYS_CHDIR:
        # Resolve to absolute first so the stored cwd is always
        # absolute. That keeps subsequent SYS_GETCWD coherent and
        # makes future "cd .." straightforward to implement.
        abs_path: Array[256, uint8]
        rc: int32 = resolve_path(cast[Ptr[char]](a0), &abs_path[0], 256)
        if rc != 0:
            return cast[uint64](rc)
        # Validate the resolved path is an existing directory BEFORE
        # we install it as the task cwd. Without this, real-hardware
        # testing on GNOME Boxes showed `cd nope/nope/nope` silently
        # accumulating bogus segments into per-task cwd and
        # `cd SUBDIR; ls` listing root. Strategy: open the path;
        # require the fd to be a directory marker (FD_DIR_MARK, set
        # by vfs.ad::_open_dir_*); close it. vfs_listdir() was the
        # obvious candidate but only routes /mnt + /ext today, so
        # /etc/{...} would spuriously fail.
        probe_fd: int32 = vfs_open(cast[Ptr[char]](&abs_path[0]))
        if probe_fd < 0:
            set_current_errstr("chdir: no such directory")
            return cast[uint64](-2)            # -ENOENT
        if vfs_fd_is_dir(probe_fd) == 0:
            vfs_close(probe_fd)
            set_current_errstr("chdir: not a directory")
            return cast[uint64](-20)           # -ENOTDIR
        vfs_close(probe_fd)
        rc = set_task_cwd(current_idx_get(), &abs_path[0])
        if rc < 0:
            set_current_errstr("chdir: path too long")
            return cast[uint64](-7)            # -E2BIG
        return 0
    if nr == SYS_GETCWD:
        # Copy current cwd into the user buffer, up to a1 bytes
        # including the NUL terminator. Returns the number of bytes
        # written (incl NUL) or -ERANGE if a1 is 0.
        if a1 == 0:
            set_current_errstr("getcwd: buffer too small")
            return cast[uint64](-34)           # -ERANGE
        src: Ptr[uint8] = get_cwd_buf(current_idx_get())
        dst: Ptr[uint8] = cast[Ptr[uint8]](a0)
        i: uint64 = 0
        while i + 1 < a1:
            c: uint8 = src[i]
            dst[i] = c
            i = i + 1
            if c == 0:
                return i
        dst[i] = 0
        return i + 1
    if nr == SYS_UNLINK:
        # Resolve to absolute first so vfs_unlink's prefix routing
        # sees the canonical form (matches SYS_OPEN's behaviour).
        abs_path: Array[256, uint8]
        rc: int32 = resolve_path(cast[Ptr[char]](a0), &abs_path[0], 256)
        if rc != 0:
            set_current_errstr("unlink: path too long")
            return cast[uint64](rc)
        rc = vfs_unlink(cast[Ptr[char]](&abs_path[0]))
        if rc < 0:
            set_current_errstr("unlink: no such file")
        return cast[uint64](rc)
    if nr == SYS_MKDIR:
        # fs/namei.c::do_mkdirat(). tmpfs is a real tree now (V1):
        # mkdir creates a directory entry under the resolved parent.
        # Resolve to an absolute path first so vfs_mkdir's prefix
        # routing + tmpfs's component walk see the canonical form
        # (matches SYS_OPEN / SYS_UNLINK). Non-tmpfs paths return
        # -EROFS (cpio is read-only; ext4 mkdir is a later job).
        abs_path: Array[256, uint8]
        rc: int32 = resolve_path(cast[Ptr[char]](a0), &abs_path[0], 256)
        if rc != 0:
            set_current_errstr("mkdir: path too long")
            return cast[uint64](rc)
        rc = vfs_mkdir(cast[Ptr[char]](&abs_path[0]))
        if rc < 0:
            set_current_errstr("mkdir: cannot create directory")
        return cast[uint64](rc)
    if nr == SYS_WAITPID:
        # Block until the named child enters STATE_EXITED, then
        # return its exit_code AND reap the slot. Without the reap
        # step, pipelines exhaust NTASKS within a handful of
        # commands — slot stays as STATE_EXITED forever and
        # create_user_task can't find a free slot.
        target: int32 = task_lookup_by_pid(a0)
        if target < 0:
            set_current_errstr("wait: no such child")
            return cast[uint64](-10)           # -ECHILD
        while task_state(target) != STATE_EXITED:
            yield_to_others()
            target = task_lookup_by_pid(a0)
            if target < 0:
                set_current_errstr("wait: no such child")
                return cast[uint64](-10)
        code: int64 = task_exit_code(target)
        task_reap(target)
        return cast[uint64](code)
    # Phase B / M16.93: Plan 9-shape native syscall block (256..265).
    # Every entry below returns -ENOSYS (38) except SYS_ERRSTR (265),
    # which has a real implementation in sys/src/9/port/error.ad.
    # The numbers exist now so user binaries built today don't need
    # to be rebuilt when Phase C lands the bodies for rfork / bind /
    # mount / create / stat / fstat / remove / fd2path.
    if nr == SYS_RFORK:
        # Phase C / M16.98: Plan 9-shape process / namespace primitive.
        # a0 = flags (RF* bit field). §1: a1 = child_stack and a2 = tls,
        # consumed only on the RFMEM thread path (sys_rfork_thread sets
        # them; the plain sys_rfork wrapper leaves them 0). a5 = user-
        # side %rbp captured by the runtime.S wrappers — do_rfork
        # patches the child's initial-stack image so the child's first
        # user-mode instruction has a valid frame pointer. SYS_CLONE (3)
        # stays for the Linux ABI; both work concurrently.
        return cast[uint64](do_rfork(cast[int32](a0), a1, a2, a5))
    if nr == SYS_BIND:
        # Phase C / M16.107: graft `new` (a0) onto `old` (a1) in the
        # calling task's namespace. a2 carries the MREPL/MBEFORE/
        # MAFTER flag bits — recorded by the mount table but only
        # MREPL is honoured at this milestone (union mounts are a
        # Phase D follow-up). Body lives in sys/src/9/port/syschan.ad.
        return cast[uint64](do_bind(a0, a1, cast[int32](a2)))
    if nr == SYS_MOUNT:
        # Phase C / M16.107: attach the srvfd (a0) at `old` (a2).
        # a1 = afd (auth — accepted but ignored, no fauth yet),
        # a3 = flag, a4 = spec (server attach string; recorded by
        # chan.ad but not dereferenced until Phase D's 9P client
        # lands). Real 9P traffic over the srvfd is hamwd's job.
        return cast[uint64](do_mount(cast[int32](a0),
                                     cast[int32](a1),
                                     a2,
                                     cast[int32](a3),
                                     a4))
    if nr == SYS_UNMOUNT:
        # Phase C / M16.107: remove bindings. a0=new (or 0 to
        # unbind everything at old), a1=old. Returns 0 on success
        # or -1 with errstr "not mounted" if nothing matched.
        return cast[uint64](do_unmount(a0, a1))
    if nr == SYS_FDBIND:
        # HAMSH §7: bind a Chan at an /fd/N name — THE one primitive
        # pipe, redirect, AND dup all reduce to. a0=pid (0=self),
        # a1=fdnum, a2=channel kind (DEVFD_*), a3=arg (pipe slot /
        # kernel fd / source /fd number, kind-dependent). dup is
        # kind==DEVFD_DUP with a3 the source /fd slot — no separate
        # dup syscall. Body in syschan.ad.
        return cast[uint64](do_fdbind(cast[int32](a0),
                                      cast[int32](a1),
                                      cast[int32](a2),
                                      cast[int32](a3)))
    if nr == SYS_PIPECHAN:
        # HAMSH §7: create a local pipe Chan pair; returns the pipe
        # SLOT id (not fds). The shell threads the slot into two
        # SYS_FDBIND calls — write end at the producer's /fd/1, read
        # end at the consumer's /fd/0. A local pipe never speaks 9P.
        return cast[uint64](do_pipechan())
    if nr == SYS_OPENCHAN:
        # HAMSH §7: open an on-disk file as a namespace-shareable
        # channel. a0=path, a1=write (0=read/lookup, 1=create+trunc).
        # Returns the tmpfs slot — the shell binds it at a child's
        # /fd/N (DEVFD_FILE) for `cmd > file` / `cmd < file`.
        return cast[uint64](do_openchan(a0, cast[int32](a1)))
    if nr == SYS_NSID:
        # HAMSH §13: an opaque, stable per-Pgrp namespace identity —
        # the calling task's Pgrp pointer. rfork(RFNAMEG) (every
        # `ns {}` / `enter` / `spawn`) gives the child a fresh Pgrp,
        # hence a fresh nsid. A live handle records the nsid it was
        # created under; using it where sys_nsid() differs is the
        # cross-namespace-handle error.
        return pgrp_current()
    if nr == SYS_DFS_LOAD:
        # distrofs persistent backing: load distrofs instance a0's
        # RAM-table snapshot from the ext4 volume into user buffer a1
        # (max a2 bytes). Returns bytes read, 0 if no snapshot exists
        # yet, -1 if no ext4 volume is mounted. Backing file name is
        # kernel-owned — userland passes only a small instance id, no
        # path (namespace law: the ext4 image is distrofs's private
        # backing, not a global route).
        return cast[uint64](vfs_distrofs_load(a0, a1, a2))
    if nr == SYS_DFS_SAVE:
        # distrofs persistent backing: persist a2 bytes from user
        # buffer a1 as distrofs instance a0's RAM-table snapshot on
        # the ext4 volume, fsync'd. Returns bytes written, -1 on
        # failure.
        return cast[uint64](vfs_distrofs_save(a0, a1, a2))
    if nr == SYS_NSLABEL:
        # HAMSH §14: mount handles. a0=op (0=stamp a label onto the
        # mount at a2[/a3], 1=unmount the entry carrying label a1).
        # `mount $srv /to as L` and `unmount L` both route here; a
        # label is the unique handle that lets a union branch be
        # named in /proc/self/ns and peeled off precisely.
        return cast[uint64](do_nslabel(cast[int32](a0), a1, a2, a3))
    if nr == SYS_NETCFG:
        # Network info + config. `ifconfig` reads/writes the IPv4
        # stack here. a0 = op; see SYS_NETCFG's comment above and
        # do_netcfg for the per-op argument layout.
        return cast[uint64](do_netcfg(a0, a1, a2))
    if nr == SYS_CREATE:
        # Phase C / M16.101: create-or-truncate + open. Body lives in
        # sys/src/9/port/sysfile.ad. a0=path, a1=flags, a2=mode.
        return cast[uint64](do_create(a0, cast[int32](a1),
                                      cast[uint32](a2)))
    if nr == SYS_STAT_P9:
        # Phase C / M16.101: 9P stat record by path. a0=path,
        # a1=buf, a2=nbuf. Writes a Dir record into buf; returns
        # bytes written or -1 with errstr.
        return cast[uint64](do_stat(a0, a1, a2))
    if nr == SYS_FSTAT_P9:
        # Phase C / M16.101: 9P stat record by open fd. a0=fd,
        # a1=buf, a2=nbuf.
        return cast[uint64](do_fstat(cast[int32](a0), a1, a2))
    if nr == SYS_REMOVE:
        # Phase C / M16.101: Plan 9-shape unlink. a0=path. Wraps
        # vfs_unlink. Replaces SYS_UNLINK (21) semantically; Phase G
        # retires the old number.
        return cast[uint64](do_remove(a0))
    if nr == SYS_FD2PATH:
        # Phase C / M16.101: recover path from an open fd. a0=fd,
        # a1=buf, a2=nbuf. Best-effort: returns the canonical archive
        # name for initramfs fds (may differ from the open()-time
        # path); synthetic /dev path for FD_*_MARK fds; -1 +
        # "backend has no path" for pipes / sockets / tmpfs / fat /
        # ext4 (Phase G adds per-fd path tracking).
        return cast[uint64](do_fd2path(cast[int32](a0), a1, a2))
    if nr == SYS_ERRSTR:
        # a0 = user buffer pointer, a1 = buffer length. The body
        # implements the Plan 9 swap-buffer semantics: read the
        # current task's errstr into the user's buffer AND, if the
        # user's buffer started with a non-zero byte, install that
        # string as the new current error. See sys/src/9/port/error.ad
        # for the full contract.
        return cast[uint64](_u_errstr(a0, a1))
    if nr == SYS_WSTAT:
        # Phase C: Plan 9 wstat — rename + chmod + truncate + utime
        # unified. a0=path, a1=Dir buf, a2=nbuf. This commit honours
        # the `name` (rename, tmpfs-only) and `mode` (no-op success)
        # fields; length / mtime / gid / muid must be sentinels.
        # Body in sys/src/9/port/sysfile.ad::do_wstat.
        return cast[uint64](do_wstat(a0, a1, a2))
    if nr == SYS_FWSTAT:
        # Phase C: fd-keyed wstat. a0=fd, a1=Dir buf, a2=nbuf. Only
        # FD_TMPFS_MARK fds are supported today; other backends
        # return -1 with "fwstat: backend not supported".
        return cast[uint64](do_fwstat(cast[int32](a0), a1, a2))
    if nr == SYS_RESOLVE:
        # U-resolve: native-ABI hostname -> IPv4. a0 = Ptr to a
        # NUL-terminated hostname, a1 = its byte length (advisory).
        # Bridges straight to the in-kernel DNS resolver
        # (drivers/net/dns.ad::dns_lookup), which sends an A-record
        # query over UDP/53 to the DHCP-supplied server and polls
        # virtio_net internally — the same blocking model apt's
        # SYS_CONNECT already uses, so it is safe here. On success we
        # pack the 4 octets big-endian into the low 32 bits (octet 0
        # in bits 31:24): a positive int64 is always a valid IPv4, a
        # negative int64 is an errno. Resolution failure (timeout /
        # NXDOMAIN / no DNS server) -> -ENOENT so userland surfaces a
        # clear "cannot resolve" diagnostic.
        if a0 == 0:
            set_current_errstr("resolve: null hostname")
            return cast[uint64](-2)            # -ENOENT
        # dns_lookup writes the 4-byte IPv4 (network order, octet 0
        # first) through this pointer. 200 jiffies (~2 s @ HZ=100)
        # matches the boot smoke + http.ad lookup budget.
        resolve_ip: Array[4, uint8]
        rc: int32 = dns_lookup(cast[Ptr[uint8]](a0),
                               cast[Ptr[uint8]](&resolve_ip[0]), 200)
        if rc != 0:
            set_current_errstr("resolve: cannot resolve hostname")
            return cast[uint64](-2)            # -ENOENT
        resolve_packed: uint64 = (cast[uint64](resolve_ip[0]) << 24) \
                               | (cast[uint64](resolve_ip[1]) << 16) \
                               | (cast[uint64](resolve_ip[2]) << 8) \
                               | cast[uint64](resolve_ip[3])
        return resolve_packed
    if nr == SYS_NOTIFY:
        # Phase C / M16.109: install (or clear, when a0==0) the
        # user-mode note handler for the current task. a0 = handler
        # entry RIP. Body in sys/src/9/port/sysnote.ad. Returns 0.
        return cast[uint64](do_notify(a0))
    if nr == SYS_NOTED:
        # Phase C / M16.109: handler-return primitive. a0 = action
        # (NCONT=0 / NDFLT=1 / NSAVE=2 / NRSTR=3); Phase C treats
        # every action as NCONT and restores the saved iret-frame
        # RIP/RSP. Body in sys/src/9/port/sysnote.ad.
        return cast[uint64](do_noted(cast[int32](a0)))
    if nr == SYS_SRV_POST:
        # Phase D / V4: publish (name -> srvfd) into the kernel-internal
        # srv table. a0 = NUL-terminated leaf name (Ptr[char]), a1 =
        # srvfd in the CALLER's fd table. Validation:
        #   * name must pass _srv_name_valid (1..32 bytes, printable
        #     ASCII, no '/' or leading '.').
        #   * srvfd must be open in the current task's fd table.
        #   * name must not collide with an existing entry, and the
        #     16-slot table must have room.
        # Returns 0 on success, -1 with errstr on any failure.
        nm: Ptr[char] = cast[Ptr[char]](a0)
        if _srv_name_valid(nm) == 0:
            set_current_errstr("srv: bad name")
            return cast[uint64](-1)
        post_fd: int32 = cast[int32](a1)
        if post_fd < 0 or post_fd >= 16:
            set_current_errstr("srv: bad fd")
            return cast[uint64](-1)
        if vfs_fd_is_open(post_fd) == 0:
            set_current_errstr("srv: bad fd")
            return cast[uint64](-1)
        poster_slot: int32 = cast[int32](current_idx_get())
        rc: int32 = devsrv_post_from(nm, post_fd, poster_slot)
        if rc < 0:
            # devsrv_post_from returns -1 for both "dup name" and
            # "table full". The two cases share an error string at
            # this milestone — `errstr` callers see one of these
            # two literals; a finer-grained distinction is V4.5 work
            # if a userspace tool needs to differentiate.
            set_current_errstr("srv: name in use or table full")
            return cast[uint64](-1)
        return 0
    if nr == SYS_SRV_OPEN:
        # Phase D / V4: look up (name) and dup the poster's underlying
        # file/pipe into the CALLER's fd table. a0 = NUL-terminated
        # leaf name (Ptr[char]). Returns the new fd on success or -1
        # with errstr on miss. The dup pattern follows sys_pipe and
        # sys_dup — _alloc_fd in the current task, then copy_fd_entry
        # bumps any pipe refcount so closing the poster's end doesn't
        # collapse the channel under the opener.
        nm2: Ptr[char] = cast[Ptr[char]](a0)
        if _srv_name_valid(nm2) == 0:
            set_current_errstr("srv: bad name")
            return cast[uint64](-1)
        src_slot: int32 = -1
        src_fd:   int32 = -1
        rc2: int32 = devsrv_lookup_full(nm2, &src_slot, &src_fd)
        if rc2 < 0:
            set_current_errstr("srv: not posted")
            return cast[uint64](-1)
        if src_slot < 0:
            # Kernel-posted entry (devsrv_post via the V3 entry point);
            # no source TaskStruct to dup from. The opener gets a clear
            # error rather than a silent ENOENT.
            set_current_errstr("srv: kernel-only")
            return cast[uint64](-1)
        src_task: Ptr[TaskStruct] = task_struct_at(src_slot)
        if cast[uint64](src_task) == 0:
            set_current_errstr("srv: poster gone")
            return cast[uint64](-1)
        new_fd: int32 = vfs_srv_dup_into_current(src_task,
                                                 cast[uint64](src_fd))
        if new_fd < 0:
            set_current_errstr("srv: dup failed")
            return cast[uint64](-1)
        return cast[uint64](new_fd)
    if nr == SYS_INIT_MODULE:
        # Linux-ABI .ko loader (L1). a0=Ptr[uint8] image, a1=size,
        # a2=Ptr[char] params (param string, NUL-terminated; can be
        # NULL or empty). Returns module slot id (>= 1) on success
        # or -errno on parse / OOM failure. The L1 loader ignores
        # `params`; the L2 milestone parses MODULE_PARM_DESC entries
        # and pushes the values into the module's .data section.
        rc: int32 = kmod_linux_load(cast[Ptr[uint8]](a0), a1)
        if rc < 0:
            set_current_errstr("init_module: bad image or out of slots")
        return cast[uint64](rc)
    if nr == SYS_DELETE_MODULE:
        # delete_module(name, flags). For L1 we ignore `name` (no
        # /proc/modules name index yet) and treat a0 as the slot id
        # returned by SYS_INIT_MODULE. Wrapped this way so userland
        # rmmod can write `delete_module(name=<slot encoded>, 0)`
        # without spinning up a full name->slot lookup. L2 grows the
        # name index.
        rc: int32 = kmod_linux_unload(cast[int32](a0))
        if rc < 0:
            set_current_errstr("delete_module: not loaded")
        return cast[uint64](rc)
    printk2("Hamnix: unknown syscall nr=%d a0=%x\n", nr, a0)
    set_current_errstr("unknown syscall")
    return cast[uint64](-1)


# --- SYS_NETCFG: network info + static configuration ----------------
#
# The single kernel choke point behind the `ifconfig` command. The
# IPv4 stack's address / netmask / gateway live in drivers/net/ip.ad;
# the DNS resolver in drivers/net/dns.ad; the DHCP lease state in
# drivers/net/dhcp.ad. do_netcfg bridges all three to userland.
#
# op 0 (GET): a1 = Ptr to a 24-byte buffer. Layout (every IP is 4
#   bytes, network order):
#     [0..3]   our IPv4 address       (zeros if unset)
#     [4..7]   netmask                (zeros if unset)
#     [8..11]  default gateway        (zeros if unset)
#     [12..15] DNS server             (zeros if unset)
#     [16]     have_addr   (0/1)
#     [17]     have_mask   (0/1)
#     [18]     have_gw     (0/1)
#     [19]     have_dns    (0/1)
#     [20]     cfg_source  (0=none, 1=DHCP, 2=static)  — for addr/gw
#     [21]     dns_source  (0=DHCP, 1=static)
#     [22..23] reserved (zeroed)
#   Returns 0.
#
# op 1 (SET_ADDR): a1 = address packed (octet0<<24 | .. | octet3),
#   a2 = netmask packed the same way. Installs a STATIC address +
#   mask (latches ip_cfg_source = static). Returns 0.
#
# op 2 (SET_GW): a1 = gateway packed. Installs a STATIC gateway.
#   Returns 0.
#
# op 3 (SET_DNS): a1 = DNS server packed. Pins a STATIC resolver.
#   Returns 0.
#
# Any other op returns -1 with errstr.

def do_netcfg(op: uint64, a1: uint64, a2: uint64) -> int64:
    if op == 0:
        # GET — fill the caller's 24-byte buffer.
        if a1 == 0:
            set_current_errstr("netcfg: null buffer")
            return -1
        buf: Ptr[uint8] = cast[Ptr[uint8]](a1)
        i: uint64 = 0
        while i < 24:
            buf[i] = 0
            i = i + 1
        have_addr: int32 = ip_have_our_ip()
        have_gw:   int32 = ip_have_gateway()
        have_mask: int32 = ip_have_netmask()
        if have_addr == 1:
            buf[0] = ip_our_ip_b(0)
            buf[1] = ip_our_ip_b(1)
            buf[2] = ip_our_ip_b(2)
            buf[3] = ip_our_ip_b(3)
            buf[16] = 1
        if have_mask == 1:
            buf[4] = ip_netmask_b(0)
            buf[5] = ip_netmask_b(1)
            buf[6] = ip_netmask_b(2)
            buf[7] = ip_netmask_b(3)
            buf[17] = 1
        else:
            # ip.ad has no mask of its own — surface what DHCP knows
            # (option 1 from the OFFER/ACK) so the display is honest
            # even if the install path didn't carry the mask.
            dmask: Array[4, uint8]
            if dhcp_get_mask(cast[Ptr[uint8]](&dmask[0])) == 0:
                buf[4] = dmask[0]
                buf[5] = dmask[1]
                buf[6] = dmask[2]
                buf[7] = dmask[3]
                buf[17] = 1
        if have_gw == 1:
            buf[8]  = ip_gateway_b(0)
            buf[9]  = ip_gateway_b(1)
            buf[10] = ip_gateway_b(2)
            buf[11] = ip_gateway_b(3)
            buf[18] = 1
        dns_tmp: Array[4, uint8]
        dns_rc: int32 = dns_get_server(cast[Ptr[uint8]](&dns_tmp[0]))
        if dns_rc >= 0:
            buf[12] = dns_tmp[0]
            buf[13] = dns_tmp[1]
            buf[14] = dns_tmp[2]
            buf[15] = dns_tmp[3]
            buf[19] = 1
            if dns_rc == 1:
                buf[21] = 1
        buf[20] = ip_cfg_source_get()
        return 0
    if op == 1:
        # SET_ADDR — a1 = packed address, a2 = packed netmask.
        addr0: uint8 = cast[uint8]((a1 >> 24) & 0xFF)
        addr1: uint8 = cast[uint8]((a1 >> 16) & 0xFF)
        addr2: uint8 = cast[uint8]((a1 >> 8) & 0xFF)
        addr3: uint8 = cast[uint8](a1 & 0xFF)
        mask0: uint8 = cast[uint8]((a2 >> 24) & 0xFF)
        mask1: uint8 = cast[uint8]((a2 >> 16) & 0xFF)
        mask2: uint8 = cast[uint8]((a2 >> 8) & 0xFF)
        mask3: uint8 = cast[uint8](a2 & 0xFF)
        ip_apply_static_addr(addr0, addr1, addr2, addr3,
                             mask0, mask1, mask2, mask3)
        return 0
    if op == 2:
        # SET_GW — a1 = packed gateway.
        gw0: uint8 = cast[uint8]((a1 >> 24) & 0xFF)
        gw1: uint8 = cast[uint8]((a1 >> 16) & 0xFF)
        gw2: uint8 = cast[uint8]((a1 >> 8) & 0xFF)
        gw3: uint8 = cast[uint8](a1 & 0xFF)
        ip_apply_static_gw(gw0, gw1, gw2, gw3)
        return 0
    if op == 3:
        # SET_DNS — a1 = packed DNS server.
        d0: uint8 = cast[uint8]((a1 >> 24) & 0xFF)
        d1: uint8 = cast[uint8]((a1 >> 16) & 0xFF)
        d2: uint8 = cast[uint8]((a1 >> 8) & 0xFF)
        d3: uint8 = cast[uint8](a1 & 0xFF)
        dns_set_static_server(d0, d1, d2, d3)
        return 0
    set_current_errstr("netcfg: bad op")
    return -1


def _netcfg_pack(b0: uint8, b1: uint8, b2: uint8, b3: uint8) -> uint64:
    # Pack a 4-octet IPv4 into a uint64 the way the `ifconfig` command
    # does for the SYS_NETCFG SET_* ops (octet 0 in bits 31:24).
    return (cast[uint64](b0) << 24) | (cast[uint64](b1) << 16) \
         | (cast[uint64](b2) << 8) | cast[uint64](b3)


def netcfg_smoke_test():
    # In-kernel smoke test for the SYS_NETCFG path (the syscall behind
    # the `ifconfig` command). Runs after the live SLIRP DHCP path has
    # reached BOUND so we can prove both:
    #   1. GET reflects the DHCP-assigned address as cfg_source == DHCP.
    #   2. A static SET_ADDR / SET_GW / SET_DNS takes effect and the
    #      following GET shows cfg_source == static with the new values.
    #
    # GATED on /etc/netcfg-test (the test pins a static config, which
    # would perturb downstream net tests; only scripts/test_net_cfg.sh
    # plants the marker). Drives do_netcfg directly — exactly the path
    # SYS_NETCFG dispatches to.
    #
    # PASS markers (consumed by scripts/test_net_cfg.sh):
    #   [netcfg] dhcp-reflect PASS  — GET showed the DHCP lease
    #   [netcfg] static-addr PASS   — SET_ADDR took effect
    #   [netcfg] static-gw PASS     — SET_GW took effect
    #   [netcfg] static-dns PASS    — SET_DNS took effect
    #   [netcfg] PASS               — all four observed
    buf: Array[24, uint8]
    bp: uint64 = cast[uint64](&buf[0])

    # --- 1. GET reflects the DHCP lease -----------------------------
    if do_netcfg(0, bp, 0) != 0:
        printk0("[netcfg] FAIL (GET op returned non-zero)\n")
        return
    if buf[16] != 1:
        printk0("[netcfg] FAIL (GET: no address — DHCP not bound?)\n")
        return
    if buf[20] != 1:
        printk1("[netcfg] FAIL (GET: cfg_source=%d expected 1=DHCP)\n",
                cast[uint64](buf[20]))
        return
    printk0("[netcfg] dhcp-reflect PASS ip=")
    printk1("%d", cast[uint64](buf[0]))
    printk0(".")
    printk1("%d", cast[uint64](buf[1]))
    printk0(".")
    printk1("%d", cast[uint64](buf[2]))
    printk0(".")
    printk1("%d", cast[uint64](buf[3]))
    printk0(" source=dhcp\n")

    # --- 2. SET_ADDR: pin 192.168.50.10 / 255.255.255.0 -------------
    if do_netcfg(1, _netcfg_pack(192, 168, 50, 10),
                 _netcfg_pack(255, 255, 255, 0)) != 0:
        printk0("[netcfg] FAIL (SET_ADDR returned non-zero)\n")
        return
    if do_netcfg(0, bp, 0) != 0:
        printk0("[netcfg] FAIL (GET after SET_ADDR)\n")
        return
    if buf[0] != 192 or buf[1] != 168 or buf[2] != 50 or buf[3] != 10:
        printk0("[netcfg] FAIL (SET_ADDR: address not applied)\n")
        return
    if buf[4] != 255 or buf[5] != 255 or buf[6] != 255 or buf[7] != 0:
        printk0("[netcfg] FAIL (SET_ADDR: netmask not applied)\n")
        return
    if buf[20] != 2:
        printk1("[netcfg] FAIL (SET_ADDR: cfg_source=%d expected 2)\n",
                cast[uint64](buf[20]))
        return
    printk0("[netcfg] static-addr PASS ip=192.168.50.10/24 source=static\n")

    # --- 3. SET_GW: pin 192.168.50.1 --------------------------------
    if do_netcfg(2, _netcfg_pack(192, 168, 50, 1), 0) != 0:
        printk0("[netcfg] FAIL (SET_GW returned non-zero)\n")
        return
    if do_netcfg(0, bp, 0) != 0:
        printk0("[netcfg] FAIL (GET after SET_GW)\n")
        return
    if buf[8] != 192 or buf[9] != 168 or buf[10] != 50 or buf[11] != 1:
        printk0("[netcfg] FAIL (SET_GW: gateway not applied)\n")
        return
    printk0("[netcfg] static-gw PASS gw=192.168.50.1\n")

    # --- 4. SET_DNS: pin 1.1.1.1 ------------------------------------
    if do_netcfg(3, _netcfg_pack(1, 1, 1, 1), 0) != 0:
        printk0("[netcfg] FAIL (SET_DNS returned non-zero)\n")
        return
    if do_netcfg(0, bp, 0) != 0:
        printk0("[netcfg] FAIL (GET after SET_DNS)\n")
        return
    if buf[12] != 1 or buf[13] != 1 or buf[14] != 1 or buf[15] != 1:
        printk0("[netcfg] FAIL (SET_DNS: server not applied)\n")
        return
    if buf[21] != 1:
        printk1("[netcfg] FAIL (SET_DNS: dns_source=%d expected 1)\n",
                cast[uint64](buf[21]))
        return
    printk0("[netcfg] static-dns PASS dns=1.1.1.1 source=static\n")

    printk0("[netcfg] PASS\n")
