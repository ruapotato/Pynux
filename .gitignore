# Build outputs
*.elf
*.bin
*.hex
*.o
*.s
!runtime/*.s
# ISO images — the higher-half kernel can't be `qemu -kernel`-booted
# (64-bit ELF); the test harness wraps it in a throwaway GRUB ISO
# (scripts/_kernel_iso.sh), often written next to a kernel .elf.
*.iso

# QEMU
*.img

# x86_64 kernel-module build artifacts (kbuild + Pynux-generated .S)
kernel-modules/**/*.S
kernel-modules/**/*.ko
kernel-modules/**/*.mod
kernel-modules/**/*.mod.c
kernel-modules/**/*.order
kernel-modules/**/*.symvers
kernel-modules/**/.*.cmd
kernel-modules/**/.tmp_versions/
# ...with a force-include exception for the stock Linux e1000e.ko
# checked in for the strategic-pivot demo (loaded via L-series loader
# at boot in place of the hand-rolled drivers/net/e1000e.ad).
!kernel-modules/e1000e/e1000e.ko
# Same force-include for the r8169 (Realtek consumer NIC) and igb
# (Intel server/workstation NIC) drivers — scaling the L-shim to a
# multi-NIC matrix on top of the e1000e proof-of-concept.
!kernel-modules/r8169/r8169.ko
!kernel-modules/igb/igb.ko
# Storage-pivot batch: stock Linux ahci.ko (SATA AHCI controller)
# and nvme.ko (PCIe NVMe SSD) for the L-shim storage validation.
!kernel-modules/ahci/ahci.ko
!kernel-modules/nvme/nvme.ko
# USB host-controller drivers (usbcore + xhci_pci + xhci_hcd +
# ehci_pci + ehci_hcd).
!kernel-modules/usbcore/usbcore.ko
!kernel-modules/xhci_pci/xhci_pci.ko
!kernel-modules/xhci_hcd/xhci_hcd.ko
!kernel-modules/ehci_pci/ehci_pci.ko
!kernel-modules/ehci_hcd/ehci_hcd.ko
# Intel HD Audio family — snd_hda_intel.ko plus 4 deps. Filenames
# normalised to underscores so modprobe's path emitter finds them.
!kernel-modules/snd/snd.ko
!kernel-modules/snd_pcm/snd_pcm.ko
!kernel-modules/snd_hda_core/snd_hda_core.ko
!kernel-modules/snd_hda_codec/snd_hda_codec.ko
!kernel-modules/snd_hda_intel/snd_hda_intel.ko
# WiFi framework modules — foundational for every wifi driver.
# No PCI alias; loaded explicitly via /etc/framework-modules.
!kernel-modules/cfg80211/cfg80211.ko
!kernel-modules/mac80211/mac80211.ko
initramfs.cpio.gz
# Generated cpio-archive assembly blob — regenerated by build_initramfs.py
# on every build_iso.sh / run_x86_bare.sh / test_*.sh run, so it should
# never be tracked. (Was tracked historically; untracked 2026-05-20.)
fs/initramfs_blob.S

