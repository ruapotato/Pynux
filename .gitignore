# Debian minbase rootfs staged by tests/distros/debian-minbase/BUILD.sh
# (~80-150 MB of real Debian binaries — too large to commit, and
# upstream archive is the source of truth). BUILD.sh + MANIFEST.txt +
# HOWTO.md stay tracked.
