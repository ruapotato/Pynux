# =====================================================================

def linux_abi_register_snd_core():
    # Called from linux_abi_exports_init() after the api_igb batch.
    # Adds the snd-core surface so snd.ko + every module that depends
    # on snd_* (snd-pcm, snd-hda-*, snd-hda-intel) loads via the
    # L-series loader.

    # ---- snd_card lifecycle ----
    _add_export("snd_card_new",
                cast[uint64](&_snd_card_new))
    _add_export("snd_card_free",
                cast[uint64](&_snd_card_free))
    _add_export("snd_card_disconnect",
                cast[uint64](&_snd_card_disconnect))
    _add_export("snd_card_register",
                cast[uint64](&_snd_card_register))
    _add_export("snd_card_file_add",
                cast[uint64](&_snd_card_file_add))
    _add_export("snd_card_file_remove",
                cast[uint64](&_snd_card_file_remove))
    _add_export("snd_card_rw_proc_new",
                cast[uint64](&_snd_card_rw_proc_new))

    # ---- snd_device lifecycle ----
    _add_export("snd_device_new",
                cast[uint64](&_snd_device_new))
    _add_export("snd_device_register",
                cast[uint64](&_snd_device_register))
    _add_export("snd_device_disconnect",
                cast[uint64](&_snd_device_disconnect))
    _add_export("snd_device_free",
                cast[uint64](&_snd_device_free))
    _add_export("snd_device_initialize",
                cast[uint64](&_snd_device_initialize))

    # ---- snd_ctl ----
