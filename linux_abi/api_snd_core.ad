# linux_abi/api_snd_core.ad
#
# Linux sound-subsystem core (snd.ko) — ALSA's `card` / `device` /
# `control` / `info` / `hwdep` / `timer` / `jack` framework. Stock
# Debian 6.1.0-32 snd.ko has 144 UND symbols; L<=68 + the NIC family
# resolve 100 of them. This file closes the 44-symbol gap so the
# L-series loader can insmod snd.ko, plus exposes the snd_* family
# entry points so dependent modules (snd-pcm, snd-hda-core,
# snd-hda-codec, snd-hda-intel) get every "needs snd_*" external
# wired straight to a Hamnix-side stub — same V0 strategy the NIC
# scale-out used (shim ALL cross-.ko refs so modules.dep isn't
# required for load ordering to work).
#
# Categories of fresh exports (count is against the post-igb
# 1556-export baseline):
#
#   * ~50 snd_* framework entry points — snd_card_new/_free/_register/
#     _disconnect, snd_card_file_add/_remove, snd_device_new/_register/
#     _disconnect/_free/_initialize, snd_ctl_* (add/remove/new1/find_id/
#     enum_info/boolean_mono_info/register_ioctl, etc.), snd_info_*
#     (create_card_entry / create_module_entry / free_entry / register /
#     get_line / get_str), snd_hwdep_new, snd_jack_new/_report/_set_key,
#     snd_timer_new/_interrupt/_notify, snd_array_new/_free,
#     snd_dma_alloc_dir_pages/_free_pages, snd_sgbuf_get_addr/_chunk_size,
#     snd_kill_fasync, snd_fasync_helper/_free, snd_register_device,
#     snd_unregister_device, snd_lookup_minor_data, snd_component_add,
#     snd_power_wait, snd_pci_quirk_lookup/_id, snd_card_rw_proc_new,
#     snd_pcm_add_chmap_ctls (lives in snd_pcm but is referenced by
#     snd_hda_core's gap so we point it at the snd_pcm shim — wired
#     in api_snd_pcm.ad's register call), snd_ctl_apply_vmaster_followers,
#     snd_ctl_add_vmaster_hook, snd_ctl_make_virtual_master,
#     snd_ctl_sync_vmaster, _snd_ctl_add_follower, snd_ctl_rename_id.
#
#   * 1 snd_* DATA symbol — `snd_major`. Linux's snd-core registers
#     a sound major (default 116); userland opens /dev/snd/* against
#     that major. We expose a 4-byte int holding 116 — the value never
#     changes once snd-core finishes its module-init.
#
#   * 1 `sound_class` DATA pointer — Linux's `struct class *sound_class`
#     points at /sys/class/sound. We expose an 8-byte pointer slot
#     holding 0 (NULL is OK — code paths that take sound_class only
#     dereference it inside class_create-style helpers, which our
#     L<=68 surface already short-circuits).
#
#   * 18 generic-kernel cold-path stubs unique to snd.ko's UND gap:
#     register_sound_special_device, unregister_sound_special (legacy
#     OSS /dev/dsp-style minor allocator — not used by ALSA's snd_*
#     callers), proc_create_data, proc_mkdir_mode, proc_set_size,
#     proc_symlink (per-card /proc entries — cold), input_allocate_device,
#     input_event, input_free_device, input_register_device,
#     input_set_capability, input_unregister_device (jack-detect input
#     device — only registered on real codec hotplug), kobject_set_name
#     (sysfs name setter — class_create-style helpers don't fire here),
#     devm_add_action, devm_remove_action, devres_add, __devres_alloc_node,
#     devres_find, devres_free (devres lifetime tracking — cold without
#     a real device_release), free_dma, request_dma (legacy ISA-DMA
#     channel allocator — never fires for PCI HDA), dma_spin_lock,
#     stream_open, fasync_helper, kill_fasync (file-level helpers —
#     cold without an /dev/snd/* fd open), single_open_size (procfs
#     single-shot show — cold), pid_vnr (PID-namespace VID — single
#     namespace), release_resource (I/O resource tree — cold without
#     real ISA), strlcat, vmemdup_user, downgrade_write, memcpy_toio,
#     _raw_read_lock_irqsave, _raw_read_unlock_irqrestore,
#     _raw_write_lock_irqsave, _raw_write_unlock_irqrestore,
#     __list_del_entry_valid, kvmalloc_node, xa_destroy, xa_erase,
#     __xa_insert, xa_load, xa_store_range.
#
# Stub philosophy: every shim here is init-cold for a vanilla insmod
# of snd.ko / snd-pcm.ko / snd-hda-{core,codec,intel}.ko. The PCM
# playback / capture path stays dormant — opening /dev/snd/pcmC0D0p
# eventually lands a -ENODEV through the un-wired fops, but the
# modules themselves load and probe.
#
# The "_snd_" prefix marks the Hamnix-side shim — same prefix-naming
# discipline the NIC-family agents used.

from linux_abi.exports import _add_export
from kernel.printk.printk import printk0
from mm.slab import kmalloc, kfree, kzalloc

extern def memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64) -> Ptr[uint8]
extern def memset(dst: Ptr[uint8], val: int32, n: uint64) -> Ptr[uint8]


# =====================================================================
# DATA buffers for "global state" symbols
# =====================================================================
#
# snd_major: Linux's sound-major number. Userland's open("/dev/snd/...")
# resolves to (sound_major, minor); the value is fixed at 116 in stock
# kernels. We expose a 4-byte int holding 116.
snd_major_var:          int32 = 116

# sound_class: struct class *sound_class. Linux populates this in
# snd-core's module-init via class_create("sound"). Modules that
# need the pointer (jack-detect, codec sysfs) read it but never
# dereference deeper than the class_register fast-paths we already
# short-circuit. Expose an 8-byte slot holding 0.
snd_sound_class_var:    uint64 = 0

# snd_hda_bus_type: Linux's `struct bus_type snd_hda_bus_type`.
# Lives at the snd-hda-codec module image but is referenced by
# every codec module (realtek/hdmi/via/...) and by the controller.
# Codec module-init paths read bus_type.dev_groups + bus_type.name;
# a zeroed 256-byte slot keeps every read inside the slot.
snd_hda_bus_type_buf:   Array[256, uint8]

# dma_spin_lock: kernel-global `spinlock_t dma_spin_lock`. A spinlock_t
# is a 64-byte (sometimes smaller) struct on x86_64; modules call
# raw_spin_lock_irqsave(&dma_spin_lock) which only reads/writes the
# memory at &dma_spin_lock. Without preemption (our env), a zeroed
# slot works — every lock acquisition succeeds, every release no-ops.
snd_dma_spin_lock_buf:  Array[64, uint8]


# =====================================================================
# Group 1: snd_card lifecycle
# =====================================================================
#
# A `struct snd_card` is ALSA's top-level container for a single audio
# device (one PCI HDA controller -> one snd_card). The driver allocates
# it with snd_card_new, attaches PCM/control/hwdep "devices" to it,
# then snd_card_register makes /dev/snd/* visible. For V0 we hand back
# a kzalloc'd 4 KiB buffer that's large enough to back every struct
# snd_card field the in-tree drivers touch through the pointer (Linux's
# real struct is ~1.2 KiB at 6.1).

def _snd_card_new(parent: uint64, idx: int32, xid: Ptr[char],
                   module: uint64, extra_size: int32,
                   card_ret: Ptr[uint64]) -> int32:
    # int snd_card_new(struct device *parent, int idx, const char *xid,
    #                  struct module *, size_t extra_size,
    #                  struct snd_card **card_ret);
    # Allocates the snd_card. We return 0 (success) and stash a fresh
    # 4 KiB zeroed slab into *card_ret.
    card: uint64 = kzalloc(4096)
    if card == 0:
        return -12                              # -ENOMEM
    if cast[uint64](card_ret) != 0:
        card_ret[0] = card
    return 0


def _snd_card_free(card: uint64) -> int32:
    # int snd_card_free(struct snd_card *);
    # Releases the card. With kzalloc-only backing we kfree it.
    if card != 0:
        kfree(card)
    return 0


def _snd_card_disconnect(card: uint64) -> int32:
    # int snd_card_disconnect(struct snd_card *);
    # Marks the card for disconnect (driver_unbind path). We don't
    # track per-card device lists; a no-op success is correct.
    return 0


def _snd_card_register(card: uint64) -> int32:
    # int snd_card_register(struct snd_card *);
    # Finalises /dev/snd/* nodes and exposes the card to userland.
    # Without a real /dev/snd registrar, return success; userland
    # never finds the device anyway because our chrdev table is
    # not wired into the L-shim sound class.
    return 0


def _snd_card_file_add(card: uint64, file: uint64) -> int32:
    # Tracks an open file against a card so refcount drives unbind.
    return 0


def _snd_card_file_remove(card: uint64, file: uint64) -> int32:
    return 0


def _snd_card_rw_proc_new(card: uint64, name: Ptr[char], priv: uint64,
                            read_op: uint64, write_op: uint64,
                            entry_ret: uint64) -> int32:
    # int snd_card_rw_proc_new(struct snd_card *, const char *name,
    #                            void *priv, snd_info_read_t *,
    #                            snd_info_write_t *, struct snd_info_entry **);
    # Adds a procfs entry rooted at /proc/asound/cardN/. Cold path.
    return 0


