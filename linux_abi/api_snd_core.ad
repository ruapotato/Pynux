# =====================================================================
# Group 6: snd_array_*
# =====================================================================
#
# snd_array is ALSA's grow-on-demand slab — codec drivers use it for
# arrays of controls / nodes. snd_array_new returns a pointer to the
# Nth element (allocating as needed); snd_array_free releases.

def _snd_array_new(array: uint64) -> uint64:
    # struct snd_array { void *list; unsigned int used; unsigned int alloc_max;
    #                     unsigned int elem_size; unsigned int alloc_align;
    #                     ... };
    # Linear bump-allocator over array->list, growing it via krealloc.
    # We back V0 with a fresh kzalloc each call; the elem_size is at
    # struct offset 12 (uint32) per snd_array layout. Returning NULL
    # is a benign "out of memory" the driver tolerates.
    if array == 0:
        return 0
    sz_ptr: Ptr[uint32] = cast[Ptr[uint32]](array + 12)
    sz: uint64 = cast[uint64](sz_ptr[0])
    if sz == 0:
        sz = 64
    return kzalloc(sz)


def _snd_array_free(array: uint64):
    return


# =====================================================================
# Group 7: snd_dma / snd_sgbuf
# =====================================================================

def _snd_dma_alloc_dir_pages(type: int32, dev: uint64, dir: int32,
                              size: uint64, dmab: uint64) -> int32:
    # int snd_dma_alloc_dir_pages(int type, struct device *, enum dma_data_direction,
    #                              size_t size, struct snd_dma_buffer *);
    # dmab fields: dmab->area (cpu va), dmab->addr (dma handle),
    # dmab->bytes, dmab->dev. For V0 we kzalloc and fill area + bytes;
    # addr stays 0 since insmod-cold paths don't program DMA.
    if dmab == 0:
        return -22                              # -EINVAL
    area: uint64 = kzalloc(size)
    if area == 0:
        return -12                              # -ENOMEM
    # struct snd_dma_buffer layout (kernel 6.1):
    #   .dev    (struct snd_dma_device, 24 bytes)
    #   .area   (void *,        offset 24)
    #   .addr   (dma_addr_t,    offset 32)
    #   .bytes  (size_t,        offset 40)
    #   .private_data (void *,  offset 48)
    area_ptr: Ptr[uint64] = cast[Ptr[uint64]](dmab + 24)
    addr_ptr: Ptr[uint64] = cast[Ptr[uint64]](dmab + 32)
    bytes_ptr: Ptr[uint64] = cast[Ptr[uint64]](dmab + 40)
    area_ptr[0] = area
    addr_ptr[0] = area                          # identity-mapped
    bytes_ptr[0] = size
    return 0


def _snd_dma_free_pages(dmab: uint64):
    if dmab == 0:
        return
    area_ptr: Ptr[uint64] = cast[Ptr[uint64]](dmab + 24)
    area: uint64 = area_ptr[0]
    if area != 0:
        kfree(area)
        area_ptr[0] = 0


def _snd_sgbuf_get_addr(dmab: uint64, offset: uint64) -> uint64:
    # dma_addr_t snd_sgbuf_get_addr(struct snd_dma_buffer *, size_t offset);
    # Contiguous V0 backing -> base + offset.
    if dmab == 0:
        return 0
    addr_ptr: Ptr[uint64] = cast[Ptr[uint64]](dmab + 32)
    return addr_ptr[0] + offset


def _snd_sgbuf_get_chunk_size(dmab: uint64, ofs: uint32,
                                size: uint32) -> uint32:
    # unsigned int snd_sgbuf_get_chunk_size(struct snd_dma_buffer *,
    #                                        unsigned int ofs, unsigned int size);
    # Contiguous backing -> the whole requested chunk is one piece.
    return size


