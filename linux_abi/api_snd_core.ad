# =====================================================================
# Group 4: snd_info_* — procfs/sysfs info entries
# =====================================================================

def _snd_info_create_card_entry(card: uint64, name: Ptr[char],
                                  parent: uint64) -> uint64:
    # struct snd_info_entry *snd_info_create_card_entry(
    #     struct snd_card *, const char *name, struct snd_info_entry *parent);
    #
    # Returns a heap-backed snd_info_entry. The caller (snd-core's own
    # snd_card_info_init and snd_minor_info_init) immediately writes
    # entry->ops at offset 0x20 and registers it via snd_info_register;
    # if we returned NULL the caller cascades up with -ENOMEM, which
    # would fail snd.ko's init_module. A real Linux entry is ~152 bytes
    # (kmalloc_trace($0xdc0, $0x98) per the inline kmalloc); 256 bytes
    # of zeroed slab is plenty for every offset the callers touch.
    return kzalloc(256)


def _snd_info_create_module_entry(module: uint64, name: Ptr[char],
                                    parent: uint64) -> uint64:
    # struct snd_info_entry *snd_info_create_module_entry(
    #     struct module *, const char *name, struct snd_info_entry *parent);
    #
    # Same shape as snd_info_create_card_entry but module-scoped. snd.ko's
    # init_module path calls this via snd_minor_info_init / snd_card_info_init
    # and treats a NULL return as -ENOMEM, which used to cascade snd.ko's
    # init to -ENOMEM. Hand back a zeroed 256-byte slab so the caller's
    # entry->ops / entry->p writes land inside the buffer.
    return kzalloc(256)


def _snd_info_free_entry(entry: uint64):
    if entry != 0:
        kfree(entry)


def _snd_info_register(entry: uint64) -> int32:
    return 0


def _snd_info_get_line(buffer: uint64, line: Ptr[char], lineMax: int32) -> int32:
    # int snd_info_get_line(struct snd_info_buffer *, char *line, int len);
    # Reads a line from /proc/asound/. EOF == -ENOENT.
    return -2


def _snd_info_get_str(dest: Ptr[char], src: Ptr[char], n: int32) -> Ptr[char]:
    # char *snd_info_get_str(char *dest, char *src, int len);
    return cast[Ptr[char]](0)


