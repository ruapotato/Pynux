def _snd_devres_alloc_node(release: uint64, size: uint64, gfp: uint32,
                            node: int32) -> uint64:
    # void *__devres_alloc_node(dr_release_t, size_t size, gfp_t,
    #                             int nid, const char *name);
    # Returns a zeroed slab — the body lives at offset 16 (after the
    # struct devres header). Cold without device_release.
    blob: uint64 = kzalloc(size + 16)
    if blob == 0:
        return 0
    return blob + 16


def _snd_devres_find(dev: uint64, release: uint64, m: uint64,
                      data: uint64) -> uint64:
    return 0


def _snd_devres_destroy(dev: uint64, release: uint64, m: uint64,
                         data: uint64) -> int32:
    return 0


def _snd_devres_free(res: uint64):
    return


def _snd_free_dma(dmanr: uint32):
    return


def _snd_request_dma(dmanr: uint32, name: Ptr[char]) -> int32:
    # int request_dma(unsigned int dmanr, const char *device_id);
    # ISA-DMA channel allocator — never fires for PCI HDA. -EINVAL.
    return -22


def _snd_stream_open(inode: uint64, file: uint64) -> int32:
    return 0


def _snd_kill_fasync_generic(fasync: uint64, signal: int32, band: int32):
    return


def _snd_single_open_size(file: uint64, show: uint64, data: uint64,
                            size: uint64) -> int32:
    return 0


def _snd_pid_vnr(task_pid: uint64) -> int32:
    return 0


def _snd_release_resource(res: uint64) -> int32:
    return 0


def _snd_strlcat(dst: Ptr[char], src: Ptr[char], n: uint64) -> uint64:
    # size_t strlcat(char *dst, const char *src, size_t size);
    # Adds NUL-terminated src to dst[]; returns intended length.
    # Cold path callers (snd_card name composition) tolerate either
    # the full strlcat or a benign truncation. We do the minimal
    # correct thing — find end of dst, then byte-copy src bytes.
    dlen: uint64 = 0
    while dst[dlen] != 0 and dlen < n:
        dlen = dlen + 1
    slen: uint64 = 0
    while src[slen] != 0:
        slen = slen + 1
    if dlen >= n:
        return dlen + slen
    i: uint64 = 0
    while i < slen and dlen + i + 1 < n:
        dst[dlen + i] = src[i]
        i = i + 1
    dst[dlen + i] = 0
    return dlen + slen


def _snd_vmemdup_user(src: uint64, size: uint64) -> uint64:
    blob: uint64 = kzalloc(size)
    if blob == 0:
        return 0
    if src != 0:
        memcpy(cast[Ptr[uint8]](blob), cast[Ptr[uint8]](src), size)
    return blob


def _snd_downgrade_write(sem: uint64):
    return


def _snd_memcpy_toio(dst: uint64, src: uint64, n: uint64):
    # void memcpy_toio(volatile void __iomem *to, const void *from, size_t count);
    if dst == 0 or src == 0 or n == 0:
        return
    memcpy(cast[Ptr[uint8]](dst), cast[Ptr[uint8]](src), n)


def _snd_raw_read_lock_irqsave(lock: uint64) -> uint64:
    return 0


def _snd_raw_read_unlock_irqrestore(lock: uint64, flags: uint64):
    return


def _snd_raw_write_lock_irqsave(lock: uint64) -> uint64:
    return 0


def _snd_raw_write_unlock_irqrestore(lock: uint64, flags: uint64):
    return


def _snd_list_del_entry_valid(entry: uint64) -> int32:
    # bool __list_del_entry_valid(struct list_head *);
    # Sanity-check in CONFIG_DEBUG_LIST builds. Always-valid (true=1).
    return 1


def _snd_kvmalloc_node(size: uint64, gfp: uint32, node: int32) -> uint64:
    return kzalloc(size)


def _snd_xa_destroy(xa: uint64):
    return


def _snd_xa_erase(xa: uint64, index: uint64) -> uint64:
    return 0


def _snd_xa_insert(xa: uint64, index: uint64, entry: uint64,
                    gfp: uint32) -> int32:
    return 0


def _snd_xa_load(xa: uint64, index: uint64) -> uint64:
    return 0


def _snd_xa_store_range(xa: uint64, first: uint64, last: uint64,
                         entry: uint64, gfp: uint32) -> int32:
    return 0


