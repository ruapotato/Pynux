def _snd_register_sound_special_device(unit: int32, name: Ptr[char],
                                         fops: uint64) -> int32:
    # int register_sound_special_device(const struct file_operations *,
    #                                     int unit, const char *name);
    # Legacy OSS minor allocator. Return the unit; cold.
