def _snd_unregister_sound_special(unit: int32) -> int32:
    return 0


def _snd_proc_create_data(name: Ptr[char], mode: int32, parent: uint64,
                            proc_fops: uint64, data: uint64) -> uint64:
    # struct proc_dir_entry *proc_create_data(const char *name, umode_t,
    #     struct proc_dir_entry *parent, const struct proc_ops *,
    #     void *data);
    #
    # snd.ko's own snd_info_register tail-calls this from the leaf-file
    # branch and treats a NULL return as -ENOMEM, which would cascade
    # up to snd.ko's init_module. Hand back a non-zero opaque handle
    # (a small zeroed slab; the caller stores the pointer but never
    # dereferences it on the insmod path).
    return kzalloc(64)


def _snd_proc_mkdir_mode(name: Ptr[char], mode: int32,
                          parent: uint64) -> uint64:
    # struct proc_dir_entry *proc_mkdir_mode(const char *name, umode_t,
    #     struct proc_dir_entry *parent);
    #
    # snd.ko's own snd_info_register's S_IFDIR branch calls this for
    # the /proc/asound/{oss,seq,card0,...} subdirs and treats NULL as
    # -ENOMEM. That used to cascade to snd.ko's init returning -ENOMEM
    # (which then re-triggered every retry through the dep walker). A
    # zeroed 64-byte slab is enough: snd_info_register stashes the
    # returned pointer in entry->p and only NULL-checks it.
    return kzalloc(64)


