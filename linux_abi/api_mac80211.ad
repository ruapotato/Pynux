def _mac_ieee80211_amsdu_to_8023s(skb: uint64, list_head: uint64,
                                    addr: uint64, iftype: int32,
                                    extra_headroom: uint32,
                                    check_da: uint64, check_sa: uint64,
                                    mesh_control: int32):
