def _mac_dev_alloc_name(dev: uint64, name: Ptr[char]) -> int32:
    # int dev_alloc_name(struct net_device *, const char *name) —
    # picks the next free name matching `name` (e.g. "wlan%d"). Just
    # succeed; we don't enforce uniqueness.
    return 0


def _mac_netdev_set_default_ethtool_ops(dev: uint64, ops: uint64):
    return


def _mac_netif_receive_skb(skb: uint64) -> int32:
    # Stub — drop the packet by freeing the skb. The real packet flow
    # for mac80211 only fires when a wifi driver delivers an RX
    # frame, which doesn't happen at init.
    if skb != 0:
        kfree(skb)
    return 0


def _mac_netif_receive_skb_list(head: uint64):
    return


# =====================================================================
# Group 9: bitmap / percpu / idr / find_first_* / misc utilities
# =====================================================================

def _mac_alloc_percpu_gfp(size: uint64, align: uint64, gfp: uint32) -> uint64:
    # void __percpu *__alloc_percpu_gfp(size_t, size_t align, gfp_t).
    # Hamnix has no per-CPU machinery; return a single-cpu-sized
    # allocation. Any subsequent per_cpu_ptr(..., 0) deref hits the
    # one slot, which is what we want for the SMP=1 layout.
    return kzalloc(size)


def _mac_bitmap_free(bitmap: uint64):
    if bitmap != 0:
        kfree(bitmap)


def _mac_bitmap_zalloc(nbits: uint32, flags: uint32) -> uint64:
    # nbits / 8, round up.
    nbytes: uint64 = (cast[uint64](nbits) + 7) / 8
    return kzalloc(nbytes)


def _mac_find_first_bit(addr: uint64, size: uint64) -> uint64:
    # unsigned long _find_first_bit(const unsigned long *addr,
    #                                 unsigned long size).
    # Returns size if no set bit. For init-cold paths we treat input
    # as all-zero (the typical empty-bitmap state) and report size.
    return size


def _mac_find_first_zero_bit(addr: uint64, size: uint64) -> uint64:
    # All-zero buffer means first zero is bit 0.
    return 0


def _mac_idr_find(idr: uint64, id: int32) -> uint64:
    # void *idr_find(const struct idr *, int id). NULL == not found.
    return 0


def _mac_idr_for_each(idr: uint64, fn: uint64, data: uint64) -> int32:
    return 0


def _mac_kernel_param_lock(mod: uint64):
    return


def _mac_kernel_param_unlock(mod: uint64):
    return


def _mac_ktime_get_seconds() -> int64:
    # time64_t ktime_get_seconds(void). Wall-clock seconds since boot.
    # 10 ms per jiffy at HZ=100.
    return cast[int64](jiffies / 100)


# =====================================================================
# Group 10: __x86_indirect_thunk_rbp
# =====================================================================
#
# Retpoline for `call *%rbp` / `jmp *%rbp`. Same shape as the _rax
# variant in api_lib80211, but %rbp is the saved-base-pointer
# register Adder's prologue pushes — extra care is needed because
# `popq %rbp` (used in _rax) restores the caller's saved rbp from
# the stack and would also restore %rbp here to the caller's value.
# That's actually what we WANT because the call target is in %rbp,
# not in a temporary, so after `popq %rbp` the target's address is
# GONE. Instead, transfer %rbp into a scratch register BEFORE
# undoing the prologue.

def _mac_x86_indirect_thunk_rbp():
    asm_volatile("""
        movq %rbp, %r11
        popq %rbp
        jmpq *%r11
    """)


# =====================================================================
# Group 11: misc + DATA
# =====================================================================

def _mac_freq_reg_info(wiphy: uint64, center_freq: uint32) -> uint64:
    # const struct ieee80211_reg_rule *freq_reg_info(...) — looks up
    # the regulatory rule applying to a given frequency. Return NULL
    # (== "no rule found" — caller falls back to the world-roaming
    # default rule already baked into the wiphy).
    return 0


def _mac_kmalloc_large(size: uint64, flags: uint32) -> uint64:
    # void *kmalloc_large(size_t size, gfp_t flags). The slowpath
    # of kmalloc for >page-size allocations. Forward to our slab.
    return kmalloc(size)


def _mac_kvmalloc_node(size: uint64, flags: uint32, node: int32) -> uint64:
    # void *kvmalloc_node(size_t, gfp_t, int node) — try kmalloc,
    # fall back to vmalloc. Single-node + unified address space:
    # forward to plain kmalloc.
    return kmalloc(size)


def _mac_led_trigger_blink(trig: uint64, delay_on: uint64,
                              delay_off: uint64):
    return


def _mac_regulatory_pre_cac_allowed(wiphy: uint64) -> int32:
    return 0


