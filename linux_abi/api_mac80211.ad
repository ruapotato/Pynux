    return 0


def _mac_ieee80211_chandef_to_operating_class(chandef: uint64,
                                                op_class: uint64) -> int32:
    return 0


def _mac_ieee80211_channel_to_freq_khz(chan: int32, band: int32) -> uint32:
    # u32 ieee80211_channel_to_freq_khz(int chan, enum nl80211_band);
    # Trivial table lookup; implement 2.4 GHz + 5 GHz cases that
    # 99% of channels fall into. 0 == invalid.
    if chan <= 0:
        return 0
    if band == 0:                                   # NL80211_BAND_2GHZ
        if chan == 14:
            return 2484000
        if chan < 14:
            return cast[uint32](2407000 + chan * 5000)
        return 0
    if band == 1:                                   # NL80211_BAND_5GHZ
        return cast[uint32](5000000 + chan * 5000)
    return 0


def _mac_ieee80211_data_to_8023_exthdr(skb: uint64, ehdr: uint64,
                                         addr: uint64, iftype: int32,
                                         data_offset: uint8, is_amsdu: int32) -> int32:
    return -22                                     # -EINVAL — no real translation


def _mac_ieee80211_freq_khz_to_channel(freq: uint32) -> int32:
    # int ieee80211_freq_khz_to_channel(u32 freq) — inverse of above.
    if freq == 2484000:
        return 14
    if freq >= 2412000 and freq <= 2472000:
        return cast[int32]((freq - 2407000) / 5000)
    if freq >= 5000000:
        return cast[int32]((freq - 5000000) / 5000)
    return 0


def _mac_ieee80211_get_8023_tunnel_proto(hdr: uint64, proto: uint64) -> int32:
