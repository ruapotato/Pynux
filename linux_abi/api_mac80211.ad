# =====================================================================
# Group 5: crypto + arc4 (7 stubs)
# =====================================================================

def _mac_crypto_alloc_aead(alg_name: Ptr[char], type_arg: uint32,
                             mask: uint32) -> uint64:
    # struct crypto_aead *crypto_alloc_aead(...). NULL/ERR_PTR
    # would prevent the WPA path from progressing — return a small
    # zeroed handle so driver code stores it without dereferencing.
    return kzalloc(64)


def _mac_crypto_alloc_skcipher(alg_name: Ptr[char], type_arg: uint32,
                                 mask: uint32) -> uint64:
    return kzalloc(64)


def _mac_crypto_shash_digest(desc: uint64, data: uint64, len_arg: uint32,
                                out: uint64) -> int32:
    # int crypto_shash_digest(struct shash_desc *, const u8 *data,
    #                            unsigned int len, u8 *out).
    return -95                                     # -EOPNOTSUPP


def _mac_crypto_shash_finup(desc: uint64, data: uint64, len_arg: uint32,
                                out: uint64) -> int32:
    return -95


def _mac_crypto_shash_setkey(tfm: uint64, key: uint64, keylen: uint32) -> int32:
    return -95


def _mac_arc4_crypt(ctx: uint64, dst: uint64, src: uint64, len_arg: uint32):
    # ARC4 stream cipher. Stubbed; legacy WEP keys aren't exercised
    # at init. If a connection later needs it, this is a known TODO.
    return


def _mac_arc4_setkey(ctx: uint64, in_key: uint64, key_len: uint32):
    return


# =====================================================================
# Group 6: skb gap-fillers (9 stubs)
# =====================================================================

def _mac_kfree_skb_list_reason(segs: uint64, reason: uint32):
    # Walk a chain of skbs and free each. Without a real skb_list_
    # next traversal here we just NULL-check; the only mac80211 path
    # that calls this at init has an already-empty list.
    return


def _mac_skb_clone_sk(skb: uint64) -> uint64:
    # struct sk_buff *skb_clone_sk(struct sk_buff *) — clones and
    # ties to the originating sock. Stub returns NULL ("OOM"),
    # which mac80211 ack-frame paths handle by silently dropping.
    return 0


def _mac_skb_complete_wifi_ack(skb: uint64, acked: int32):
    if skb != 0:
        kfree(skb)


def _mac_skb_copy(skb: uint64, gfp_mask: uint32) -> uint64:
    return 0                                       # OOM (deferred path)


def _mac_skb_copy_expand(skb: uint64, newheadroom: int32,
                            newtailroom: int32, gfp_mask: uint32) -> uint64:
    return 0


def _mac_skb_get_hash(skb: uint64) -> uint32:
    # u32 __skb_get_hash(struct sk_buff *) — packet flow hash. Always
    # returning the same constant funnels all packets onto one queue
    # — harmless in single-queue Hamnix.
    return 0x1234


def _mac_skb_gso_segment(skb: uint64, features: uint64) -> uint64:
    # struct sk_buff *__skb_gso_segment(struct sk_buff *,
    #                                     netdev_features_t).
    # Returns the original skb or a list. ERR_PTR(-EINVAL) tells the
    # caller to drop without freeing the original.
    return 0xFFFFFFFFFFFFFFEA                      # ERR_PTR(-EINVAL)


def _mac_skb_queue_head(list_arg: uint64, newsk: uint64):
    return


def _mac_skb_queue_purge(list_arg: uint64):
    return


# =====================================================================
# Group 7: workqueue / tasklet / timer (5 funcs + 1 DATA)
# =====================================================================

def _mac_round_jiffies_relative(j: uint64) -> uint64:
    return j


def _mac_round_jiffies_up(j: uint64) -> uint64:
    return j


def _mac_usecs_to_jiffies(u: uint32) -> uint64:
    # unsigned long __usecs_to_jiffies(unsigned int u). With HZ=100
    # in Hamnix's PIT setup, 1 jiffy == 10 ms == 10000 us.
    return cast[uint64](u) / 10000


def _mac_tasklet_kill(t: uint64):
    return


def _mac_tasklet_unlock_wait(t: uint64):
    return


