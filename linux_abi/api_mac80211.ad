def _mac_wiphy_free(wiphy: uint64):
    if wiphy != 0:
        kfree(wiphy)


def _mac_wiphy_new_nm(ops: uint64, sizeof_priv: int32,
                        requested_name: Ptr[char]) -> uint64:
    # struct wiphy *wiphy_new_nm(...). Allocates a wiphy + driver-
    # private region. Each wiphy is ~5 KiB plus the driver's
    # priv-area; use a generous bound so common driver alloc
    # patterns succeed.
    total: uint64 = 8192 + cast[uint64](sizeof_priv)
    return kzalloc(total)


