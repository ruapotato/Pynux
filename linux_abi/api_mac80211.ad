def _mac_ieee80211_hdrlen(fc: uint16) -> uint32:
    # unsigned int ieee80211_hdrlen(__le16 fc) — returns 24, 26, 28,
    # or 30 bytes based on the 802.11 frame control field. 24 is the
    # standard data-frame header length.
    return 24


