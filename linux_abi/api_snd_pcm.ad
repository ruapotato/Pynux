    return 0


def _snd_pcm_set_memory_wc(addr: uint64, numpages: int32) -> int32:
    return 0


def _snd_pcm_set_pages_array_wb(pages: uint64, addrinarray: int32) -> int32:
    return 0


def _snd_pcm_set_pages_array_wc(pages: uint64, addrinarray: int32) -> int32:
    return 0


def _snd_pcm_cachemode2protval(cm: uint32) -> uint64:
    return 0


def _snd_pcm_pgprot_writecombine(prot: uint64) -> uint64:
    return prot


def _snd_pcm_sg_page_iter_start(piter: uint64, sglist: uint64, nents: int32,
                                  pgoffset: uint64):
    return


def _snd_pcm_sg_page_iter_next(piter: uint64) -> int32:
    # bool __sg_page_iter_next(struct sg_page_iter *);
    # End-of-iteration on first call.
    return 0


def _snd_pcm_sg_page_iter_dma_next(piter: uint64) -> int32:
    return 0


# =====================================================================
# Group 3: kernel utility cold stubs
# =====================================================================

def _snd_pcm_clear_user(to: uint64, n: uint64) -> uint64:
    # unsigned long clear_user_*(void __user *to, unsigned long n);
    # Returns the number of bytes that could NOT be cleared (0 == all OK).
    if to == 0:
        return n
    memset(cast[Ptr[uint8]](to), 0, n)
    return 0


def _snd_pcm_cpu_latency_qos_request_active(req: uint64) -> int32:
    return 0


def _snd_pcm_ktime_get_ts64(ts: uint64):
    # void ktime_get_ts64(struct timespec64 *ts);
    # Zero out the 16-byte timespec64.
    if ts != 0:
        memset(cast[Ptr[uint8]](ts), 0, 16)


def _snd_pcm_ktime_get_raw_ts64(ts: uint64):
    if ts != 0:
        memset(cast[Ptr[uint8]](ts), 0, 16)


def _snd_pcm_gcd(a: uint64, b: uint64) -> uint64:
    # unsigned long gcd(unsigned long a, unsigned long b);
    # Standard Euclidean gcd.
    while b != 0:
        t: uint64 = b
        b = a % b
        a = t
    return a


def _snd_pcm_nonseekable_open(inode: uint64, file: uint64) -> int32:
    return 0


def _snd_pcm_fput(file: uint64):
    return


def _snd_pcm_fdget(fd: uint32) -> uint64:
    return 0


def _snd_pcm_simple_strtoul(cp: Ptr[char], endp: uint64,
                              base: uint32) -> uint64:
    # unsigned long simple_strtoul(const char *cp, char **endp,
    #                                unsigned int base);
    # Parse decimal (base ignored for V0). Cold callers tolerate a
    # benign 0 + endp==cp (no chars consumed).
    if cast[uint64](cp) == 0:
        return 0
    v: uint64 = 0
    i: uint64 = 0
    while cp[i] >= 48 and cp[i] <= 57:
        v = v * 10 + cast[uint64](cp[i] - 48)
        i = i + 1
    if endp != 0:
        ep: Ptr[uint64] = cast[Ptr[uint64]](endp)
        ep[0] = cast[uint64](cp) + i
    return v


def _snd_pcm_raw_spin_trylock(lock: uint64) -> int32:
    return 1


# =====================================================================
# Registration
# =====================================================================

def linux_abi_register_snd_pcm():
    # Called from linux_abi_exports_init() after linux_abi_register_snd_core().
    # Adds the PCM framework + DMA / vmalloc / page-utility surface so
    # snd-pcm.ko + its dependents load via the L-series loader.

    # ---- snd_pcm_* framework ----
    _add_export("snd_pcm_new",
                cast[uint64](&_snd_pcm_new))
    _add_export("snd_pcm_set_ops",
                cast[uint64](&_snd_pcm_set_ops))
    _add_export("snd_pcm_set_sync",
                cast[uint64](&_snd_pcm_set_sync))
    _add_export("snd_pcm_set_managed_buffer_all",
                cast[uint64](&_snd_pcm_set_managed_buffer_all))
    _add_export("snd_pcm_period_elapsed",
                cast[uint64](&_snd_pcm_period_elapsed))
    _add_export("snd_pcm_hw_constraint_integer",
                cast[uint64](&_snd_pcm_hw_constraint_integer))
    _add_export("snd_pcm_hw_constraint_minmax",
                cast[uint64](&_snd_pcm_hw_constraint_minmax))
    _add_export("snd_pcm_hw_constraint_step",
                cast[uint64](&_snd_pcm_hw_constraint_step))
    _add_export("snd_pcm_hw_limit_rates",
                cast[uint64](&_snd_pcm_hw_limit_rates))
    _add_export("snd_pcm_format_width",
                cast[uint64](&_snd_pcm_format_width))
    _add_export("snd_pcm_std_chmaps",
                cast[uint64](&_snd_pcm_std_chmaps))
    _add_export("snd_pcm_add_chmap_ctls",
                cast[uint64](&_snd_pcm_add_chmap_ctls))
    _add_export("snd_pcm_suspend_all",
                cast[uint64](&_snd_pcm_suspend_all))

    # ---- DMA / page ----
    _add_export("dma_alloc_pages",
                cast[uint64](&_snd_pcm_dma_alloc_pages))
    _add_export("dma_free_pages",
                cast[uint64](&_snd_pcm_dma_free_pages))
    _add_export("dma_alloc_noncontiguous",
                cast[uint64](&_snd_pcm_dma_alloc_noncontiguous))
    _add_export("dma_free_noncontiguous",
                cast[uint64](&_snd_pcm_dma_free_noncontiguous))
    _add_export("dma_can_mmap",
                cast[uint64](&_snd_pcm_dma_can_mmap))
    _add_export("dma_need_sync",
                cast[uint64](&_snd_pcm_dma_need_sync))
    _add_export("dma_sync_sg_for_cpu",
                cast[uint64](&_snd_pcm_dma_sync_sg_for_cpu))
    _add_export("dma_sync_sg_for_device",
                cast[uint64](&_snd_pcm_dma_sync_sg_for_device))
    _add_export("dma_vmap_noncontiguous",
                cast[uint64](&_snd_pcm_dma_vmap_noncontiguous))
    _add_export("dma_vunmap_noncontiguous",
                cast[uint64](&_snd_pcm_dma_vunmap_noncontiguous))
    _add_export("dma_mmap_pages",
                cast[uint64](&_snd_pcm_dma_mmap_pages))
    _add_export("dma_mmap_noncontiguous",
                cast[uint64](&_snd_pcm_dma_mmap_noncontiguous))
    _add_export("alloc_pages_exact",
                cast[uint64](&_snd_pcm_alloc_pages_exact))
    _add_export("free_pages_exact",
                cast[uint64](&_snd_pcm_free_pages_exact))
    _add_export("__vmalloc",
                cast[uint64](&_snd_pcm_vmalloc))
    _add_export("vmalloc_to_page",
                cast[uint64](&_snd_pcm_vmalloc_to_page))
    _add_export("vmap",
                cast[uint64](&_snd_pcm_vmap))
    _add_export("vunmap",
                cast[uint64](&_snd_pcm_vunmap))
    _add_export("vm_iomap_memory",
                cast[uint64](&_snd_pcm_vm_iomap_memory))
    _add_export("vm_map_pages",
                cast[uint64](&_snd_pcm_vm_map_pages))
    _add_export("vm_get_page_prot",
                cast[uint64](&_snd_pcm_vm_get_page_prot))
    _add_export("remap_vmalloc_range",
                cast[uint64](&_snd_pcm_remap_vmalloc_range))
    _add_export("set_memory_wb",
                cast[uint64](&_snd_pcm_set_memory_wb))
    _add_export("set_memory_wc",
                cast[uint64](&_snd_pcm_set_memory_wc))
    _add_export("set_pages_array_wb",
                cast[uint64](&_snd_pcm_set_pages_array_wb))
    _add_export("set_pages_array_wc",
                cast[uint64](&_snd_pcm_set_pages_array_wc))
    _add_export("cachemode2protval",
                cast[uint64](&_snd_pcm_cachemode2protval))
    _add_export("pgprot_writecombine",
                cast[uint64](&_snd_pcm_pgprot_writecombine))
    _add_export("__sg_page_iter_start",
                cast[uint64](&_snd_pcm_sg_page_iter_start))
    _add_export("__sg_page_iter_next",
                cast[uint64](&_snd_pcm_sg_page_iter_next))
    _add_export("__sg_page_iter_dma_next",
                cast[uint64](&_snd_pcm_sg_page_iter_dma_next))

    # ---- kernel utility cold stubs ----
    _add_export("clear_user_erms",
                cast[uint64](&_snd_pcm_clear_user))
    _add_export("clear_user_original",
                cast[uint64](&_snd_pcm_clear_user))
    _add_export("clear_user_rep_good",
                cast[uint64](&_snd_pcm_clear_user))
    _add_export("cpu_latency_qos_request_active",
                cast[uint64](&_snd_pcm_cpu_latency_qos_request_active))
    _add_export("ktime_get_ts64",
                cast[uint64](&_snd_pcm_ktime_get_ts64))
    _add_export("ktime_get_raw_ts64",
                cast[uint64](&_snd_pcm_ktime_get_raw_ts64))
    _add_export("gcd",
                cast[uint64](&_snd_pcm_gcd))
    _add_export("nonseekable_open",
                cast[uint64](&_snd_pcm_nonseekable_open))
    _add_export("fput",
                cast[uint64](&_snd_pcm_fput))
    _add_export("__fdget",
                cast[uint64](&_snd_pcm_fdget))
    _add_export("simple_strtoul",
                cast[uint64](&_snd_pcm_simple_strtoul))
    _add_export("_raw_spin_trylock",
                cast[uint64](&_snd_pcm_raw_spin_trylock))

    # ---- DATA exports ----
    _add_export("dma_ops",
                cast[uint64](&snd_pcm_dma_ops_buf[0]))
    _add_export("sme_me_mask",
                cast[uint64](&snd_pcm_sme_me_mask_var))
    _add_export("__default_kernel_pte_mask",
                cast[uint64](&snd_pcm_default_pte_mask_var))
    _add_export("param_ops_ulong",
                cast[uint64](&snd_pcm_param_ops_ulong_buf[0]))
