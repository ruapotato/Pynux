    # int __srcu_read_lock(struct srcu_struct *). Returns the
    # generation index (0 or 1) the read-side critical section is in.
    # 0 is fine for cold path — synchronize_srcu's stub doesn't block.
    return 0


def _ncx_srcu_read_unlock(srcu: uint64, idx: int32):
    return


def _ncx_synchronize_srcu(srcu: uint64):
    # void synchronize_srcu(struct srcu_struct *).
    # Waits for all current SRCU readers to exit. With no concurrent
    # readers (single-CPU cold path) the post-condition holds trivially.
    return


# =====================================================================
# Group 4: xa_* (XArray)
# =====================================================================

def _ncx_xa_store(xa: uint64, index: uint64, entry: uint64,
                   gfp: uint32) -> uint64:
    # void *xa_store(struct xarray *, unsigned long index,
    #                  void *entry, gfp_t).
    # Stores entry at index, returns the OLD entry at that slot
    # (NULL on first store). Cold path: we don't actually track
    # the index->entry mapping, so we always return NULL ("new
    # store"). This means a subsequent xa_load wouldn't find it,
    # which is fine because the cold path never xa_load's back.
    return 0


def _ncx_xa_find_after(xa: uint64, indexp: uint64, max: uint64,
                        filter: uint32) -> uint64:
    # void *xa_find_after(struct xarray *, unsigned long *indexp,
    #                       unsigned long max, xa_mark_t filter).
    # Finds the next entry after *indexp. NULL == none found.
    # Cold path: namespace scan iterates nvme-core's ns_ida xarray
    # via xa_find / xa_find_after; with no entries stored, NULL
    # terminates the iteration immediately.
    return 0


