def _ncx_blk_status_to_errno(status: int32) -> int32:
    # int blk_status_to_errno(blk_status_t).
    # Maps BLK_STS_* to -errno. BLK_STS_OK (0) == 0; anything else
    # we collapse to -EIO (-5). nvme-core uses this in error paths
    # we don't reach in cold-path stubs.
    if status == 0:
        return 0
    return -5


