    # We don't expose NVMe temperature attrs in cold path.
    return 0


# =====================================================================
# Group 9: ida_* (id allocator) + misc helpers
# =====================================================================

_ncx_ida_counter: uint32 = 0


def _ncx_ida_alloc_range(ida: uint64, min: uint32, max: uint32,
                          gfp: uint32) -> int32:
    # int ida_alloc_range(struct ida *, unsigned int min,
    #                      unsigned int max, gfp_t).
    # Returns a new ID in [min,max] or -ENOSPC. We hand out a
    # monotonically increasing counter starting from min so each
    # call yields a distinct ID (controller-instance, namespace-id,
    # etc.). The counter is global across all ida's — fine for cold
    # path since IDs aren't compared across allocators.
    id: uint32 = min + _ncx_ida_counter
    _ncx_ida_counter = _ncx_ida_counter + 1
    if id > max:
        return -28                                   # -ENOSPC
    return cast[int32](id)


def _ncx_ida_destroy(ida: uint64):
    return


def _ncx_ida_free(ida: uint64, id: uint32):
    return


def _ncx_kfree_const(p: uint64):
    # void kfree_const(const void *). Free unless `p` is in the
    # rodata section. We don't track rodata; just kfree.
    if p == 0:
        return
    kfree(p)


def _ncx_node_distance(from_node: int32, to_node: int32) -> int32:
    # int __node_distance(int from, int to). NUMA distance metric;
    # 10 == "local" (same node) per the kernel default. Hamnix is
    # UMA so every distance is local.
    return 10


def _ncx_kblockd_schedule_work(work: uint64) -> int32:
    # bool kblockd_schedule_work(struct work_struct *).
    # Queues `work` on the kblockd workqueue. Returns true ==
    # "scheduled". Cold path: we have no kblockd worker, so the
    # work is dropped. Returning true keeps the caller on the
    # happy path.
    return 1


def _ncx_sed_ioctl(dev: uint64, cmd: uint32, arg: uint64) -> int32:
    # int sed_ioctl(struct opal_dev *, unsigned int cmd, void __user *).
    # TCG Opal SED ioctl. -ENOSYS — no Opal in our env.
    return -38


def _ncx_device_remove_file_self(dev: uint64, attr: uint64) -> int32:
    # bool device_remove_file_self(struct device *, const struct device_attribute *).
    # Returns true if the file is actively being removed. Cold path: false.
    return 0


def _ncx_trace_seq_printf(s: uint64, fmt: uint64) -> uint32:
    # void trace_seq_printf(struct trace_seq *, const char *fmt, ...).
    # Variadic shim: discard everything. No-op.
    return 0


def _ncx_trace_seq_putc(s: uint64, c: uint8) -> uint32:
    return 0


def _ncx_sysfs_streq(s1: uint64, s2: uint64) -> int32:
    # bool sysfs_streq(const char *s1, const char *s2).
    # sysfs-style string equality (trailing newline tolerated).
    # Used by nvme-core's sysfs attr setters. Cold path: not reached
    # by sysfs writes (no userland writes to /sys/class/nvme/...).
    # Implementation: byte-equal up to either NUL or '\n'.
    if s1 == 0 or s2 == 0:
        return 0
    p1: Ptr[uint8] = cast[Ptr[uint8]](s1)
    p2: Ptr[uint8] = cast[Ptr[uint8]](s2)
    i: uint64 = 0
    while True:
        c1: uint8 = p1[i]
        c2: uint8 = p2[i]
        # Treat trailing '\n' as equivalent to NUL.
        if c1 == 10:
            c1 = 0
        if c2 == 10:
            c2 = 0
        if c1 != c2:
            return 0
        if c1 == 0:
            return 1
        i = i + 1


# =====================================================================
# Group 10: DIF/DIX integrity CRC functions
# =====================================================================
#
# t10-pi.ko exports the actual CRC implementations; nvme-core relocates
# against them as direct EXPORT_SYMBOL references. Without t10-pi.ko
# side-loaded (it pulls in crc_t10dif + crc64_rocksoft, another two-
# module chain), we stub these to identity-return. nvme-core only
# calls them when a namespace has PI enabled (NSFEAT.PI bit); QEMU's
# nvme device doesn't advertise PI, so these are unreachable in our
# test env.

def _ncx_t10_pi_type1_crc(iter: uint64, sectors: uint32) -> int32:
    # blk_status_t t10_pi_type1_crc(struct blk_integrity_iter *,
    #                                 unsigned int).
    return 0


def _ncx_t10_pi_type3_crc(iter: uint64, sectors: uint32) -> int32:
    return 0


