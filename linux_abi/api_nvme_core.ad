# linux_abi/api_nvme_core.ad
#
# Side-load of Linux's stock nvme-core.ko (Debian 6.1.0-32 build,
# ~380 KiB) via the L-series .ko loader. nvme-core owns the bulk
# of NVMe protocol logic (controller lifecycle, namespace scan,
# identify dispatch, blk-mq glue, sysfs surface, tracepoints); the
# bundled nvme.ko depends on it via `depends: nvme-core` and
# resolves its nvme_*/__SCK_*/__SCT_*/tracepoint relocations
# against nvme-core's EXPORT_SYMBOL table.
#
# Strategic frame:
#   Pre-side-load (commit fb5aa49): linux_abi/api_nvme.ad provided
#   45 cold-path stubs for nvme_*/__SCK_*/__SCT_* names that nvme.ko
#   relocates against. Those stubs returned 0/-ENODEV/NULL/no-op
#   to let init complete. nvme_submit_sync_cmd returned -ENODEV so
#   namespace scan never produced a gendisk.
#
#   Post-side-load: nvme-core.ko loads BEFORE nvme.ko (modules.dep
#   wiring; depends: nvme-core). The loader's cross-module ksymtab
#   path (commit deb21cc) registers nvme-core's 64 EXPORT_SYMBOL
#   names; when nvme.ko's RELA tables resolve, the ksymtab provider
#   wins over the api_nvme.ad shim. Visible in the boot log as
#   `[ksymtab_hit] nvme -> nvme_core: <symbol>` for every overlap.
#   Real nvme_submit_sync_cmd is then in play.
#
# This file closes nvme-core's NET-NEW UND surface (102 symbols
# beyond what L<=68 + ahci + nvme + e1000e + ahci/scsi already
# exported). The categories:
#
#   * 38 blk_* / blk_mq_* / blk_queue_* — block-layer multi-queue
#     extensions that nvme-core uses to register gendisks, throttle
#     I/O queues, and translate request structs to NVMe commands.
#     Most are setters on the request_queue (no-op in cold path);
#     blk_execute_rq / blk_mq_complete_request are reachable from
#     the sync-command path and return BLK_STS_OK / no-op so the
#     completion-wait loop bails immediately.
#
#   * 8 bio_* / submit_bio_noacct — bio-layer entry points. Cold
#     path returns 0; bio submission paths are unreachable until a
#     real I/O bio is built (gendisk + filesystem).
#
#   * 9 srcu_* / synchronize_srcu / __srcu_read_* — sleepable RCU
#     primitives. Real Linux uses these in the controller-lifecycle
#     paths (e.g. ctrl_lock + reset_work). No-op / 0 since no real
#     concurrent reader can collide with us (single CPU model in
#     cold path).
#
#   * 6 xa_* (xa_store, xa_find_after) — XArray (Linux's compact
#     radix-tree-backed sparse-index container) extensions. nvme-core
#     uses an XArray keyed by namespace-id to track per-NS state.
#     Cold path: cold-path stubs.
#
#   * 4 io_uring_cmd_* + 2 sed_/disk_set_zoned/disk_uevent —
#     io_uring passthru hooks (not exercised; no userland io_uring
#     ring yet), security-erase ioctl glue, zoned-block-device knobs,
#     uevent emitter. All no-op / 0.
#
#   * 4 tracepoint surface (__SCK__/__SCT__/__tracepoint__ for
#     block_bio_complete + block_bio_remap) — static-call thunks.
#     Same shape as the nvme_sq tracepoint trio in api_nvme.ad:
#     SCK is a key (data buffer), SCT is the trampoline (real fn
#     whose body is bare ret), tracepoint is a 256-byte zero buffer.
#
#   * 9 device-add-disk family (add_disk, device_add_disk, put_disk,
#     __blk_alloc_disk, __blk_mq_alloc_disk, bdev_disk_changed,
#     blk_revalidate_disk_zones, set_capacity_and_notify,
#     set_disk_ro). These are the gendisk registration entry points
#     that would land a /dev/nvmeNnN block device. Cold path returns
#     a non-NULL token / 0 status so the caller's downstream chain
#     continues but no real Hamnix blockdev is registered yet —
#     that's the remaining gap (see project_e1000e_ko-style M16
#     follow-up: a gendisk -> blk_register_blockdev translator).
#
#   * 18 misc — chardev (cdev_device_add/_del), srcu wrappers,
#     dev_pm_qos latency knobs (not exercised; no PM in cold path),
#     hwmon_device_register_with_info (NVMe temperature exposure;
#     stubbed), ida_alloc/_free (id allocator — return monotonically
#     increasing IDs), sysfs_streq (case-sensitive string-equality),
#     blk_status_to_errno (BLK_STS_* -> -errno mapper), uuid_null
#     (data: zeroed 16-byte UUID), node_states (NUMA node mask data),
#     __node_distance (return 10 == local), kfree_const (kfree
#     passthrough), kblockd_schedule_work (immediate no-op),
#     param_ops_byte (module-param vtable; data), blkdev_compat_
#     ptr_ioctl (32-on-64 ioctl forwarder; -ENOIOCTLCMD),
#     dev_pm_qos_*_latency_tolerance, blk_freeze_queue_start,
#     blk_steal_bios, blk_sync_queue, device_remove_file_self,
#     ext_pi_type1/3_crc64 + t10_pi_type1/3_crc (DIF/DIX CRC funcs —
#     unused when no PI namespace; return src unchanged).
#
# 24 of the 102 names collide with the SCSI mid-layer agent's
# api_scsi.ad / api_libata.ad shim (blk_execute_rq, blk_mq_complete_
# request, blk_mq_delay_kick_requeue_list, blk_mq_freeze_queue,
# blk_mq_quiesce_queue, blk_mq_requeue_request, blk_mq_tagset_busy_
# iter, blk_mq_unfreeze_queue, blk_mq_unquiesce_queue, blk_mq_wait_
# quiesce_done, blk_queue_dma_alignment, blk_queue_max_hw_sectors,
# blk_queue_max_segments, blk_queue_virt_boundary, blk_rq_map_kern,
# blk_rq_map_user_io, blk_rq_unmap_user, ida_alloc_range, ida_destroy,
# ida_free, kblockd_schedule_work, sysfs_streq, trace_seq_printf,
# trace_seq_putc). _add_export uses first-match-wins lookup; whichever
# of {scsi_mod, nvme_core} registers first owns the symbol. Cold-path
# semantics are equivalent, so either ordering boots cleanly.
#
# Compiler-quirk notes:
#   * Adder reserves `bytes`, `match`, `case`, `type`, `field`, `file` —
#     renamed where they would collide.
#   * Function-pointer fields treated as raw uint64.
#   * No default-valued params; every arg is passed explicitly.
#
# The "_ncx_" prefix marks the Hamnix-side shim. Same convention
# as e1000e (_e1k_), ahci (_ahc_), nvme (_nvm_), scsi (_scs_).

from linux_abi.exports import _add_export
from kernel.printk.printk import printk0, printk1
from mm.slab import kmalloc, kzalloc, kfree
from kernel.block.blk import find_blockdev
# Hand-rolled NVMe driver. The L-shim finish-add-disk path bridges to
# nvme_smoke_test() to drive CC.EN + admin IDENTIFY + create I/O queues
# + register_blockdev("nvme0n1", ...) — mirroring AHCI's bridge through
# linux_abi_finish_ahci_add_disk -> ahci_smoke_test. See the comment
# block on linux_abi_finish_nvme_add_disk for the architectural framing.
from drivers.nvme.nvme import nvme_smoke_test


# =====================================================================
# DATA buffers
# =====================================================================
#
# uuid_null — Linux exports a zeroed 16-byte uuid_t. nvme-core
# compares ns->uuid against this to detect "no UUID assigned".
#
# node_states — Linux's per-NUMA-node bitmap array (NR_NODE_STATES
# enums; each is a nodemask_t = unsigned long[BITS_TO_LONGS(MAX_NUMNODES)]).
# Hamnix is UMA; we publish a 256-byte zero buffer that's big enough
# for any sane MAX_NUMNODES * NR_NODE_STATES indexing.
#
# param_ops_byte — struct kernel_param_ops vtable for byte-valued
# module params. nvme-core takes none; the relocation must resolve.
# A 64-byte zeroed buffer satisfies it (every fn slot is NULL ==
# "no setter / getter, treat as fixed").
#
# __SCK__tp_func_block_bio_complete / block_bio_remap — static-call
# keys. Same as nvme_sq: data, not code. 256 zeroed bytes each.
#
# __tracepoint_block_bio_complete / block_bio_remap — tracepoint
# structs. Same shape as __tracepoint_nvme_sq. 256 zeroed bytes each.

_ncx_uuid_null_buf:                  Array[16, uint8]
_ncx_node_states_buf:                Array[256, uint8]
_ncx_param_ops_byte_buf:             Array[64, uint8]
_ncx_sck_bio_complete_buf:           Array[256, uint8]
_ncx_sck_bio_remap_buf:              Array[256, uint8]
_ncx_tp_bio_complete_buf:            Array[256, uint8]
_ncx_tp_bio_remap_buf:               Array[256, uint8]


# __SCT__tp_func_block_bio_complete / block_bio_remap are STATIC-CALL
# TRAMPOLINES — CODE the .ko emits `call` against. Backing them with
# a data buffer triggers #UD. Provide real fn bodies that just `ret`
# (drops the tracepoint call when no tracer is attached).

def _ncx_sct_tp_bio_complete():
    # Static-call trampoline body. Same rationale as
    # _nvm_sct_tp_func_nvme_sq in api_nvme.ad.
    return


def _ncx_sct_tp_bio_remap():
    return


# =====================================================================
# Group 1: blk_* / blk_mq_* / blk_queue_* (38)
# =====================================================================

def _ncx_blk_execute_rq(rq: uint64, at_head: int32) -> int32:
    # blk_status_t blk_execute_rq(struct request *, bool at_head).
    # Submits a request and waits for completion. Cold-path: there's
    # no hctx running, no IRQ delivers a completion. Return 0 ==
    # BLK_STS_OK so callers (nvme_submit_sync_cmd) think the command
    # succeeded — they then read the per-request status word from
    # the request struct, which is whatever the caller initialised
    # it to (typically 0 from a kzalloc'd request). With status==0
    # nvme_submit_sync_cmd's check `if (status < 0)` skips its
    # error path; the result-pointer's value (whatever was last
    # written by the cold-path setup, i.e. zero) is returned.
    return 0


def _ncx_blk_freeze_queue_start(q: uint64):
    # void blk_freeze_queue_start(struct request_queue *). Prep
    # for the freeze cycle. No-op.
    return


