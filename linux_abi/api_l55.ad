# linux_abi/api_l55.ad
#
# L55: shims for stock Debian 6.12 8021q.ko (VLAN core). One module,
# 87 new UND symbols — by far our biggest single-module hit. Most are
# runtime-path helpers (rtnetlink, ethtool, procfs, GARP/MRP, netpoll,
# netdev address-list management); the init path itself touches only
# six: register_netdevice_notifier, unregister_netdevice_notifier,
# rtnl_link_register, garp_register_application, mrp_register_application,
# and vlan_ioctl_set. Everything else is shimmed for relocation-time
# resolution so the loader doesn't spam "unresolved external symbol".
#
# Init-path disassembly (objdump -drC -j .init.text 8021q.ko):
#
#   init_module:
#       call __fentry__
#       printk("8021q: %s v%s\n", &vlan_fullname, &vlan_version)
#       call register_pernet_subsys(&vlan_net_ops)        # L41
#       call register_netdevice_notifier(&vlan_notifier_block)
#       call vlan_gvrp_init()                              # internal:
#           -> garp_register_application(&vlan_gvrp_app)
#       call vlan_mvrp_init()                              # internal:
#           -> mrp_register_application(&vlan_mvrp_app)
#       call vlan_netlink_init()                           # internal:
#           -> rtnl_link_register(&vlan_link_ops)
#       vlan_ioctl_set(&vlan_ioctl_handler)
#       return 0
#
# Cross-check against L1..L54 confirmed 87 distinct UND not yet exported.
# Six on the init path (above); 81 on runtime paths the loader's
# relocation pass binds even though the call site never fires during
# module load. Future milestones (full VLAN runtime — vconfig, real
# netdev ops, GARP/MRP timers) will grow these stubs into real
# implementations without touching call sites here.
#
# Symbol-name notes:
#   * The `nbytes` reservation (see feedback_compiler_quirks.md) doesn't
#     fire in this batch — no param is named `bytes`.
#   * `dev` is fine; `match` is reserved (Python keyword) but doesn't
#     appear here.
#   * `dev_addr_mod` keeps its name; the parameter list uses `nb`.
#
# Stub philosophy (matches L51..L54):
#   * Return 0 (success) for any function whose Linux signature returns
#     int. -EINVAL only when a null pointer would crash a real consumer.
#   * Return 0 (NULL) for any alloc-style function — no consumer here
#     dereferences the result during module load.
#   * No-op for void functions.
#   * DATA exports point at backing buffers / variables in this file;
#     the relocation pass patches the *address* of the storage into
#     the module's reference site.

from linux_abi.exports import _add_export
from kernel.printk.printk import printk0
from mm.slab import kmalloc, kfree


# =====================================================================
# Group 1: netdev notifier chain
# =====================================================================
#
# Linux:
#   int  register_netdevice_notifier(struct notifier_block *nb);
#   int  unregister_netdevice_notifier(struct notifier_block *nb);
#   int  call_netdevice_notifiers(unsigned long val, struct net_device *dev);
#
# 8021q's init registers a notifier block (vlan_notifier_block) so the
# VLAN core gets NETDEV_UP / NETDEV_DOWN / NETDEV_UNREGISTER callbacks
# when its lower devices change state. Hamnix has no netdev events yet,
# so registration is a logical no-op and call_netdevice_notifiers (used
# only on runtime VLAN-device add/remove) returns NOTIFY_DONE (0).

def _l_register_netdevice_notifier(nb: uint64) -> int32:
    # int register_netdevice_notifier(struct notifier_block *nb);
    return 0


def _l_unregister_netdevice_notifier(nb: uint64) -> int32:
    # int unregister_netdevice_notifier(struct notifier_block *nb);
    return 0


def _l_call_netdevice_notifiers(val: uint64, dev: uint64) -> int32:
    # int call_netdevice_notifiers(unsigned long val, struct net_device *dev);
    # NOTIFY_DONE = 0x0000.
    return 0


# =====================================================================
# Group 2: rtnetlink link-ops registration
# =====================================================================
#
# Linux:
#   int  rtnl_link_register(struct rtnl_link_ops *ops);
#   void rtnl_link_unregister(struct rtnl_link_ops *ops);
#   void rtnl_lock(void);
#   void rtnl_unlock(void);
#   int  rtnl_is_locked(void);
#
# rtnl_link_register publishes a struct rtnl_link_ops (`vlan_link_ops`)
# so userspace `ip link add link eth0 name eth0.10 type vlan id 10`
# can find the VLAN newlink handler. No userspace consumer exists yet;
# register is success, lock/unlock are no-ops, is_locked answers 1
# (callers of rtnl_is_locked typically assert it's true).

def _l_rtnl_link_register(ops: uint64) -> int32:
    # int rtnl_link_register(struct rtnl_link_ops *ops);
    if ops == 0:
        return -22
    return 0


def _l_rtnl_link_unregister(ops: uint64):
    # void rtnl_link_unregister(struct rtnl_link_ops *ops);
    return


def _l_rtnl_lock():
    # void rtnl_lock(void);
    return


def _l_rtnl_unlock():
    # void rtnl_unlock(void);
    return


def _l_rtnl_is_locked() -> int32:
    # int rtnl_is_locked(void);
    return 1


