# vlan_filter_drop_vids, vlan_vid_add, vlan_vid_del are all defined in
# stock Linux's net/8021q/vlan_core.c (built-in) or net/socket.c
# (vlan_ioctl_set). When 8021q.ko loads it references them as kernel
# exports.
#
# vlan_ioctl_set IS called by init (init_module assigns the VLAN ioctl
# handler into a global function pointer in net/socket.c). Stub: store
# the handler into a local backing slot and return.

vlan_ioctl_handler_slot: uint64 = 0


def _l_vlan_ioctl_set(handler: uint64):
    # void vlan_ioctl_set(int (*hook)(struct net *, void __user *));
    vlan_ioctl_handler_slot = handler


