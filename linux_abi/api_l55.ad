                cast[uint64](&_l_rtnl_link_unregister))
    _add_export("rtnl_lock",
                cast[uint64](&_l_rtnl_lock))
    _add_export("rtnl_unlock",
                cast[uint64](&_l_rtnl_unlock))
    _add_export("rtnl_is_locked",
                cast[uint64](&_l_rtnl_is_locked))

    # Group 3: GARP applicant
