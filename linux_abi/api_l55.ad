def _l_dev_addr_mod(dev: uint64, off: uint32, addr: uint64, n: uint64) -> int32:
    # int dev_addr_mod(struct net_device *dev, unsigned int offset,
    #                   const void *addr, size_t len);
    # Copies `len` bytes from `addr` into `dev->dev_addr + offset`.
    # The probe path of stock Linux NIC drivers calls this with
    # offset=0, len=6 to set the netdev's hardware address. With
    # dev_addr_mod as a no-op, netdev->dev_addr stayed at whatever
    # alloc_etherdev_mqs left it (in our api_netdev.ad: a 32-byte
    # in-struct buffer pre-zeroed), and the immediately-following
    # is_valid_ether_addr test saw all-zero MAC and bailed -EIO.
    if dev == 0 or addr == 0 or n == 0:
        return 0
    # dev_addr field at offset 0x330 (Linux 6.1 layout) is a pointer
    # to the actual address buffer. The pointer is set up by
    # _l_alloc_etherdev_mqs to point at netdev+0x340.
    dap: Ptr[uint64] = cast[Ptr[uint64]](dev + 0x330)
    dst_base: uint64 = dap[0]
    if dst_base == 0:
        return 0
    dst: Ptr[uint8] = cast[Ptr[uint8]](dst_base + cast[uint64](off))
    src: Ptr[uint8] = cast[Ptr[uint8]](addr)
    i: uint64 = 0
    while i < n:
        dst[i] = src[i]
        i = i + 1
    return 0


