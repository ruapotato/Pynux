# =====================================================================
# Group 15: capability + percpu + RCU + bit-search runtime
# =====================================================================
#
# Linux:
#   bool ns_capable(struct user_namespace *ns, int cap);
#   void __percpu *pcpu_alloc_noprof(size_t size, size_t align, bool reserved,
#                                      gfp_t gfp);
#   void free_percpu(void __percpu *ptr);
#   void rcu_barrier(void);
#   unsigned long _find_next_bit(const unsigned long *addr1,
#                                  const unsigned long *addr2,
#                                  unsigned long nbits, unsigned long start,
#                                  unsigned long invert, unsigned long le);
#   void BUG_func(void);
#   void netdev_warn(const struct net_device *dev, const char *fmt, ...);
#
# Hamnix has no namespaces, no per-CPU areas yet, no RCU. Stubs return
# success / NULL / no-op. BUG_func / netdev_warn log and continue
# (BUG_func in real Linux panics, but we don't fire it).

def _l_ns_capable(ns: uint64, cap: int32) -> int32:
    # Returns true (1).
    return 1


def _l_pcpu_alloc_noprof(n: uint64, align: uint64, reserved: int32, gfp: uint64) -> uint64:
    # void __percpu *pcpu_alloc_noprof(...);
    if n == 0:
        return 0
    return kmalloc(n)


def _l_free_percpu(ptr: uint64):
    if ptr == 0:
        return
    kfree(ptr)


def _l_rcu_barrier():
    return


def _l_find_next_bit(addr1: uint64, addr2: uint64, nbits: uint64,
                      start: uint64, invert: uint64, le: uint64) -> uint64:
    # Mirrors lib/find_bit.c; stub returns nbits (caller's "not found").
    return nbits


def _l_BUG_func():
    printk0("BUG_func\n")
    return


def _l_netdev_warn(dev: uint64, fmt: uint64) -> int32:
    return 0


# =====================================================================
# Group 16: DATA exports (cpu masks + percpu offset + paravirt ops)
# =====================================================================
#
# Linux:
#   extern const struct cpumask __cpu_possible_mask;     # bitmap, NR_CPUS bits
#   extern unsigned int          nr_cpu_ids;             # active CPU count
#   extern unsigned long         this_cpu_off;           # %gs-relative offset
#   extern struct paravirt_patch_template pv_ops;
#
# All are referenced by inlines / inlines-via-headers baked into
# 8021q.ko (RCU read-side, percpu accessor, cpumask iter, paravirt'd
# native_{read,write}_*). Init's actual control flow doesn't traverse
# them, but the relocations against the symbols need a live address.
#
# Backing storage:
#   * __cpu_possible_mask — 64-byte bitmap, only bit 0 set (UP-only).
#   * nr_cpu_ids — uint32 = 1.
#   * this_cpu_off — uint64 = 0 (no real per-CPU yet).
#   * pv_ops — 1 KiB of zeroed function-pointer table; any call through
#     a NULL entry would crash, but no module-load path invokes one.

__cpu_possible_mask_buf:  Array[64, uint8]
nr_cpu_ids_var:           uint32 = 1
this_cpu_off_var:         uint64 = 0
pv_ops_buf:               Array[1024, uint8]


def _l55_init_data():
    # Set bit 0 of __cpu_possible_mask. The other 511 bits stay zero.
    __cpu_possible_mask_buf[0] = 1
    return


# =====================================================================
# Registration
# =====================================================================

def linux_abi_register_l55():
    # Called from linux_abi_exports_init() after L54's rows.
    # Adds 87 exports for 8021q.ko's full UND closure.

    # Initialize backing data first (cpu_possible_mask bit-0).
    _l55_init_data()

    # Group 1: netdev notifier chain
    _add_export("register_netdevice_notifier",
                cast[uint64](&_l_register_netdevice_notifier))
    _add_export("unregister_netdevice_notifier",
                cast[uint64](&_l_unregister_netdevice_notifier))
    _add_export("call_netdevice_notifiers",
                cast[uint64](&_l_call_netdevice_notifiers))

    # Group 2: rtnetlink link-ops
    _add_export("rtnl_link_register",
                cast[uint64](&_l_rtnl_link_register))
