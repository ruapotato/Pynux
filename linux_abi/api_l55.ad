# =====================================================================
# Group 5: net_device allocation + registration runtime
# =====================================================================
#
# Linux (include/linux/netdevice.h):
#   struct net_device *alloc_netdev_mqs(int sizeof_priv, const char *name,
#                                         unsigned char name_assign_type,
#                                         void (*setup)(struct net_device *),
#                                         unsigned int txqs, unsigned int rxqs);
#   int  register_netdevice(struct net_device *dev);
#   void unregister_netdevice_queue(struct net_device *dev, struct list_head *head);
#   void unregister_netdevice_many(struct list_head *head);
#
# Allocator returns a buffer the caller subsequently fills; 16 KiB is
# more than enough for stock struct net_device + sizeof_priv slack.
# Register/unregister are runtime — userspace `ip link add type vlan`
# is what triggers them, and we have no userspace ip(8) yet.

def _l_alloc_netdev_mqs(sizeof_priv: int32, name: uint64, name_type: uint32,
                         setup: uint64, txqs: uint32, rxqs: uint32) -> uint64:
    # struct net_device *alloc_netdev_mqs(...);
    n: uint64 = 16384
    if sizeof_priv > 0:
        n = n + cast[uint64](sizeof_priv)
    p: uint64 = kmalloc(n)
    return p


def _l_register_netdevice(dev: uint64) -> int32:
    # int register_netdevice(struct net_device *dev);
    return 0


def _l_unregister_netdevice_queue(dev: uint64, head: uint64):
    # void unregister_netdevice_queue(struct net_device *dev,
    #                                  struct list_head *head);
    return


def _l_unregister_netdevice_many(head: uint64):
    # void unregister_netdevice_many(struct list_head *head);
    return


