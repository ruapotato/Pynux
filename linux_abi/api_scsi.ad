def _scs_scsi_build_sense_buffer(desc: int32, buf: uint64, key: uint8,
                                   asc: uint8, ascq: uint8):
    # void scsi_build_sense_buffer(int desc, u8 *buf, u8 key,
    #                                u8 asc, u8 ascq).
    # Writes a SCSI sense buffer at *buf. Fixed-format (desc=0) layout:
    #   buf[0] = 0x70  (response code, current error)
    #   buf[2] = key   (sense key)
    #   buf[7] = 0x0a  (additional length: 10)
    #   buf[12] = asc
    #   buf[13] = ascq
    if buf == 0:
        return
    p: Ptr[uint8] = cast[Ptr[uint8]](buf)
    if desc != 0:
        # Descriptor format (desc != 0):
        #   buf[0] = 0x72, buf[1] = key, buf[2] = asc, buf[3] = ascq
        p[0] = 0x72
        p[1] = key
        p[2] = asc
        p[3] = ascq
        return
    p[0] = 0x70
    p[2] = key
    p[7] = 0x0A
    p[12] = asc
    p[13] = ascq


def _scs_scsilun_to_int(lun: uint64) -> int32:
    # int scsilun_to_int(struct scsi_lun *lun).
    # Decodes a struct scsi_lun (8 bytes, big-endian) to a host-byte
    # int. For LUN 0 (typical for SATA) the bytes are all zero, so 0
    # is the right cold-path answer.
    if lun == 0:
        return 0
    p: Ptr[uint8] = cast[Ptr[uint8]](lun)
    # Per Linux's scsilun_to_int: interleave bytes (0,1)(2,3)(4,5)(6,7)
    # into 16-bit words then OR them shifted. For LUN values < 256 the
    # result is just byte 1 (the low byte of the first word). Good
    # enough.
    return cast[int32](p[1])


def _scs_scsi_normalize_sense(sense_buffer: uint64, sb_len: int32,
                                sshdr: uint64) -> int32:
    # bool scsi_normalize_sense(const u8 *sense_buffer, int sb_len,
    #                            struct scsi_sense_hdr *sshdr).
    # Parses a sense buffer into a normalised header. Returns true on
    # success. If sshdr is non-NULL we zero it; the caller treats
    # all-zero as "no sense data" which is the safe cold-path outcome.
    if sshdr == 0:
        return 0
    p: Ptr[uint8] = cast[Ptr[uint8]](sshdr)
    # sizeof(struct scsi_sense_hdr) == 8 (response_code, sense_key,
    # asc, ascq, byte4, byte5, byte6, additional_length).
    i: uint64 = 0
    while i < 8:
        p[i] = 0
        i = i + 1
    if sense_buffer == 0 or sb_len < 1:
        return 0
    sp: Ptr[uint8] = cast[Ptr[uint8]](sense_buffer)
    p[0] = sp[0] & 0x7F                          # response_code
    if sb_len >= 14 and (sp[0] & 0x7F) == 0x70:
        p[1] = sp[2] & 0x0F                      # sense_key
        p[2] = sp[12]                            # asc
        p[3] = sp[13]                            # ascq
        p[7] = sp[7]                             # additional_length
    elif sb_len >= 4 and (sp[0] & 0x7F) == 0x72:
        p[1] = sp[1] & 0x0F
        p[2] = sp[2]
        p[3] = sp[3]
        if sb_len >= 8:
            p[7] = sp[7]
    return 1


def _scs_scsi_sense_desc_find(sense_buffer: uint64, sb_len: int32,
                                desc_type: int32) -> uint64:
    # u8 *scsi_sense_desc_find(const u8 *sense_buffer, int sb_len,
    #                           int desc_type).
    # Locates a sense descriptor of a given type. NULL == not found
    # (cold-path safe — caller bails).
    return 0


# =====================================================================
# Group 3: sbitmap_* / ida_* — bit allocator + ID allocator
# =====================================================================

def _scs_sbitmap_get(sb: uint64) -> int32:
    # int sbitmap_get(struct sbitmap *sb).
    # Allocates a bit. -1 == no bits available. In our env nothing has
    # been freed back, so -1 is reasonable; the caller (tag allocation)
    # will treat as "queue full, retry" which propagates harmlessly
    # on cold paths.
    return -1


def _scs_sbitmap_init_node(sb: uint64, depth: uint32, shift: int32,
                             flags: uint32, node: int32,
                             roundup_to_pwr2: int32,
                             alloc_hint: int32) -> int32:
    # int sbitmap_init_node(struct sbitmap *, unsigned int depth,
    #     int shift, gfp_t flags, int node, bool round_robin_pwr2,
    #     bool alloc_hint).
    # 0 == success.
    return 0


def _scs_sbitmap_resize(sb: uint64, depth: uint32):
    # void sbitmap_resize(struct sbitmap *, unsigned int depth).
    return


def _scs_sbitmap_weight(sb: uint64) -> int32:
    # unsigned int sbitmap_weight(const struct sbitmap *).
    # Returns the number of set bits. 0 == nothing allocated.
    return 0


def _scs_ida_alloc_range(ida: uint64, min_id: uint32, max_id: uint32,
                          gfp: uint32) -> int32:
    # int ida_alloc_range(struct ida *, unsigned int min, unsigned int max,
    #                      gfp_t gfp).
    # Allocates a fresh ID in [min, max]. Return `min` as a deterministic
    # first-allocation; callers that allocate two and check uniqueness
    # would see a collision, but cold-path init only allocates once.
    return cast[int32](min_id)


def _scs_ida_destroy(ida: uint64):
    # void ida_destroy(struct ida *).
    return


def _scs_ida_free(ida: uint64, id: uint32):
