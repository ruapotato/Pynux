def _scs_execute_in_process_context(fn: uint64, ew: uint64) -> int32:
    # int execute_in_process_context(work_func_t fn, struct execute_work *ew).
    # Linux uses this to run a function in process context (deferred).
    # We don't have a workqueue scheduler the SCSI mid-layer expects,
    # so the safe cold-path answer is 0 (success — work queued).
    return 0


def _scs_hex_dump_to_buffer(buf: uint64, len: uint64, rowsize: int32,
                              groupsize: int32, linebuf: uint64,
                              linebuflen: uint64, ascii: int32) -> int32:
    # int hex_dump_to_buffer(const void *buf, size_t len, int rowsize,
    #     int groupsize, char *linebuf, size_t linebuflen, bool ascii).
    # Writes a hex-dump line. Stub returns 0 (zero bytes written).
    if linebuf != 0 and linebuflen > 0:
        cast[Ptr[uint8]](linebuf)[0] = 0
    return 0


def _scs_jiffies_to_clock_t(j: uint64) -> uint64:
    return j


def _scs_kblockd_schedule_work(work: uint64) -> int32:
    # bool kblockd_schedule_work(struct work_struct *).
    # Queues a work struct on the kblockd workqueue. We have no
    # workqueue scheduler running here; return true so the caller
    # thinks queueing succeeded. The work won't actually fire, but
    # scsi_mod's cold paths don't depend on it executing.
    return 1


def _scs_kmem_cache_alloc_node(cache: uint64, gfp: uint32,
                                 node: int32) -> uint64:
    # void *kmem_cache_alloc_node(struct kmem_cache *, gfp_t, int node).
    # Forward to plain kmalloc. The cache size isn't tracked; we
    # allocate a generous 4 KiB to avoid undersized regions for any
    # struct (struct scsi_cmnd is ~1 KiB, struct scsi_device is
    # smaller, so 4 KiB is comfortable headroom).
    return kmalloc(4096)


def _scs_kmem_cache_create_usercopy(name: Ptr[char], size: uint64,
                                      align: uint32, flags: uint64,
                                      useroffset: uint64,
                                      usersize: uint64,
                                      ctor: uint64) -> uint64:
    # struct kmem_cache *kmem_cache_create_usercopy(...).
    # Returns a non-NULL pointer (a tagged uint64). Hamnix's slab.ad
    # doesn't track named caches yet; we hand back the size as the
    # cookie so debug printk("%s") on the cache name works.
    return cast[uint64](name) | 1                  # never zero


def _scs_memory_read_from_buffer(to: uint64, count: uint64, ppos: uint64,
                                   from_: uint64, available: uint64) -> int64:
    # ssize_t memory_read_from_buffer(void *to, size_t count, loff_t *ppos,
    #     const void *from, size_t available).
    # Linux's small helper for seq_file reads. EOF (return 0) is fine.
    return 0


def _scs_netlink_capable(skb: uint64, cap: int32) -> int32:
    # bool netlink_capable(const struct sk_buff *, int cap).
    # 1 == permitted; in our env every netlink request is from kernel
    # itself, so allow.
    return 1


def _scs_register_sysctl_table(table: uint64) -> uint64:
    # struct ctl_table_header *register_sysctl_table(struct ctl_table *).
    # Non-NULL == registered. We don't have sysctl; return a stable
    # non-zero cookie.
    return 1


def _scs_unregister_sysctl_table(header: uint64):
    return


def _scs_simple_strtoull(cp: Ptr[char], endp: uint64, base: int32) -> uint64:
    # unsigned long long simple_strtoull(const char *cp, char **endp,
    #                                     unsigned int base).
    # Parse a numeric string. Implement decimal-only (base 10) since
    # that covers nearly all SCSI string parsing; base 16 and base 8
    # are also straightforward to handle but cold-path callers in
    # scsi_mod use this for human-friendly knobs that default to 0.
    if cp == 0:
        return 0
    v: uint64 = 0
    i: uint64 = 0
    while True:
        c: int32 = cp[i]
        if c == 0:
            break
        if c < 48 or c > 57:
            break
        v = v * 10 + cast[uint64](c - 48)
        i = i + 1
    if endp != 0:
        ep: Ptr[uint64] = cast[Ptr[uint64]](endp)
        ep[0] = cast[uint64](cp) + i
    return v


def _scs_sysfs_streq(s1: Ptr[char], s2: Ptr[char]) -> int32:
    # bool sysfs_streq(const char *s1, const char *s2).
    # Like strcmp but ignoring trailing '\n' in s1. Implement naive
    # equality; cold-path callers (echo X > /sys/...) don't run.
    if s1 == 0 or s2 == 0:
        return 0
    i: uint64 = 0
    while True:
        a: int32 = s1[i]
        b: int32 = s2[i]
        if a == 10 and b == 0:
            return 1
        if a != b:
            return 0
        if a == 0:
            return 1
        i = i + 1


def _scs_vscnprintf(buf: uint64, size: uint64, fmt: Ptr[char],
                     args: uint64) -> int32:
    # int vscnprintf(char *buf, size_t size, const char *fmt, va_list).
    # Returns the count actually written (>= 0). Return 0 to keep
    # buffer at empty; emit a NUL terminator if size > 0.
    if buf != 0 and size > 0:
        cast[Ptr[uint8]](buf)[0] = 0
    return 0


def _scs_param_ops_string():
    # struct kernel_param_ops param_ops_string — used by module_param
    # macros for string-typed params. We expose a zeroed buffer (no
    # set/get callbacks); module-param init doesn't dereference
    # callbacks on cold paths.
    return


scs_param_ops_string_buf: Array[64, uint8]


