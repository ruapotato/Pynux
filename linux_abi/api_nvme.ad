                cast[uint64](&_nvm_blk_mq_end_request_batch))
    _add_export("blk_mq_map_queues",
                cast[uint64](&_nvm_blk_mq_map_queues))
    _add_export("blk_mq_pci_map_queues",
                cast[uint64](&_nvm_blk_mq_pci_map_queues))
