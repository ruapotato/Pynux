# Registration
# =====================================================================

def linux_abi_register_nvme():
    # Called from linux_abi_exports_init() after the ahci batch.
    # Adds 89 new exports for the stock nvme.ko UND surface.

    # ---- Group 1: nvme_* core surface ----
    _add_export("nvme_init_ctrl",
                cast[uint64](&_nvm_nvme_init_ctrl))
    _add_export("nvme_init_ctrl_finish",
                cast[uint64](&_nvm_nvme_init_ctrl_finish))
    _add_export("nvme_uninit_ctrl",
                cast[uint64](&_nvm_nvme_uninit_ctrl))
    _add_export("nvme_start_ctrl",
                cast[uint64](&_nvm_nvme_start_ctrl))
    _add_export("nvme_stop_ctrl",
                cast[uint64](&_nvm_nvme_stop_ctrl))
    _add_export("nvme_reset_ctrl",
                cast[uint64](&_nvm_nvme_reset_ctrl))
    _add_export("nvme_try_sched_reset",
                cast[uint64](&_nvm_nvme_try_sched_reset))
    _add_export("nvme_wait_reset",
                cast[uint64](&_nvm_nvme_wait_reset))
    _add_export("nvme_change_ctrl_state",
                cast[uint64](&_nvm_nvme_change_ctrl_state))
    _add_export("nvme_disable_ctrl",
                cast[uint64](&_nvm_nvme_disable_ctrl))
    _add_export("nvme_enable_ctrl",
                cast[uint64](&_nvm_nvme_enable_ctrl))
    _add_export("nvme_shutdown_ctrl",
                cast[uint64](&_nvm_nvme_shutdown_ctrl))
    _add_export("nvme_complete_rq",
                cast[uint64](&_nvm_nvme_complete_rq))
    _add_export("nvme_complete_batch_req",
                cast[uint64](&_nvm_nvme_complete_batch_req))
    _add_export("nvme_complete_async_event",
                cast[uint64](&_nvm_nvme_complete_async_event))
    _add_export("nvme_fail_nonready_command",
                cast[uint64](&_nvm_nvme_fail_nonready_command))
    _add_export("nvme_setup_cmd",
                cast[uint64](&_nvm_nvme_setup_cmd))
    _add_export("nvme_cleanup_cmd",
                cast[uint64](&_nvm_nvme_cleanup_cmd))
    _add_export("nvme_init_request",
                cast[uint64](&_nvm_nvme_init_request))
    _add_export("nvme_submit_sync_cmd",
                cast[uint64](&_nvm_nvme_submit_sync_cmd))
    _add_export("nvme_set_queue_count",
                cast[uint64](&_nvm_nvme_set_queue_count))
    _add_export("nvme_set_features",
                cast[uint64](&_nvm_nvme_set_features))
    _add_export("nvme_get_features",
                cast[uint64](&_nvm_nvme_get_features))
    _add_export("__nvme_check_ready",
                cast[uint64](&_nvm_nvme_check_ready))
    _add_export("nvme_start_admin_queue",
                cast[uint64](&_nvm_nvme_start_admin_queue))
    _add_export("nvme_stop_admin_queue",
                cast[uint64](&_nvm_nvme_stop_admin_queue))
    _add_export("nvme_start_queues",
                cast[uint64](&_nvm_nvme_start_queues))
    _add_export("nvme_stop_queues",
                cast[uint64](&_nvm_nvme_stop_queues))
    _add_export("nvme_start_freeze",
                cast[uint64](&_nvm_nvme_start_freeze))
    _add_export("nvme_unfreeze",
                cast[uint64](&_nvm_nvme_unfreeze))
    _add_export("nvme_wait_freeze",
                cast[uint64](&_nvm_nvme_wait_freeze))
    _add_export("nvme_wait_freeze_timeout",
                cast[uint64](&_nvm_nvme_wait_freeze_timeout))
    _add_export("nvme_sync_queues",
                cast[uint64](&_nvm_nvme_sync_queues))
    _add_export("nvme_kill_queues",
                cast[uint64](&_nvm_nvme_kill_queues))
    _add_export("nvme_cancel_tagset",
                cast[uint64](&_nvm_nvme_cancel_tagset))
    _add_export("nvme_cancel_admin_tagset",
                cast[uint64](&_nvm_nvme_cancel_admin_tagset))
    _add_export("nvme_remove_namespaces",
                cast[uint64](&_nvm_nvme_remove_namespaces))
