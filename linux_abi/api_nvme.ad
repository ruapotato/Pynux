                cast[uint64](&_nvm_blk_rq_map_sg))

    # ---- Group 3: pci_* / pcibios_* / pcie_aspm_* ----
    _add_export("pci_request_irq",
                cast[uint64](&_nvm_pci_request_irq))
    _add_export("pci_free_irq",
                cast[uint64](&_nvm_pci_free_irq))
    _add_export("pci_request_selected_regions",
                cast[uint64](&_nvm_pci_request_selected_regions))
    _add_export("pci_load_saved_state",
                cast[uint64](&_nvm_pci_load_saved_state))
    _add_export("pci_device_is_present",
                cast[uint64](&_nvm_pci_device_is_present))
    _add_export("pcibios_resource_to_bus",
                cast[uint64](&_nvm_pcibios_resource_to_bus))
    _add_export("pci_sriov_configure_simple",
                cast[uint64](&_nvm_pci_sriov_configure_simple))
    _add_export("pcie_aspm_enabled",
                cast[uint64](&_nvm_pcie_aspm_enabled))

    # ---- Group 4: mempool_* ----
    _add_export("mempool_create_node",
                cast[uint64](&_nvm_mempool_create_node))
    _add_export("mempool_destroy",
                cast[uint64](&_nvm_mempool_destroy))
    _add_export("mempool_alloc",
                cast[uint64](&_nvm_mempool_alloc))
    _add_export("mempool_free",
                cast[uint64](&_nvm_mempool_free))
    _add_export("mempool_kmalloc",
                cast[uint64](&_nvm_mempool_kmalloc))
    _add_export("mempool_kfree",
                cast[uint64](&_nvm_mempool_kfree))

    # ---- Group 5: opal_* ----
    _add_export("init_opal_dev",
                cast[uint64](&_nvm_init_opal_dev))
    _add_export("free_opal_dev",
                cast[uint64](&_nvm_free_opal_dev))
    _add_export("opal_unlock_from_suspend",
                cast[uint64](&_nvm_opal_unlock_from_suspend))

    # ---- Group 6: misc helpers ----
    _add_export("async_schedule_node",
                cast[uint64](&_nvm_async_schedule_node))
    # dev_set_name override: api_devclass.ad's _l_dev_set_name returns
    # -EINVAL when called on a heap-allocated device pointer (it
    # expects a 1-based slot index). nvme-core's nvme_init_ctrl passes
    # such a heap pointer; without this override probe bails -EINVAL
    # before reset_work queues. linux_abi_lookup is last-match-wins
    # (see exports.ad), so this registration (later in
    # linux_abi_exports_init() than api_devclass.ad) wins.
    _add_export("dev_set_name",
                cast[uint64](&_nvm_dev_set_name))
    _add_export("wait_for_completion_io_timeout",
                cast[uint64](&_nvm_wait_for_completion_io_timeout))
    _add_export("dma_map_sgtable",
                cast[uint64](&_nvm_dma_map_sgtable))
    _add_export("dma_max_mapping_size",
                cast[uint64](&_nvm_dma_max_mapping_size))
    _add_export("dma_pci_p2pdma_supported",
                cast[uint64](&_nvm_dma_pci_p2pdma_supported))
    _add_export("__kmalloc_node",
                cast[uint64](&_nvm_kmalloc_node))
    _add_export("kmalloc_node_trace",
                cast[uint64](&_nvm_kmalloc_node_trace))
    _add_export("dmi_match",
                cast[uint64](&_nvm_dmi_match))
    _add_export("__flush_workqueue",
                cast[uint64](&_nvm_flush_workqueue))
    _add_export("param_set_uint_minmax",
                cast[uint64](&_nvm_param_set_uint_minmax))
    _add_export("__do_once_start",
                cast[uint64](&_nvm_do_once_start))
    _add_export("__do_once_done",
                cast[uint64](&_nvm_do_once_done))
    _add_export("__bitmap_weight",
                cast[uint64](&_nvm_bitmap_weight))
    _add_export("dma_unmap_sg_attrs",
                cast[uint64](&_nvm_dma_unmap_sg_attrs))
    _add_export("device_release_driver",
                cast[uint64](&_nvm_device_release_driver))
    _add_export("disable_irq",
                cast[uint64](&_nvm_disable_irq))

    # ---- DATA exports ----
    _add_export("admin_timeout",
                cast[uint64](&nvm_admin_timeout_var))
    _add_export("nvme_io_timeout",
