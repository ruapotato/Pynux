# linux_abi/api_snd_hda.ad
#
# Linux HDA bus + controller surface (snd-hda-core.ko, snd-hda-codec.ko,
# snd-hda-intel.ko). Stock Debian 6.1.0-32 binaries together carry ~200
# unique unresolved externals beyond what L<=68 + the NIC family +
# api_snd_core + api_snd_pcm covers. This file closes the remaining
# ~120-symbol gap so the L-series loader can insmod the entire HDA
# stack (snd_hda_core <- snd_hda_codec <- snd_hda_intel) without modules.dep:
# every cross-.ko reference resolves to a Hamnix-side stub.
#
# Categories:
#
#   * ~50 snd_hdac_* — the HDA-Audio Codec bus framework. Lives in
#     snd-hda-core.ko but is consumed by snd-hda-codec / snd-hda-intel.
#     snd_hdac_bus_init/_exit/_init_chip/_stop_chip/_send_cmd/_get_response/
#     _exec_verb_unlocked/_update_rirb/_parse_capabilities/_stop_cmd_io/
#     _alloc_stream_pages/_free_stream_pages/_handle_stream_irq/
#     _enter_link_reset, snd_hdac_stream_init/_release/_assign/_setup/
#     _cleanup/_set_params/_start/_stop/_reset/_sync/_sync_trigger/
#     _timecounter_init, snd_hdac_codec_read/_write/_link_up/_link_down/
#     _modalias, snd_hdac_device_init/_register/_unregister/_exit/
#     _set_chip_name, snd_hdac_power_up/_down/_up_pm/_down_pm/
#     _sync_power_state, snd_hdac_check_power_state, snd_hdac_display_power,
#     snd_hdac_i915_init/_set_bclk, snd_hdac_acomp_exit,
#     snd_hdac_set_codec_wakeup, snd_hdac_dsp_prepare/_trigger/_cleanup,
#     snd_hdac_query_supported_pcm, snd_hdac_is_supported_format,
#     snd_hdac_calc_stream_format, snd_hdac_refresh_widgets,
#     snd_hdac_get_connections/_get_sub_nodes, snd_hdac_read,
#     _snd_hdac_read_parm, snd_hdac_read_parm_uncached,
#     snd_hdac_override_parm, snd_hdac_regmap_init/_exit/_read_raw/
#     _write_raw/_update_raw/_update_raw_once/_sync,
#     snd_hdac_stop_streams.
#
#   * ~10 snd_hda_* — top-level controller surface from snd-hda-codec /
#     snd-hda-intel. snd_hda_lock_devices/_unlock_devices/_load_patch/
#     _set_power_save.
#
#   * ~10 azx_* — inline'd helpers in snd-hda-intel that get exported
#     when CONFIG_SND_HDA_INTEL=m. azx_bus_init, azx_codec_configure,
#     azx_init_chip, azx_init_streams, azx_free_streams, azx_get_pos_*,
#     azx_interrupt, azx_probe_codecs, azx_stop_all_streams, azx_stop_chip.
#
#   * 1 snd_intel_dsp_driver_probe — Intel SST DSP driver-probe helper.
#
#   * ~15 generic-kernel — acpi_dev_get_first_match_dev,
#     acpi_get_first_physical_node, acpi_get_handle, component_*
#     (bind/master_add/del/match/unbind), pnp_get_resource,
#     pci_get_class/_get_domain_bus_and_slot/_intx/_match_id/_pr3_present/
#     _dev_put, pm_runtime_force_resume/_force_suspend/_get_if_active,
#     vga_switcheroo_register_audio_client/_unregister_client/
#     _get_client_state, request_firmware_nowait, param_get_int/_set_int/
#     _ops_bint, bpf_trace_run4.
#
#   * ~15 regmap / regcache — regmap_read/_write/_update_bits_base/_exit/
#     __regmap_init, regcache_cache_only/_mark_dirty/_sync. Used by the
#     HDA codec verb-cache; cold for V0 (no codec attach).
#
#   * ~15 generic utility — kstrndup, kstrtoull, kvasprintf, kmemdup,
#     kobject_add/_init, skip_spaces, sort, sysfs_emit_at, vsprintf,
#     strcpy, clocks_calc_mult_shift, current_work.
#
# Stub philosophy: every shim is init-cold. The HDA controller's full
# probe path runs through azx_bus_init -> snd_hdac_bus_parse_capabilities
# -> azx_init_chip -> azx_init_streams -> azx_probe_codecs. With
# QEMU's `-device intel-hda` attached, that path lands at probe_codecs
# which fails benignly (NULL codec response from the RIRB) — exactly
# the milestone the brief asks for: module loads + probe invokes.

from linux_abi.exports import _add_export
from kernel.printk.printk import printk0
from mm.slab import kmalloc, kfree, kzalloc

extern def memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64) -> Ptr[uint8]
extern def memset(dst: Ptr[uint8], val: int32, n: uint64) -> Ptr[uint8]


