def _snd_hda_azx_probe_codecs(chip: uint64, max_slots: uint32) -> int32:
    # int azx_probe_codecs(struct azx *chip, unsigned int max_slots);
    # Walks slots 0..max_slots looking for a codec response on the
    # RIRB. No codec on QEMU's hda-output (it answers from the
    # controller side only); -ENXIO is the benign "no codec found"
    # return that the controller's probe-path handles by treating the
    # device as a no-audio HDA bus.
    return -6


