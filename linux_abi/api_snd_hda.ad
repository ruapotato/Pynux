# DATA buffers for "global state" symbols
# =====================================================================

# param_ops_bint: struct kernel_param_ops for a "buggy int" param type.
# Same shape as param_ops_int; zeroed 64-byte slot. Module-param
# readers tolerate NULL .set/.get.
snd_hda_param_ops_bint_buf:  Array[64, uint8]


