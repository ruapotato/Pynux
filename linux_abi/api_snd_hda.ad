# =====================================================================
# Group 12: generic utility cold stubs
# =====================================================================

def _snd_hda_kmemdup(src: uint64, len: uint64, gfp: uint32) -> uint64:
    blob: uint64 = kzalloc(len)
    if blob == 0:
        return 0
    if src != 0:
        memcpy(cast[Ptr[uint8]](blob), cast[Ptr[uint8]](src), len)
    return blob


def _snd_hda_kstrndup(s: Ptr[char], len: uint64, gfp: uint32) -> uint64:
    blob: uint64 = kzalloc(len + 1)
    if blob == 0:
        return 0
    if cast[uint64](s) != 0:
        memcpy(cast[Ptr[uint8]](blob), cast[Ptr[uint8]](s), len)
    return blob


def _snd_hda_kstrtoull(cp: Ptr[char], base: uint32, res: uint64) -> int32:
    if res != 0:
        p: Ptr[uint64] = cast[Ptr[uint64]](res)
        p[0] = 0
    return 0


def _snd_hda_kvasprintf(gfp: uint32, fmt: Ptr[char], ap: uint64) -> uint64:
    # char *kvasprintf(gfp_t, const char *fmt, va_list);
    # Allocate a 64-byte buffer holding the empty string. Real callers
    # use it for short dev-name strings; the actual content doesn't
    # affect insmod success.
    blob: uint64 = kzalloc(64)
    return blob


def _snd_hda_kobject_add(kobj: uint64, parent: uint64, fmt: Ptr[char]) -> int32:
    return 0


def _snd_hda_kobject_init(kobj: uint64, ktype: uint64):
    return


def _snd_hda_skip_spaces(s: Ptr[char]) -> Ptr[char]:
    if cast[uint64](s) == 0:
        return s
    i: uint64 = 0
    while s[i] == 32 or s[i] == 9:
        i = i + 1
    return cast[Ptr[char]](cast[uint64](s) + i)


def _snd_hda_sort(base: uint64, num: uint64, size: uint64, cmp: uint64,
                    swap_fn: uint64):
    # void sort(void *base, size_t num, size_t size, cmp_func_t cmp,
    #            swap_func_t swap);
    # Sort a flat array using cmp. Cold-path callers (codec node lists)
    # tolerate an unsorted array (the post-load iteration falls back
    # to linear matching). No-op is correct for V0.
    return


def _snd_hda_sysfs_emit_at(buf: Ptr[char], at: int32, fmt: Ptr[char]) -> int32:
    return 0


def _snd_hda_vsprintf(buf: Ptr[char], fmt: Ptr[char], args: uint64) -> int32:
    # int vsprintf(char *buf, const char *fmt, va_list args);
    # Write a NUL byte and return 0. Cold callers tolerate empty
    # output (they're filling banners that never reach userland).
    if cast[uint64](buf) != 0:
        buf[0] = 0
    return 0


def _snd_hda_strcpy(dst: Ptr[char], src: Ptr[char]) -> Ptr[char]:
    # char *strcpy(char *dst, const char *src);
    if cast[uint64](dst) == 0 or cast[uint64](src) == 0:
        return dst
    i: uint64 = 0
    while src[i] != 0:
        dst[i] = src[i]
        i = i + 1
    dst[i] = 0
    return dst


def _snd_hda_clocks_calc_mult_shift(mult: uint64, shift: uint64,
                                       fr: uint32, to: uint32,
                                       maxsec: uint32):
    # void clocks_calc_mult_shift(u32 *mult, u32 *shift, u32 from, u32 to,
    #                                u32 maxsec);
    # Compute mult/shift for cycle_t -> ns conversion. Cold without
    # a real timecounter; just write mult=1, shift=0.
    if mult != 0:
        p: Ptr[uint32] = cast[Ptr[uint32]](mult)
        p[0] = 1
    if shift != 0:
        p2: Ptr[uint32] = cast[Ptr[uint32]](shift)
        p2[0] = 0


def _snd_hda_current_work() -> uint64:
    return 0


