# linux_abi/api_drm.ad
#
# DRM/KMS (graphics) subsystem L-shim leg — the drm.ko core framework.
# The stock Debian 6.1.0-32 drm.ko (the DRM core: drm_drv, drm_ioctl,
# drm_gem, drm_mode_object, the GEM/PRIME buffer machinery, the atomic
# modeset core, ...) has 316 UND symbols. 214 are already exported by
# L1..L68 + the existing api_*.ad shims (slab, strings, sysfs, pci,
# kthread, irq, sync, timer, ...) plus the autostub generator (which
# covers drm's lone __x86_indirect_thunk_rsi). This file closes the
# remaining 101-symbol gap so drm.ko links with skipped=0 and its
# init_module runs.
#
# This is a LOAD-ONLY harvest (the L-series coverage-probe bar):
# "relocations skipped=0 + init_module returns". Under QEMU's emulated
# VGA there is no real GPU, so drm.ko's init registers its chrdev /
# debugfs scaffolding and returns — exactly like snd_hda landing at
# -ENXIO. None of the closers below is on the hot path of any real
# mode-set; they exist so the relocation pass resolves every UND to a
# non-zero address.
#
# Symbol categories (101 closers):
#   * ACPI glue           acpi_disabled (data), acpi_evaluate_integer,
#                         acpi_get_devices, register/unregister already
#                         in L-shims
#   * aperture/fbdev      aperture_remove_conflicting_*, fb_get_options,
#                         devm_aperture_acquire_for_platform_device
#   * dma-buf / PRIME     dma_buf_* (8) — GEM<->dma-buf import/export
#   * dma-fence           dma_fence_* (14) — the fence/sync primitives
#   * dma-resv            dma_resv_* (3) — reservation objects
#   * ww_mutex            ww_mutex_* (4) + reservation_ww_class (data)
#   * anon-inode / pseudo-fs   alloc_anon_inode, init_pseudo,
#                         kill_anon_super, simple_pin_fs/release_fs, ...
#   * fd table            fd_install, get_unused_fd_flags, put_unused_fd
#   * shmem / GEM pages    shmem_file_setup, shmem_read_mapping_page_gfp,
#                         set_page_dirty, mark_page_accessed, ...
#   * kthread_worker      kthread_create_worker/destroy/queue/flush (6)
#   * idr / rbtree / sg   idr_preload/replace, __rb_*, sg_*, list_sort
#   * HDMI infoframe      hdmi_avi/vendor_infoframe_init
#   * misc data globals   oops_in_progress, platform_bus_type,
#                         xen_domain_type, dma_fence_chain_ops
#   * leaf helpers        cc_platform_has, simple_strtol, strscpy_pad,
#                         wbinvd_on_all_cpus, vga_switcheroo_*_ddc, ...
#
# Stub philosophy: each closer returns a benign default (0 / NULL /
# -ENODEV-ish) so the framework's init scaffolding completes. Data
# symbols resolve to a small zeroed buffer (Linux reads/writes them but
# the values are inert on a GPU-less host). Prefix: "_drm_".

from linux_abi.exports import _add_export
from kernel.printk.printk import printk0
from mm.slab import kmalloc, kfree, kzalloc


# =====================================================================
# Data-symbol backing buffers
# =====================================================================
#
# A handful of drm.ko UND are DATA, not functions: the relocation must
# resolve to a real (zeroed) global so a `mov sym(%rip),%rax` lands on
# valid memory. None is meaningfully consumed on a GPU-less host.
#
#   * acpi_disabled        int — 0 means "ACPI is enabled". drm only
#                          reads it to gate ACPI lid/backlight probing.
#   * oops_in_progress     int — 0 (we are never mid-oops at insmod).
#   * xen_domain_type      enum — 0 (XEN_NATIVE; we are bare metal).
#   * platform_bus_type    struct bus_type — drm registers a platform
#                          driver for vgem/udl; a zeroed bus is inert.
#   * reservation_ww_class struct ww_class — the global ww_class every
#                          dma_resv uses; zeroed is fine for our no-op
#                          ww_mutex stubs.
#   * dma_fence_chain_ops  struct dma_fence_ops — vtable for fence
#                          chains; never invoked (we never signal a
#                          real chain).
acpi_disabled_buf:          Array[8, uint8]
oops_in_progress_buf:       Array[8, uint8]
xen_domain_type_buf:        Array[8, uint8]
platform_bus_type_buf:      Array[256, uint8]
reservation_ww_class_buf:   Array[128, uint8]
dma_fence_chain_ops_buf:    Array[128, uint8]

# A shared 4 KiB scratch page handed back where a driver expects a
# kernel object pointer it will poke at (anon inode, dma_buf, fence
# stub, ...). Zeroed; absorbs reads/writes harmlessly on a host where
# the object is never actually consumed.
_drm_scratch_buf:           Array[4096, uint8]


# =====================================================================
# Group 1: ACPI glue
# =====================================================================
#
# drm probes ACPI for lid state, backlight and _DSM video methods.
# With ACPI present but no GPU, every query returns "not found" so
# drm falls back to its non-ACPI defaults.

def _drm_acpi_evaluate_integer(handle: uint64, pathname: uint64,
                               arguments: uint64, data: uint64) -> int32:
    # acpi_status acpi_evaluate_integer(acpi_handle, acpi_string,
    #   struct acpi_object_list *, unsigned long long *);
    # AE_NOT_FOUND (0x05) — drm treats any non-AE_OK as "absent".
    return 5

def _drm_acpi_get_devices(hid: uint64, callback: uint64,
                          context: uint64, return_value: uint64) -> int32:
    # acpi_status acpi_get_devices(char *HID, acpi_walk_callback,
    #   void *context, void **return_value);
    # AE_OK with the callback never invoked — no matching device.
    return 0


# =====================================================================
# Group 2: aperture / fbdev handover
# =====================================================================
#
# On a real boot drm kicks the firmware framebuffer (efifb/vesafb)
# before taking over the aperture. With no conflicting fb device these
# are no-ops that return success.

def _drm_aperture_remove_conflicting_devices(base: uint64, size: uint64,
                                             name: uint64) -> int32:
    # int aperture_remove_conflicting_devices(resource_size_t base,
    #   resource_size_t size, const char *name);
    return 0

def _drm_aperture_remove_conflicting_pci_devices(pdev: uint64,
                                                 name: uint64) -> int32:
    # int aperture_remove_conflicting_pci_devices(struct pci_dev *,
    #   const char *name);
    return 0

def _drm_devm_aperture_acquire_for_platform_device(pdev: uint64,
                                                   base: uint64,
                                                   size: uint64) -> int32:
    # int devm_aperture_acquire_for_platform_device(struct platform_device *,
    #   resource_size_t base, resource_size_t size);
    return 0

def _drm_fb_get_options(name: uint64, option: uint64) -> int32:
    # int fb_get_options(const char *name, char **option);
    # 1 == "this fbdev is disabled on the kernel cmdline" → drm skips
    # the legacy fbdev path entirely. Safest for a load-only probe.
    return 1


# =====================================================================
# Group 3: dma-buf (PRIME import/export)
# =====================================================================
#
# dma_buf is the cross-driver buffer-sharing object. On a GPU-less
# host nothing ever imports/exports a real buffer; the export path is
# only reached by an ioctl we never issue. All NULL/0/-ENODEV.

def _drm_dma_buf_attach(dmabuf: uint64, dev: uint64) -> uint64:
    # struct dma_buf_attachment *dma_buf_attach(struct dma_buf *,
    #   struct device *); ERR_PTR(-ENODEV) == (uint64)(-19).
    return cast[uint64](0) - 19

def _drm_dma_buf_detach(dmabuf: uint64, attach: uint64):
    return

def _drm_dma_buf_export(exp_info: uint64) -> uint64:
    # struct dma_buf *dma_buf_export(struct dma_buf_export_info *);
    # ERR_PTR(-ENODEV).
    return cast[uint64](0) - 19

def _drm_dma_buf_fd(dmabuf: uint64, flags: int32) -> int32:
    # int dma_buf_fd(struct dma_buf *, int flags); -ENODEV.
    return cast[int32](0) - 19

def _drm_dma_buf_get(fd: int32) -> uint64:
    # struct dma_buf *dma_buf_get(int fd); ERR_PTR(-EBADF == -9).
    return cast[uint64](0) - 9

def _drm_dma_buf_map_attachment(attach: uint64, direction: int32) -> uint64:
    # struct sg_table *dma_buf_map_attachment(...); ERR_PTR(-ENODEV).
    return cast[uint64](0) - 19

def _drm_dma_buf_put(dmabuf: uint64):
    return

def _drm_dma_buf_unmap_attachment(attach: uint64, sg_table: uint64,
                                  direction: int32):
    return


# =====================================================================
# Group 4: dma-fence (explicit sync primitives)
# =====================================================================
#
# dma_fence is the GPU completion-signalling object. drm's GEM/atomic
# core threads fences through every flip. On a load-only probe none is
# ever waited on; the only init-time consumer is dma_fence_context_alloc
# (called from drm_dev_init to seed a context id). Treat fences as
# already-signalled so any (never-hit) wait returns immediately.

def _drm_dma_fence_add_callback(fence: uint64, cb: uint64,
                                func: uint64) -> int32:
    # int dma_fence_add_callback(...); -ENOENT(-2) == "already signalled,
    # callback not added" — the documented return for a signalled fence.
    return cast[int32](0) - 2

def _drm_dma_fence_allocate_private_stub(timestamp: uint64) -> uint64:
    # struct dma_fence *dma_fence_allocate_private_stub(ktime_t);
    # A pre-signalled stub fence. Hand back the scratch page.
    return cast[uint64](&_drm_scratch_buf[0])

def _drm_dma_fence_chain_find_seqno(pfence: uint64, seqno: uint64) -> int32:
    return 0

def _drm_dma_fence_chain_init(chain: uint64, prev: uint64, fence: uint64,
                              seqno: uint64):
    return

def _drm_dma_fence_chain_walk(fence: uint64) -> uint64:
    # struct dma_fence *dma_fence_chain_walk(struct dma_fence *); NULL
    # == end of chain.
    return 0

def _drm_dma_fence_context_alloc(num: uint64) -> uint64:
    # u64 dma_fence_context_alloc(unsigned num); a monotonically
    # increasing context id. 1 is a fine seed (uniqueness across the
    # never-fired fence paths doesn't matter for a load probe).
    return 1

def _drm_dma_fence_get_stub() -> uint64:
    # struct dma_fence *dma_fence_get_stub(void); the singleton
    # already-signalled fence. Scratch page.
    return cast[uint64](&_drm_scratch_buf[0])

def _drm_dma_fence_init(fence: uint64, ops: uint64, lock: uint64,
                        context: uint64, seqno: uint64):
    return

def _drm_dma_fence_release(kref: uint64):
    return

def _drm_dma_fence_remove_callback(fence: uint64, cb: uint64) -> int32:
    # bool dma_fence_remove_callback(...); false == "was already
    # signalled / not pending".
    return 0

def _drm_dma_fence_signal(fence: uint64) -> int32:
    return 0

def _drm_dma_fence_signal_timestamp(fence: uint64, timestamp: uint64) -> int32:
    return 0

def _drm_dma_fence_unwrap_merge() -> uint64:
    # struct dma_fence *__dma_fence_unwrap_merge(...); variadic in
    # Linux. NULL == no merged fence produced.
    return 0


# =====================================================================
# Group 5: dma-resv (reservation objects) + ww_mutex
# =====================================================================
#
# dma_resv wraps a ww_mutex + a set of fences guarding a buffer. drm
# inits one per GEM object. With no real contention the ww_mutex stubs
# always "win" the lock immediately.

def _drm_dma_resv_init(obj: uint64):
    return

def _drm_dma_resv_fini(obj: uint64):
    return

def _drm_dma_resv_wait_timeout(obj: uint64, usage: int32, intr: int32,
                               timeout: uint64) -> int64:
    # long dma_resv_wait_timeout(...); >0 == "fences signalled, time
    # left". Return the full timeout so a (never-hit) wait succeeds.
    return cast[int64](timeout)

def _drm_ww_mutex_lock(lock: uint64, ctx: uint64) -> int32:
    return 0

def _drm_ww_mutex_lock_interruptible(lock: uint64, ctx: uint64) -> int32:
    return 0

def _drm_ww_mutex_trylock(lock: uint64, ctx: uint64) -> int32:
    # bool ww_mutex_trylock(...); 1 == acquired.
    return 1

def _drm_ww_mutex_unlock(lock: uint64):
    return

def _drm_atomic_dec_and_mutex_lock(cnt: uint64, lock: uint64) -> int32:
    # int atomic_dec_and_mutex_lock(atomic_t *, struct mutex *);
    # 0 == "decremented but didn't hit zero, mutex not taken".
    return 0

def _drm_mutex_is_locked(lock: uint64) -> int32:
    return 0


