# =====================================================================

def _drm_cc_platform_has(attr: uint32) -> int32:
    # bool cc_platform_has(enum cc_attr); 0 == no confidential-compute
    # features (we're not SEV/TDX).
    return 0

def _drm_cc_mkdec(val: uint64) -> uint64:
    # u64 cc_mkdec(u64); strip the C-bit. No CC → identity.
    return val

def _drm_wbinvd_on_all_cpus():
    # void wbinvd_on_all_cpus(void); cache flush — no-op is safe under
    # emulation (the L-shim doesn't model coherency the driver worries
    # about). drm calls it from the write-combining setup path.
    return

def _drm_static_key_enable(key: uint64):
    return

def _drm_simple_strtol(cp: uint64, endp: uint64, base: uint32) -> int64:
    return 0

def _drm_strscpy_pad(dst: uint64, src: uint64, count: uint64) -> int64:
    # ssize_t strscpy_pad(char *dest, const char *src, size_t count);
    # Copy src into dst up to count-1, NUL-pad the rest. Implemented for
    # real since drm dev_set_name-style paths read it back. Returns the
    # copied length (excluding NUL), or -E2BIG. Minimal byte loop.
    if count == 0:
        return 0
    d: Ptr[uint8] = cast[Ptr[uint8]](dst)
    s: Ptr[uint8] = cast[Ptr[uint8]](src)
    i: uint64 = 0
    # copy until NUL or count-1
    while i < count - 1:
        c: uint8 = s[i]
        d[i] = c
        if c == 0:
            break
        i = i + 1
    copied: uint64 = i
    # NUL + pad remainder
    while i < count:
        d[i] = 0
        i = i + 1
    return cast[int64](copied)

def _drm_kstrdup_const(s: uint64, gfp: uint64) -> uint64:
    # const char *kstrdup_const(const char *s, gfp_t gfp);
    # The "_const" variant returns the original pointer if it lives in
    # .rodata. We can't tell, so return the input unchanged (drm never
    # kfree_const's it back on the load-only path). NULL-safe.
    return s

def _drm_memdup_user_nul(src: uint64, len: uint64) -> uint64:
    # void *memdup_user_nul(const void __user *, size_t); ERR_PTR(-EFAULT
    # == -14) — no userspace blob is copied at init.
    return cast[uint64](0) - 14

def _drm_fwnode_handle_put(fwnode: uint64):
    return

def _drm_pid_task(pid: uint64, type: int32) -> uint64:
    # struct task_struct *pid_task(struct pid *, enum pid_type);
    # NULL == no task (drm's debugfs client list is empty at init).
    return 0

def _drm_task_pid_nr_ns(task: uint64, type: int32, ns: uint64) -> int32:
    return 0

def _drm_nsecs_to_jiffies64(n: uint64) -> uint64:
    # u64 nsecs_to_jiffies64(u64 n); HZ=250 → /4_000_000 ns per jiffy.
    return n / 4000000

def _drm_kmalloc_node_track_caller(size: uint64, gfp: uint64,
                                   node: int32) -> uint64:
    # void *__kmalloc_node_track_caller(size_t, gfp_t, int node, unsigned
    #   long caller); node-aware kmalloc. We have one node — plain
    # kmalloc. NULL on size 0 mirrors the kernel.
    if size == 0:
        return 0
    return kmalloc(size)


# =====================================================================
# Registration
# =====================================================================

def linux_abi_register_drm():
    # 101 closers beyond the L1..L68 + api_*.ad surface (the autostub
    # generator covers drm's lone __x86_indirect_thunk_rsi). Together
    # they take drm.ko's relocation pass to skipped=0.
    printk0("linux_abi_register_drm: closing drm.ko UND gap\n")

